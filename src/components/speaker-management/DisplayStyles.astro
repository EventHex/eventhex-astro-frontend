---
// Display Styles — improved with Bg.svg background and better cards
const styles = [
  { num: "01", title: "Card Layout", desc: "Clean grid with photo, name & social links. White background, centered layout with gradient avatar." },
  { num: "02", title: "Overlay Style", desc: "Full image background with text overlay. Dark background, speaker info at bottom with semi-transparent gradient." },
  { num: "03", title: "Minimal Design", desc: "Text-focused with small avatar. Clean border, bio preview, tags. Lightweight and elegant." },
  { num: "04", title: "Modern Card", desc: "Gradient text with contemporary style. Purple gradient avatar and tag pills for a modern look." },
  { num: "05", title: "Profile Banner", desc: "Wide format showcasing credentials. Pink gradient header banner with avatar overlap." },
];
---

<section class="sm-styles">
  <div class="sm-styles__header">
    <span class="sm-styles__tag animate-on-scroll" data-animation="fadeIn">Event Website Integration</span>
    <h2 class="sm-styles__title animate-on-scroll" data-animation="fadeInUp"><b>5 Display Styles</b> for Your Speaker Page</h2>
    <p class="sm-styles__desc animate-on-scroll" data-animation="fadeInUp">Customize how speakers appear on your event website with multiple display styles, layout modes, image hover effects, and full typography control.</p>
  </div>
  <div class="sm-styles__cards">
    {styles.map((s, i) => (
      <div class="sm-styles__card animate-on-scroll" data-animation="fadeInUp" style={`--anim-duration: 600ms`}>
        <div class="sm-styles__card-num-wrap">
          <span class="sm-styles__card-num">{s.num}</span>
        </div>
        <h3 class="sm-styles__card-title">{s.title}</h3>
        <p class="sm-styles__card-desc">{s.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .sm-styles {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    background: url('https://eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .sm-styles__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
  .sm-styles__tag {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--brand-blue);
  }
  .sm-styles__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0;
  }
  .sm-styles__title b { font-weight: 700; }
  .sm-styles__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
    max-width: 700px;
  }
  .sm-styles__cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .sm-styles__card {
    background: #F5F8FF;
    border: 1px solid #E8ECF2;
    border-radius: 20px;
    padding: 28px 20px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.03);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .sm-styles__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(55, 93, 251, 0.08);
    border-color: rgba(55, 93, 251, 0.15);
  }
  .sm-styles__card-num-wrap {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-blue);
    border-radius: 12px;
  }
  .sm-styles__card-num {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #fff;
  }
  .sm-styles__card-title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--heading-dark);
    margin: 0;
  }
  .sm-styles__card-desc {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .sm-styles { padding: 60px 20px; }
    .sm-styles__title { font-size: 36px; }
    .sm-styles__desc { font-size: 16px; }
    .sm-styles__cards { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 767px) {
    .sm-styles { padding: 40px 16px; }
    .sm-styles__title { font-size: 28px; line-height: 1.2em; }
    .sm-styles__desc { font-size: 15px; }
    .sm-styles__cards { grid-template-columns: repeat(2, 1fr); }
  }
</style>
