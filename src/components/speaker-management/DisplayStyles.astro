---
// Section 9: Display Styles — Elementor page 3711, container c585ac6
const styles = [
  { num: "01", title: "Card", desc: "Clean grid with photo, name & social links. White background, centered layout with gradient avatar." },
  { num: "02", title: "Overlay", desc: "Full image background with text overlay. Dark background, speaker info at bottom with semi-transparent gradient." },
  { num: "03", title: "Minimal", desc: "Text-focused with small avatar. Clean border, bio preview, tags. Lightweight and elegant." },
  { num: "04", title: "Modern Card", desc: "Gradient text with contemporary style. Purple gradient avatar and tag pills." },
  { num: "05", title: "Profile Banner", desc: "Wide format showcasing credentials. Pink gradient header banner with avatar overlap." },
];
---

<section class="sm-styles">
  <div class="sm-styles__header">
    <span class="sm-styles__tag">Event Website</span>
    <h2 class="sm-styles__title"><b>5 Display Styles</b> for Your Speaker Page</h2>
    <p class="sm-styles__desc">Customize how speakers appear on your event website with multiple display styles, layout modes, image hover effects, and full typography control.</p>
  </div>
  <div class="sm-styles__cards">
    {styles.map((s) => (
      <div class="sm-styles__card">
        <span class="sm-styles__card-num">{s.num}</span>
        <h3 class="sm-styles__card-title">{s.title}</h3>
        <p class="sm-styles__card-desc">{s.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .sm-styles {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .sm-styles__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  .sm-styles__tag {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--brand-blue);
  }

  .sm-styles__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 50px;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0;
  }
  .sm-styles__title b { font-weight: 700; }

  .sm-styles__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
    max-width: 700px;
  }

  .sm-styles__cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .sm-styles__card {
    background: #fff;
    border: 1px solid #E5EBFF;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 30px rgba(55, 93, 251, 0.06);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sm-styles__card-num {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    line-height: 32px;
    letter-spacing: -1px;
    color: var(--brand-blue);
  }

  .sm-styles__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 24px;
    color: var(--heading-dark);
    margin: 0;
  }

  .sm-styles__card-desc {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .sm-styles { padding: 60px 20px; }
    .sm-styles__title { font-size: 35px; line-height: 1.2em; }
    .sm-styles__desc { font-size: 16px; }
    .sm-styles__tag { font-size: 13px; }
    .sm-styles__cards { grid-template-columns: repeat(3, 1fr); }
    .sm-styles__card-num { font-size: 24px; }
    .sm-styles__card-title { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .sm-styles { padding: 40px 16px; }
    .sm-styles__title { font-size: 28px; line-height: 1.2em; }
    .sm-styles__desc { font-size: 15px; }
    .sm-styles__tag { font-size: 12px; }
    .sm-styles__cards { grid-template-columns: repeat(2, 1fr); }
    .sm-styles__card-num { font-size: 22px; }
    .sm-styles__card-desc { font-size: 15px; }
  }
</style>
