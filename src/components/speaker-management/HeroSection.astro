---
// Section 0: Hero — Elementor page 3711, container bd3a8c6
---

<section class="sm-hero">
  <div class="sm-hero__inner">
    <div class="sm-hero__content">
      <span class="sm-hero__tag">Speaker Management</span>
      <h1 class="sm-hero__title">AI-Powered <b>Speaker</b> &amp; <b>Session Management</b> for Modern Events</h1>
      <p class="sm-hero__desc">From AI LinkedIn imports to live polls and InstaRecap transcription—EventHex centralizes every aspect of speaker coordination, session scheduling, and audience engagement in one powerful platform.</p>
      <div class="sm-hero__cta">
        <a href="/book-a-demo/" class="sm-hero__btn sm-hero__btn--primary">Get a Free Demo</a>
        <a href="#how-it-works" class="sm-hero__btn sm-hero__btn--secondary">See How It Works</a>
      </div>
      <div class="sm-hero__proof">
        <span class="sm-hero__proof-item">⭐ 4.8/5 rating</span>
        <span class="sm-hero__proof-item">✅ Trusted by 500+ organizers</span>
      </div>
    </div>
    <div class="sm-hero__image">
      <img
        src="https://eventhex.ai/wp-content/uploads/2025/03/Feature-banner.png"
        alt="EventHex Speaker Management Dashboard showing speaker profiles and session schedules"
        width="700"
        height="500"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .sm-hero {
    padding: 40px 20px 60px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .sm-hero__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 60px 40px;
    border-radius: 49px;
    background:
      radial-gradient(ellipse at center, #F5F8FF, #FFFFFF),
      url('https://eventhex.ai/wp-content/uploads/2025/03/Rectangle-1205.jpg') center / cover no-repeat;
    background-blend-mode: normal;
    gap: 20px;
  }

  .sm-hero__content {
    width: 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
  }

  .sm-hero__tag {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--brand-blue);
  }

  .sm-hero__title {
    font-family: var(--font-heading);
    font-size: 50px;
    font-weight: 400;
    line-height: 58px;
    letter-spacing: -1px;
    color: #000;
    margin: 0;
  }
  .sm-hero__title b {
    font-weight: 700;
  }

  .sm-hero__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
  }

  .sm-hero__cta {
    display: flex;
    gap: 12px;
  }

  .sm-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    padding: 12px 24px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s;
  }

  .sm-hero__btn--primary {
    background: var(--brand-blue);
    color: #fff;
  }
  .sm-hero__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: scale(1.03);
  }

  .sm-hero__btn--secondary {
    background: transparent;
    color: var(--heading-dark);
    border: 1px solid #E5EBFF;
  }
  .sm-hero__btn--secondary:hover {
    background: var(--surface-light);
  }

  .sm-hero__proof {
    display: flex;
    gap: 20px;
  }

  .sm-hero__proof-item {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    letter-spacing: -0.48px;
    color: #8A94A6;
  }

  .sm-hero__image {
    width: 55%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sm-hero__image img {
    width: 100%;
    height: auto;
  }

  @media (max-width: 1024px) {
    .sm-hero__inner {
      padding: 30px;
      border-radius: 32px;
    }
    .sm-hero__tag { font-size: 13px; }
    .sm-hero__title { font-size: 35px; line-height: 1.15em; }
    .sm-hero__desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .sm-hero {
      padding: 20px 16px 40px;
    }
    .sm-hero__inner {
      flex-direction: column;
      padding: 40px 20px 20px;
      border-radius: 24px;
    }
    .sm-hero__content {
      width: 100%;
    }
    .sm-hero__image {
      width: 100%;
    }
    .sm-hero__tag { font-size: 12px; }
    .sm-hero__title { font-size: 30px; line-height: 1.2em; }
    .sm-hero__desc { font-size: 15px; }
    .sm-hero__cta { flex-direction: column; }
    .sm-hero__proof { flex-direction: column; gap: 8px; }
    .sm-hero__proof-item { font-size: 15px; }
  }
</style>
