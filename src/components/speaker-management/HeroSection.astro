---
// Speaker-management hero with a more distinct split layout than the home page hero
---

<section class="smh-hero">
  <div class="smh-hero__shell">
    <div class="smh-hero__grid">
      <div class="smh-hero__content">
        <div class="smh-hero__badge animate-on-scroll" data-animation="fadeInDown">
          <span class="smh-hero__badge-dot"></span>
          <span>Speaker Management</span>
        </div>

        <h1 class="smh-hero__title animate-on-scroll" data-animation="fadeInUp">
          Run Speaker Ops Without
          <span>Spreadsheet Chaos</span>
        </h1>

        <p class="smh-hero__desc animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 800ms">
          Centralize speaker profiles, automate outreach, build multi-track schedules,
          and power live audience engagement from one workflow designed for event teams.
        </p>

        <div class="smh-hero__points animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 950ms">
          <span class="smh-hero__point">AI LinkedIn import</span>
          <span class="smh-hero__point">Visual session timeline</span>
          <span class="smh-hero__point">Live polls, Q&amp;A, InstaRecap</span>
        </div>

        <div class="smh-hero__cta animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 1100ms">
          <a href="/book-a-demo/" class="smh-hero__btn smh-hero__btn--primary">Get a Free Demo</a>
          <a href="#spk-bento" class="smh-hero__btn smh-hero__btn--secondary">Explore Features</a>
        </div>

        <div class="smh-hero__trust animate-on-scroll" data-animation="fadeIn" style="--anim-duration: 1250ms">
          <span class="smh-hero__trust-item">4.8/5 organizer rating</span>
          <span class="smh-hero__trust-item">Trusted by 400+ events</span>
        </div>
      </div>

      <div class="smh-hero__visual animate-on-scroll" data-animation="fadeInRight">
        <div class="smh-hero__visual-card">
          <div class="smh-hero__floating smh-hero__floating--top">
            <span class="smh-hero__floating-label">Setup</span>
            <strong>90% faster with AI import</strong>
          </div>

          <img
            src="https://cms.eventhex.ai/wp-content/uploads/2025/03/Feature-banner.png"
            alt="EventHex Speaker Management Dashboard showing speaker profiles and session schedules"
            width="700"
            height="500"
            loading="eager"
          />

          <div class="smh-hero__floating smh-hero__floating--bottom">
            <span class="smh-hero__floating-label">Live Event Day</span>
            <strong>Polls, Q&amp;A and scheduling in one view</strong>
          </div>

          <div class="smh-hero__metric-row">
            <div class="smh-hero__metric">
              <strong>2,000+</strong>
              <span>speakers managed</span>
            </div>
            <div class="smh-hero__metric">
              <strong>20+</strong>
              <span>countries supported</span>
            </div>
            <div class="smh-hero__metric">
              <strong>85%</strong>
              <span>coordination time saved</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .smh-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    padding: 0 0 220px;
    background:
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }

  .smh-hero__shell {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 160px 0 0;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat;
  }

  .smh-hero__grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .smh-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .smh-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .smh-hero__badge-dot {
    display: none;
  }

  .smh-hero__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 600;
    line-height: 60px;
    letter-spacing: -1px;
    color: var(--heading-dark);
  }

  .smh-hero__title span {
    display: block;
    color: var(--brand-blue);
  }

  .smh-hero__desc {
    margin: 0;
    max-width: 580px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .smh-hero__points {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .smh-hero__point {
    display: inline-flex;
    align-items: center;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #e5ebff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #475467;
    box-shadow: 0 8px 24px rgba(34, 39, 47, 0.05);
  }

  .smh-hero__cta {
    display: flex;
    gap: 14px;
    padding-top: 6px;
  }

  .smh-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, border-color 0.3s;
  }

  .smh-hero__btn--primary {
    color: #fff;
    background: var(--brand-blue);
    box-shadow: 0 10px 24px rgba(55, 93, 251, 0.28);
  }

  .smh-hero__btn--primary:hover {
    transform: translateY(-2px);
    background: var(--brand-blue-hover);
    box-shadow: 0 14px 30px rgba(55, 93, 251, 0.34);
  }

  .smh-hero__btn--secondary {
    color: var(--heading-dark);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #dce4ff;
  }

  .smh-hero__btn--secondary:hover {
    transform: translateY(-2px);
    border-color: #c5d2ff;
    box-shadow: 0 10px 24px rgba(34, 39, 47, 0.06);
  }

  .smh-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .smh-hero__trust-item {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #667085;
  }

  .smh-hero__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
  }

  .smh-hero__visual {
    position: relative;
  }

  .smh-hero__visual-card {
    position: relative;
    padding: 20px 0 36px;
  }

  .smh-hero__visual-card img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    filter: drop-shadow(0 26px 48px rgba(34, 39, 47, 0.14));
  }

  .smh-hero__floating {
    position: absolute;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.94);
    color: var(--heading-dark);
    border: 1px solid rgba(229, 235, 255, 0.9);
    box-shadow: 0 18px 36px rgba(34, 39, 47, 0.12);
    backdrop-filter: blur(12px);
  }

  .smh-hero__floating--top {
    top: -18px;
    left: -18px;
    max-width: 230px;
  }

  .smh-hero__floating--bottom {
    right: -18px;
    bottom: 94px;
    max-width: 250px;
  }

  .smh-hero__floating-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    line-height: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #667085;
  }

  .smh-hero__floating strong {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.45;
  }

  .smh-hero__metric-row {
    display: none;
  }

  @media (max-width: 1120px) {
    .smh-hero {
      padding: 0 20px 110px;
    }

    .smh-hero__shell {
      padding: 136px 0 0;
    }

    .smh-hero__grid {
      gap: 28px;
      padding: 0 0 40px;
    }

    .smh-hero__desc {
      max-width: 520px;
    }

    .smh-hero__title {
      font-size: 46px;
      line-height: 1.1em;
    }
  }

  @media (max-width: 960px) {
    .smh-hero {
      padding: 0 20px 96px;
    }

    .smh-hero__shell {
      padding: 130px 0 0;
    }

    .smh-hero__grid {
      grid-template-columns: 1fr;
      gap: 34px;
      padding: 0 0 40px;
    }

    .smh-hero__content {
      align-items: center;
      text-align: center;
    }

    .smh-hero__desc {
      max-width: 720px;
    }

    .smh-hero__trust,
    .smh-hero__points,
    .smh-hero__cta {
      justify-content: center;
    }

    .smh-hero__title {
      font-size: 42px;
      line-height: 1.1em;
    }

    .smh-hero__visual-card {
      padding: 26px 0 0;
    }

    .smh-hero__floating--top {
      left: 0;
    }

    .smh-hero__floating--bottom {
      right: 0;
      bottom: 34px;
    }
  }

  @media (max-width: 767px) {
    .smh-hero {
      margin-top: -80px;
      padding: 0 20px 90px;
    }

    .smh-hero__shell {
      padding: 120px 0 0;
    }

    .smh-hero__grid {
      padding: 0 0 30px;
    }

    .smh-hero__title {
      font-size: 30px;
      line-height: 1.2em;
      letter-spacing: 0;
    }

    .smh-hero__desc {
      font-size: 15px;
      line-height: 1.7;
    }

    .smh-hero__badge {
      font-size: 16px;
      line-height: 1.1em;
    }

    .smh-hero__point {
      font-size: 13px;
      padding: 8px 12px;
    }

    .smh-hero__cta {
      width: 100%;
      flex-direction: column;
    }

    .smh-hero__btn {
      width: 100%;
    }

    .smh-hero__trust {
      gap: 10px;
      justify-content: center;
    }

    .smh-hero__floating {
      position: static;
      margin-bottom: 12px;
      max-width: none;
    }

    .smh-hero__visual-card {
      padding: 18px 0 0;
    }
  }
</style>
