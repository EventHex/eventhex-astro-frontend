---
// Section 4: Session Scheduling — Elementor page 3711, container c61b88f
const cards = [
  {
    title: "Visual Timeline View",
    desc: "See all sessions on an interactive timeline, color-coded by type. Drag sessions to reschedule instantly.",
  },
  {
    title: "Sub-sessions & Breakouts",
    desc: "Create nested sessions under any parent—perfect for workshops, panel breakouts, and multi-track conferences.",
  },
  {
    title: "Ticket-Restricted Sessions",
    desc: "Limit session access to specific ticket types or participant categories. Set maximum bookings per session.",
  },
  {
    title: "Multi-Stage Management",
    desc: "Manage multiple stages and locations, assign sessions to venues, and group schedules by stage or session type.",
  },
];
---

<section class="sm-sessions">
  <div class="sm-sessions__header">
    <span class="sm-sessions__tag">Session Scheduling</span>
    <h2 class="sm-sessions__title">Powerful <b>Session Management</b> with Timeline View</h2>
    <p class="sm-sessions__desc">Schedule sessions across multiple days and stages with our visual timeline. Create sub-sessions, set capacity limits, and let speakers manage their own schedules.</p>
  </div>
  <div class="sm-sessions__image">
    <img
      src="https://cms.eventhex.ai/wp-content/uploads/2026/03/session-timeline-v2.svg"
      alt="EventHex Session Timeline View with Multi-Stage Scheduling"
      width="1100"
      height="600"
      loading="lazy"
    />
  </div>
  <div class="sm-sessions__cards">
    {cards.map((card) => (
      <div class="sm-sessions__card">
        <h3 class="sm-sessions__card-title">{card.title}</h3>
        <p class="sm-sessions__card-desc">{card.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .sm-sessions {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 10px;
    background: var(--surface-light);
    border-radius: 0;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .sm-sessions__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  .sm-sessions__tag {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--brand-blue);
  }

  .sm-sessions__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 50px;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0;
  }
  .sm-sessions__title b { font-weight: 700; }

  .sm-sessions__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
    max-width: 700px;
  }

  .sm-sessions__image {
    padding: 20px 0;
  }

  .sm-sessions__image img {
    width: 100%;
    height: auto;
  }

  .sm-sessions__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .sm-sessions__card {
    background: #fff;
    border: 1px solid #E5EBFF;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 4px 30px rgba(55, 93, 251, 0.06);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sm-sessions__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3em;
    color: var(--heading-dark);
    margin: 0;
  }

  .sm-sessions__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6em;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .sm-sessions { padding: 60px 20px; }
    .sm-sessions__title { font-size: 35px; line-height: 1.2em; }
    .sm-sessions__desc { font-size: 16px; }
    .sm-sessions__tag { font-size: 13px; }
    .sm-sessions__cards { grid-template-columns: repeat(2, 1fr); }
    .sm-sessions__card-title { font-size: 16px; }
    .sm-sessions__card-desc { font-size: 14px; }
  }

  @media (max-width: 767px) {
    .sm-sessions { padding: 40px 16px; }
    .sm-sessions__title { font-size: 28px; line-height: 1.2em; }
    .sm-sessions__desc { font-size: 15px; }
    .sm-sessions__tag { font-size: 12px; }
    .sm-sessions__cards { grid-template-columns: 1fr; }
  }
</style>
