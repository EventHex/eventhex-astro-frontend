---
// Section 1: Stats — Elementor page 3711, container fc5f044
const stats = [
  { value: "10,000+", label: "Speakers Managed" },
  { value: "85%", label: "Time Saved" },
  { value: "20+", label: "Countries" },
  { value: "4.8/5", label: "Satisfaction" },
];
---

<section class="sm-stats">
  <div class="sm-stats__card">
    {stats.map((stat) => (
      <div class="sm-stats__item">
        <span class="sm-stats__value">{stat.value}</span>
        <span class="sm-stats__label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .sm-stats {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 10px;
  }

  .sm-stats__card {
    display: flex;
    justify-content: space-around;
    gap: 20px;
    background: #fff;
    border-radius: 16px;
    padding: 30px 40px;
    border: 1px solid #E5EBFF;
    box-shadow: 0 4px 30px rgba(55, 93, 251, 0.06);
  }

  .sm-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .sm-stats__value {
    font-family: var(--font-heading);
    font-size: 34px;
    font-weight: 700;
    line-height: 40px;
    letter-spacing: -1px;
    color: var(--brand-blue);
  }

  .sm-stats__label {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #8A94A6;
  }

  @media (max-width: 1024px) {
    .sm-stats__card { padding: 24px 20px; gap: 16px; }
    .sm-stats__value { font-size: 28px; }
    .sm-stats__label { font-size: 13px; }
  }

  @media (max-width: 767px) {
    .sm-stats { padding: 20px 16px; }
    .sm-stats__card {
      flex-wrap: wrap;
      justify-content: center;
      padding: 24px 16px;
    }
    .sm-stats__item { width: 45%; }
    .sm-stats__value { font-size: 24px; }
    .sm-stats__label { font-size: 12px; }
  }
</style>
