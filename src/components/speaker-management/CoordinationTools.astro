---
// Coordination Tools — improved full-width design with nice dark background
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="#375DFB" stroke-width="2"/><path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Assign Roles & Tasks",
    desc: "Designate roles such as keynote speaker, panellist, or presenter. Create custom speaker types and assign them inline.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 4h16v12H14l-3 3v-3H4V4z" stroke="#375DFB" stroke-width="2" stroke-linejoin="round"/><circle cx="9" cy="10" r="1" fill="#375DFB"/><circle cx="12" cy="10" r="1" fill="#375DFB"/><circle cx="15" cy="10" r="1" fill="#375DFB"/></svg>`,
    title: "Streamline Communication",
    desc: "Contact speakers directly, send automated reminders, share event updates, and collect presentation materials—all from one place.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#375DFB" stroke-width="2"/><ellipse cx="12" cy="12" rx="4" ry="9" stroke="#375DFB" stroke-width="1.5"/><line x1="3" y1="12" x2="21" y2="12" stroke="#375DFB" stroke-width="1.5"/></svg>`,
    title: "Multi-language Support",
    desc: "Manage speaker profiles and session data in multiple languages—perfect for international conferences and diverse audiences.",
  },
];
---

<section class="sm-coord-full">
  <div class="sm-coord-full__inner">
    <div class="sm-coord-full__header">
      <span class="sm-coord-full__tag animate-on-scroll" data-animation="fadeIn">Coordination Tools</span>
      <h2 class="sm-coord-full__title animate-on-scroll" data-animation="fadeInUp">Effortless Speaker <b>Coordination</b></h2>
      <p class="sm-coord-full__desc animate-on-scroll" data-animation="fadeInUp">Manage speakers end-to-end—from role assignments and automated communication to multi-language support for global events.</p>
    </div>

    <div class="sm-coord-full__cards">
      {cards.map((card) => (
        <div class="sm-coord-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="sm-coord-full__card-icon" set:html={card.icon}></div>
          <h3 class="sm-coord-full__card-title">{card.title}</h3>
          <p class="sm-coord-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .sm-coord-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://cms.eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .sm-coord-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .sm-coord-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .sm-coord-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .sm-coord-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .sm-coord-full__title b { font-weight: 700; }

  .sm-coord-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .sm-coord-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .sm-coord-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .sm-coord-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .sm-coord-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .sm-coord-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .sm-coord-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .sm-coord-full { padding: 64px 0; }
    .sm-coord-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .sm-coord-full { padding: 52px 0; }
    .sm-coord-full__title { font-size: 30px; line-height: 1.15; }
    .sm-coord-full__desc { font-size: 15px; }
    .sm-coord-full__cards { grid-template-columns: 1fr; }
  }
</style>
