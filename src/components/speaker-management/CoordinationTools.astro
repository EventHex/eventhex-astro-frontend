---
// Section 5: Coordination Tools — Elementor page 3711, container 3637038
const cards = [
  {
    title: "Assign Roles & Tasks",
    desc: "Designate roles such as keynote speaker, panellist, or presenter. Create custom speaker types and assign them inline.",
  },
  {
    title: "Streamline Communication",
    desc: "Contact speakers directly, send automated reminders, share event updates, and collect presentation materials—all from one place.",
  },
  {
    title: "Multi-language Support",
    desc: "Manage speaker profiles and session data in multiple languages—perfect for international conferences and diverse audiences.",
  },
];
---

<section class="sm-coord">
  <div class="sm-coord__inner"
    style="background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat">
    <div class="sm-coord__content">
      <span class="sm-coord__tag">Coordination Tools</span>
      <h2 class="sm-coord__title">Effortless Speaker <b>Coordination</b></h2>
      <div class="sm-coord__cards">
        {cards.map((card) => (
          <div class="sm-coord__card">
            <h3 class="sm-coord__card-title">{card.title}</h3>
            <p class="sm-coord__card-desc">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="sm-coord__image">
      <img
        src="https://eventhex.ai/wp-content/uploads/2025/03/iPhone-16-Pro-mockup-natural-titanium.svg"
        alt="Speaker management mobile app showing speaker profiles"
        width="400"
        height="500"
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .sm-coord {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 10px;
  }

  .sm-coord__inner {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: center;
    border-radius: 32px;
    padding: 60px 40px;
    overflow: hidden;
  }

  .sm-coord__content {
    width: 60%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sm-coord__tag {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--brand-blue);
  }

  .sm-coord__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 50px;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }
  .sm-coord__title b { font-weight: 700; }

  .sm-coord__cards {
    display: flex;
    flex-direction: row;
    gap: 16px;
  }

  .sm-coord__card {
    background: #fff;
    border: 1px solid #E5EBFF;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 4px 30px rgba(55, 93, 251, 0.06);
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .sm-coord__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3em;
    color: var(--heading-dark);
    margin: 0;
  }

  .sm-coord__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6em;
    color: var(--subheading-gray);
    margin: 0;
  }

  .sm-coord__image {
    width: 40%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sm-coord__image img {
    width: 100%;
    height: auto;
    max-width: 400px;
  }

  @media (max-width: 1024px) {
    .sm-coord { padding: 60px 20px; }
    .sm-coord__inner { padding: 40px 24px; }
    .sm-coord__title { font-size: 35px; line-height: 1.2em; }
    .sm-coord__tag { font-size: 13px; }
    .sm-coord__cards { flex-direction: column; }
    .sm-coord__card-title { font-size: 16px; }
    .sm-coord__card-desc { font-size: 14px; }
  }

  @media (max-width: 767px) {
    .sm-coord { padding: 40px 16px; }
    .sm-coord__inner {
      flex-direction: column;
      padding: 32px 16px;
      border-radius: 20px;
    }
    .sm-coord__content, .sm-coord__image { width: 100%; }
    .sm-coord__title { font-size: 28px; line-height: 1.2em; }
    .sm-coord__tag { font-size: 12px; }
  }
</style>
