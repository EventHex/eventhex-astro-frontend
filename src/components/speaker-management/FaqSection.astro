---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "What is speaker management software?", a: "Speaker management software helps event organizers centralize all speaker-related tasks from collecting bios and photos to scheduling sessions, automating communications, and engaging audiences with live polls and Q&A. EventHex provides an all-in-one AI-powered solution for managing speakers at conferences, summits, and corporate events." },
  { q: "How does the AI LinkedIn import work?", a: "Simply paste a speaker's LinkedIn profile URL into EventHex, and our AI automatically extracts their name, title, company, bio, and profile photo. This eliminates most manual data entry and keeps speaker profiles accurate and up to date." },
  { q: "Can I manage multiple sessions and stages?", a: "Yes. EventHex supports unlimited sessions across multiple stages and venues. You can use the visual timeline to schedule sessions, create sub-sessions and breakouts, set capacity limits, restrict access by ticket type, and let speakers manage their own schedules." },
  { q: "What audience engagement tools are available?", a: "EventHex includes live polls with real-time analytics, audience Q&A with spotlight mode for fullscreen display, emoji reactions, star ratings, and session feedback, all accessible from attendees' phones without any app download." },
  { q: "What is InstaRecap?", a: "InstaRecap is EventHex's AI-powered transcription and summary tool. It supports audio uploads, YouTube links, and live recording, then generates transcripts, AI summaries, key takeaways, and translated content for multilingual events." },
  { q: "Can I automate speaker communication and reminders?", a: "Yes. EventHex helps you streamline speaker coordination with automated reminders, direct communication workflows, update sharing, and material collection from one place. This reduces follow-up delays and keeps speakers aligned before and during the event." },
  { q: "Is there a free trial available?", a: "You can book a free demo to see EventHex's speaker management workflow in action. No credit card is required, and the team provides onboarding support to help you launch quickly." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need a custom setup?"
  title="Frequently Asked Questions"
  description="We help event teams shape speaker onboarding, approvals, reminder flows, and live engagement around how their conference operations actually run."
/>
