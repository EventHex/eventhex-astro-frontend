---
// FAQ Section — SEO-focused with JSON-LD structured data
const faqs = [
  {
    q: "What is speaker management software?",
    a: "Speaker management software helps event organizers centralize all speaker-related tasks from collecting bios and photos to scheduling sessions, automating communications, and engaging audiences with live polls and Q&A. EventHex provides an all-in-one AI-powered solution for managing speakers at conferences, summits, and corporate events."
  },
  {
    q: "How does the AI LinkedIn import work?",
    a: "Simply paste a speaker's LinkedIn profile URL into EventHex, and our AI automatically extracts their name, title, company, bio, and profile photo. This eliminates most manual data entry and keeps speaker profiles accurate and up to date."
  },
  {
    q: "Can I manage multiple sessions and stages?",
    a: "Yes. EventHex supports unlimited sessions across multiple stages and venues. You can use the visual timeline to schedule sessions, create sub-sessions and breakouts, set capacity limits, restrict access by ticket type, and let speakers manage their own schedules."
  },
  {
    q: "What audience engagement tools are available?",
    a: "EventHex includes live polls with real-time analytics, audience Q&A with spotlight mode for fullscreen display, emoji reactions, star ratings, and session feedback, all accessible from attendees' phones without any app download."
  },
  {
    q: "What is InstaRecap?",
    a: "InstaRecap is EventHex's AI-powered transcription and summary tool. It supports audio uploads, YouTube links, and live recording, then generates transcripts, AI summaries, key takeaways, and translated content for multilingual events."
  },
  {
    q: "Can I automate speaker communication and reminders?",
    a: "Yes. EventHex helps you streamline speaker coordination with automated reminders, direct communication workflows, update sharing, and material collection from one place. This reduces follow-up delays and keeps speakers aligned before and during the event."
  },
  {
    q: "Is there a free trial available?",
    a: "You can book a free demo to see EventHex's speaker management workflow in action. No credit card is required, and the team provides onboarding support to help you launch quickly."
  }
];

const checklist = [
  "Speaker onboarding and bio collection",
  "Session approvals and automated reminders",
  "Live polls, Q&A, and recap readiness"
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a
    }
  }))
};
---

<section class="sm-faq">
  <div class="sm-faq__inner">
    <div class="sm-faq__support">
      <span class="sm-faq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need a custom setup?</span>
      <h2 class="sm-faq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="sm-faq__desc animate-on-scroll" data-animation="fadeInUp">
        We help event teams shape speaker onboarding, approvals, reminder flows, and live engagement
        around how their conference operations actually run.
      </p>

      <div class="sm-faq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="sm-faq__support-label">Included with every rollout</span>
        <ul class="sm-faq__support-list">
          {checklist.map((item) => (
            <li class="sm-faq__support-item">{item}</li>
          ))}
        </ul>

        <div class="sm-faq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your speaker flow before launch and keep your event team aligned.</span>
        </div>

        <a href="/book-a-demo/" class="sm-faq__cta">Plan my speaker flow</a>
      </div>
    </div>

    <div class="sm-faq__list">
      {faqs.map((faq, index) => (
        <details class="sm-faq__item animate-on-scroll" data-animation="fadeInUp" data-faq-item open={index === 0}>
          <summary class="sm-faq__question">
            <span>{faq.q}</span>
            <span class="sm-faq__icon" aria-hidden="true">
              <span class="sm-faq__icon-line sm-faq__icon-line--horizontal"></span>
              <span class="sm-faq__icon-line sm-faq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="sm-faq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const faqItems = Array.from(document.querySelectorAll('[data-faq-item]'));

  faqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      faqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style>
  .sm-faq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .sm-faq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .sm-faq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .sm-faq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .sm-faq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .sm-faq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .sm-faq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .sm-faq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .sm-faq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .sm-faq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .sm-faq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .sm-faq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .sm-faq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .sm-faq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .sm-faq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .sm-faq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .sm-faq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sm-faq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .sm-faq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
    transition: color 0.2s ease;
  }

  .sm-faq__question::-webkit-details-marker {
    display: none;
  }

  .sm-faq__question::marker {
    display: none;
    content: "";
  }

  .sm-faq__question:hover {
    color: #375dfb;
  }

  .sm-faq__icon {
    position: relative;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    margin-top: 3px;
    color: #375dfb;
  }

  .sm-faq__icon-line {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 999px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .sm-faq__icon-line--horizontal {
    width: 20px;
    height: 2px;
  }

  .sm-faq__icon-line--vertical {
    width: 2px;
    height: 20px;
  }

  .sm-faq__answer {
    padding: 0 24px 24px;
  }

  .sm-faq__answer p {
    margin: 0;
    max-width: 92%;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.8;
    color: #5b6477;
  }

  .sm-faq__item[open] {
    background: #fff;
    border-color: rgba(55, 93, 251, 0.2);
    box-shadow: 0 2px 16px rgba(55, 93, 251, 0.06);
  }

  .sm-faq__item[open] .sm-faq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) scaleY(0.35);
  }

  @media (max-width: 1100px) {
    .sm-faq {
      padding: 76px 0;
    }

    .sm-faq__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .sm-faq__support {
      position: static;
    }
  }

  @media (max-width: 1024px) {
    .sm-faq__title {
      font-size: 40px;
    }

    .sm-faq__desc {
      font-size: 16px;
    }

    .sm-faq__question {
      padding: 24px 22px;
      font-size: 20px;
    }

    .sm-faq__answer {
      padding: 0 22px 22px;
    }
  }

  @media (max-width: 767px) {
    .sm-faq {
      padding: 56px 0;
    }

    .sm-faq__inner {
      padding: 0 16px;
      gap: 24px;
    }

    .sm-faq__title {
      font-size: 32px;
      line-height: 1.08;
    }

    .sm-faq__desc {
      font-size: 15px;
      line-height: 1.7;
    }

    .sm-faq__support-card {
      padding: 20px 18px;
      border-radius: 24px;
    }

    .sm-faq__support-item {
      font-size: 15px;
    }

    .sm-faq__support-note strong {
      font-size: 18px;
    }

    .sm-faq__cta {
      width: 100%;
    }

    .sm-faq__item {
      border-radius: 24px;
    }

    .sm-faq__question {
      padding: 20px 18px;
      font-size: 17px;
      line-height: 1.45;
    }

    .sm-faq__answer {
      padding: 0 18px 20px;
    }

    .sm-faq__answer p {
      max-width: 100%;
      font-size: 15px;
      line-height: 1.75;
    }
  }
</style>