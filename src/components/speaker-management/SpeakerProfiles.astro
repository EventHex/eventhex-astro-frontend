---
// Section 2: Speaker Profiles — Elementor page 3711, container 790d017
const features = [
  {
    title: "Rich speaker profiles",
    desc: "Bio, photo, designation, company & 7 social links—imported or entered manually.",
  },
  {
    title: "AI LinkedIn auto-import",
    desc: "Paste a URL—AI extracts name, title, company & bio instantly.",
  },
];
---

<section class="sm-profiles">
  <div class="sm-profiles__inner">
    <div class="sm-profiles__image">
      <img
        src="https://cms.eventhex.ai/wp-content/uploads/2026/03/speaker-dashboard-anim.svg"
        alt="EventHex Speaker Dashboard with AI LinkedIn Import"
        width="600"
        height="450"
        loading="lazy"
      />
    </div>
    <div class="sm-profiles__content">
      <span class="sm-profiles__tag">Speaker Profiles</span>
      <h2 class="sm-profiles__title">All Speaker Details in <b>One Dashboard</b></h2>
      <p class="sm-profiles__desc">Centralize speaker profiles and auto-import from LinkedIn with AI—everything in one place.</p>
      <ul class="sm-profiles__list">
        {features.map((f) => (
          <li class="sm-profiles__list-item">
            <img src="https://cms.eventhex.ai/wp-content/uploads/2025/03/Vector-4.svg" alt="" class="sm-profiles__list-icon" width="16" height="16" />
            <div>
              <strong>{f.title}</strong>
              <br />
              <span>{f.desc}</span>
            </div>
          </li>
        ))}
      </ul>
      <a href="#bento-features" class="sm-profiles__btn">Explore speaker tools</a>
    </div>
  </div>
</section>

<style>
  .sm-profiles {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 0;
  }

  .sm-profiles__inner {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: center;
  }

  .sm-profiles__image {
    width: 52%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sm-profiles__image img {
    width: 90%;
    height: auto;
  }

  .sm-profiles__content {
    width: 48%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sm-profiles__tag {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--brand-blue);
  }

  .sm-profiles__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 50px;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0;
  }
  .sm-profiles__title b { font-weight: 700; }

  .sm-profiles__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
  }

  .sm-profiles__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .sm-profiles__list-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: var(--subheading-gray);
  }

  .sm-profiles__list-item strong {
    color: #000;
    font-size: 18px;
    font-weight: 600;
  }

  .sm-profiles__list-icon {
    margin-top: 6px;
    flex-shrink: 0;
  }

  .sm-profiles__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    background: var(--brand-blue);
    padding: 12px 24px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s;
  }
  .sm-profiles__btn:hover {
    background: var(--brand-blue-hover);
    transform: scale(1.03);
  }

  @media (max-width: 1024px) {
    .sm-profiles { padding: 60px 20px; }
    .sm-profiles__title { font-size: 35px; line-height: 1.2em; }
    .sm-profiles__desc { font-size: 16px; }
    .sm-profiles__tag { font-size: 13px; }
  }

  @media (max-width: 767px) {
    .sm-profiles { padding: 40px 16px; }
    .sm-profiles__inner { flex-direction: column; }
    .sm-profiles__image, .sm-profiles__content { width: 100%; }
    .sm-profiles__image img { width: 100%; }
    .sm-profiles__title { font-size: 28px; line-height: 1.2em; }
    .sm-profiles__desc { font-size: 15px; }
    .sm-profiles__tag { font-size: 12px; }
  }
</style>
