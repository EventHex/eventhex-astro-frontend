    font-weight: 500;
    color: #4D5A6B;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(.4,0,.2,1);
    white-space: nowrap;
  }
  .spk-tab:hover { background: rgba(55,93,251,.08); }

  .spk-tab--active {
    background: var(--brand-blue) !important;
    color: #fff !important;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .spk-panel { display: none; }
  .spk-panel--active {
    display: block;
    animation: spkFadeUp 0.4s ease;
  }

  @keyframes spkFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .spk-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    height: 460px;
  }

  .spk-grid[data-layout="a"] .spk-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .spk-grid[data-layout="a"] .spk-pos-1 { grid-column: 2; grid-row: 1; }
  .spk-grid[data-layout="a"] .spk-pos-2 { grid-column: 3; grid-row: 1; }
  .spk-grid[data-layout="a"] .spk-pos-3 { grid-column: 2; grid-row: 2; }
  .spk-grid[data-layout="a"] .spk-pos-4 { grid-column: 3; grid-row: 2; }

  .spk-grid[data-layout="b"] .spk-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  .spk-grid[data-layout="b"] .spk-pos-1 { grid-column: 1; grid-row: 1; }
  .spk-grid[data-layout="b"] .spk-pos-2 { grid-column: 2; grid-row: 1; }
  .spk-grid[data-layout="b"] .spk-pos-3 { grid-column: 1; grid-row: 2; }
  .spk-grid[data-layout="b"] .spk-pos-4 { grid-column: 2; grid-row: 2; }

  .spk-grid[data-layout="c"] .spk-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  .spk-grid[data-layout="c"] .spk-pos-1 { grid-column: 1; grid-row: 1; }
  .spk-grid[data-layout="c"] .spk-pos-2 { grid-column: 3; grid-row: 1; }
  .spk-grid[data-layout="c"] .spk-pos-3 { grid-column: 1; grid-row: 2; }
  .spk-grid[data-layout="c"] .spk-pos-4 { grid-column: 3; grid-row: 2; }

  @property --spk-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .spk-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0;
    animation: spkCardIn 0.5s ease forwards;
  }
  .spk-card::after {
    content: "";
