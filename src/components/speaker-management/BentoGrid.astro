<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".spk-tab");
    const panels = document.querySelectorAll(".spk-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const index = tab.getAttribute("data-tab");

        tabs.forEach((t) => t.classList.remove("spk-tab--active"));
        panels.forEach((p) => p.classList.remove("spk-panel--active"));

        tab.classList.add("spk-tab--active");
        const panel = document.querySelector(`.spk-panel[data-tab="${index}"]`);
        if (panel) panel.classList.add("spk-panel--active");
      });
    });
  });
</script>

<style is:global>
  .sm-bento-section {
