---
// Stacking Cards section — matches home-new/AISection.astro pattern
// Dark bg with bg-2.webp, sticky stacking cards for key features
// Content sourced from: SpeakerProfiles, SessionScheduling, AudienceInteraction, InstaRecap

const featureCards = [
  {
    title: "Speaker Profiles & AI LinkedIn Import",
    desc: "Centralize all speaker details—bio, photo, designation, company, and social links—in one dashboard. Paste a LinkedIn URL and AI auto-extracts speaker information instantly, saving 90% of data entry time.",
    image: "/feature-images/speaker-management/speaker-dashboard-v2.svg",
    alt: "EventHex Speaker Dashboard with AI LinkedIn Import",
    animated: true,
    width: 669,
    height: 705,
  },
  {
    title: "Visual Session Timeline & Scheduling",
    desc: "Schedule sessions across multiple days and stages with our interactive visual timeline. Create sub-sessions, set capacity limits, manage multi-track conferences, and let speakers manage their own schedules with drag-and-drop ease.",
    image: "/feature-images/speaker-management/session-timeline-v2.svg",
    alt: "EventHex Session Timeline View with Multi-Stage Scheduling",
    animated: true,
    width: 701,
    height: 729,
  },
  {
    title: "Real-time Audience Engagement",
    desc: "Turn passive attendees into active participants with live polls, real-time Q&A with spotlight mode, emoji reactions, and star ratings. Collect instant feedback and view color-coded analytics as votes pour in—all accessible from attendees' phones.",
    image: "/feature-images/speaker-management/live-engagement-v2.svg",
    alt: "EventHex Live Engagement Tools with Polls and Q&A",
    animated: true,
    width: 606,
    height: 765,
  },
  {
    title: "InstaRecap: AI Transcription & Summaries",
    desc: "Never lose a session insight again. Upload recordings, link YouTube URLs, or record live—InstaRecap automatically transcribes, generates AI summaries with key takeaways, and translates content for global audiences in multiple languages.",
    image: "/feature-images/speaker-management/instarecap-v2.svg",
    alt: "EventHex InstaRecap AI Transcription and Summary Dashboard",
    animated: true,
    width: 603,
    height: 746,
  },
];
---

<section class="smf-shell">
  <div class="smf-section">
    <!-- Header -->
    <div class="smf-header">
      <span class="smf-subtitle">Key features that transform speaker management</span>
      <h2 class="smf-title">
        Everything You Need to <span class="smf-highlight">Manage Speakers</span><br/>& Engage Audiences
      </h2>
    </div>

    <!-- Stacking Cards -->
    <div class="smf-cards" id="smf-stacking-cards">
      {featureCards.map((card, i) => (
        <div
          class="smf-card"
          data-card-index={i}
          style={`--card-index: ${i}; top: calc(20px + ${i * 20}px);`}
        >
          <div class="smf-card-content">
            <h3 class="smf-card-title">{card.title}</h3>
            <p class="smf-card-desc">{card.desc}</p>
            <a href="/book-a-demo/" class="smf-card-btn">Explore More</a>
          </div>
          <div class:list={["smf-card-image", card.animated && "smf-card-image--animated"]}>
            <img src={card.image} alt={card.alt} width={card.width} height={card.height} loading="lazy" decoding="async" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .smf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .smf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .smf-header {
    width: 70%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }
  .smf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }
  .smf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }
  .smf-highlight {
    color: #AFA3FF;
  }

  /* Stacking cards — sticky scroll */
  .smf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }
  .smf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg);
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }
  .smf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }
  .smf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple);
    margin: 0;
    line-height: 1.2;
  }
  .smf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }
  .smf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }
  .smf-card-btn:hover {
    transform: scale(1.05);
  }
  .smf-card-image {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30px;
    overflow: hidden;
  }
  .smf-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    image-rendering: high-quality;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
  }

  /* Subtle float animation for featured card image */
  .smf-card-image--animated img {
    animation: smf-float 4s ease-in-out infinite;
  }
  @keyframes smf-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 1024px) {
    .smf-section { padding: 60px 20px 30px; }
    .smf-header { width: 80%; }
    .smf-subtitle { font-size: 16px; }
    .smf-title { font-size: 40px; line-height: 1em; }
    .smf-card { height: 450px; }
    .smf-card-content { flex-basis: 50%; }
    .smf-card-title { font-size: 28px; }
    .smf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .smf-section { padding: 50px 20px 30px; }
    .smf-header { width: 100%; }
    .smf-title { font-size: 30px; }
    .smf-card { flex-direction: column; height: 520px; }
    .smf-card-content { flex: 0 0 50%; padding: 20px 20px 0; }
    .smf-card-image { padding: 10px; }
    .smf-card-title { font-size: 24px; }
    .smf-card-desc { font-size: 15px; }
    .smf-cards { padding-bottom: 40px; }
  }
</style>
