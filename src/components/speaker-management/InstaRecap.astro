---
// Section 7: InstaRecap — Elementor page 3711, container 828f3be
const featuresRow1 = [
  { title: "Audio Upload", desc: "Upload recordings in any format. Multi-stage pipeline converts and transcribes automatically." },
  { title: "YouTube Integration", desc: "Link YouTube URLs to auto-extract and process audio for transcription—no manual downloads." },
  { title: "Live Recording", desc: "Record sessions in real-time from the dashboard. Processed immediately after the session ends." },
];
const featuresRow2 = [
  { title: "AI Summaries", desc: "Generates concise summaries highlighting key topics, decisions, and action items from every session." },
  { title: "Multi-language", desc: "Transcripts can be automatically translated into multiple languages for international conferences." },
  { title: "Export & Share", desc: "Download transcripts, share summaries with attendees, and integrate with your post-event communication." },
];
---

<section class="sm-recap">
  <div class="sm-recap__inner">
    <div class="sm-recap__image">
      <img
        src="https://cms.eventhex.ai/wp-content/uploads/2026/03/instarecap-anim.svg"
        alt="EventHex InstaRecap AI Transcription and Summary Dashboard"
        width="600"
        height="450"
        loading="lazy"
      />
    </div>
    <div class="sm-recap__content">
      <span class="sm-recap__tag">InstaRecap</span>
      <h2 class="sm-recap__title">AI-Powered <b>Transcription &amp; Summaries</b></h2>
      <p class="sm-recap__desc">Never lose a session insight again. EventHex's InstaRecap automatically transcribes recordings, generates AI summaries, and even translates content for global audiences.</p>
      <div class="sm-recap__cards">
        {featuresRow1.map((f) => (
          <div class="sm-recap__card">
            <h3 class="sm-recap__card-title">{f.title}</h3>
            <p class="sm-recap__card-desc">{f.desc}</p>
          </div>
        ))}
      </div>
      <div class="sm-recap__cards">
        {featuresRow2.map((f) => (
          <div class="sm-recap__card">
            <h3 class="sm-recap__card-title">{f.title}</h3>
            <p class="sm-recap__card-desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .sm-recap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 20px;
    background: var(--surface-light);
  }

  .sm-recap__inner {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: flex-start;
  }

  .sm-recap__image {
    width: 45%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: sticky;
    top: 100px;
  }

  .sm-recap__image img {
    width: 100%;
    height: auto;
  }

  .sm-recap__content {
    width: 55%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sm-recap__tag {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--brand-blue);
  }

  .sm-recap__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 50px;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0;
  }
  .sm-recap__title b { font-weight: 700; }

  .sm-recap__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
  }

  .sm-recap__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .sm-recap__card {
    background: #fff;
    border: 1px solid #E5EBFF;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 4px 30px rgba(55, 93, 251, 0.06);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sm-recap__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 24px;
    color: var(--heading-dark);
    margin: 0;
  }

  .sm-recap__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 22px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .sm-recap { padding: 60px 20px; }
    .sm-recap__title { font-size: 35px; line-height: 1.2em; }
    .sm-recap__desc { font-size: 16px; }
    .sm-recap__tag { font-size: 13px; }
    .sm-recap__cards { grid-template-columns: repeat(2, 1fr); }
    .sm-recap__card-title { font-size: 16px; }
    .sm-recap__card-desc { font-size: 14px; }
    .sm-recap__image { position: static; }
  }

  @media (max-width: 767px) {
    .sm-recap { padding: 40px 16px; }
    .sm-recap__inner { flex-direction: column; }
    .sm-recap__image, .sm-recap__content { width: 100%; }
    .sm-recap__title { font-size: 28px; line-height: 1.2em; }
    .sm-recap__desc { font-size: 15px; }
    .sm-recap__tag { font-size: 12px; }
    .sm-recap__cards { grid-template-columns: 1fr; }
  }
</style>
