---

<section class="sm-cta">
  <div class="sm-cta__card">
    <h2 class="sm-cta__title">Ready to simplify your speaker workflow?</h2>
    <p class="sm-cta__desc">Join hundreds of event organizers who manage speakers, sessions, and engagement—all in one platform.</p>
    <div class="sm-cta__buttons">
      <a href="/book-a-demo/" class="sm-cta__btn sm-cta__btn--primary">Book a Demo</a>
      <a href="/pricing/" class="sm-cta__btn sm-cta__btn--secondary">View Pricing</a>
    </div>
  </div>
</section>

<style>
  .sm-cta {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .sm-cta__card {
    background: #0F1629;
    border-radius: 20px;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
  }

  .sm-cta__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 700;
    line-height: 50px;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .sm-cta__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: #bbb;
    margin: 0;
    max-width: 600px;
  }

  .sm-cta__buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  .sm-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    padding: 12px 24px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s;
  }

  .sm-cta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
  }
  .sm-cta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: scale(1.03);
  }

  .sm-cta__btn--secondary {
    background: rgba(255, 255, 255, 0.13);
    color: #fff;
  }
  .sm-cta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 1024px) {
    .sm-cta__card { padding: 60px 24px; }
    .sm-cta__title { font-size: 35px; line-height: 1.2em; }
    .sm-cta__desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .sm-cta { padding: 40px 16px; }
    .sm-cta__card { padding: 48px 20px; border-radius: 16px; }
    .sm-cta__title { font-size: 28px; line-height: 1.2em; }
    .sm-cta__desc { font-size: 15px; }
    .sm-cta__buttons { flex-direction: column; width: 100%; }
    .sm-cta__btn { width: 100%; }
  }
</style>
