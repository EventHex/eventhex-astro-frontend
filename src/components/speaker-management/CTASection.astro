---
// CTA Section — clean gradient card design inside a white background
---

<section class="sm-cta">
  <div class="sm-cta__card">
    <div class="sm-cta__glow sm-cta__glow--1"></div>
    <div class="sm-cta__glow sm-cta__glow--2"></div>
    <div class="sm-cta__content">
      <span class="sm-cta__eyebrow animate-on-scroll" data-animation="fadeIn">Start Your Next Event Faster</span>
      <h2 class="sm-cta__title animate-on-scroll" data-animation="fadeInUp">Ready to Simplify Your Speaker Workflow?</h2>
      <p class="sm-cta__desc animate-on-scroll" data-animation="fadeInUp">Join hundreds of event organizers who manage speakers, sessions, and engagement—all in one AI-powered platform.</p>
      <div class="sm-cta__proof-row animate-on-scroll" data-animation="fadeInUp">
        <span class="sm-cta__proof-pill">AI-powered setup</span>
        <span class="sm-cta__proof-pill">Live event-day tools</span>
        <span class="sm-cta__proof-pill">Free onboarding support</span>
      </div>
      <div class="sm-cta__buttons">
        <a href="/book-a-demo/" class="sm-cta__btn sm-cta__btn--primary">
          Book a Free Demo
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
    <div class="sm-cta__image">
      <img src="/feature-images/speaker-management/cta-illustration.svg" alt="Speaker Management Platform Illustration" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .sm-cta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }
  .sm-cta__card {
    position: relative;
    border-radius: 24px;
    padding: 60px 40px;
    display: flex;
    flex-direction: row;
    align-items: center;
    text-align: left;
    overflow: hidden;
    background: #0F1629;
    gap: 40px;
  }
  .sm-cta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .sm-cta__glow--1 {
    width: 400px;
    height: 400px;
    background: rgba(55, 93, 251, 0.2);
    top: -100px;
    left: -50px;
  }
  .sm-cta__glow--2 {
    width: 300px;
    height: 300px;
    background: rgba(159, 129, 255, 0.15);
    bottom: -80px;
    right: -30px;
  }
  .sm-cta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    flex: 1;
    min-width: 0;
  }
  .sm-cta__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }
  .sm-cta__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }
  .sm-cta__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.3px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }
  .sm-cta__proof-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 10px;
  }
  .sm-cta__proof-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: rgba(255, 255, 255, 0.74);
  }
  .sm-cta__buttons { display: flex; gap: 12px; justify-content: flex-start; }
  .sm-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.3px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  }
  .sm-cta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.35);
  }
  .sm-cta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(55, 93, 251, 0.4);
  }
  .sm-cta__btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .sm-cta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }
  .sm-cta__trust {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-top: 8px;
  }
  .sm-cta__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
  }

  @media (max-width: 1024px) {
    .sm-cta__card { padding: 60px 24px; }
    .sm-cta__title { font-size: 36px; }
    .sm-cta__desc { font-size: 16px; }
    .sm-cta__image { flex: 0 0 40%; }
  }

  @media (max-width: 767px) {
    .sm-cta { padding: 40px 16px 60px; }
    .sm-cta__card { padding: 48px 20px; border-radius: 20px; flex-direction: column; }
    .sm-cta__content { align-items: center; text-align: center; }
    .sm-cta__proof-row { justify-content: center; }
    .sm-cta__buttons { justify-content: center; }
    .sm-cta__title { font-size: 28px; line-height: 1.2em; }
    .sm-cta__desc { font-size: 15px; }
    .sm-cta__proof-row { gap: 8px; }
    .sm-cta__buttons { flex-direction: column; width: 100%; }
    .sm-cta__btn { width: 100%; justify-content: center; }
    .sm-cta__trust { flex-direction: column; gap: 8px; }
    .sm-cta__image { display: none; }
  }

  /* CTA image */
  .sm-cta__image {
    position: relative;
    z-index: 1;
    flex: 0 0 45%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sm-cta__image img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    animation: sm-cta-float 4s ease-in-out infinite;
  }
  @keyframes sm-cta-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
</style>
