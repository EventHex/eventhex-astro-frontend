---
// Section 6: Audience Interaction — Elementor page 3711, container 1bb1e16
const features = [
  {
    title: "Live Polls & Analytics",
    desc: "Create real-time polls with multiple options during sessions. View color-coded bar charts and instant analytics as votes pour in.",
  },
  {
    title: "Q&A with Spotlight Mode",
    desc: "Collect audience questions in real time. Use spotlight mode to display questions fullscreen for the speaker—no more missed questions.",
  },
  {
    title: "Emoji Reactions & Star Ratings",
    desc: "Let attendees respond with 5-level emoji reactions and star ratings. View real-time sentiment distribution and averages.",
  },
];
---

<section class="sm-audience">
  <div class="sm-audience__inner">
    <div class="sm-audience__content">
      <h2 class="sm-audience__title">Real-time <b>Audience Interaction</b> Tools</h2>
      <p class="sm-audience__desc">Turn passive attendees into active participants with polls, Q&amp;A, and instant feedback—all accessible from their phones.</p>
      <ul class="sm-audience__list">
        {features.map((f) => (
          <li class="sm-audience__list-item">
            <img src="https://eventhex.ai/wp-content/uploads/2025/03/Vector-4.svg" alt="" class="sm-audience__list-icon" width="16" height="16" />
            <div>
              <strong>{f.title}</strong>
              <br />
              <span>{f.desc}</span>
            </div>
          </li>
        ))}
      </ul>
    </div>
    <div class="sm-audience__image">
      <img
        src="https://eventhex.ai/wp-content/uploads/2026/03/live-engagement-v2.svg"
        alt="EventHex Live Engagement Tools with Polls and Q&A"
        width="600"
        height="450"
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .sm-audience {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 0;
  }

  .sm-audience__inner {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: center;
  }

  .sm-audience__content {
    width: 50%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sm-audience__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 50px;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0;
  }
  .sm-audience__title b { font-weight: 700; }

  .sm-audience__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin: 0;
  }

  .sm-audience__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .sm-audience__list-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: var(--subheading-gray);
  }

  .sm-audience__list-item strong {
    color: #000;
    font-size: 18px;
    font-weight: 600;
  }

  .sm-audience__list-icon {
    margin-top: 6px;
    flex-shrink: 0;
  }

  .sm-audience__image {
    width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sm-audience__image img {
    width: 100%;
    height: auto;
  }

  @media (max-width: 1024px) {
    .sm-audience { padding: 60px 20px; }
    .sm-audience__title { font-size: 35px; line-height: 1.2em; }
    .sm-audience__desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .sm-audience { padding: 40px 16px; }
    .sm-audience__inner { flex-direction: column; }
    .sm-audience__content, .sm-audience__image { width: 100%; }
    .sm-audience__title { font-size: 28px; line-height: 1.2em; }
    .sm-audience__desc { font-size: 15px; }
  }
</style>
