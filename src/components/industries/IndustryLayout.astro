---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { emojiIcon } from "../../lib/featureIcons";

interface Props {
  industry: string;
  title: string;
  description: string;
  canonical: string;
  badge: string;
  heroTitleLine1: string;
  heroTitleLine2: string;
  heroCopy: string;
  trustItems: string[];
  challenges: { icon: string; title: string; desc: string }[];
  solutions: { icon: string; title: string; desc: string; link: string }[];
  useCases: { title: string; desc: string }[];
  ctaTitle: string;
  ctaCopy: string;
  faqs: { q: string; a: string }[];
  supportNote: { title: string; desc: string };
  supportCta: { label: string; href: string };
}

const {
  industry,
  title,
  description,
  canonical,
  badge,
  heroTitleLine1,
  heroTitleLine2,
  heroCopy,
  trustItems,
  challenges,
  solutions,
  useCases,
  ctaTitle,
  ctaCopy,
  faqs,
  supportNote,
  supportCta,
} = Astro.props;

const platformStats = [
  { value: "400+", label: "Events Powered" },
  { value: "50+", label: "Countries Worldwide" },
  { value: "4.8/5", label: "Client Satisfaction" },
  { value: "25+", label: "Platform Features" },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical={canonical}
  showFooterCta={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ① HERO — centered gradient text with floating glows -->
  <section class="ind-hero">
    <div class="ind-hero__bg-glow ind-hero__bg-glow--1"></div>
    <div class="ind-hero__bg-glow ind-hero__bg-glow--2"></div>
    <div class="ind-hero__inner">
      <div class="ind-hero__badge animate-on-scroll" data-animation="fadeInDown">
        <span class="ind-hero__badge-dot"></span>
        <span>{badge}</span>
      </div>
      <h1 class="ind-hero__title animate-on-scroll" data-animation="fadeInUp">
        {heroTitleLine1}<br />
        <span class="ind-hero__highlight">{heroTitleLine2}</span>
      </h1>
      <p class="ind-hero__copy animate-on-scroll" data-animation="fadeInUp">{heroCopy}</p>
      <div class="ind-hero__ctas animate-on-scroll" data-animation="fadeInUp">
        <a href="/book-a-demo/" class="ind-btn ind-btn--primary">
          Book a Demo
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/features/" class="ind-btn ind-btn--outline">View Features</a>
      </div>
      <div class="ind-hero__trust animate-on-scroll" data-animation="fadeIn">
        {trustItems.map((t) => (
          <span class="ind-hero__trust-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#375DFB" opacity=".15"/><path d="M5 8l2 2 4-4" stroke="#375DFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ② STATS — dark band with bg-1.webp, colored headline + 4 stat cards -->
  <section class="ind-stats">
    <div class="ind-stats__engagement">
      <div class="ind-stats__engagement-text">
        <h2 class="ind-stats__heading animate-on-scroll" data-animation="fadeInDown">
          <span class="ind-stats--white">EventHex powers </span>
          <span class="ind-stats--purple">{industry} events </span>
          <span class="ind-stats--white">with </span>
          <span class="ind-stats--cyan">AI-driven tools</span>
        </h2>
      </div>
    </div>
    <div class="ind-stats__grid">
      {platformStats.map((stat) => (
        <div class="ind-stats__card animate-on-scroll" data-animation="fadeInUp">
          <span class="ind-stats__value">{stat.value}</span>
          <span class="ind-stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ③ CHALLENGES — dark bg with Bg.svg, numbered glass cards -->
  <section class="ind-challenges">
    <div class="ind-challenges__inner">
      <div class="ind-challenges__header">
        <span class="ind-challenges__tag animate-on-scroll" data-animation="fadeIn">Key Challenges</span>
        <h2 class="ind-challenges__title animate-on-scroll" data-animation="fadeInUp">
          Common Event Challenges in <b>{industry}</b>
        </h2>
        <p class="ind-challenges__desc animate-on-scroll" data-animation="fadeInUp">
          Understanding your pain points so we can solve them.
        </p>
      </div>
      <div class="ind-challenges__cards">
        {challenges.map((c, i) => (
          <article class="ind-challenges__card animate-on-scroll" data-animation="fadeInUp">
            <div class="ind-challenges__card-num">{String(i + 1).padStart(2, "0")}</div>
            <span class="ind-challenges__card-icon" set:html={emojiIcon(c.icon)} />
            <h3 class="ind-challenges__card-title">{c.title}</h3>
            <p class="ind-challenges__card-desc">{c.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ④ SOLUTIONS — dark bg with bg-2.webp, premium hover-glow cards -->
  <section class="ind-solutions">
    <div class="ind-solutions__inner">
      <div class="ind-solutions__header">
        <span class="ind-solutions__eyebrow animate-on-scroll" data-animation="fadeIn">EventHex Solutions</span>
        <h2 class="ind-solutions__title animate-on-scroll" data-animation="fadeInUp">
          How EventHex Solves <span class="ind-solutions__highlight">{industry}</span> Event Challenges
        </h2>
      </div>
      <div class="ind-solutions__grid">
        {solutions.map((s) => (
          <a href={s.link} class="ind-solutions__card animate-on-scroll" data-animation="fadeInUp">
            <div class="ind-solutions__card-glow"></div>
            <span class="ind-solutions__card-icon" set:html={emojiIcon(s.icon)} />
            <h3 class="ind-solutions__card-title">{s.title}</h3>
            <p class="ind-solutions__card-desc">{s.desc}</p>
            <span class="ind-solutions__card-link">
              Learn more
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑤ USE CASES — dark bg with bg.svg, card grid -->
  <section class="ind-usecases">
    <div class="ind-usecases__inner">
      <div class="ind-usecases__header">
        <span class="ind-usecases__tag animate-on-scroll" data-animation="fadeIn">Use Cases</span>
        <h2 class="ind-usecases__title animate-on-scroll" data-animation="fadeInUp">
          {industry} Event Use Cases
        </h2>
        <p class="ind-usecases__desc animate-on-scroll" data-animation="fadeInUp">
          Real-world applications of EventHex for {industry.toLowerCase()} events.
        </p>
      </div>
      <div class="ind-usecases__cards">
        {useCases.map((u, i) => (
          <div class="ind-usecases__card animate-on-scroll" data-animation="fadeInUp">
            <div class="ind-usecases__card-num">{String(i + 1).padStart(2, "0")}</div>
            <h3 class="ind-usecases__card-title">{u.title}</h3>
            <p class="ind-usecases__card-desc">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑥ CTA — dark card with glows (feature-page pattern) -->
  <section class="ind-cta">
    <div class="ind-cta__card">
      <div class="ind-cta__glow ind-cta__glow--1"></div>
      <div class="ind-cta__glow ind-cta__glow--2"></div>
      <div class="ind-cta__content">
        <span class="ind-cta__eyebrow animate-on-scroll" data-animation="fadeIn">Start Your Next Event Faster</span>
        <h2 class="ind-cta__title animate-on-scroll" data-animation="fadeInUp">{ctaTitle}</h2>
        <p class="ind-cta__copy animate-on-scroll" data-animation="fadeInUp">{ctaCopy}</p>
        <div class="ind-cta__proof-row animate-on-scroll" data-animation="fadeInUp">
          <span class="ind-cta__proof-pill">AI-powered platform</span>
          <span class="ind-cta__proof-pill">Free onboarding support</span>
          <span class="ind-cta__proof-pill">No credit card required</span>
        </div>
        <div class="ind-cta__buttons animate-on-scroll" data-animation="fadeInUp">
          <a href="/book-a-demo/" class="ind-btn ind-btn--white">
            Book a Free Demo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/features/" class="ind-btn ind-btn--ghost">Explore Features</a>
        </div>
        <div class="ind-cta__trust animate-on-scroll" data-animation="fadeIn">
          {trustItems.map((t) => (
            <span class="ind-cta__trust-item">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
              {t}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ⑦ FAQ — split layout, sidebar + accordion (feature-page pattern) -->
  <section class="ind-faq">
    <div class="ind-faq__inner">
      <div class="ind-faq__sidebar animate-on-scroll" data-animation="fadeInLeft">
        <span class="ind-faq__eyebrow">Need a custom setup?</span>
        <h2 class="ind-faq__sidebar-title">Frequently Asked Questions</h2>
        <p class="ind-faq__sidebar-desc">
          We help event teams in {industry.toLowerCase()} configure the perfect event workflow.
        </p>
        <div class="ind-faq__support-card">
          <h3 class="ind-faq__support-title">{supportNote.title}</h3>
          <p class="ind-faq__support-desc">{supportNote.desc}</p>
        </div>
        <a href={supportCta.href} class="ind-btn ind-btn--primary ind-btn--sm">{supportCta.label}</a>
      </div>
      <div class="ind-faq__list">
        {faqs.map((f) => (
          <details class="ind-faq__item animate-on-scroll" data-animation="fadeInUp">
            <summary class="ind-faq__question">
              {f.q}
              <svg class="ind-faq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div class="ind-faq__answer"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* ══════════════════════════════════════════
     ① HERO — centered gradient + floating glows
     ═══════════════════════════════════════════ */
  .ind-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    text-align: center;
    background:
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat,
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }
  .ind-hero__bg-glow {
    display: none;
  }
  .ind-hero__bg-glow--1,
  .ind-hero__bg-glow--2 {
    display: none;
  }
  .ind-hero__inner {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    padding: 160px 1.5rem 5rem;
  }
  .ind-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
    margin-bottom: 1.5rem;
  }
  .ind-hero__badge-dot {
    display: none;
  }
  .ind-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 52px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin-bottom: 1.25rem;
  }
  .ind-hero__highlight {
    display: block;
    color: var(--brand-blue);
  }
  .ind-hero__copy {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    max-width: 680px;
    margin: 0 auto 2rem;
  }
  .ind-hero__ctas {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .ind-hero__trust {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .ind-hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--subheading-gray);
  }

  /* ══════════════════════════════════════════
     ② STATS — dark band with bg-1.webp
     ═══════════════════════════════════════════ */
  .ind-stats {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 100px 1.5rem;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }
  .ind-stats__engagement {
    width: 100%;
    padding: 0 0 60px;
    display: flex;
    justify-content: center;
  }
  .ind-stats__engagement-text {
    width: 65%;
    max-width: 800px;
  }
  .ind-stats__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    text-align: center;
    margin: 0;
  }
  .ind-stats--white { color: #fff; }
  .ind-stats--purple { color: #AFA3FF; }
  .ind-stats--cyan { color: #ABFFFF; }
  .ind-stats__grid {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    max-width: 1100px;
    margin: 0 auto;
  }
  .ind-stats__card {
    flex: 0 0 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    text-align: center;
  }
  .ind-stats__value {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -1px;
  }
  .ind-stats__label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ══════════════════════════════════════════
     ③ CHALLENGES — dark bg + Bg.svg, numbered glass cards
     ═══════════════════════════════════════════ */
  .ind-challenges {
    width: 100%;
    padding: 80px 1.5rem;
    background: #fff;
  }
  .ind-challenges__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  .ind-challenges__header {
    text-align: center;
    max-width: 700px;
  }
  .ind-challenges__tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-blue);
    margin-bottom: 0.75rem;
  }
  .ind-challenges__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--heading-dark);
    line-height: 1.25;
    margin: 0 0 0.75rem;
  }
  .ind-challenges__title b {
    color: var(--brand-blue);
    font-weight: 700;
  }
  .ind-challenges__desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0;
  }
  .ind-challenges__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    width: 100%;
  }
  .ind-challenges__card {
    position: relative;
    background: var(--surface-light);
    border: 1px solid var(--surface-card-border);
    border-radius: 16px;
    padding: 2rem 1.5rem 1.75rem;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .ind-challenges__card:hover {
    transform: translateY(-6px);
    border-color: var(--brand-blue);
    box-shadow: 0 12px 32px rgba(55, 93, 251, 0.1);
  }
  .ind-challenges__card-num {
    position: absolute;
    top: 16px;
    right: 16px;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(55, 93, 251, 0.2);
    letter-spacing: 0.05em;
  }
  .ind-challenges__card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(55, 93, 251, 0.08);
    border-radius: 10px;
    margin-bottom: 1rem;
    color: var(--brand-blue);
  }
  .ind-challenges__card-icon svg {
    width: 28px;
    height: 28px;
    color: var(--brand-blue);
  }
  .ind-challenges__card-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0 0 0.5rem;
    line-height: 1.35;
  }
  .ind-challenges__card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--subheading-gray);
    margin: 0;
  }

  /* ══════════════════════════════════════════
     ④ SOLUTIONS — dark bg-2.webp, hover-glow cards
     ═══════════════════════════════════════════ */
  .ind-solutions {
    width: 100%;
    padding: 80px 1.5rem;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }
  .ind-solutions__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }
  .ind-solutions__header {
    text-align: center;
    max-width: 700px;
  }
  .ind-solutions__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #ABFFFF;
    margin-bottom: 0.75rem;
  }
  .ind-solutions__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }
  .ind-solutions__highlight {
    color: #ABFFFF;
    font-weight: 700;
  }
  .ind-solutions__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    width: 100%;
  }
  .ind-solutions__card {
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2rem;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .ind-solutions__card:hover {
    transform: translateY(-6px);
    border-color: rgba(55, 93, 251, 0.5);
  }
  .ind-solutions__card-glow {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(55, 93, 251, 0.15);
    filter: blur(60px);
    top: -60px;
    right: -60px;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .ind-solutions__card:hover .ind-solutions__card-glow {
    opacity: 1;
  }
  .ind-solutions__card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    position: relative;
    color: var(--brand-blue);
  }
  .ind-solutions__card-icon svg {
    width: 28px;
    height: 28px;
    color: var(--brand-blue);
  }
  .ind-solutions__card-title {
    font-family: var(--font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
    position: relative;
  }
  .ind-solutions__card-desc {
