---
const stats = [
  { value: "100+", label: "Badge Templates" },
  { value: "1M+", label: "Badges Printed" },
  { value: "5s", label: "Per-Badge Print Time" },
  { value: "50+", label: "Printer Models Supported" },
];
---

<section class="bcds-dark">
  <div class="bcds-engagement">
    <div class="bcds-engagement-text">
      <h2 class="bcds-heading animate-on-scroll" data-animation="fadeInDown">
        <span class="bcds-white">Design badges with </span>
        <span class="bcds-purple">visual editor </span>
        <span class="bcds-white">and </span>
        <span class="bcds-cyan">on-site printing</span>
      </h2>
    </div>
  </div>

  <div class="bcds-stats">
    {stats.map((stat) => (
      <div class="bcds-stat">
        <span class="bcds-stat-value">{stat.value}</span>
        <span class="bcds-stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .bcds-dark {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 110px 0;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .bcds-engagement {
    width: 100%;
    padding: 0 0 60px;
    display: flex;
    justify-content: center;
  }

  .bcds-engagement-text {
    width: 65%;
  }

  .bcds-heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 52px;
    letter-spacing: -1px;
    color: #fff;
    text-align: center;
    margin: 0;
  }

  .bcds-white { color: #fff; }
  .bcds-purple { color: #AFA3FF; }
  .bcds-cyan { color: #ABFFFF; }

  .bcds-stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    padding: 0 20px;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .bcds-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .bcds-stat-value {
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 700;
    line-height: 48px;
    letter-spacing: -1px;
    color: #fff;
  }

  .bcds-stat-label {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 20px;
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 1024px) {
    .bcds-dark { padding: 80px 0; }
    .bcds-engagement { padding: 0 20px 40px; }
    .bcds-engagement-text { width: 85%; }
    .bcds-heading { font-size: 40px; line-height: 1.1em; }
    .bcds-stats { gap: 40px; }
    .bcds-stat-value { font-size: 32px; }
    .bcds-stat-label { font-size: 14px; }
  }

  @media (max-width: 767px) {
    .bcds-dark { padding: 64px 0; }
    .bcds-engagement { padding: 0 15px 30px; }
    .bcds-engagement-text { width: 100%; }
    .bcds-heading { font-size: 25px; line-height: 1.2em; letter-spacing: 0; }
    .bcds-stats {
      flex-wrap: wrap;
      gap: 24px;
      justify-content: center;
    }
    .bcds-stat { width: 40%; }
    .bcds-stat-value { font-size: 28px; }
    .bcds-stat-label { font-size: 13px; }
  }
</style>
