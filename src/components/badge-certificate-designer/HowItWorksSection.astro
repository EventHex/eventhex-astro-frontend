---
const steps = [
  {
    num: "01",
    title: "Design Your Badge",
    desc: "Choose a template, add your event brand, QR codes, and dynamic data fields using the visual editor.",
  },
  {
    num: "02",
    title: "Connect Attendee Data",
    desc: "Link your registration data — names, companies, roles, and ticket types auto-populate into badge fields.",
  },
  {
    num: "03",
    title: "Print On Arrival",
    desc: "Set up on-site printers or self-service kiosks. Attendees scan their QR and get a printed badge in seconds.",
  },
  {
    num: "04",
    title: "Send Certificates",
    desc: "After the event, auto-generate and email personalized certificates to all attendees.",
  },
];
---

<section class="bcdhw-full">
  <div class="bcdhw-full__inner">
    <div class="bcdhw-full__header">
      <span class="bcdhw-full__tag animate-on-scroll" data-animation="fadeIn">How Badge Designer Works</span>
      <h2 class="bcdhw-full__title animate-on-scroll" data-animation="fadeInUp">From Design to <b>Printed Badge</b></h2>
      <p class="bcdhw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Design your badge, connect attendee data, set up on-site printers, and deliver certificates post-event.
      </p>
    </div>

    <div class="bcdhw-full__cards">
      {steps.map((step) => (
        <article class="bcdhw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="bcdhw-full__card-icon">{step.num}</div>
          <h3 class="bcdhw-full__card-title">{step.title}</h3>
          <p class="bcdhw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .bcdhw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .bcdhw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .bcdhw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .bcdhw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bcdhw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .bcdhw-full__title b { font-weight: 700; }

  .bcdhw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .bcdhw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .bcdhw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .bcdhw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .bcdhw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .bcdhw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .bcdhw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .bcdhw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .bcdhw-full { padding: 64px 0; }
    .bcdhw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .bcdhw-full { padding: 52px 0; }
    .bcdhw-full__title { font-size: 30px; line-height: 1.15; }
    .bcdhw-full__desc { font-size: 15px; }
    .bcdhw-full__cards { grid-template-columns: 1fr; }
  }
</style>
