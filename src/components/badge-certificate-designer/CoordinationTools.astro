---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5z" stroke="#375DFB" stroke-width="2" stroke-linejoin="round"/><path d="M2 17l10 5 10-5" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 12l10 5 10-5" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "100+ professional templates",
    desc: "Badge designs for every event type — conference, expo, gala, workshop, and hybrid events.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="6" y="2" width="12" height="20" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M6 6h12M6 18h12" stroke="#375DFB" stroke-width="2"/><circle cx="12" cy="12" r="2" fill="#375DFB"/></svg>`,
    title: "On-site badge printing",
    desc: "Print badges on arrival in under 5 seconds with thermal printers and self-service kiosks.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M3 10h18" stroke="#375DFB" stroke-width="2"/><circle cx="12" cy="16" r="1.5" fill="#375DFB"/><path d="M9 7h6" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Certificates at scale",
    desc: "Bulk-generate personalized certificates with auto-filled data and email delivery.",
  },
];
---

<section class="bcdc-full">
  <div class="bcdc-full__inner">
    <div class="bcdc-full__header">
      <span class="bcdc-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Badge Designer</span>
      <h2 class="bcdc-full__title animate-on-scroll" data-animation="fadeInUp">Professional Event <b>Credentialing</b></h2>
      <p class="bcdc-full__desc animate-on-scroll" data-animation="fadeInUp">Design, print, and deliver event badges and certificates without design tools or printing hassles.</p>
    </div>

    <div class="bcdc-full__cards">
      {cards.map((card) => (
        <div class="bcdc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="bcdc-full__card-icon" set:html={card.icon}></div>
          <h3 class="bcdc-full__card-title">{card.title}</h3>
          <p class="bcdc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .bcdc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://cms.eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .bcdc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .bcdc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .bcdc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .bcdc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .bcdc-full__title b { font-weight: 700; }

  .bcdc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .bcdc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .bcdc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .bcdc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .bcdc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .bcdc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .bcdc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .bcdc-full { padding: 64px 0; }
    .bcdc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .bcdc-full { padding: 52px 0; }
    .bcdc-full__title { font-size: 30px; line-height: 1.15; }
    .bcdc-full__desc { font-size: 15px; }
    .bcdc-full__cards { grid-template-columns: 1fr; }
  }
</style>
