---
const featureCards = [
  {
    eyebrow: "visual editor",
    title: "Design professional badges without design skills",
    desc: "Pick a template, customize with drag-and-drop, add QR codes and dynamic fields — then print at scale. No design skills needed.",
    items: [
      "Intuitive drag-and-drop editor",
      "QR codes for check-in and lead exchange",
      "Dynamic data fields auto-filled per attendee",
    ],
    visual: "editor",
  },
  {
    eyebrow: "on-site ops",
    title: "Print badges on arrival in under 5 seconds",
    desc: "Attendees arrive, scan their QR code, and get a printed badge in seconds. Self-service kiosks handle high-volume events without staff bottlenecks.",
    items: [
      "QR scan triggers instant badge print",
      "Self-service kiosk mode available",
      "Live print queue dashboard",
    ],
    visual: "onsite",
  },
  {
    eyebrow: "certificates",
    title: "Auto-generate certificates at scale for every attendee",
    desc: "Design once, generate thousands. Certificates auto-fill with attendee data and are delivered as high-res PDFs via email or attendee portal.",
    items: [
      "Bulk generation for all attendees",
      "Auto email delivery post-event",
      "Unique verification URL per certificate",
    ],
    visual: "certscale",
  },
  {
    eyebrow: "delivery",
    title: "Digital and physical badge delivery across all channels",
    desc: "Support thermal printers, pre-event mailing, digital wallet badges, and self-service kiosks — all from one platform.",
    items: [
      "50+ printer models supported",
      "Apple Wallet and LinkedIn integration",
      "Pre-event VIP badge mailing",
    ],
    visual: "deliver",
  },
];
---

<section class="bcdf-shell">
  <div class="bcdf-section">
    <div class="bcdf-header">
      <span class="bcdf-subtitle">Everything you need to design, print, and deliver event credentials</span>
      <h2 class="bcdf-title">
        Everything You Need to <span class="bcdf-highlight">Design, Print, and Deliver</span><br />
        Event Badges & Certificates
      </h2>
    </div>

    <div class="bcdf-cards" id="bcdf-stacking-cards">
      {featureCards.map((card, index) => (
        <div class="bcdf-card" data-card-index={index} style={`--card-index: ${index}; top: calc(20px + ${index * 20}px);`}>
          <div class="bcdf-card-content">
            <span class="bcdf-card-eyebrow">{card.eyebrow}</span>
            <h3 class="bcdf-card-title">{card.title}</h3>
            <p class="bcdf-card-desc">{card.desc}</p>
            <ul class="bcdf-card-items">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href="/book-a-demo/" class="bcdf-card-btn">Explore More</a>
          </div>

          <div class={`bcdf-card-visual bcdf-card-visual--${card.visual}`}>
            {card.visual === "editor" && (
              <Fragment>
                <div class="bcdf-editor-canvas">
                  <div class="bcdf-editor-canvas__badge">
                    <div class="bcdf-editor-canvas__header"></div>
                    <div class="bcdf-editor-canvas__photo"></div>
                    <div class="bcdf-editor-canvas__name"></div>
                    <div class="bcdf-editor-canvas__qr">
                      <span></span><span></span><span></span>
                      <span></span><span></span><span></span>
                      <span></span><span></span><span></span>
                    </div>
                  </div>
                  <div class="bcdf-editor-canvas__drag-handle bcdf-editor-canvas__drag-handle--1"></div>
                  <div class="bcdf-editor-canvas__drag-handle bcdf-editor-canvas__drag-handle--2"></div>
                  <div class="bcdf-editor-canvas__drag-handle bcdf-editor-canvas__drag-handle--3"></div>
                  <div class="bcdf-editor-canvas__drag-handle bcdf-editor-canvas__drag-handle--4"></div>
                </div>
                <div class="bcdf-visual-pill">Drag-and-drop</div>
              </Fragment>
            )}

            {card.visual === "onsite" && (
              <Fragment>
                <div class="bcdf-onsite-flow">
                  <div class="bcdf-onsite-flow__qr">
                    <span></span><span></span><span></span>
                    <span></span><span></span><span></span>
                    <span></span><span></span><span></span>
                  </div>
                  <div class="bcdf-onsite-flow__arrow">&#8594;</div>
                  <div class="bcdf-onsite-flow__printer">
                    <div class="bcdf-onsite-flow__printer-body"></div>
                    <div class="bcdf-onsite-flow__printer-slot"></div>
                  </div>
                  <div class="bcdf-onsite-flow__arrow">&#8594;</div>
                  <div class="bcdf-onsite-flow__badge">
                    <span></span><span></span>
                  </div>
                </div>
                <div class="bcdf-visual-pill">5s print time</div>
              </Fragment>
            )}

            {card.visual === "certscale" && (
              <Fragment>
                <div class="bcdf-cert-stack">
                  <div class="bcdf-cert-stack__cert bcdf-cert-stack__cert--1"></div>
                  <div class="bcdf-cert-stack__cert bcdf-cert-stack__cert--2"></div>
                  <div class="bcdf-cert-stack__cert bcdf-cert-stack__cert--3"></div>
                </div>
                <div class="bcdf-cert-progress">
                  <div class="bcdf-cert-progress__bar"></div>
                  <span class="bcdf-cert-progress__label">2,847 / 3,000</span>
                </div>
                <div class="bcdf-visual-pill">Bulk generation</div>
              </Fragment>
            )}

            {card.visual === "deliver" && (
              <Fragment>
                <div class="bcdf-deliver-channels">
                  <div class="bcdf-deliver-channels__item bcdf-deliver-channels__item--print">
                    <div class="bcdf-deliver-channels__icon"></div>
                    <span>Print</span>
                  </div>
                  <div class="bcdf-deliver-channels__item bcdf-deliver-channels__item--digital">
                    <div class="bcdf-deliver-channels__icon"></div>
                    <span>Digital</span>
                  </div>
                  <div class="bcdf-deliver-channels__item bcdf-deliver-channels__item--mail">
                    <div class="bcdf-deliver-channels__icon"></div>
                    <span>Mail</span>
                  </div>
                </div>
                <div class="bcdf-visual-pill">Multi-channel</div>
              </Fragment>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .bcdf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .bcdf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .bcdf-header {
    width: 72%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .bcdf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .bcdf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .bcdf-highlight { color: #AFA3FF; }

  .bcdf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .bcdf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.88));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .bcdf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .bcdf-card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(175, 163, 255, 0.12);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #afa3ff;
  }

  .bcdf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .bcdf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .bcdf-card-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bcdf-card-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .bcdf-card-items li::before {
    content: "";
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
  }

  .bcdf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .bcdf-card-btn:hover { transform: scale(1.05); }

  .bcdf-card-visual {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
    background: radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 52%);
  }

  /* Editor visual: Badge canvas with drag handles and QR */
  .bcdf-editor-canvas {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .bcdf-editor-canvas__badge {
    width: 180px;
    padding: 20px;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 22px 46px -36px rgba(17, 28, 56, 0.52);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .bcdf-editor-canvas__header {
    width: 60%;
    height: 8px;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
  }

  .bcdf-editor-canvas__photo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(55, 93, 251, 0.3), rgba(34, 197, 94, 0.2));
  }

  .bcdf-editor-canvas__name {
    width: 55%;
    height: 6px;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.12);
  }

  .bcdf-editor-canvas__qr {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    width: 36px;
    height: 36px;
    margin-top: 4px;
  }

  .bcdf-editor-canvas__qr span {
    background: #0f1117;
    border-radius: 1px;
  }

  .bcdf-editor-canvas__qr span:nth-child(5) { background: transparent; }

  .bcdf-editor-canvas__drag-handle {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #375dfb;
    border: 2px solid #fff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.4);
  }

  .bcdf-editor-canvas__drag-handle--1 { top: 30px; left: calc(50% - 95px); }
  .bcdf-editor-canvas__drag-handle--2 { top: 30px; right: calc(50% - 95px); }
  .bcdf-editor-canvas__drag-handle--3 { bottom: 30px; left: calc(50% - 95px); }
  .bcdf-editor-canvas__drag-handle--4 { bottom: 30px; right: calc(50% - 95px); }

  .bcdf-visual-pill {
    position: absolute;
    right: 32px;
    bottom: 36px;
    display: inline-flex;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: #183465;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
  }

  /* Onsite visual: Printer + QR scan + badge output flow */
  .bcdf-onsite-flow {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .bcdf-onsite-flow__qr {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    width: 48px;
    height: 48px;
    padding: 6px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.1);
  }

  .bcdf-onsite-flow__qr span {
    background: #fff;
    border-radius: 1px;
  }

  .bcdf-onsite-flow__qr span:nth-child(5) { background: transparent; }

  .bcdf-onsite-flow__arrow {
    color: #afa3ff;
    font-size: 20px;
    animation: bcdf-pulse 1.5s infinite;
  }

  .bcdf-onsite-flow__printer {
    position: relative;
  }

  .bcdf-onsite-flow__printer-body {
    width: 56px;
    height: 36px;
    border-radius: 8px 8px 0 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.08));
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .bcdf-onsite-flow__printer-slot {
    width: 80%;
    height: 3px;
    margin: 0 auto;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }

  .bcdf-onsite-flow__badge {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 44px;
    padding: 10px 8px;
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.06));
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .bcdf-onsite-flow__badge span {
    height: 4px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
  }

  .bcdf-onsite-flow__badge span:first-child { width: 90%; }
  .bcdf-onsite-flow__badge span:last-child { width: 60%; }

  /* Certscale visual: Stacked certificates with generation progress */
  .bcdf-cert-stack {
    position: absolute;
    left: 50%;
    top: 60px;
    transform: translateX(-50%);
    width: 180px;
    height: 140px;
  }

  .bcdf-cert-stack__cert {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    border: 2px solid rgba(212, 160, 23, 0.3);
    background: linear-gradient(180deg, rgba(255, 253, 245, 0.15), rgba(254, 243, 199, 0.1));
  }

  .bcdf-cert-stack__cert--1 { transform: rotate(-4deg); }
  .bcdf-cert-stack__cert--2 { transform: rotate(1deg) translateY(-6px); }
  .bcdf-cert-stack__cert--3 { transform: rotate(-1deg) translateY(-12px); background: linear-gradient(180deg, rgba(255, 253, 245, 0.2), rgba(254, 243, 199, 0.15)); }

  .bcdf-cert-progress {
    position: absolute;
    left: 34px;
    right: 34px;
    bottom: 80px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }

  .bcdf-cert-progress__bar {
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
  }

  .bcdf-cert-progress__bar::after {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 78%;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #22c55e);
    animation: bcdf-progress-fill 3s ease-in-out infinite;
  }

  .bcdf-cert-progress__label {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
  }

  /* Deliver visual: Multi-channel delivery */
  .bcdf-deliver-channels {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    gap: 20px;
  }

  .bcdf-deliver-channels__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .bcdf-deliver-channels__item span {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .bcdf-deliver-channels__icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .bcdf-deliver-channels__item--print .bcdf-deliver-channels__icon {
    background: rgba(55, 93, 251, 0.15);
    border-color: rgba(55, 93, 251, 0.25);
  }

  .bcdf-deliver-channels__item--digital .bcdf-deliver-channels__icon {
    background: rgba(34, 197, 94, 0.15);
    border-color: rgba(34, 197, 94, 0.25);
  }

  .bcdf-deliver-channels__item--mail .bcdf-deliver-channels__icon {
    background: rgba(245, 158, 11, 0.15);
    border-color: rgba(245, 158, 11, 0.25);
  }

  @keyframes bcdf-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @keyframes bcdf-progress-fill {
    0% { width: 0; }
    50% { width: 78%; }
    100% { width: 100%; }
  }

  @media (max-width: 1024px) {
    .bcdf-section { padding: 60px 20px 30px; }
    .bcdf-header { width: 80%; }
    .bcdf-subtitle { font-size: 16px; }
    .bcdf-title { font-size: 40px; line-height: 1em; }
    .bcdf-card { height: 450px; }
    .bcdf-card-content { flex-basis: 50%; }
    .bcdf-card-title { font-size: 28px; }
    .bcdf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .bcdf-section { padding: 50px 20px 30px; }
    .bcdf-header { width: 100%; }
    .bcdf-title { font-size: 30px; }
    .bcdf-card { flex-direction: column; height: 620px; }
    .bcdf-card-content { flex: 0 0 55%; padding: 20px 20px 0; }
    .bcdf-card-visual { min-height: 260px; padding: 12px; }
    .bcdf-card-title { font-size: 24px; }
    .bcdf-card-desc { font-size: 15px; }
    .bcdf-cards { padding-bottom: 40px; }
    .bcdf-editor-canvas { width: 160px; }
    .bcdf-editor-canvas__badge { width: 140px; padding: 14px; }
    .bcdf-onsite-flow { gap: 10px; }
    .bcdf-deliver-channels { gap: 14px; }
    .bcdf-cert-stack { width: 140px; }
  }
</style>
