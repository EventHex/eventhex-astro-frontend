---
const tabs = [
  {
    label: "Badge Design",
    hero: {
      eyebrow: "Visual Editor",
      title: "Drag-and-drop badge designer with QR codes, dynamic data, and templates",
      desc: "Pick a template, customize with your brand, add QR codes and dynamic attendee data fields, and preview across badge sizes.",
      points: ["100+ badge templates", "QR code auto-generation", "Dynamic data field mapping"],
      visual: "badgeedit",
    },
    cards: [
      {
        eyebrow: "Templates",
        title: "Template Gallery",
        desc: "100+ professional badge templates for every event type and format.",
        visual: "gallery",
      },
      {
        eyebrow: "QR",
        title: "QR Code Integration",
        desc: "Auto-generated QR codes for check-in, contact exchange, and verification.",
        visual: "qrcode",
      },
      {
        eyebrow: "Data",
        title: "Dynamic Data Fields",
        desc: "Auto-fill attendee name, company, role, and custom fields per badge.",
        visual: "datafields",
      },
      {
        eyebrow: "Sizes",
        title: "Multiple Badge Sizes",
        desc: "Standard, compact, and VIP sizes with auto-layout adjustment.",
        visual: "sizes",
      },
    ],
  },
  {
    label: "Certificate Design",
    hero: {
      eyebrow: "Certificate Engine",
      title: "Professional certificate templates with auto-fill and bulk PDF generation",
      desc: "Design once, generate thousands. Certificates auto-fill with attendee data and are delivered as high-resolution PDFs via email.",
      points: ["Custom branding", "Auto-fill attendee data", "Bulk PDF generation"],
      visual: "certedit",
    },
    cards: [
      {
        eyebrow: "Branding",
        title: "Custom Branding",
        desc: "Add your event logo, colors, fonts, and sponsor logos to certificates.",
        visual: "branding",
      },
      {
        eyebrow: "Auto-fill",
        title: "Auto-Fill Data",
        desc: "Merge attendee names, dates, and course details automatically.",
        visual: "autofill",
      },
      {
        eyebrow: "PDF",
        title: "PDF Generation",
        desc: "High-resolution downloadable PDF certificates for every attendee.",
        visual: "pdfgen",
      },
      {
        eyebrow: "Bulk",
        title: "Bulk Generation",
        desc: "Generate thousands of unique certificates in minutes.",
        visual: "bulkgen",
      },
    ],
  },
  {
    label: "Printing & Delivery",
    hero: {
      eyebrow: "Print Operations",
      title: "On-site badge printing with thermal printers, kiosks, and digital delivery",
      desc: "Attendees arrive, scan QR, and get a printed badge in seconds. Self-service kiosks handle high-volume events.",
      points: ["Thermal printer support", "Self-service kiosks", "Digital badge delivery"],
      visual: "printing",
    },
    cards: [
      {
        eyebrow: "Printers",
        title: "Thermal Printer Support",
        desc: "Compatible with 50+ thermal and inkjet badge printers.",
        visual: "thermal",
      },
      {
        eyebrow: "Mail",
        title: "Pre-Event Mailing",
        desc: "Print and mail badges before the event for VIP attendees.",
        visual: "mailing",
      },
      {
        eyebrow: "Digital",
        title: "Digital Badges",
        desc: "Send digital badge images to attendee phones via app or email.",
        visual: "digital",
      },
      {
        eyebrow: "Kiosk",
        title: "Self-Service Kiosk",
        desc: "Attendees scan QR and print their own badge at check-in kiosks.",
        visual: "kiosk",
      },
    ],
  },
];
---

<section class="bcdb-section" id="bcd-bento">
  <div class="bcdb-shell">
    <h2 class="bcdb-title">
      Badge <b>Design</b>, Certificate <b>Templates</b> & <b>Printing</b>
    </h2>
    <p class="bcdb-subtitle">
      Design, print, and deliver event badges and certificates from one integrated tool.
    </p>

    <nav class="bcdb-nav" aria-label="Badge certificate designer workflows">
      {tabs.map((tab, index) => (
        <button
          class={`bcdb-tab${index === 0 ? " bcdb-tab--active" : ""}`}
          data-bcdb-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`bcdb-panel${tabIndex === 0 ? " bcdb-panel--active" : ""}`}
        data-bcdb-panel={tabIndex}
      >
        <div class="bcdb-grid">
          <article class="bcdb-card bcdb-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="bcdb-card__content">
              <span class="bcdb-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="bcdb-card__title">{tab.hero.title}</h3>
              <p class="bcdb-card__desc">{tab.hero.desc}</p>

              <ul class="bcdb-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`bcdb-art bcdb-art--hero bcdb-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "badgeedit" && (
                <Fragment>
                  <div class="bcdb-badge-canvas">
                    <div class="bcdb-badge-canvas__header"></div>
                    <div class="bcdb-badge-canvas__photo"></div>
                    <div class="bcdb-badge-canvas__name"></div>
                    <div class="bcdb-badge-canvas__role"></div>
                    <div class="bcdb-badge-canvas__qr">
                      <span></span><span></span><span></span>
                      <span></span><span></span><span></span>
                      <span></span><span></span><span></span>
                    </div>
                    <div class="bcdb-badge-canvas__handle bcdb-badge-canvas__handle--tl"></div>
                    <div class="bcdb-badge-canvas__handle bcdb-badge-canvas__handle--tr"></div>
                    <div class="bcdb-badge-canvas__handle bcdb-badge-canvas__handle--bl"></div>
                    <div class="bcdb-badge-canvas__handle bcdb-badge-canvas__handle--br"></div>
                  </div>
                  <div class="bcdb-ai-chip">Visual Editor</div>
                  <div class="bcdb-lang-pill">QR Ready</div>
                </Fragment>
              )}

              {tab.hero.visual === "certedit" && (
                <Fragment>
                  <div class="bcdb-cert-frame">
                    <div class="bcdb-cert-frame__border">
                      <div class="bcdb-cert-frame__title"></div>
                      <div class="bcdb-cert-frame__name"></div>
                      <div class="bcdb-cert-frame__desc"></div>
                      <div class="bcdb-cert-frame__seal"></div>
                      <div class="bcdb-cert-frame__sig"></div>
                    </div>
                  </div>
                  <div class="bcdb-ai-chip">Certificate Ready</div>
                </Fragment>
              )}

              {tab.hero.visual === "printing" && (
                <Fragment>
                  <div class="bcdb-printer-unit">
                    <div class="bcdb-printer-unit__body">
                      <div class="bcdb-printer-unit__slot"></div>
                      <div class="bcdb-printer-unit__light"></div>
                    </div>
                    <div class="bcdb-printer-unit__badge">
                      <div class="bcdb-printer-unit__badge-inner">
                        <span></span><span></span>
                      </div>
                    </div>
                  </div>
                  <div class="bcdb-ai-chip">Print Ready</div>
                  <div class="bcdb-lang-pill">5s per badge</div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="bcdb-card bcdb-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="bcdb-card__content">
                <span class="bcdb-card__eyebrow">{card.eyebrow}</span>
                <h3 class="bcdb-card__title">{card.title}</h3>
                <p class="bcdb-card__desc">{card.desc}</p>
              </div>

              <div class={`bcdb-art bcdb-art--mini bcdb-art--${card.visual}`} aria-hidden="true">
                {card.visual === "gallery" && (
                  <Fragment>
                    <div class="bcdb-template-grid">
                      <span></span><span></span><span></span>
                      <span></span><span></span><span class="bcdb-template-grid--selected"></span>
                    </div>
                    <div class="bcdb-mini-chip">100+ templates</div>
                  </Fragment>
                )}

                {card.visual === "qrcode" && (
                  <Fragment>
                    <div class="bcdb-qr-badge">
                      <div class="bcdb-qr-badge__card">
                        <span></span><span></span>
                      </div>
                      <div class="bcdb-qr-badge__qr">
                        <span></span><span></span><span></span>
                        <span></span><span></span><span></span>
                        <span></span><span></span><span></span>
                      </div>
                      <div class="bcdb-qr-badge__scan"></div>
                    </div>
                    <div class="bcdb-mini-chip">Auto QR</div>
                  </Fragment>
                )}

                {card.visual === "datafields" && (
                  <Fragment>
                    <div class="bcdb-data-panel">
                      <div class="bcdb-data-panel__field"><span>Name</span><span class="bcdb-data-panel__val"></span></div>
                      <div class="bcdb-data-panel__field"><span>Company</span><span class="bcdb-data-panel__val"></span></div>
                      <div class="bcdb-data-panel__field"><span>Role</span><span class="bcdb-data-panel__val"></span></div>
                      <div class="bcdb-data-panel__arrow">&#8594;</div>
                    </div>
                    <div class="bcdb-mini-chip">Auto-fill</div>
                  </Fragment>
                )}

                {card.visual === "sizes" && (
                  <Fragment>
                    <div class="bcdb-size-row">
                      <div class="bcdb-size-row__badge bcdb-size-row__badge--vip"><span>VIP</span></div>
                      <div class="bcdb-size-row__badge bcdb-size-row__badge--std"><span>STD</span></div>
                      <div class="bcdb-size-row__badge bcdb-size-row__badge--compact"><span>CPT</span></div>
                    </div>
                    <div class="bcdb-mini-chip">3 sizes</div>
                  </Fragment>
                )}

                {card.visual === "branding" && (
                  <Fragment>
                    <div class="bcdb-brand-panel">
                      <div class="bcdb-brand-panel__colors">
                        <span style="background:#375dfb"></span>
                        <span style="background:#22c55e"></span>
                        <span style="background:#f59e0b"></span>
                        <span style="background:#0f1117"></span>
                      </div>
                      <div class="bcdb-brand-panel__logo"></div>
                    </div>
                    <div class="bcdb-mini-chip">Brand kit</div>
                  </Fragment>
                )}

                {card.visual === "autofill" && (
                  <Fragment>
                    <div class="bcdb-autofill-viz">
                      <div class="bcdb-autofill-viz__source">
                        <span></span><span></span><span></span>
                      </div>
                      <div class="bcdb-autofill-viz__arrow">&#8594;</div>
                      <div class="bcdb-autofill-viz__cert">
                        <span class="bcdb-autofill-viz__cursor"></span>
                      </div>
                    </div>
                    <div class="bcdb-mini-chip">Auto-merge</div>
                  </Fragment>
                )}

                {card.visual === "pdfgen" && (
                  <Fragment>
                    <div class="bcdb-pdf-icon">
                      <span>PDF</span>
                    </div>
                    <div class="bcdb-pdf-dl">
                      <span class="bcdb-pdf-dl__btn">&#8595;</span>
                    </div>
                    <div class="bcdb-mini-chip">Download</div>
                  </Fragment>
                )}

                {card.visual === "bulkgen" && (
                  <Fragment>
                    <div class="bcdb-bulk-stack">
                      <span></span><span></span><span></span>
                    </div>
                    <div class="bcdb-bulk-progress">
                      <div class="bcdb-bulk-progress__bar"></div>
                    </div>
                    <div class="bcdb-mini-chip">Bulk ready</div>
                  </Fragment>
                )}

                {card.visual === "thermal" && (
                  <Fragment>
                    <div class="bcdb-printer-models">
                      <div class="bcdb-printer-models__item"><span>&#10003;</span></div>
                      <div class="bcdb-printer-models__item"><span>&#10003;</span></div>
                      <div class="bcdb-printer-models__item"><span>&#10003;</span></div>
                    </div>
                    <div class="bcdb-mini-chip">50+ printers</div>
                  </Fragment>
                )}

                {card.visual === "mailing" && (
                  <Fragment>
                    <div class="bcdb-envelope">
                      <div class="bcdb-envelope__flap"></div>
                      <div class="bcdb-envelope__body">
                        <div class="bcdb-envelope__badge-inside"></div>
                      </div>
                    </div>
                    <div class="bcdb-mini-chip">VIP mailing</div>
                  </Fragment>
                )}

                {card.visual === "digital" && (
                  <Fragment>
                    <div class="bcdb-phone">
                      <div class="bcdb-phone__screen">
                        <div class="bcdb-phone__badge-img"></div>
                        <div class="bcdb-phone__wallet-btns">
                          <span></span><span></span>
                        </div>
                      </div>
                    </div>
                    <div class="bcdb-mini-chip">Digital badge</div>
                  </Fragment>
                )}

                {card.visual === "kiosk" && (
                  <Fragment>
                    <div class="bcdb-kiosk">
                      <div class="bcdb-kiosk__screen">
                        <div class="bcdb-kiosk__qr-area">
                          <span class="bcdb-kiosk__corner bcdb-kiosk__corner--tl"></span>
                          <span class="bcdb-kiosk__corner bcdb-kiosk__corner--tr"></span>
                          <span class="bcdb-kiosk__corner bcdb-kiosk__corner--bl"></span>
                          <span class="bcdb-kiosk__corner bcdb-kiosk__corner--br"></span>
                        </div>
                      </div>
                      <div class="bcdb-kiosk__base"></div>
                    </div>
                    <div class="bcdb-mini-chip">Self-service</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".bcdb-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".bcdb-tab"));
      const panels = Array.from(root.querySelectorAll(".bcdb-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("bcdb-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("bcdb-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .bcdb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .bcdb-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .bcdb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .bcdb-title b { font-weight: 700; }

  .bcdb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .bcdb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .bcdb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .bcdb-tab:hover,
  .bcdb-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .bcdb-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .bcdb-panel { display: none; }
  .bcdb-panel--active { display: block; }

  .bcdb-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .bcdb-panel--active .bcdb-card {
    animation: bcdb-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  .bcdb-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .bcdb-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .bcdb-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .bcdb-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .bcdb-card--mini:nth-of-type(2) { grid-area: mini1; }
  .bcdb-card--mini:nth-of-type(3) { grid-area: mini2; }
  .bcdb-card--mini:nth-of-type(4) { grid-area: mini3; }
  .bcdb-card--mini:nth-of-type(5) { grid-area: mini4; }

  .bcdb-card__content { position: relative; z-index: 1; }

  .bcdb-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .bcdb-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .bcdb-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .bcdb-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .bcdb-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .bcdb-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .bcdb-art { position: relative; z-index: 1; min-height: 146px; }
  .bcdb-art--hero { min-height: 228px; margin-top: 0.6rem; }
  .bcdb-art--mini { align-self: end; }

  /* === Hero visuals === */

  /* badgeedit: Badge canvas with draggable elements and QR code */
  .bcdb-badge-canvas {
    position: absolute;
    inset: 0 8% auto 0;
    height: 92%;
    padding: 1rem;
    border-radius: 1.3rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 22px 46px -36px rgba(17, 28, 56, 0.52);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    animation: bcdb-float 5.2s ease-in-out infinite;
  }

  .bcdb-badge-canvas__header {
    width: 60%;
    height: 0.5rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
  }

  .bcdb-badge-canvas__photo {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(55, 93, 251, 0.3), rgba(34, 197, 94, 0.2));
    margin-top: 0.3rem;
  }

  .bcdb-badge-canvas__name {
    width: 55%;
    height: 0.4rem;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.12);
  }

  .bcdb-badge-canvas__role {
    width: 35%;
    height: 0.3rem;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.08);
  }

  .bcdb-badge-canvas__qr {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    width: 1.8rem;
    height: 1.8rem;
    margin-top: 0.3rem;
  }

  .bcdb-badge-canvas__qr span {
    background: #0f1117;
    border-radius: 1px;
  }

  .bcdb-badge-canvas__qr span:nth-child(5) { background: transparent; }
  .bcdb-badge-canvas__qr span:nth-child(8) { background: transparent; }

  .bcdb-badge-canvas__handle {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #375dfb;
    border: 2px solid #fff;
    box-shadow: 0 2px 6px rgba(55, 93, 251, 0.3);
  }

  .bcdb-badge-canvas__handle--tl { top: -4px; left: -4px; }
  .bcdb-badge-canvas__handle--tr { top: -4px; right: -4px; }
  .bcdb-badge-canvas__handle--bl { bottom: -4px; left: -4px; }
  .bcdb-badge-canvas__handle--br { bottom: -4px; right: -4px; }

  /* certedit: Certificate with gold border, seal, signature line */
  .bcdb-cert-frame {
    position: absolute;
    inset: 0 6% auto 0;
    height: 90%;
    animation: bcdb-float 5.2s ease-in-out infinite;
  }

  .bcdb-cert-frame__border {
    height: 100%;
    padding: 1.2rem;
    border-radius: 1.3rem;
    background: linear-gradient(180deg, #fffdf5, #fef3c7);
    border: 3px solid #d4a017;
    box-shadow: 0 22px 46px -36px rgba(17, 28, 56, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .bcdb-cert-frame__title {
    width: 50%;
    height: 0.5rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #d4a017, #f59e0b);
  }

  .bcdb-cert-frame__name {
    width: 65%;
    height: 0.45rem;
    border-radius: 999px;
    background: rgba(212, 160, 23, 0.2);
    margin-top: 0.4rem;
  }

  .bcdb-cert-frame__desc {
    width: 80%;
    height: 0.3rem;
    border-radius: 999px;
    background: rgba(212, 160, 23, 0.1);
