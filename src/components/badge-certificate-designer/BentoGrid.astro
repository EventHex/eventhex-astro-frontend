---
import { bcdbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Badge Design",
    hero: {
      title: "Drag-and-drop badge designer with QR codes, dynamic data, and templates",
      desc: "Pick a template, customize with your brand, add QR codes and dynamic attendee data fields, and preview across badge sizes.",
      visual: "badgeedit",
    },
    cards: [
      { title: "Template Gallery", desc: "100+ professional badge templates for every event type and format.", visual: "gallery" },
      { title: "QR Code Integration", desc: "Auto-generated QR codes for check-in, contact exchange, and verification.", visual: "qrcode" },
      { title: "Dynamic Data Fields", desc: "Auto-fill attendee name, company, role, and custom fields per badge.", visual: "datafields" },
      { title: "Multiple Badge Sizes", desc: "Standard, compact, and VIP sizes with auto-layout adjustment.", visual: "sizes" },
    ],
  },
  {
    label: "Certificate Design",
    hero: {
      title: "Professional certificate templates with auto-fill and bulk PDF generation",
      desc: "Design once, generate thousands. Certificates auto-fill with attendee data and are delivered as high-resolution PDFs via email.",
      visual: "certedit",
    },
    cards: [
      { title: "Custom Branding", desc: "Add your event logo, colors, fonts, and sponsor logos to certificates.", visual: "branding" },
      { title: "Auto-Fill Data", desc: "Merge attendee names, dates, and course details automatically.", visual: "autofill" },
      { title: "PDF Generation", desc: "High-resolution downloadable PDF certificates for every attendee.", visual: "pdfgen" },
      { title: "Bulk Generation", desc: "Generate thousands of unique certificates in minutes.", visual: "bulkgen" },
    ],
  },
  {
    label: "Printing & Delivery",
    hero: {
      title: "On-site badge printing with thermal printers, kiosks, and digital delivery",
      desc: "Attendees arrive, scan QR, and get a printed badge in seconds. Self-service kiosks handle high-volume events.",
      visual: "printing",
    },
    cards: [
      { title: "Thermal Printer Support", desc: "Compatible with 50+ thermal and inkjet badge printers.", visual: "thermal" },
      { title: "Pre-Event Mailing", desc: "Print and mail badges before the event for VIP attendees.", visual: "mailing" },
      { title: "Digital Badges", desc: "Send digital badge images to attendee phones via app or email.", visual: "digital" },
      { title: "Self-Service Kiosk", desc: "Attendees scan QR and print their own badge at check-in kiosks.", visual: "kiosk" },
    ],
  },
];

const ICON = '<svg class="bcdb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="bcdb-section" id="bcd-bento">
  <div class="bcdb">
    <h2 class="bcdb-title">
      Badge <b>Design</b>, Certificate <b>Templates</b> & <b>Printing</b>
    </h2>
    <p class="bcdb-subtitle">
      Design, print, and deliver event badges and certificates from one integrated tool.
    </p>

    <nav class="bcdb-nav" aria-label="Badge certificate designer workflows">
      {tabs.map((t, i) => (
        <button class={`bcdb-tab ${i === 0 ? "bcdb-tab--active" : ""}`} data-bcdb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`bcdb-panel ${tabIdx === 0 ? "bcdb-panel--active" : ""}`} data-bcdb-panel={String(tabIdx)}>
        <div class="bcdb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="bcdb-card bcdb-card--tall bcdb-pos-0" style="animation-delay:0s">
            <div class="bcdb-card__inner">
              <div class="bcdb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="bcdb-card__title">{t.hero.title}</h3>
                <p class="bcdb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="bcdb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`bcdb-card bcdb-card--sm bcdb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="bcdb-card__inner bcdb-card__inner--row">
                <div class="bcdb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="bcdb-card__title">{c.title}</h3>
                  <p class="bcdb-card__desc">{c.desc}</p>
                </div>
                <div class="bcdb-card__img bcdb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const bcdbTabs = Array.from(document.querySelectorAll('[data-bcdb-tab]'));
  const bcdbPanels = Array.from(document.querySelectorAll('[data-bcdb-panel]'));
  let bcdbActive = 0;
  let bcdbInterval: ReturnType<typeof setInterval>;

  function setBcdbTab(index: number) {
    bcdbTabs.forEach((t) => t.classList.remove('bcdb-tab--active'));
    bcdbPanels.forEach((p) => p.classList.remove('bcdb-panel--active'));
    bcdbTabs[index]?.classList.add('bcdb-tab--active');
    bcdbPanels[index]?.classList.add('bcdb-panel--active');
    bcdbActive = index;
  }
  function startBcdb() {
    bcdbInterval = setInterval(() => setBcdbTab((bcdbActive + 1) % bcdbTabs.length), 5000);
  }
  bcdbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setBcdbTab(i); clearInterval(bcdbInterval); startBcdb(); }));
  startBcdb();
  const bcdbSection = document.querySelector('.bcdb-section');
  if (bcdbSection) {
    bcdbSection.addEventListener('mouseenter', () => clearInterval(bcdbInterval));
    bcdbSection.addEventListener('mouseleave', () => startBcdb());
  }
</script>

<style>
  .bcdb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .bcdb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .bcdb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .bcdb-title b { font-weight: 700; }
  .bcdb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .bcdb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .bcdb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .bcdb-tab:hover { background: rgba(55,93,251,.08); }
  .bcdb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .bcdb-panel { display: none; }
  .bcdb-panel--active { display: block; animation: bcdbFadeUp 0.4s ease; }
  @keyframes bcdbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .bcdb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .bcdb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .bcdb-pos-1 { grid-column: 2; grid-row: 1; }
  .bcdb-pos-2 { grid-column: 3; grid-row: 1; }
  .bcdb-pos-3 { grid-column: 2; grid-row: 2; }
  .bcdb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .bcdb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .bcdb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .bcdb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .bcdb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .bcdb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .bcdb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .bcdb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .bcdb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .bcdb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .bcdb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --bcdb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .bcdb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: bcdbCardIn 0.5s ease forwards;
  }
  .bcdb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--bcdb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .bcdb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .bcdb-card:hover::after { opacity: 1; animation: bcdbBorder 2.4s linear infinite; }
  @keyframes bcdbBorder { to { --bcdb-angle: 360deg; } }
  @keyframes bcdbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .bcdb-pos-1 { animation-delay: 0.06s; }
  .bcdb-pos-2 { animation-delay: 0.12s; }
  .bcdb-pos-3 { animation-delay: 0.18s; }
  .bcdb-pos-4 { animation-delay: 0.24s; }

  .bcdb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .bcdb-card__inner--row { flex-direction: row; }
  .bcdb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .bcdb-card--tall .bcdb-card__text { padding: 20px 20px 8px; }
  .bcdb-card--sm .bcdb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .bcdb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .bcdb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .bcdb-card--sm .bcdb-card__title { font-size: 17px; }
  .bcdb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .bcdb-card--sm .bcdb-card__desc { font-size: 13px; }

  .bcdb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .bcdb-card--tall .bcdb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .bcdb-card--sm .bcdb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .bcdb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .bcdb-card:hover .bcdb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: bcdbFloat 2.2s ease-in-out infinite;
  }
  @keyframes bcdbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .bcdb-section { padding: 60px 0 48px; }
    .bcdb-title { font-size: 36px; }
    .bcdb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .bcdb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .bcdb-pos-1, .bcdb-pos-2, .bcdb-pos-3, .bcdb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .bcdb-pos-0, [data-layout="c"] .bcdb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .bcdb-pos-1, [data-layout="b"] .bcdb-pos-2, [data-layout="b"] .bcdb-pos-3, [data-layout="b"] .bcdb-pos-4,
    [data-layout="c"] .bcdb-pos-1, [data-layout="c"] .bcdb-pos-2, [data-layout="c"] .bcdb-pos-3, [data-layout="c"] .bcdb-pos-4 { grid-column: auto; grid-row: auto; }
    .bcdb-card--tall .bcdb-card__inner { flex-direction: row; }
    .bcdb-card--tall .bcdb-card__text { flex: 1; }
    .bcdb-card--tall .bcdb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .bcdb-title { font-size: 28px; }
    .bcdb-subtitle { font-size: 15px; }
    .bcdb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .bcdb-tab { border-radius: 12px; }
    .bcdb-grid { grid-template-columns: 1fr; }
    .bcdb-pos-0, .bcdb-pos-1, .bcdb-pos-2, .bcdb-pos-3, .bcdb-pos-4,
    [data-layout="b"] .bcdb-pos-0, [data-layout="b"] .bcdb-pos-1, [data-layout="b"] .bcdb-pos-2, [data-layout="b"] .bcdb-pos-3, [data-layout="b"] .bcdb-pos-4,
    [data-layout="c"] .bcdb-pos-0, [data-layout="c"] .bcdb-pos-1, [data-layout="c"] .bcdb-pos-2, [data-layout="c"] .bcdb-pos-3, [data-layout="c"] .bcdb-pos-4 { grid-column: 1; grid-row: auto; }
    .bcdb-card--sm .bcdb-card__inner, .bcdb-card--tall .bcdb-card__inner { flex-direction: row; }
    .bcdb-card--sm .bcdb-card__text, .bcdb-card--tall .bcdb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .bcdb-card--sm .bcdb-card__img, .bcdb-card--tall .bcdb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .bcdb-card { animation: none !important; opacity: 1; transform: none; }
    .bcdb-card:hover::after { animation: none !important; }
    .bcdb-card:hover .bcdb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
