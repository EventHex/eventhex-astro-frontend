---
const faqs = [
  {
    q: "Can I design custom badges for my event?",
    a: "Yes. The visual drag-and-drop editor lets you customize templates or create badges from scratch — add logos, colors, QR codes, attendee photos, and dynamic data fields.",
  },
  {
    q: "Does it support on-site badge printing?",
    a: "Yes. Set up thermal or inkjet printers at the venue. Attendees scan their QR code at a kiosk or check-in desk, and their personalized badge prints in under 5 seconds.",
  },
  {
    q: "Can certificates be auto-generated for attendees?",
    a: "Yes. Design a certificate template once, and the system auto-fills attendee data (name, course, date) and generates unique PDFs for every participant.",
  },
  {
    q: "What printer types are supported?",
    a: "We support 50+ printer models including popular thermal badge printers (Zebra, Brady, Dymo), inkjet printers, and standard laser printers.",
  },
  {
    q: "Can QR codes be added to badges?",
    a: "Yes. QR codes are auto-generated for each attendee and can link to their profile, enable check-in scanning, or facilitate contact exchange at the event.",
  },
  {
    q: "Can I bulk-generate certificates?",
    a: "Yes. Generate thousands of unique certificates in minutes. Each certificate is personalized with the attendee's details and delivered via email or the attendee portal.",
  },
];

const checklist = [
  "Visual badge designer",
  "On-site printing setup",
  "Certificate generation",
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="bcdfq">
  <div class="bcdfq__inner">
    <div class="bcdfq__support">
      <span class="bcdfq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need help with badges & certificates?</span>
      <h2 class="bcdfq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="bcdfq__desc animate-on-scroll" data-animation="fadeInUp">
        We help event teams design, print, and deliver professional badges and certificates tailored to their event workflow.
      </p>

      <div class="bcdfq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="bcdfq__support-label">Included with every rollout</span>
        <ul class="bcdfq__support-list">
          {checklist.map((item) => (
            <li class="bcdfq__support-item">{item}</li>
          ))}
        </ul>

        <div class="bcdfq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your badge and certificate workflow before launch and keep your team aligned on design, printing, and delivery.</span>
        </div>

        <a href="/book-a-demo/" class="bcdfq__cta">Plan my badge workflow</a>
      </div>
    </div>

    <div class="bcdfq__list">
      {faqs.map((faq, index) => (
        <details class="bcdfq__item animate-on-scroll" data-animation="fadeInUp" data-bcd-faq open={index === 0}>
          <summary class="bcdfq__question">
            <span>{faq.q}</span>
            <span class="bcdfq__icon" aria-hidden="true">
              <span class="bcdfq__icon-line bcdfq__icon-line--horizontal"></span>
              <span class="bcdfq__icon-line bcdfq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="bcdfq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const bcdFaqItems = Array.from(document.querySelectorAll('[data-bcd-faq]'));

  bcdFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      bcdFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .bcdfq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .bcdfq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .bcdfq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .bcdfq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .bcdfq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .bcdfq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .bcdfq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .bcdfq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .bcdfq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .bcdfq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .bcdfq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .bcdfq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .bcdfq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .bcdfq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .bcdfq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .bcdfq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .bcdfq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bcdfq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .bcdfq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
  }

  .bcdfq__question::-webkit-details-marker,
  .bcdfq__question::marker {
    display: none;
  }

  .bcdfq__icon {
    position: relative;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 4px;
  }

  .bcdfq__icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #375dfb;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .bcdfq__icon-line--vertical {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .bcdfq__item[open] .bcdfq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0);
  }

  .bcdfq__answer {
    padding: 0 24px 24px;
  }

  .bcdfq__answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #5b6477;
  }

  @media (max-width: 1100px) {
    .bcdfq { padding: 76px 0; }
    .bcdfq__inner { grid-template-columns: 1fr; gap: 28px; }
    .bcdfq__support { position: static; }
  }

  @media (max-width: 1024px) {
    .bcdfq__title { font-size: 40px; }
    .bcdfq__desc { font-size: 16px; }
    .bcdfq__question { padding: 24px 22px; font-size: 20px; }
    .bcdfq__answer { padding: 0 22px 22px; }
  }

  @media (max-width: 767px) {
    .bcdfq { padding: 56px 0; }
    .bcdfq__inner { padding: 0 16px; gap: 24px; }
    .bcdfq__title { font-size: 32px; line-height: 1.08; }
    .bcdfq__desc { font-size: 15px; line-height: 1.7; }
    .bcdfq__support-card { padding: 20px 18px; border-radius: 24px; }
    .bcdfq__support-item { font-size: 15px; }
    .bcdfq__support-note strong { font-size: 18px; }
    .bcdfq__cta { width: 100%; }
    .bcdfq__item { border-radius: 24px; }
    .bcdfq__question { padding: 20px 18px; font-size: 17px; line-height: 1.45; }
    .bcdfq__answer { padding: 0 18px 20px; }
    .bcdfq__answer p { font-size: 15px; line-height: 1.75; }
  }
</style>
