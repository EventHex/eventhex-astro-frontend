---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "Can I design custom badges for my event?", a: "Yes. The visual drag-and-drop editor lets you customize templates or create badges from scratch — add logos, colors, QR codes, attendee photos, and dynamic data fields." },
  { q: "Does it support on-site badge printing?", a: "Yes. Set up thermal or inkjet printers at the venue. Attendees scan their QR code at a kiosk or check-in desk, and their personalized badge prints in under 5 seconds." },
  { q: "Can certificates be auto-generated for attendees?", a: "Yes. Design a certificate template once, and the system auto-fills attendee data (name, course, date) and generates unique PDFs for every participant." },
  { q: "What printer types are supported?", a: "We support 50+ printer models including popular thermal badge printers (Zebra, Brady, Dymo), inkjet printers, and standard laser printers." },
  { q: "Can QR codes be added to badges?", a: "Yes. QR codes are auto-generated for each attendee and can link to their profile, enable check-in scanning, or facilitate contact exchange at the event." },
  { q: "Can I bulk-generate certificates?", a: "Yes. Generate thousands of unique certificates in minutes. Each certificate is personalized with the attendee's details and delivered via email or the attendee portal." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with badges & certificates?"
  title="Frequently Asked Questions"
  description="We help event teams design, print, and deliver professional badges and certificates tailored to their event workflow."
/>
