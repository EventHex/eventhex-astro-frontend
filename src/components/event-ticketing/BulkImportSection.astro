---
// Section 6: Bulk Import & Waitlist — redesigned with animated step flow

interface Card {
  title: string;
  desc: string;
  image: string;
}

interface Props {
  title: string;
  cards: Card[];
}

const { title, cards } = Astro.props;
---

<section class="etb-bulk" id="ticket-workflows">
  <div class="etb-bulk__shell">
    <!-- Header -->
    <div class="etb-bulk__hd animate-on-scroll" data-animation="fadeInUp" style="--anim-duration:700ms">
      <span class="etb-bulk__eyebrow">Registration ops</span>
      <h2 class="etb-bulk__title">{title}</h2>
      <p class="etb-bulk__copy">
        Keep imports, approvals, and ticket styling moving inside one workflow instead of bouncing between multiple tools.
      </p>
    </div>

    <!-- Signal strip (micro-animation) -->
    <div class="etb-bulk__signals" aria-hidden="true">
      <span class="etb-bulk__signal">
        <span class="etb-bulk__signal-dot"></span>CSV upload ready
      </span>
      <span class="etb-bulk__signal etb-bulk__signal--delay1">
        <span class="etb-bulk__signal-dot"></span>Approval logic synced
      </span>
      <span class="etb-bulk__signal etb-bulk__signal--delay2">
        <span class="etb-bulk__signal-dot"></span>Brand assets attached
      </span>
    </div>

    <!-- Step cards (connected by animated line) -->
    <div class="etb-bulk__steps">
      {cards.map((card, i) => (
        <div class="etb-bulk__step animate-on-scroll" data-animation="fadeInUp" data-delay={String(i * 130)} style="--anim-duration:650ms">
          {i < cards.length - 1 && (
            <div class="etb-bulk__connector" aria-hidden="true">
              <span class="etb-bulk__connector-line"></span>
            </div>
          )}
          <div class="etb-bulk__step-card">
            <div class="etb-bulk__step-num">{String(i + 1).padStart(2, "0")}</div>
            <div class="etb-bulk__step-icon">
              <img src={card.image} alt="" width="40" height="40" loading="lazy" />
            </div>
            <h3 class="etb-bulk__step-title">{card.title}</h3>
            <p class="etb-bulk__step-desc">{card.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA inline -->
    <div class="etb-bulk__ft animate-on-scroll" data-animation="fadeInUp" data-delay="400" style="--anim-duration:600ms">
      <a href="/book-a-demo/" class="etb-bulk__cta">Set up my ticket workflow</a>
    </div>
  </div>
</section>

<style>
  .etb-bulk {
    max-width: 1260px;
    margin: 0 auto;
    padding: 24px 24px 80px;
  }

  .etb-bulk__shell {
    padding: 52px 48px 44px;
    border-radius: 40px;
    background:
      radial-gradient(circle at 8% 10%, rgba(55, 93, 251, 0.18), transparent 32%),
      radial-gradient(circle at 92% 90%, rgba(159, 129, 255, 0.16), transparent 28%),
      linear-gradient(180deg, #0b1225 0%, #14203e 100%);
    color: #fff;
    box-shadow: 0 32px 80px rgba(11, 18, 37, 0.2);
    overflow: hidden;
    position: relative;
  }

  /* Subtle grid texture */
  .etb-bulk__shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.024) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.024) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .etb-bulk__hd {
    position: relative;
    max-width: 60%;
  }

  .etb-bulk__eyebrow {
    display: inline-flex;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c4d2ff;
  }

  .etb-bulk__title {
    margin-top: 16px;
    font-family: var(--font-heading);
    font-size: 44px;
    line-height: 1.08;
    font-weight: 700;
    letter-spacing: -1.4px;
    color: #fff;
  }

  .etb-bulk__copy {
    margin-top: 14px;
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.64);
    max-width: 86%;
  }

  /* Signal strip */
  .etb-bulk__signals {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
    position: relative;
  }

  .etb-bulk__signal {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.18);
    border: 1px solid rgba(55, 93, 251, 0.3);
    font-size: 13px;
    font-weight: 600;
    color: #a0b4ff;
    animation: signalPulse 2.4s ease-in-out infinite;
  }

  .etb-bulk__signal--delay1 { animation-delay: 0.4s; }
  .etb-bulk__signal--delay2 { animation-delay: 0.8s; }

  @keyframes signalPulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }

  .etb-bulk__signal-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #60a5fa;
    box-shadow: 0 0 8px #60a5fa;
    animation: dotBlink 1.6s ease-in-out infinite;
  }

  .etb-bulk__signal--delay1 .etb-bulk__signal-dot { animation-delay: 0.4s; }
  .etb-bulk__signal--delay2 .etb-bulk__signal-dot { animation-delay: 0.8s; }

  @keyframes dotBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Step cards */
  .etb-bulk__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin-top: 40px;
    position: relative;
  }

  .etb-bulk__step {
    position: relative;
    padding: 0 12px;
  }

  .etb-bulk__step:first-child { padding-left: 0; }
  .etb-bulk__step:last-child { padding-right: 0; }

  /* Horizontal connector arrow */
  .etb-bulk__connector {
    position: absolute;
    top: 44px;
    right: -16px;
    z-index: 2;
    display: flex;
    align-items: center;
  }

  .etb-bulk__connector-line {
    display: block;
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg, rgba(55, 93, 251, 0.4), rgba(159, 129, 255, 0.4));
    position: relative;
  }

  .etb-bulk__connector-line::after {
    content: "";
    position: absolute;
    right: -1px;
    top: -4px;
    border-left: 8px solid rgba(159, 129, 255, 0.6);
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
  }

  .etb-bulk__step-card {
    padding: 26px 22px;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    height: 100%;
    transition: background 0.28s ease, border-color 0.28s ease, transform 0.28s ease;
  }

  .etb-bulk__step-card:hover {
    background: rgba(55, 93, 251, 0.14);
    border-color: rgba(55, 93, 251, 0.3);
    transform: translateY(-4px);
  }

  .etb-bulk__step-num {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -2px;
    color: rgba(255, 255, 255, 0.08);
    margin-bottom: 12px;
  }

  .etb-bulk__step-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: rgba(55, 93, 251, 0.2);
    margin-bottom: 16px;
  }

  .etb-bulk__step-icon img {
    width: 26px;
    height: 26px;
    object-fit: contain;
    filter: brightness(0) invert(1) opacity(0.9);
  }

  .etb-bulk__step-title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 10px;
  }

  .etb-bulk__step-desc {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.62);
  }

  /* Footer CTA */
  .etb-bulk__ft {
    display: flex;
    justify-content: center;
    margin-top: 42px;
  }

  .etb-bulk__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border-radius: 14px;
    background: var(--brand-blue);
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(55, 93, 251, 0.36);
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }

  .etb-bulk__cta:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 14px 36px rgba(55, 93, 251, 0.44);
  }

  @media (max-width: 1024px) {
    .etb-bulk { padding: 16px 20px 60px; }
    .etb-bulk__shell { padding: 40px 32px 36px; }
    .etb-bulk__hd { max-width: none; }
    .etb-bulk__title { font-size: 36px; }
    .etb-bulk__steps { grid-template-columns: 1fr; gap: 18px; }
    .etb-bulk__step { padding: 0; }
    .etb-bulk__connector { display: none; }
  }

  @media (max-width: 640px) {
    .etb-bulk__shell { padding: 28px 22px 28px; border-radius: 28px; }
    .etb-bulk__title { font-size: 28px; }
    .etb-bulk__copy { font-size: 15px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .etb-bulk__signal,
    .etb-bulk__signal-dot { animation: none; opacity: 1; }
  }
</style>
