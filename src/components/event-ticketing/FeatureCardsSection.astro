---
// Stacking Cards section — matches speaker-management FeatureCards pattern
// Dark bg with bg-2.webp, sticky stacking cards for key ticketing features
// Content sourced from existing FeatureSplitSection data

const featureCards = [
  {
    title: "Simplified Checkout for Higher Conversions",
    desc: "Provide attendees with a mobile-first, intuitive ticket booking flow. From selection to secure payment, the frictionless design minimizes drop-offs and boosts ticket completion rates across devices.",
    image: "/feature-images/event-ticketing/simplified-checkout.svg",
    alt: "EventHex checkout flow preview on desktop display",
  },
  {
    title: "Secure Payment Processing",
    desc: "Get instant payouts with your own payment gateway at 0% platform fees, or use EventHex's competitive rates. Either way, payments are secure, fast, and fully transparent for organizers and attendees.",
    image: "/feature-images/event-ticketing/secure-payment.svg",
    alt: "Tablet preview of secure ticket payment processing",
  },
  {
    title: "QR Code Scanning & Badge Printing",
    desc: "Generate QR-enabled tickets that streamline event check-ins. Pair them with on-demand badge printing for instant attendee identification — a hassle-free registration experience at the venue.",
    image: "/feature-images/event-ticketing/qr-badge-cards.svg",
    alt: "Printed badges and QR-enabled event tickets",
  },
  {
    title: "Custom Ticketing with Brand Support",
    desc: "Create unlimited ticket types — early-bird, VIP, group bundles — with discounts, coupon codes, and campaign pricing. Every ticket carries your event branding for a professional, memorable experience.",
    image: "/feature-images/event-ticketing/custom-ticketing-brand.svg",
    alt: "Tablet preview of branded ticket customization",
  },
  {
    title: "Paid Add-Ons, Coupon Codes & Price Quotes",
    desc: "Offer paid add-ons like workshop seats, meal plans, or parking at checkout. Generate shareable price quotes for group buyers, and issue targeted coupon codes — percentage, flat, or early-bird — to drive conversions.",
    image: "/feature-images/event-ticketing/simplified-checkout.svg",
    alt: "Add-ons and coupon code management for event ticketing",
  },
];
---

<section class="etf-shell">
  <div class="etf-section">
    <div class="etf-header">
      <span class="etf-subtitle animate-on-scroll" data-animation="fadeInUp">Flow-by-flow</span>
      <h2 class="etf-title animate-on-scroll" data-animation="fadeInUp">
        Everything Built Into One <span class="etf-highlight">Ticketing Platform</span>
      </h2>
    </div>

    <div class="etf-cards" id="etf-stacking-cards">
      {featureCards.map((card, i) => (
        <div
          class="etf-card"
          data-card-index={i}
          style={`--card-index: ${i}; top: calc(20px + ${i * 20}px);`}
        >
          <div class="etf-card-content">
            <h3 class="etf-card-title">{card.title}</h3>
            <p class="etf-card-desc">{card.desc}</p>
            <a href="/book-a-demo/" class="etf-card-btn">Explore More</a>
          </div>
          <div class="etf-card-image">
            <img src={card.image} alt={card.alt} loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .etf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .etf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .etf-header {
    width: 70%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .etf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .etf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .etf-highlight { color: #AFA3FF; }

  .etf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .etf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.8));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .etf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .etf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .etf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .etf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .etf-card-btn:hover { transform: scale(1.05); }

  .etf-card-image {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow: hidden;
  }

  .etf-card-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    animation: etfFloat 4s ease-in-out infinite;
  }

  .etf-card[data-card-index="0"] .etf-card-image img {
    max-width: 80%;
  }

  .etf-card[data-card-index="1"] .etf-card-image img {
    max-width: 80%;
  }

  @keyframes etfFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @media (max-width: 1024px) {
    .etf-section { padding: 60px 20px 30px; }
    .etf-header { width: 80%; }
    .etf-subtitle { font-size: 16px; }
    .etf-title { font-size: 40px; line-height: 1em; }
    .etf-card { height: 450px; }
    .etf-card-content { flex-basis: 50%; }
    .etf-card-title { font-size: 28px; }
    .etf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .etf-section { padding: 50px 20px 30px; }
    .etf-header { width: 100%; }
    .etf-title { font-size: 30px; }
    .etf-card { flex-direction: column; height: 520px; }
    .etf-card-content { flex: 0 0 50%; padding: 20px 20px 0; }
    .etf-card-image { padding: 10px; }
    .etf-card-title { font-size: 24px; }
    .etf-card-desc { font-size: 15px; }
    .etf-cards { padding-bottom: 40px; }
  }
</style>
