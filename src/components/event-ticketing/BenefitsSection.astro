---
// Section 7: Benefits — redesigned bento-style grid with dark + light cards

interface BenefitCard {
  title: string;
  desc: string;
  image: string;
}

interface Props {
  title: string;
  rows: BenefitCard[][];
}

const { title, rows } = Astro.props;
const cards = rows.flat();
---

<section class="etb-benefits">
  <!-- Dark header band mirrors home page dark sections -->
  <div class="etb-benefits__hd-band">
    <div class="etb-benefits__hd-inner">
      <span class="etb-benefits__eyebrow animate-on-scroll" data-animation="fadeInUp" style="--anim-duration:600ms">Why organizers choose EventHex</span>
      <h2 class="etb-benefits__title animate-on-scroll" data-animation="fadeInUp" data-delay="100" style="--anim-duration:700ms">{title}</h2>
      <p class="etb-benefits__subtitle animate-on-scroll" data-animation="fadeInUp" data-delay="200" style="--anim-duration:700ms">
        Everything you need to sell tickets, manage attendees, and run on-site check-in&mdash;in one platform.
      </p>
    </div>
  </div>

  <!-- Bento grid -->
  <div class="etb-benefits__grid">
    {cards.map((card, i) => (
      <article
        class:list={[
          "etb-benefits__card",
          "animate-on-scroll",
          i === 0 && "etb-benefits__card--featured",
          i === 2 && "etb-benefits__card--accent",
          (i === 1 || i === 3) && "etb-benefits__card--tall",
        ]}
        data-animation="fadeInUp"
        data-delay={String(i * 80)}
        style="--anim-duration: 600ms"
      >
        <div class="etb-benefits__card-img">
          <img src={card.image} alt="" width="80" height="80" loading="lazy" />
        </div>
        <h3 class="etb-benefits__card-title">{card.title}</h3>
        <p class="etb-benefits__card-desc">{card.desc}</p>
        {i === 0 && (
          <span class="etb-benefits__card-cta">Learn more</span>
        )}
      </article>
    ))}
  </div>

  <!-- Stats row -->
  <div class="etb-benefits__stats">
    <div class="etb-benefits__stat animate-on-scroll" data-animation="fadeInLeft" style="--anim-duration:700ms">
      <strong>1</strong>
      <span>Dashboard for sales &amp; approvals &amp; on-site entry</span>
    </div>
    <div class="etb-benefits__divider" aria-hidden="true"></div>
    <div class="etb-benefits__stat animate-on-scroll" data-animation="fadeInUp" data-delay="100" style="--anim-duration:700ms">
      <strong>Multi</strong>
      <span>Payment gateway paths without checkout friction</span>
    </div>
    <div class="etb-benefits__divider" aria-hidden="true"></div>
    <div class="etb-benefits__stat animate-on-scroll" data-animation="fadeInRight" data-delay="200" style="--anim-duration:700ms">
      <strong>Live</strong>
      <span>Analytics that help you sell smarter next time</span>
    </div>
  </div>
</section>

<style>
  /* ─── Outer container ─── */
  .etb-benefits {
    padding: 0 0 80px;
  }

  /* ─── Dark header band ─── */
  .etb-benefits__hd-band {
    background:
      radial-gradient(circle at 12% 10%, rgba(171, 255, 255, 0.1), transparent 26%),
      #000 url("https://cms.eventhex.ai/wp-content/uploads/2025/03/bg-back.svg") center top / cover no-repeat;
    padding: 80px 0 100px;
    margin-bottom: -4px;
  }

  .etb-benefits__hd-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }

  .etb-benefits__eyebrow {
    display: inline-flex;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c4d2ff;
  }

  .etb-benefits__title {
    margin-top: 20px;
    font-family: var(--font-heading);
    font-size: 52px;
    line-height: 1.06;
    font-weight: 700;
    letter-spacing: -1.4px;
    color: #fff;
  }

  .etb-benefits__subtitle {
    margin-top: 16px;
    font-size: 18px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
  }

  /* ─── Bento grid ─── */
  .etb-benefits__grid {
    max-width: 1260px;
    margin: 0 auto;
    padding: 48px 24px 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: auto auto;
    gap: 18px;
  }

  /* Card defaults */
  .etb-benefits__card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    border-radius: 28px;
    background: linear-gradient(180deg, #fff 0%, #f5f8ff 100%);
    border: 1px solid rgba(55, 93, 251, 0.08);
    box-shadow: 0 4px 24px rgba(19, 29, 52, 0.05);
    transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
  }

  .etb-benefits__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 48px rgba(55, 93, 251, 0.1);
    border-color: rgba(55, 93, 251, 0.18);
  }

  /* Featured card (large, spans 2 rows) */
  .etb-benefits__card--featured {
    grid-column: 1;
    grid-row: 1 / 3;
    background:
      radial-gradient(circle at top right, rgba(55, 93, 251, 0.15), transparent 40%),
      linear-gradient(180deg, #fff 0%, #edf2ff 100%);
    justify-content: space-between;
  }

  .etb-benefits__card--featured:hover {
    box-shadow: 0 24px 64px rgba(55, 93, 251, 0.14);
  }

  /* Accent card (dark) */
  .etb-benefits__card--accent {
    background:
      radial-gradient(circle at top, rgba(171, 255, 255, 0.18), transparent 40%),
      linear-gradient(180deg, #141e35 0%, #0d172d 100%);
    border-color: rgba(172, 161, 241, 0.32);
    color: #fff;
  }

  .etb-benefits__card--accent .etb-benefits__card-title { color: #fff; }
  .etb-benefits__card--accent .etb-benefits__card-desc { color: rgba(255, 255, 255, 0.72); }

  .etb-benefits__card-img {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    background: rgba(55, 93, 251, 0.1);
    padding: 10px;
  }

  .etb-benefits__card--accent .etb-benefits__card-img {
    background: rgba(255, 255, 255, 0.1);
  }

  .etb-benefits__card-img img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .etb-benefits__card-title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--heading-dark);
  }

  .etb-benefits__card-desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--body-gray);
  }

  .etb-benefits__card-cta {
    display: inline-flex;
    margin-top: auto;
    padding: 10px 18px;
    border-radius: 10px;
    background: var(--brand-blue);
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    width: fit-content;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .etb-benefits__card--featured:hover .etb-benefits__card-cta {
    background: var(--brand-blue-hover);
    transform: translateX(4px);
  }

  /* ─── Stats row ─── */
  .etb-benefits__stats {
    max-width: 1260px;
    margin: 40px auto 0;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 0;
    align-items: center;
    background: linear-gradient(180deg, #fff 0%, #f5f8ff 100%);
    border: 1px solid rgba(55, 93, 251, 0.09);
    border-radius: 28px;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.06);
    overflow: hidden;
  }

  .etb-benefits__stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px 32px;
  }

  .etb-benefits__stat strong {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--brand-blue);
  }

  .etb-benefits__stat span {
    font-size: 15px;
    line-height: 1.5;
    color: var(--body-gray);
  }

  .etb-benefits__divider {
    align-self: stretch;
    width: 1px;
    background: rgba(55, 93, 251, 0.08);
  }

  @media (max-width: 1024px) {
    .etb-benefits__grid {
      grid-template-columns: 1fr 1fr;
    }
    .etb-benefits__card--featured {
      grid-column: 1 / 3;
      grid-row: auto;
    }
    .etb-benefits__title { font-size: 40px; }
    .etb-benefits__stats {
      grid-template-columns: 1fr;
    }
    .etb-benefits__divider { width: 100%; height: 1px; align-self: auto; }
  }

  @media (max-width: 640px) {
    .etb-benefits__hd-band { padding: 60px 0 70px; }
    .etb-benefits__title { font-size: 30px; }
    .etb-benefits__subtitle { font-size: 16px; }
    .etb-benefits__grid {
      grid-template-columns: 1fr;
      padding: 32px 20px 0;
    }
    .etb-benefits__card--featured { grid-row: auto; }
    .etb-benefits__stats { margin: 28px 20px 0; padding: 0; }
    .etb-benefits__stat { padding: 20px 24px; }
    .etb-benefits__stat strong { font-size: 28px; }
  }
</style>
