---
interface Props {
  title: string;
  items: string[];
  image: string;
  imageAlt: string;
  imageLeft?: boolean;
  framed?: boolean;
  dark?: boolean;
  backgroundImage?: string;
  backgroundColor?: string;
  titleWidth?: string;
  listWidth?: string;
  contentWidth?: string;
  mediaWidth?: string;
  contentPadding?: string;
  mobileReverse?: boolean;
  eyebrow?: string;
  metric?: string;
  sectionNumber?: number;
}

const {
  title,
  items,
  image,
  imageAlt,
  imageLeft = true,
  framed = false,
  dark = false,
  backgroundImage = "",
  backgroundColor = "transparent",
  titleWidth = "70%",
  listWidth = "80%",
  contentWidth = "48%",
  mediaWidth = "52%",
  contentPadding = "0",
  mobileReverse = false,
  eyebrow = "Ticketing workflow",
  metric = "",
  sectionNumber = 1,
} = Astro.props;

const sectionStyle = [
  `--ticket-section-bg-color:${backgroundColor}`,
  `--ticket-section-title-width:${titleWidth}`,
  `--ticket-section-list-width:${listWidth}`,
  `--ticket-section-content-width:${contentWidth}`,
  `--ticket-section-media-width:${mediaWidth}`,
  `--ticket-section-content-padding:${contentPadding}`,
  backgroundImage ? `--ticket-section-bg-image:url("${backgroundImage}")` : "",
].filter(Boolean).join(";");

const sectionStep = String(sectionNumber).padStart(2, "0");
---

<section
  class:list={[
    "ticket-split",
    imageLeft ? "ticket-split--image-first" : "ticket-split--content-first",
    framed && "ticket-split--framed",
    dark && "ticket-split--dark",
    mobileReverse && "ticket-split--mobile-reverse",
  ]}
  style={sectionStyle}
>
  <div class="ticket-split__shell">
    <div class="ticket-split__inner">
      {imageLeft ? (
        <>
          <div class="ticket-split__media animate-on-scroll" data-animation="fadeInLeft">
            <div class="ticket-split__media-frame">
              <img src={image} alt={imageAlt} width="720" height="540" loading="lazy" />
              <span class="ticket-split__media-badge">{metric || eyebrow}</span>
            </div>
          </div>

          <div class="ticket-split__content animate-on-scroll" data-animation="fadeInRight">
            <div class="ticket-split__meta">
              <span class="ticket-split__eyebrow">{eyebrow}</span>
              <span class="ticket-split__step">{sectionStep}</span>
            </div>
            <h2 class="ticket-split__title">{title}</h2>
            {metric && <p class="ticket-split__metric">{metric}</p>}
            <ul class="ticket-split__list">
              {items.map((item, index) => (
                <li class="ticket-split__item">
                  <span class="ticket-split__item-index">{String(index + 1).padStart(2, "0")}</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a href="/book-a-demo/" class="ticket-split__cta">See this flow live</a>
          </div>
        </>
      ) : (
        <>
          <div class="ticket-split__content animate-on-scroll" data-animation="fadeInLeft">
            <div class="ticket-split__meta">
              <span class="ticket-split__eyebrow">{eyebrow}</span>
              <span class="ticket-split__step">{sectionStep}</span>
            </div>
            <h2 class="ticket-split__title">{title}</h2>
            {metric && <p class="ticket-split__metric">{metric}</p>}
            <ul class="ticket-split__list">
              {items.map((item, index) => (
                <li class="ticket-split__item">
                  <span class="ticket-split__item-index">{String(index + 1).padStart(2, "0")}</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a href="/book-a-demo/" class="ticket-split__cta">See this flow live</a>
          </div>

          <div class="ticket-split__media animate-on-scroll" data-animation="fadeInRight">
            <div class="ticket-split__media-frame">
              <img src={image} alt={imageAlt} width="720" height="540" loading="lazy" />
              <span class="ticket-split__media-badge">{metric || eyebrow}</span>
            </div>
          </div>
        </>
      )}
    </div>
  </div>
</section>

<style>
  .ticket-split {
    max-width: 1260px;
    margin: 0 auto;
    padding: 18px 12px;
  }

  .ticket-split__shell {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(179, 204, 255, 0.4);
    border-radius: 40px;
    background:
      radial-gradient(circle at top left, rgba(55, 93, 251, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 248, 255, 0.96));
    box-shadow: 0 24px 64px rgba(19, 29, 52, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .ticket-split__shell:hover {
    transform: translateY(-4px);
    box-shadow: 0 32px 76px rgba(19, 29, 52, 0.1);
    border-color: rgba(55, 93, 251, 0.18);
  }

  .ticket-split--framed .ticket-split__shell {
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.24), rgba(0, 0, 0, 0.24)),
      var(--ticket-section-bg-color)
      var(--ticket-section-bg-image, none)
      center / cover no-repeat;
    border-color: rgba(172, 161, 241, 0.32);
  }

  .ticket-split--dark .ticket-split__shell {
    border-color: rgba(172, 161, 241, 0.32);
    background:
      radial-gradient(circle at top, rgba(171, 255, 255, 0.12), transparent 24%),
      linear-gradient(180deg, rgba(10, 13, 20, 0.96), rgba(0, 3, 18, 0.94));
  }

  .ticket-split__inner {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .ticket-split__content {
    display: flex;
    width: var(--ticket-section-content-width);
    flex-direction: column;
    gap: 18px;
    padding: 56px;
    padding-inline: max(40px, 4vw);
  }

  .ticket-split__media {
    display: flex;
    width: var(--ticket-section-media-width);
    justify-content: center;
    padding: 26px;
  }

  .ticket-split__media-frame {
    position: relative;
    width: 100%;
    padding: 18px;
    border-radius: 30px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(229, 235, 255, 0.66));
    box-shadow: inset 0 0 0 1px rgba(55, 93, 251, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ticket-split--dark .ticket-split__media-frame,
  .ticket-split--framed.ticket-split--dark .ticket-split__media-frame {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .ticket-split__media-frame img {
    width: 100%;
    display: block;
    border-radius: 20px;
    transition: transform 0.35s ease;
  }

  .ticket-split__shell:hover .ticket-split__media-frame {
    transform: translateY(-4px);
    box-shadow: inset 0 0 0 1px rgba(55, 93, 251, 0.12), 0 18px 36px rgba(55, 93, 251, 0.08);
  }

  .ticket-split__shell:hover .ticket-split__media-frame img {
    transform: scale(1.02);
  }

  .ticket-split__media-badge {
    position: absolute;
    left: 18px;
    bottom: 18px;
    display: inline-flex;
    max-width: calc(100% - 36px);
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(9, 18, 38, 0.82);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
  }

  .ticket-split__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .ticket-split__eyebrow {
    display: inline-flex;
    width: fit-content;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.1);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-blue);
  }

  .ticket-split--dark .ticket-split__eyebrow {
    background: rgba(255, 255, 255, 0.08);
    color: #c4d2ff;
  }

  .ticket-split__step {
    font-family: var(--font-heading);
    font-size: 42px;
    line-height: 1;
    font-weight: 800;
    letter-spacing: -0.06em;
    color: rgba(55, 93, 251, 0.22);
  }

  .ticket-split--dark .ticket-split__step {
    color: rgba(255, 255, 255, 0.14);
  }

  .ticket-split__title {
    max-width: var(--ticket-section-title-width);
    font-family: var(--font-heading);
    font-size: 46px;
    line-height: 1.08;
    font-weight: 600;
    letter-spacing: -1.4px;
    color: #111827;
    white-space: pre-line;
  }

  .ticket-split__metric {
    max-width: 88%;
    font-size: 18px;
    line-height: 1.6;
    font-weight: 500;
    color: #2d4fd8;
  }

  .ticket-split__list {
    display: flex;
    max-width: var(--ticket-section-list-width);
    flex-direction: column;
    gap: 12px;
    list-style: none;
  }

  .ticket-split__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: start;
    padding: 16px 18px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.72);
    box-shadow: inset 0 0 0 1px rgba(55, 93, 251, 0.08);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }

  .ticket-split__item:hover {
    transform: translateX(6px);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: inset 0 0 0 1px rgba(55, 93, 251, 0.12), 0 14px 30px rgba(55, 93, 251, 0.06);
  }

  .ticket-split__item-index {
    display: inline-flex;
    min-width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: linear-gradient(180deg, #375dfb 0%, #89a2ff 100%);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #fff;
  }

  .ticket-split__cta {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    justify-content: center;
    padding: 12px 18px;
    border-radius: 14px;
    background: var(--brand-blue);
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }

  .ticket-split__cta:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-2px);
    box-shadow: 0 14px 28px rgba(55, 93, 251, 0.2);
  }

  .ticket-split--dark .ticket-split__title,
  .ticket-split--dark .ticket-split__metric {
    color: #fff;
  }

  .ticket-split--dark .ticket-split__item {
    background: rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.86);
  }

  @media (max-width: 1024px) {
    .ticket-split {
      padding: 14px 20px;
    }

    .ticket-split__inner {
      flex-direction: column;
    }

    .ticket-split__content,
    .ticket-split__media {
      width: 100%;
    }

    .ticket-split__content {
      padding: 40px 32px 14px;
    }

    .ticket-split__media {
      padding-top: 8px;
    }

    .ticket-split__title {
      max-width: none;
      font-size: 36px;
    }

    .ticket-split__list {
      max-width: none;
    }
  }

  @media (max-width: 767px) {
    .ticket-split {
      padding: 12px 16px;
    }

    .ticket-split__shell {
      border-radius: 28px;
    }

    .ticket-split__content {
      padding: 28px 20px 12px;
    }

    .ticket-split__media {
      padding: 8px 16px 16px;
    }

    .ticket-split--mobile-reverse .ticket-split__inner {
      flex-direction: column-reverse;
    }

    .ticket-split__meta {
      align-items: flex-start;
    }

    .ticket-split__step {
      font-size: 32px;
    }

    .ticket-split__title {
      font-size: 30px;
      letter-spacing: -1px;
    }

    .ticket-split__metric,
    .ticket-split__item {
      font-size: 16px;
    }
  }

  /* ─── Micro-animation: shimmer on hover ─── */
  .ticket-split__shell::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255, 255, 255, 0.06) 50%, transparent 60%);
    background-size: 200% 100%;
    background-position: 200% 0;
    border-radius: inherit;
    transition: background-position 0.7s ease;
    pointer-events: none;
  }

  .ticket-split__shell:hover::before {
    background-position: -200% 0;
  }

  /* ─── Stagger animate list items on scroll ─── */
  .ticket-split__item {
    opacity: 0;
    transform: translateX(-12px);
    animation: none;
  }

  .ticket-split--image-first .ticket-split__item {
    transform: translateX(-12px);
  }

  .ticket-split--content-first .ticket-split__item {
    transform: translateX(12px);
  }

  .ticket-split.item-is-visible .ticket-split__item:nth-child(1) {
    animation: splitItemIn 0.5s ease forwards 0.05s;
  }
  .ticket-split.item-is-visible .ticket-split__item:nth-child(2) {
    animation: splitItemIn 0.5s ease forwards 0.15s;
  }
  .ticket-split.item-is-visible .ticket-split__item:nth-child(3) {
    animation: splitItemIn 0.5s ease forwards 0.25s;
  }
  .ticket-split.item-is-visible .ticket-split__item:nth-child(4) {
    animation: splitItemIn 0.5s ease forwards 0.35s;
  }

  @keyframes splitItemIn {
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticket-split__item {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
    .ticket-split__shell::before { display: none; }
  }
</style>

<script>
  // Trigger stagger animation when section enters viewport
  const splitSections = document.querySelectorAll(".ticket-split");
  const splitObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("item-is-visible");
          splitObs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.2 }
  );
  splitSections.forEach((el) => splitObs.observe(el));
</script>
