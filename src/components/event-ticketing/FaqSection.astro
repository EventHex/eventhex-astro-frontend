---
import SharedFaq from "../shared/FaqSection.astro";

interface FaqItem {
  question: string;
  answerHtml: string;
}

interface Props {
  title?: string;
  items: FaqItem[];
}

const { title = "Frequently Asked Questions", items } = Astro.props;

const faqs = items.map(item => ({
  q: item.question,
  a: item.answerHtml.replace(/<[^>]*>/g, ''),
}));
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need a custom setup?"
  title={title}
  description="We can help you shape branded ticket journeys, approval rules, and faster check-in experiences around the way your event team actually works."
/>
