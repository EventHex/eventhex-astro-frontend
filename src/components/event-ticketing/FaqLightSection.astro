---
// FAQ Section — Light theme with split layout, SEO JSON-LD structured data
// Pattern from speaker-management FaqSection (light variant)

interface FaqItem {
  question: string;
  answerHtml: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answerHtml.replace(/<[^>]*>/g, '')
    }
  }))
};
---

<section class="etfaq" id="ticket-faq-section">
  <div class="etfaq__inner">
    <div class="etfaq__sidebar animate-on-scroll" data-animation="fadeInLeft">
      <span class="etfaq__eyebrow">Need Help?</span>
      <h2 class="etfaq__title">Frequently Asked Questions</h2>
      <p class="etfaq__desc">
        Everything you need to know about event ticketing and how it works with EventHex.
      </p>
      <div class="etfaq__support-card">
        <h3 class="etfaq__support-title">Talk to Our Team</h3>
        <p class="etfaq__support-desc">Our experts can walk you through a personalized demo and answer any questions about ticketing setup.</p>
      </div>
      <a href="/book-a-demo/" class="etfaq__cta">Book a Demo</a>
    </div>

    <div class="etfaq__list">
      {items.map((item, index) => (
        <details class="etfaq__item animate-on-scroll" data-animation="fadeInUp" data-delay={String(index * 60)} data-faq-item>
          <summary class="etfaq__question">
            {item.question}
            <svg class="etfaq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="etfaq__answer" set:html={item.answerHtml}></div>
        </details>
      ))}
    </div>
  </div>
</section>

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(faqSchema)}</script>`} />

<script>
  const faqItems = Array.from(document.querySelectorAll('[data-faq-item]'));

  faqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) return;

      faqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .etfaq {
    background: var(--surface-light, #f8f9fc);
    padding: 5rem 1.5rem;
  }

  .etfaq__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .etfaq__sidebar {
    position: sticky;
    top: 6rem;
  }

  .etfaq__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-blue);
    margin-bottom: 0.5rem;
  }

  .etfaq__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .etfaq__desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0 0 1.25rem;
  }

  .etfaq__support-card {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf4);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .etfaq__support-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0 0 0.35rem;
  }

  .etfaq__support-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0;
  }

  .etfaq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 1.25rem;
    border-radius: 10px;
    background: var(--brand-blue);
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    transition: background 0.2s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .etfaq__cta:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(55, 93, 251, 0.25);
  }

  .etfaq__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .etfaq__item {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf4);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .etfaq__item[open] {
    border-color: var(--brand-blue);
  }

  .etfaq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--heading-dark);
    cursor: pointer;
    list-style: none;
  }

  .etfaq__question::-webkit-details-marker,
  .etfaq__question::marker {
    display: none;
  }

  .etfaq__chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
    color: var(--subheading-gray);
  }

  .etfaq__item[open] .etfaq__chevron {
    transform: rotate(180deg);
    color: var(--brand-blue);
  }

  .etfaq__answer {
    padding: 0 1.5rem 1.25rem;
  }

  .etfaq__answer :global(p) {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .etfaq__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .etfaq__sidebar {
      position: static;
    }
  }

  @media (max-width: 767px) {
    .etfaq {
      padding: 3rem 1rem;
    }
    .etfaq__title {
      font-size: 1.5rem;
    }
    .etfaq__question {
      padding: 1rem 1.25rem;
      font-size: 0.875rem;
    }
    .etfaq__answer {
      padding: 0 1.25rem 1rem;
    }
    .etfaq__cta {
      width: 100%;
    }
  }
</style>
