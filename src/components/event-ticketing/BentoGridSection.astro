---
// Tabbed Bento Grid — 3 tabs for ticketing workflows
// Pattern from speaker-management BentoGrid.astro
---

<section class="et-bento-section" id="ticket-workflows">
  <div class="etb" id="etb-bento">
    <h2 class="etb-title">
      Ticket <b>Sales</b>, Check-in & <b>Analytics</b>
    </h2>
    <p class="etb-subtitle">
      From checkout to check-in to compliance—manage your entire ticketing workflow from one dashboard.
    </p>

    <nav class="etb-nav">
      <button class="etb-tab etb-tab--active" data-etb-tab="0">Checkout & Payments</button>
      <button class="etb-tab" data-etb-tab="1">Check-in & Badges</button>
      <button class="etb-tab" data-etb-tab="2">Analytics & Compliance</button>
    </nav>

    <!-- Tab 0: Checkout & Payments -->
    <div class="etb-panel etb-panel--active" data-etb-panel="0">
      <div class="etb-grid" data-layout="a">
        <div class="etb-card etb-card--tall etb-pos-0">
          <div class="etb-card__inner">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Simplified Checkout</h3>
              <p class="etb-card__desc">Mobile-first checkout flow designed to minimize drop-offs and maximize ticket conversions.</p>
            </div>
            <div class="etb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect x="36" y="40" width="128" height="16" rx="8" fill="#375DFB" opacity=".12"/>
                <rect x="36" y="66" width="88" height="12" rx="6" fill="#375DFB" opacity=".08"/>
                <rect x="36" y="92" width="128" height="36" rx="10" fill="#375DFB" opacity=".15"/>
                <text x="100" y="115" text-anchor="middle" font-size="13" font-weight="600" fill="#375DFB">Buy Tickets</text>
                <rect x="36" y="138" width="60" height="8" rx="4" fill="#E5EBFF"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-1">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Multiple Ticket Types</h3>
              <p class="etb-card__desc">Early bird, VIP, group bundles, and custom tiers with independent pricing.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <rect x="15" y="18" width="50" height="8" rx="4" fill="#375DFB" opacity=".2"/>
                <rect x="15" y="32" width="36" height="6" rx="3" fill="#375DFB" opacity=".1"/>
                <rect x="15" y="48" width="50" height="8" rx="4" fill="#9F81FF" opacity=".2"/>
                <rect x="15" y="62" width="36" height="6" rx="3" fill="#9F81FF" opacity=".1"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-2">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Secure Payment Processing</h3>
              <p class="etb-card__desc">Use your own gateway at 0% platform fee, or our competitive default gateway.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <circle cx="60" cy="40" r="18" fill="#375DFB" opacity=".08"/>
                <path d="M52 40l6 6 10-12" stroke="#375DFB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-3">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Discount Codes & Coupons</h3>
              <p class="etb-card__desc">Create promotional campaigns with early-bird, group, and percentage-based discounts.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <rect x="20" y="25" width="80" height="30" rx="8" fill="#375DFB" opacity=".08"/>
                <text x="60" y="44" text-anchor="middle" font-size="11" font-weight="600" fill="#375DFB">EARLY20</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-4">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Instant Payouts</h3>
              <p class="etb-card__desc">Revenue flows directly to your account with no holds or delays on settlements.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <path d="M30 55l20-20 15 10 25-25" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="90" cy="20" r="4" fill="#375DFB" opacity=".3"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 1: Check-in & Badges -->
    <div class="etb-panel" data-etb-panel="1">
      <div class="etb-grid" data-layout="b">
        <div class="etb-card etb-card--tall etb-pos-0">
          <div class="etb-card__inner">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">QR Code Check-in</h3>
              <p class="etb-card__desc">Every ticket gets a unique QR code. Scan at entry for instant validation and real-time attendance tracking.</p>
            </div>
            <div class="etb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="50" y="30" width="100" height="100" rx="8" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect x="65" y="45" width="70" height="70" rx="4" fill="#375DFB" opacity=".06"/>
                <rect x="75" y="55" width="20" height="20" rx="2" fill="#375DFB" opacity=".2"/>
                <rect x="105" y="55" width="20" height="20" rx="2" fill="#375DFB" opacity=".15"/>
                <rect x="75" y="85" width="20" height="20" rx="2" fill="#375DFB" opacity=".15"/>
                <rect x="105" y="85" width="20" height="20" rx="2" fill="#375DFB" opacity=".2"/>
                <text x="100" y="150" text-anchor="middle" font-size="11" fill="#375DFB" opacity=".5">Scan to enter</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-1">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Badge Printing</h3>
              <p class="etb-card__desc">Print branded badges on-site with attendee details, ticket type, and custom designs.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="25" y="10" width="70" height="60" rx="8" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <rect x="35" y="22" width="50" height="8" rx="4" fill="#375DFB" opacity=".15"/>
                <rect x="35" y="36" width="30" height="6" rx="3" fill="#375DFB" opacity=".08"/>
                <circle cx="85" cy="50" r="8" fill="#375DFB" opacity=".1"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-2">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Hassle-free Registration</h3>
              <p class="etb-card__desc">Attendees check in quickly without manual ID verification or paper lists.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <circle cx="40" cy="40" r="14" fill="#375DFB" opacity=".06"/>
                <path d="M34 40l4 4 8-8" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/>
                <rect x="65" y="30" width="40" height="6" rx="3" fill="#375DFB" opacity=".1"/>
                <rect x="65" y="42" width="28" height="6" rx="3" fill="#375DFB" opacity=".06"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-3">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Mobile Check-in App</h3>
              <p class="etb-card__desc">Staff can scan and validate tickets from any smartphone—no special hardware needed.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="35" y="5" width="50" height="70" rx="10" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <rect x="45" y="20" width="30" height="30" rx="4" fill="#375DFB" opacity=".06"/>
                <path d="M55 30l4 4 8-8" stroke="#375DFB" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-4">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Attendee Tracking</h3>
              <p class="etb-card__desc">Real-time attendance counts and session tracking from the moment gates open.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <text x="60" y="36" text-anchor="middle" font-size="22" font-weight="700" fill="#375DFB" opacity=".2">847</text>
                <text x="60" y="52" text-anchor="middle" font-size="9" fill="#375DFB" opacity=".4">checked in</text>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 2: Analytics & Compliance -->
    <div class="etb-panel" data-etb-panel="2">
      <div class="etb-grid" data-layout="c">
        <div class="etb-card etb-card--tall etb-pos-0">
          <div class="etb-card__inner">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Real-time Analytics</h3>
              <p class="etb-card__desc">Track ticket performance, revenue trends, and attendee behavior while campaigns are live.</p>
            </div>
            <div class="etb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <path d="M40 130l30-40 25 15 35-50 30 20" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity=".3"/>
                <rect x="40" y="100" width="16" height="30" rx="4" fill="#375DFB" opacity=".15"/>
                <rect x="66" y="80" width="16" height="50" rx="4" fill="#375DFB" opacity=".2"/>
                <rect x="92" y="90" width="16" height="40" rx="4" fill="#9F81FF" opacity=".15"/>
                <rect x="118" y="60" width="16" height="70" rx="4" fill="#375DFB" opacity=".2"/>
                <rect x="144" y="75" width="16" height="55" rx="4" fill="#9F81FF" opacity=".15"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-1">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">GDPR Compliance</h3>
              <p class="etb-card__desc">Privacy-ready data handling with encryption, consent management, and secure storage.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <path d="M60 20v15M50 28l10 7 10-7" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity=".3"/>
                <rect x="40" y="45" width="40" height="20" rx="6" fill="#375DFB" opacity=".08"/>
                <text x="60" y="58" text-anchor="middle" font-size="8" fill="#375DFB" opacity=".5">GDPR</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-2">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Waitlist & Approvals</h3>
              <p class="etb-card__desc">Approval-based registration with automated waitlist management for curated events.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <rect x="20" y="22" width="80" height="12" rx="6" fill="#375DFB" opacity=".06"/>
                <rect x="20" y="22" width="48" height="12" rx="6" fill="#375DFB" opacity=".15"/>
                <rect x="20" y="42" width="80" height="12" rx="6" fill="#9F81FF" opacity=".06"/>
                <rect x="20" y="42" width="32" height="12" rx="6" fill="#9F81FF" opacity=".15"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-3">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="etb-card__title">Revenue Reports</h3>
              <p class="etb-card__desc">Exportable sales reports with breakdowns by ticket type, date, and payment method.</p>
            </div>
            <div class="etb-card__img etb-card__img--sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="120" height="80" viewBox="0 0 120 80" fill="none">
                <rect x="5" y="5" width="110" height="70" rx="12" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1"/>
                <rect x="20" y="20" width="36" height="20" rx="6" fill="#375DFB" opacity=".08"/>
                <text x="38" y="34" text-anchor="middle" font-size="10" font-weight="600" fill="#375DFB" opacity=".4">CSV</text>
                <rect x="65" y="20" width="36" height="20" rx="6" fill="#9F81FF" opacity=".08"/>
                <text x="83" y="34" text-anchor="middle" font-size="10" font-weight="600" fill="#9F81FF" opacity=".4">PDF</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="etb-card etb-card--sm etb-pos-4">
          <div class="etb-card__inner etb-card__inner--row">
            <div class="etb-card__text">
              <svg class="etb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
