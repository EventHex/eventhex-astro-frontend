<script>
  const etbTabs = document.querySelectorAll('[data-etb-tab]');
  const etbPanels = document.querySelectorAll('[data-etb-panel]');
  let etbInterval: ReturnType<typeof setInterval>;
  let etbActive = 0;

  function setEtbTab(index: number) {
    etbTabs.forEach((t) => t.classList.remove('etb-tab--active'));
    etbPanels.forEach((p) => p.classList.remove('etb-panel--active'));
    etbTabs[index]?.classList.add('etb-tab--active');
    etbPanels[index]?.classList.add('etb-panel--active');
    etbActive = index;
  }

  etbTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = parseInt(tab.getAttribute('data-etb-tab') || '0', 10);
      setEtbTab(idx);
      clearInterval(etbInterval);
      startEtbRotation();
    });
  });

  function startEtbRotation() {
    etbInterval = setInterval(() => {
      setEtbTab((etbActive + 1) % etbTabs.length);
    }, 5000);
  }

  startEtbRotation();

  const bentoBento = document.querySelector('.et-bento-section');
  if (bentoBento) {
    bentoBento.addEventListener('mouseenter', () => clearInterval(etbInterval));
    bentoBento.addEventListener('mouseleave', () => startEtbRotation());
  }
</script>

