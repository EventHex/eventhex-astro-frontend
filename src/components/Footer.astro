---
const footerLinks = [
  { title: "Home", url: "/" },
  { title: "About", url: "/about-us/" },
  { title: "Partner with us", url: "/partnership/" },
  { title: "Blog", url: "/blog/" },
  { title: "Contact", url: "/contact-en/" },
];

const featureLinks = [
  { title: "Speaker Management", url: "/speaker-management/" },
  { title: "Event Ticketing", url: "/event-ticketing/" },
  { title: "AI Smart-Connect", url: "/enhance-networking-ai-smart-connect/" },
  { title: "Event Marketing", url: "/event-marketing/" },
  { title: "Event Registration", url: "/event-registration/" },
  { title: "Sponsor Management", url: "/sponsor-management/" },
  { title: "Exhibitor Management", url: "/exhibitor-management/" },
  { title: "Centralized Dashboard", url: "/centralized-dashboard/" },
  { title: "AI Form Builder", url: "/ai-form-builder/" },
];

const socialLinks = [
  { name: "Facebook", url: "https://www.facebook.com/eventhex", icon: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" },
  { name: "Twitter", url: "https://x.com/eventhex", icon: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" },
  { name: "Instagram", url: "https://www.instagram.com/eventhex/", icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" },
  { name: "LinkedIn", url: "https://www.linkedin.com/company/eventhex/", icon: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" },
];
---

<footer class="bg-gray-900 text-white">
  <!-- CTA Banner -->
  <div class="bg-gradient-to-r from-indigo-600 to-violet-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Begin Your Journey With EventHex Now!
      </h2>
      <p class="text-indigo-100 text-lg mb-8 max-w-2xl mx-auto">
        Transform your events with AI-powered management tools
      </p>
      <a
        href="/contact-en/"
        class="inline-flex items-center px-8 py-3.5 text-base font-semibold text-indigo-600 bg-white hover:bg-gray-100 rounded-full transition-colors"
      >
        Get Started Free
      </a>
    </div>
  </div>

  <!-- Footer Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/">
          <img
            src="https://eventhex.ai/wp-content/uploads/2024/09/EventHex-Logo.svg"
            alt="EventHex"
            class="h-8 w-auto brightness-0 invert mb-4"
          />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          The AI-Powered Event Management Platform for every event, from conferences to exhibitions.
        </p>
        <!-- Social Links -->
        <div class="flex gap-3 mt-6">
          {socialLinks.map((s) => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-800 hover:bg-indigo-600 transition-colors"
              aria-label={s.name}
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                <path d={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4">Company</h3>
        <ul class="space-y-3">
          {footerLinks.map((link) => (
            <li>
              <a href={link.url} class="text-gray-300 hover:text-white text-sm transition-colors">
                {link.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Features -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4">Features</h3>
        <ul class="space-y-3">
          {featureLinks.map((link) => (
            <li>
              <a href={link.url} class="text-gray-300 hover:text-white text-sm transition-colors">
                {link.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4">Get in Touch</h3>
        <ul class="space-y-3 text-sm text-gray-300">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@eventhex.ai" class="hover:text-white transition-colors">info@eventhex.ai</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-gray-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Dubai, UAE</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {new Date().getFullYear()} EventHex. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy-policy/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Privacy Policy</a>
        <a href="/terms-of-service/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
