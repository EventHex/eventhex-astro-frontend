---
const footerLinks = [
  { title: "Home", url: "/" },
  { title: "About", url: "/about-us/" },
  { title: "Partner with us", url: "/partnership/" },
  { title: "Blog", url: "/blog/" },
  { title: "Contact", url: "/contact-en/" },
];
---

<footer class="bg-eh-dark text-white">
  <!-- CTA Section -->
  <div class="max-w-[1200px] mx-auto px-5 py-[60px]">
    <div class="bg-eh-card-dark border border-eh-card-border rounded-[20px] p-10 md:p-16">
      <h2 class="font-heading text-[36px] md:text-[48px] font-bold text-white leading-tight mb-6">
        Begin Your Journey<br />With EventHex Now!
      </h2>
      <a
        href="/book-a-demo/"
        class="inline-flex items-center px-8 py-3.5 text-[16px] font-semibold text-white bg-gradient-to-r from-eh-blue to-[#7B5EFF] hover:brightness-110 rounded-[10px] transition shadow-lg"
      >
        Get a demo
      </a>
    </div>
  </div>

  <!-- Footer Links -->
  <div class="max-w-[1200px] mx-auto px-5 pb-[60px]">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <!-- Logo -->
      <a href="/">
        <img
          src="https://eventhex.ai/wp-content/uploads/2024/09/EventHex-Logo.svg"
          alt="EventHex"
          class="h-[36px] w-auto brightness-0 invert"
        />
      </a>

      <!-- Links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        {footerLinks.map((link) => (
          <a href={link.url} class="text-white/70 hover:text-white text-[15px] transition-colors">
            {link.title}
          </a>
        ))}
      </nav>
    </div>

    <!-- Bottom border -->
    <div class="border-t border-white/10 mt-8 pt-6 text-center">
      <p class="text-white/40 text-[14px]">
        &copy; {new Date().getFullYear()} EventHex. All rights reserved.
      </p>
    </div>
  </div>
</footer>
