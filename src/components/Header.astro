---
const navItems = [
  { title: "Home", url: "/" },
  { title: "About", url: "/about-us/" },
  {
    title: "Features",
    url: "#",
    children: [
      { title: "Speaker Management Software", url: "/speaker-management/" },
      { title: "Event Ticketing", url: "/event-ticketing/" },
      { title: "AI Event Smart-Connect", url: "/enhance-networking-ai-smart-connect/" },
      { title: "Event Marketing", url: "/event-marketing/" },
      { title: "Event Registration", url: "/event-registration/" },
      { title: "Sponsor Management", url: "/sponsor-management/" },
      { title: "Exhibitor Management", url: "/exhibitor-management/" },
      { title: "Centralized Dashboard", url: "/centralized-dashboard/" },
      { title: "AI Form Builder", url: "/ai-form-builder/" },
    ],
  },
  { title: "Blog", url: "/blog/" },
  { title: "News", url: "/news/" },
  { title: "Contact", url: "/contact-en/" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          src="https://eventhex.ai/wp-content/uploads/2024/09/EventHex-Logo.svg"
          alt="EventHex"
          class="h-8 lg:h-10 w-auto"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.url}
              class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-indigo-600 transition-colors inline-flex items-center gap-1"
            >
              {item.title}
              {item.children && (
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-xl shadow-xl border border-gray-100 py-2 min-w-[260px]">
                  {item.children.map((child) => (
                    <a
                      href={child.url}
                      class="block px-4 py-2.5 text-sm text-gray-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                    >
                      {child.title}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a
          href="https://eventhex.ai/contact-en/"
          class="hidden sm:inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-full transition-colors"
        >
          Request a demo
        </a>
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-gray-600 hover:text-gray-900"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 shadow-lg">
    <div class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <>
          <a
            href={item.url}
            class="block px-3 py-2.5 text-base font-medium text-gray-700 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors"
          >
            {item.title}
          </a>
          {item.children && (
            <div class="pl-4 space-y-1">
              {item.children.map((child) => (
                <a
                  href={child.url}
                  class="block px-3 py-2 text-sm text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors"
                >
                  {child.title}
                </a>
              ))}
            </div>
          )}
        </>
      ))}
      <a
        href="https://eventhex.ai/contact-en/"
        class="block w-full text-center px-5 py-2.5 mt-3 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-full transition-colors"
      >
        Request a demo
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-20"></div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
