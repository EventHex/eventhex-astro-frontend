---
const steps = [
  {
    num: "01",
    title: "Connect Your Data",
    desc: "Analytics automatically pulls data from registrations, check-ins, sessions, feedback, and all event activities.",
  },
  {
    num: "02",
    title: "Monitor Live Dashboards",
    desc: "Watch real-time metrics during your event — attendance, engagement, and revenue updating every second.",
  },
  {
    num: "03",
    title: "Generate Reports",
    desc: "Use report templates or build custom reports. Schedule automatic delivery to stakeholders and sponsors.",
  },
  {
    num: "04",
    title: "Get AI Insights",
    desc: "AI analyzes patterns across events and recommends optimizations for future planning.",
  },
];
---

<section class="eahw-full">
  <div class="eahw-full__inner">
    <div class="eahw-full__header">
      <span class="eahw-full__tag animate-on-scroll" data-animation="fadeIn">How Event Analytics Works</span>
      <h2 class="eahw-full__title animate-on-scroll" data-animation="fadeInUp">From Raw Data to <b>Actionable Intelligence</b></h2>
      <p class="eahw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Connect your event data, monitor live dashboards, generate reports, and get AI-powered insights.
      </p>
    </div>

    <div class="eahw-full__cards">
      {steps.map((step) => (
        <article class="eahw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="eahw-full__card-icon">{step.num}</div>
          <h3 class="eahw-full__card-title">{step.title}</h3>
          <p class="eahw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .eahw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .eahw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .eahw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .eahw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eahw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .eahw-full__title b { font-weight: 700; }

  .eahw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .eahw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .eahw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .eahw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .eahw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .eahw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .eahw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .eahw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .eahw-full { padding: 64px 0; }
    .eahw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .eahw-full { padding: 52px 0; }
    .eahw-full__title { font-size: 30px; line-height: 1.15; }
    .eahw-full__desc { font-size: 15px; }
    .eahw-full__cards { grid-template-columns: 1fr; }
  }
</style>
