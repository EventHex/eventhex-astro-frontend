---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "What data is tracked by EventHex analytics?", a: "Everything — registrations, ticket sales, check-ins, attendance per session, engagement metrics (polls, Q&A, gamification), sponsor booth traffic, revenue, and post-event feedback." },
  { q: "Can I create custom reports?", a: "Yes. The custom report builder lets you select specific metrics, apply filters (date range, ticket type, attendee segment), and save report templates for recurring use." },
  { q: "Can analytics data be exported?", a: "Yes. Export any dashboard or report as CSV, PDF, or Excel. You can also pull data via REST API into your own BI tools like Tableau, Power BI, or Google Data Studio." },
  { q: "Are analytics available in real time?", a: "Yes. Dashboards update in real time during events — registration velocity, check-in rates, session attendance, and revenue all refresh automatically every few seconds." },
  { q: "Can I compare multiple events?", a: "Yes. The multi-event dashboard lets you compare registration trends, attendance, engagement, and revenue across all your events side by side." },
  { q: "How does AI improve analytics?", a: "AI analyzes data patterns across events — predicting attendance, identifying what drives engagement, flagging anomalies, and recommending specific improvements for your next event." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with event analytics?"
  title="Frequently Asked Questions"
  description="We help event teams set up dashboards, reports, and AI analytics tailored to their event data and stakeholder needs."
/>
