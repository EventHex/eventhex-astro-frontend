---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M7 17v-4M11 17v-7M15 17v-5M19 17v-9" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><circle cx="19" cy="5" r="2" fill="#22C55E" stroke="#375DFB" stroke-width="1"/></svg>`,
    title: "Real-time event dashboards",
    desc: "Live metrics that update every second across registrations, attendance, and revenue.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="18" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M6 9h3M6 13h5M6 17h4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M15 9h3M15 13h3" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M13 3v18" stroke="#375DFB" stroke-width="1.5" stroke-dasharray="2 2"/></svg>`,
    title: "Sponsor ROI analytics",
    desc: "Auto-generated sponsor engagement reports with QR-verified booth traffic data.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2l1.5 4.5H18l-3.5 2.5 1.5 4.5L12 11l-4 2.5 1.5-4.5L6 6.5h4.5L12 2z" stroke="#375DFB" stroke-width="2" stroke-linejoin="round"/><circle cx="12" cy="20" r="2" fill="#375DFB"/><path d="M12 14v4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M5 18l2-1M19 18l-2-1" stroke="#375DFB" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "AI-powered insights",
    desc: "Predictive analytics, smart recommendations, and hidden pattern detection.",
  },
];
---

<section class="eac-full">
  <div class="eac-full__inner">
    <div class="eac-full__header">
      <span class="eac-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Analytics</span>
      <h2 class="eac-full__title animate-on-scroll" data-animation="fadeInUp">Complete Event <b>Intelligence Platform</b></h2>
      <p class="eac-full__desc animate-on-scroll" data-animation="fadeInUp">Track every metric, prove sponsor ROI, and get AI-powered recommendations from one analytics hub.</p>
    </div>

    <div class="eac-full__cards">
      {cards.map((card) => (
        <div class="eac-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="eac-full__card-icon" set:html={card.icon}></div>
          <h3 class="eac-full__card-title">{card.title}</h3>
          <p class="eac-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .eac-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .eac-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .eac-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .eac-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eac-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .eac-full__title b { font-weight: 700; }

  .eac-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .eac-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .eac-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .eac-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .eac-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .eac-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .eac-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .eac-full { padding: 64px 0; }
    .eac-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .eac-full { padding: 52px 0; }
    .eac-full__title { font-size: 30px; line-height: 1.15; }
    .eac-full__desc { font-size: 15px; }
    .eac-full__cards { grid-template-columns: 1fr; }
  }
</style>
