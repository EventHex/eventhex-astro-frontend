---
const tabs = [
  {
    label: "Event Metrics",
    hero: {
      eyebrow: "Core Analytics",
      title: "Registration, attendance, revenue, and engagement tracking in real time",
      desc: "Track signups, conversion funnels, ticket sales, check-in rates, session attendance, and composite engagement scores — all updating live.",
      points: ["Registration funnels", "Revenue dashboards", "Engagement scores"],
      visual: "metrics",
    },
    cards: [
      {
        eyebrow: "Attendance",
        title: "Attendance Tracking",
        desc: "Live check-in tracking with arrival patterns and no-show rates.",
        visual: "attendance",
      },
      {
        eyebrow: "Revenue",
        title: "Revenue Dashboard",
        desc: "Real-time revenue tracking across tickets, add-ons, and sponsorships.",
        visual: "revenue",
      },
      {
        eyebrow: "Sessions",
        title: "Session Analytics",
        desc: "Attendance, ratings, and engagement data per session and speaker.",
        visual: "sessions",
      },
      {
        eyebrow: "Engagement",
        title: "Engagement Scores",
        desc: "Composite engagement scores for every attendee and session.",
        visual: "engage",
      },
    ],
  },
  {
    label: "Platform Analytics",
    hero: {
      eyebrow: "Cross-Event Intelligence",
      title: "Multi-event comparison, cohort analysis, and marketing attribution",
      desc: "Compare performance across all your events. Track returning attendees, measure marketing channels, and benchmark against industry data.",
      points: ["Multi-event comparison", "UTM attribution tracking", "Industry benchmarks"],
      visual: "platform",
    },
    cards: [
      {
        eyebrow: "Cohorts",
        title: "Cohort Analysis",
        desc: "Track returning attendees, first-timers, and VIPs across events.",
        visual: "cohort",
      },
      {
        eyebrow: "Marketing",
        title: "UTM Tracking",
        desc: "Measure which marketing channels drive the most registrations.",
        visual: "utm",
      },
      {
        eyebrow: "Trends",
        title: "Trend Analysis",
        desc: "Spot trends in attendance, revenue, and engagement over time.",
        visual: "trends",
      },
      {
        eyebrow: "Benchmark",
        title: "Benchmark Data",
        desc: "Compare your event metrics against industry benchmarks.",
        visual: "benchmark",
      },
    ],
  },
  {
    label: "Reports & Export",
    hero: {
      eyebrow: "Reporting Engine",
      title: "Scheduled reports, custom builders, and sponsor ROI with data export",
      desc: "Use 50+ report templates or build custom reports. Schedule automatic delivery, generate sponsor ROI reports, and export via CSV, PDF, or API.",
      points: ["50+ report templates", "Custom report builder", "API data access"],
      visual: "reports",
    },
    cards: [
      {
        eyebrow: "Custom",
        title: "Custom Report Builder",
        desc: "Build custom reports with drag-and-drop metrics and filters.",
        visual: "customreport",
      },
      {
        eyebrow: "Sponsors",
        title: "Sponsor ROI Reports",
        desc: "Auto-generated reports showing sponsor engagement and booth traffic.",
        visual: "sponsorreport",
      },
      {
        eyebrow: "Export",
        title: "CSV & PDF Export",
        desc: "Export any report or dashboard as CSV, PDF, or Excel format.",
        visual: "csvpdf",
      },
      {
        eyebrow: "API",
        title: "API Access",
        desc: "Pull analytics data into your own BI tools via REST API.",
        visual: "apiaccess",
      },
    ],
  },
];
---

<section class="eab-section" id="ea-bento">
  <div class="eab-shell">
    <h2 class="eab-title">
      Event <b>Metrics</b>, Platform <b>Analytics</b> & <b>Reports</b>
    </h2>
    <p class="eab-subtitle">
      Track registrations, attendance, engagement, revenue, and sponsor ROI from one analytics dashboard.
    </p>

    <nav class="eab-nav" aria-label="Event analytics workflows">
      {tabs.map((tab, index) => (
        <button
          class={`eab-tab${index === 0 ? " eab-tab--active" : ""}`}
          data-eab-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`eab-panel${tabIndex === 0 ? " eab-panel--active" : ""}`}
        data-eab-panel={tabIndex}
      >
        <div class="eab-grid">
          <article class="eab-card eab-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="eab-card__content">
              <span class="eab-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="eab-card__title">{tab.hero.title}</h3>
              <p class="eab-card__desc">{tab.hero.desc}</p>

              <ul class="eab-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`eab-art eab-art--hero eab-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "metrics" && (
                <Fragment>
                  <div class="eab-dashboard">
                    <div class="eab-dashboard-header">
                      <span class="eab-dashboard-dot eab-dashboard-dot--green"></span>
                      <span class="eab-dashboard-dot eab-dashboard-dot--yellow"></span>
                      <span class="eab-dashboard-dot eab-dashboard-dot--red"></span>
                      <span class="eab-dashboard-title-bar"></span>
                    </div>
                    <div class="eab-dashboard-body">
                      <div class="eab-dash-kpi">
                        <div class="eab-kpi-card">
                          <span class="eab-kpi-val">2,847</span>
                          <span class="eab-kpi-label">Registrations</span>
                        </div>
                        <div class="eab-kpi-card">
                          <span class="eab-kpi-val">$124K</span>
                          <span class="eab-kpi-label">Revenue</span>
                        </div>
                        <div class="eab-kpi-card">
                          <span class="eab-kpi-val">87%</span>
                          <span class="eab-kpi-label">Attendance</span>
                        </div>
                      </div>
                      <div class="eab-dash-charts">
                        <div class="eab-chart-bar">
                          <span style="--h:45%"></span>
                          <span style="--h:70%"></span>
                          <span style="--h:55%"></span>
                          <span style="--h:88%"></span>
                          <span style="--h:65%"></span>
                        </div>
                        <div class="eab-chart-line">
                          <svg viewBox="0 0 120 40" preserveAspectRatio="none">
                            <polyline points="0,35 20,28 40,18 60,22 80,10 100,14 120,5" fill="none" stroke="#375dfb" stroke-width="2"/>
                            <polyline points="0,35 20,28 40,18 60,22 80,10 100,14 120,5" fill="url(#eab-grad)" stroke="none"/>
                            <defs><linearGradient id="eab-grad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="rgba(55,93,251,0.2)"/><stop offset="100%" stop-color="rgba(55,93,251,0)"/></linearGradient></defs>
                          </svg>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="eab-live-badge">&#9679; Live</div>
                </Fragment>
              )}

              {tab.hero.visual === "platform" && (
                <Fragment>
                  <div class="eab-multi-panel">
                    <div class="eab-panel-card">
                      <span class="eab-panel-head"></span>
                      <div class="eab-panel-bars">
                        <span style="--w:85%"></span>
                        <span style="--w:60%"></span>
                        <span style="--w:72%"></span>
                      </div>
                    </div>
                    <div class="eab-panel-card">
                      <span class="eab-panel-head"></span>
                      <div class="eab-panel-bars">
                        <span style="--w:70%"></span>
                        <span style="--w:90%"></span>
                        <span style="--w:55%"></span>
                      </div>
                    </div>
                  </div>
                  <div class="eab-compare-chip">
                    <strong>3</strong>
                    <span>events compared</span>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "reports" && (
                <Fragment>
                  <div class="eab-report-grid">
                    <div class="eab-report-tmpl">
                      <div class="eab-report-tmpl-head"></div>
                      <div class="eab-report-tmpl-rows">
                        <span></span><span></span><span></span>
                      </div>
                    </div>
                    <div class="eab-report-tmpl">
                      <div class="eab-report-tmpl-head"></div>
                      <div class="eab-report-tmpl-rows">
                        <span></span><span></span><span></span>
                      </div>
                    </div>
                    <div class="eab-report-tmpl">
                      <div class="eab-report-tmpl-head"></div>
                      <div class="eab-report-tmpl-rows">
                        <span></span><span></span><span></span>
                      </div>
                    </div>
                    <div class="eab-report-tmpl">
                      <div class="eab-report-tmpl-head"></div>
                      <div class="eab-report-tmpl-rows">
                        <span></span><span></span><span></span>
                      </div>
                    </div>
                  </div>
                  <div class="eab-report-pill">50+ templates</div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="eab-card eab-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="eab-card__content">
                <span class="eab-card__eyebrow">{card.eyebrow}</span>
                <h3 class="eab-card__title">{card.title}</h3>
                <p class="eab-card__desc">{card.desc}</p>
              </div>

              <div class={`eab-art eab-art--mini eab-art--${card.visual}`} aria-hidden="true">
                {card.visual === "attendance" && (
                  <Fragment>
                    <div class="eab-line-chart">
                      <svg viewBox="0 0 120 50" preserveAspectRatio="none" class="eab-line-svg">
                        <polyline points="0,45 15,38 30,30 45,25 55,28 70,15 85,18 100,8 120,12" fill="none" stroke="#375dfb" stroke-width="2.5" stroke-linecap="round"/>
                        <polyline points="0,45 15,38 30,30 45,25 55,28 70,15 85,18 100,8 120,12 120,50 0,50" fill="url(#eab-att-grad)" stroke="none"/>
                        <defs><linearGradient id="eab-att-grad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="rgba(55,93,251,0.18)"/><stop offset="100%" stop-color="rgba(55,93,251,0)"/></linearGradient></defs>
                      </svg>
                    </div>
                    <div class="eab-mini-chip">Arrival pattern</div>
                  </Fragment>
                )}

                {card.visual === "revenue" && (
                  <Fragment>
                    <div class="eab-stacked-bars">
                      <div class="eab-stacked-col">
                        <span class="eab-bar-tickets" style="--h:40%"></span>
                        <span class="eab-bar-addons" style="--h:20%"></span>
                        <span class="eab-bar-sponsors" style="--h:15%"></span>
                      </div>
                      <div class="eab-stacked-col">
                        <span class="eab-bar-tickets" style="--h:50%"></span>
                        <span class="eab-bar-addons" style="--h:25%"></span>
                        <span class="eab-bar-sponsors" style="--h:10%"></span>
                      </div>
                      <div class="eab-stacked-col">
                        <span class="eab-bar-tickets" style="--h:60%"></span>
                        <span class="eab-bar-addons" style="--h:15%"></span>
                        <span class="eab-bar-sponsors" style="--h:20%"></span>
                      </div>
                      <div class="eab-stacked-col">
                        <span class="eab-bar-tickets" style="--h:55%"></span>
                        <span class="eab-bar-addons" style="--h:30%"></span>
                        <span class="eab-bar-sponsors" style="--h:12%"></span>
                      </div>
                    </div>
                    <div class="eab-mini-chip">Revenue mix</div>
                  </Fragment>
                )}

                {card.visual === "sessions" && (
                  <Fragment>
                    <div class="eab-session-cards">
                      <div class="eab-session-card">
                        <span class="eab-session-bar"></span>
                        <div class="eab-session-stars">
                          <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span class="eab-star-dim">&#9733;</span>
                        </div>
                      </div>
                      <div class="eab-session-card">
                        <span class="eab-session-bar"></span>
                        <div class="eab-session-stars">
                          <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
                        </div>
                      </div>
                    </div>
                    <div class="eab-mini-chip">Session ratings</div>
                  </Fragment>
                )}

                {card.visual === "engage" && (
                  <Fragment>
                    <div class="eab-gauge">
                      <svg viewBox="0 0 80 50" class="eab-gauge-svg">
                        <path d="M8,45 A32,32 0 0,1 72,45" fill="none" stroke="rgba(55,93,251,0.12)" stroke-width="8" stroke-linecap="round"/>
                        <path d="M8,45 A32,32 0 0,1 62,18" fill="none" stroke="#375dfb" stroke-width="8" stroke-linecap="round"/>
                      </svg>
                      <span class="eab-gauge-val">82</span>
                    </div>
                    <div class="eab-mini-chip">Engagement score</div>
                  </Fragment>
                )}

                {card.visual === "cohort" && (
                  <Fragment>
                    <div class="eab-cohort-circles">
                      <div class="eab-cohort-circle eab-cohort-circle--returning"></div>
                      <div class="eab-cohort-circle eab-cohort-circle--new"></div>
                      <div class="eab-cohort-overlap"></div>
                    </div>
                    <div class="eab-mini-chip">Returning vs new</div>
                  </Fragment>
                )}

                {card.visual === "utm" && (
                  <Fragment>
                    <div class="eab-utm-list">
                      <div class="eab-utm-row">
                        <span class="eab-utm-tag">google</span>
                        <span class="eab-utm-bar" style="--w:80%"></span>
                      </div>
                      <div class="eab-utm-row">
                        <span class="eab-utm-tag">email</span>
                        <span class="eab-utm-bar" style="--w:60%"></span>
                      </div>
                      <div class="eab-utm-row">
                        <span class="eab-utm-tag">social</span>
                        <span class="eab-utm-bar" style="--w:45%"></span>
                      </div>
                    </div>
                    <div class="eab-mini-chip">UTM sources</div>
                  </Fragment>
                )}

                {card.visual === "trends" && (
                  <Fragment>
                    <div class="eab-trend-chart">
                      <svg viewBox="0 0 120 50" preserveAspectRatio="none" class="eab-trend-svg">
                        <polyline points="0,42 20,38 40,30 60,28 80,18 100,12 120,5" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round"/>
                        <circle cx="40" cy="30" r="3" fill="#22c55e"/>
                        <circle cx="80" cy="18" r="3" fill="#22c55e"/>
                        <circle cx="120" cy="5" r="3" fill="#22c55e"/>
                      </svg>
                    </div>
                    <div class="eab-mini-chip">Upward trend</div>
                  </Fragment>
                )}

                {card.visual === "benchmark" && (
                  <Fragment>
                    <div class="eab-benchmark-bars">
                      <div class="eab-bench-row">
                        <span class="eab-bench-yours" style="--w:78%"></span>
                        <span class="eab-bench-industry" style="--w:60%"></span>
                      </div>
                      <div class="eab-bench-row">
                        <span class="eab-bench-yours" style="--w:85%"></span>
                        <span class="eab-bench-industry" style="--w:70%"></span>
                      </div>
                      <div class="eab-bench-row">
                        <span class="eab-bench-yours" style="--w:65%"></span>
                        <span class="eab-bench-industry" style="--w:72%"></span>
                      </div>
                    </div>
                    <div class="eab-mini-chip">You vs industry</div>
                  </Fragment>
                )}

                {card.visual === "customreport" && (
                  <Fragment>
                    <div class="eab-builder">
                      <div class="eab-builder-sidebar">
                        <span class="eab-builder-block"></span>
                        <span class="eab-builder-block"></span>
                        <span class="eab-builder-block"></span>
                      </div>
                      <div class="eab-builder-canvas">
                        <span class="eab-builder-drop"></span>
                        <span class="eab-builder-drop eab-builder-drop--filled"></span>
                      </div>
                    </div>
                    <div class="eab-mini-chip">Drag & drop</div>
                  </Fragment>
                )}

                {card.visual === "sponsorreport" && (
                  <Fragment>
                    <div class="eab-sponsor-badge">
                      <div class="eab-sponsor-logo"></div>
                      <div class="eab-sponsor-metrics">
                        <div><strong>342</strong><span>visits</span></div>
                        <div><strong>89%</strong><span>engaged</span></div>
                      </div>
                    </div>
                    <div class="eab-mini-chip">Sponsor ROI</div>
                  </Fragment>
                )}

                {card.visual === "csvpdf" && (
                  <Fragment>
                    <div class="eab-file-icons">
                      <div class="eab-file-icon eab-file-icon--csv">CSV</div>
                      <div class="eab-file-icon eab-file-icon--pdf">PDF</div>
                      <div class="eab-file-icon eab-file-icon--xls">XLS</div>
                    </div>
                    <div class="eab-mini-chip">Export formats</div>
                  </Fragment>
                )}

                {card.visual === "apiaccess" && (
                  <Fragment>
                    <div class="eab-api-block">
                      <div class="eab-api-endpoint">GET /api/analytics</div>
                      <div class="eab-api-json">
                        <span class="eab-api-brace">&#123;</span>
                        <span class="eab-api-line">"registrations": 2847</span>
                        <span class="eab-api-line">"revenue": 124000</span>
                        <span class="eab-api-brace">&#125;</span>
                      </div>
                    </div>
                    <div class="eab-mini-chip">REST API</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".eab-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".eab-tab"));
      const panels = Array.from(root.querySelectorAll(".eab-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("eab-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("eab-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .eab-section {
    padding: 80px 0 60px;
    background: url('https://eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .eab-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .eab-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .eab-title b { font-weight: 700; }

  .eab-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .eab-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .eab-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .eab-tab:hover,
  .eab-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .eab-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .eab-panel { display: none; }
  .eab-panel--active { display: block; }

  .eab-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .eab-panel--active .eab-card {
    animation: eab-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  @keyframes eab-fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .eab-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .eab-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .eab-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .eab-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .eab-card--mini:nth-of-type(2) { grid-area: mini1; }
  .eab-card--mini:nth-of-type(3) { grid-area: mini2; }
  .eab-card--mini:nth-of-type(4) { grid-area: mini3; }
  .eab-card--mini:nth-of-type(5) { grid-area: mini4; }

  .eab-card__content { position: relative; z-index: 1; }

  .eab-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eab-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .eab-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .eab-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .eab-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .eab-point-list li::before {
    content: "";
