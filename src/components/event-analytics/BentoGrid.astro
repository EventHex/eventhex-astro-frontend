---
import { eaIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Event Metrics",
    hero: {
      title: "Registration, attendance, revenue & engagement in real time",
      desc: "Track signups, conversion funnels, ticket sales, check-in rates, session attendance, and composite engagement scores — all updating live.",
      visual: "metrics",
    },
    cards: [
      { title: "Attendance Tracking", desc: "Live check-in tracking with arrival patterns and no-show rates.", visual: "attendance" },
      { title: "Revenue Dashboard", desc: "Real-time revenue across tickets, add-ons, and sponsorships.", visual: "revenue" },
      { title: "Session Analytics", desc: "Attendance, ratings, and engagement per session and speaker.", visual: "sessions" },
      { title: "Engagement Scores", desc: "Composite engagement scores for every attendee and session.", visual: "engage" },
    ],
  },
  {
    label: "Platform Analytics",
    hero: {
      title: "Multi-event comparison, cohort analysis & marketing attribution",
      desc: "Compare performance across all your events. Track returning attendees, measure marketing channels, and benchmark against industry data.",
      visual: "platform",
    },
    cards: [
      { title: "Cohort Analysis", desc: "Track returning attendees, first-timers, and VIPs across events.", visual: "cohort" },
      { title: "UTM Tracking", desc: "Measure which marketing channels drive the most registrations.", visual: "utm" },
      { title: "Trend Analysis", desc: "Spot trends in attendance, revenue, and engagement over time.", visual: "trends" },
      { title: "Benchmark Data", desc: "Compare your event metrics against industry benchmarks.", visual: "benchmark" },
    ],
  },
  {
    label: "Reports & Export",
    hero: {
      title: "Scheduled reports, custom builders & sponsor ROI with export",
      desc: "Use 50+ report templates or build custom reports. Schedule automatic delivery, generate sponsor ROI reports, and export via CSV, PDF, or API.",
      visual: "reports",
    },
    cards: [
      { title: "Custom Report Builder", desc: "Build custom reports with drag-and-drop metrics and filters.", visual: "customreport" },
      { title: "Sponsor ROI Reports", desc: "Auto-generated reports showing sponsor engagement and booth traffic.", visual: "sponsorreport" },
      { title: "CSV & PDF Export", desc: "Export any report or dashboard as CSV, PDF, or Excel.", visual: "csvpdf" },
      { title: "API Access", desc: "Pull analytics data into your own BI tools via REST API.", visual: "apiaccess" },
    ],
  },
];

const ICON = '<svg class="eab-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="eab-section" id="ea-bento">
  <div class="eab">
    <h2 class="eab-title">
      Event <b>Metrics</b>, Platform <b>Analytics</b> & <b>Reports</b>
    </h2>
    <p class="eab-subtitle">
      Track registrations, attendance, engagement, revenue, and sponsor ROI from one analytics dashboard.
    </p>

    <nav class="eab-nav">
      {tabs.map((t, i) => (
        <button class={`eab-tab ${i === 0 ? "eab-tab--active" : ""}`} data-eab-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`eab-panel ${tabIdx === 0 ? "eab-panel--active" : ""}`} data-eab-panel={String(tabIdx)}>
        <div class="eab-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="eab-card eab-card--tall eab-pos-0" style="animation-delay:0s">
            <div class="eab-card__inner">
              <div class="eab-card__text">
                <Fragment set:html={ICON} />
                <h3 class="eab-card__title">{t.hero.title}</h3>
                <p class="eab-card__desc">{t.hero.desc}</p>
              </div>
              <div class="eab-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`eab-card eab-card--sm eab-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="eab-card__inner eab-card__inner--row">
                <div class="eab-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="eab-card__title">{c.title}</h3>
                  <p class="eab-card__desc">{c.desc}</p>
                </div>
                <div class="eab-card__img eab-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const eabTabs = Array.from(document.querySelectorAll('[data-eab-tab]'));
  const eabPanels = Array.from(document.querySelectorAll('[data-eab-panel]'));
  let eabActive = 0;
  let eabInterval: ReturnType<typeof setInterval>;

  function setEabTab(index: number) {
    eabTabs.forEach((t) => t.classList.remove('eab-tab--active'));
    eabPanels.forEach((p) => p.classList.remove('eab-panel--active'));
    eabTabs[index]?.classList.add('eab-tab--active');
    eabPanels[index]?.classList.add('eab-panel--active');
    eabActive = index;
  }
  function startEab() {
    eabInterval = setInterval(() => setEabTab((eabActive + 1) % eabTabs.length), 5000);
  }
  eabTabs.forEach((tab, i) => tab.addEventListener('click', () => { setEabTab(i); clearInterval(eabInterval); startEab(); }));
  startEab();
  const eabSection = document.querySelector('.eab-section');
  if (eabSection) {
    eabSection.addEventListener('mouseenter', () => clearInterval(eabInterval));
    eabSection.addEventListener('mouseleave', () => startEab());
  }
</script>

<style>
  .eab-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .eab { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .eab-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .eab-title b { font-weight: 700; }
  .eab-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .eab-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .eab-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .eab-tab:hover { background: rgba(55,93,251,.08); }
  .eab-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .eab-panel { display: none; }
  .eab-panel--active { display: block; animation: eabFadeUp 0.4s ease; }
  @keyframes eabFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .eab-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .eab-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .eab-pos-1 { grid-column: 2; grid-row: 1; }
  .eab-pos-2 { grid-column: 3; grid-row: 1; }
  .eab-pos-3 { grid-column: 2; grid-row: 2; }
  .eab-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .eab-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .eab-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .eab-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .eab-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .eab-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .eab-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .eab-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .eab-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .eab-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .eab-pos-4 { grid-column: 3; grid-row: 2; }

  @property --eab-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .eab-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: eabCardIn 0.5s ease forwards;
  }
  .eab-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--eab-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .eab-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .eab-card:hover::after { opacity: 1; animation: eabBorder 2.4s linear infinite; }
  @keyframes eabBorder { to { --eab-angle: 360deg; } }
  @keyframes eabCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .eab-pos-1 { animation-delay: 0.06s; }
  .eab-pos-2 { animation-delay: 0.12s; }
  .eab-pos-3 { animation-delay: 0.18s; }
  .eab-pos-4 { animation-delay: 0.24s; }

  .eab-card__inner { display: flex; flex-direction: column; height: 100%; }
  .eab-card__inner--row { flex-direction: row; }
  .eab-card__text { display: flex; flex-direction: column; gap: 6px; }
  .eab-card--tall .eab-card__text { padding: 20px 20px 8px; }
  .eab-card--sm .eab-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .eab-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .eab-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .eab-card--sm .eab-card__title { font-size: 17px; }
  .eab-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .eab-card--sm .eab-card__desc { font-size: 13px; }

  .eab-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .eab-card--tall .eab-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .eab-card--sm .eab-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .eab-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .eab-card:hover .eab-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: eabFloat 2.2s ease-in-out infinite;
  }
  @keyframes eabFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .eab-section { padding: 60px 0 48px; }
    .eab-title { font-size: 36px; }
    .eab-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .eab-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .eab-pos-1, .eab-pos-2, .eab-pos-3, .eab-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .eab-pos-0, [data-layout="c"] .eab-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .eab-pos-1, [data-layout="b"] .eab-pos-2, [data-layout="b"] .eab-pos-3, [data-layout="b"] .eab-pos-4,
    [data-layout="c"] .eab-pos-1, [data-layout="c"] .eab-pos-2, [data-layout="c"] .eab-pos-3, [data-layout="c"] .eab-pos-4 { grid-column: auto; grid-row: auto; }
    .eab-card--tall .eab-card__inner { flex-direction: row; }
    .eab-card--tall .eab-card__text { flex: 1; }
    .eab-card--tall .eab-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .eab-title { font-size: 28px; }
    .eab-subtitle { font-size: 15px; }
    .eab-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .eab-tab { border-radius: 12px; }
    .eab-grid { grid-template-columns: 1fr; }
    .eab-pos-0, .eab-pos-1, .eab-pos-2, .eab-pos-3, .eab-pos-4,
    [data-layout="b"] .eab-pos-0, [data-layout="b"] .eab-pos-1, [data-layout="b"] .eab-pos-2, [data-layout="b"] .eab-pos-3, [data-layout="b"] .eab-pos-4,
    [data-layout="c"] .eab-pos-0, [data-layout="c"] .eab-pos-1, [data-layout="c"] .eab-pos-2, [data-layout="c"] .eab-pos-3, [data-layout="c"] .eab-pos-4 { grid-column: 1; grid-row: auto; }
    .eab-card--sm .eab-card__inner, .eab-card--tall .eab-card__inner { flex-direction: row; }
    .eab-card--sm .eab-card__text, .eab-card--tall .eab-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .eab-card--sm .eab-card__img, .eab-card--tall .eab-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .eab-card { animation: none !important; opacity: 1; transform: none; }
    .eab-card:hover::after { animation: none !important; }
    .eab-card:hover .eab-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
