---
import MarketingLayout from "../../layouts/MarketingLayout.astro";

/* ── TYPE DEFINITIONS ──────────────────────────────────────── */
interface StatItem { value: string; label: string }
interface BentoCard { title: string; desc: string; link?: string; illustration?: string }
interface BentoTab { tab: string; cards: BentoCard[] }
interface StackingCard { title: string; desc: string }
interface StepItem { title: string; desc: string }
interface FaqItem { q: string; a: string }
interface ChallengeItem { icon: string; title: string; desc: string }

interface Props {
  /* seo */
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  /* hero */
  badge: string;
  heroTitleLine1: string;
  heroTitleLine2: string;
  heroCopy: string;
  trustItems: string[];
  /* stats */
  stats: StatItem[];
  statsHeadline: { white1: string; accent: string; white2: string; accent2: string };
  /* challenges */
  challengesTag?: string;
  challengesHeading: string;
  challengesDesc?: string;
  challenges: ChallengeItem[];
  /* bento grid */
  bentoHeading: string;
  bentoSubtitle: string;
  bentoTabs: BentoTab[];
  /* stacking cards */
  stackingHeading: string;
  stackingHighlight: string;
  stackingCards: StackingCard[];
  /* how it works */
  howItWorksHeading: string;
  steps: StepItem[];
  /* cta */
  ctaTitle: string;
  ctaCopy: string;
  /* faq */
  faqs: FaqItem[];
  supportNote: { title: string; desc: string };
  supportCta: { label: string; href: string };
  /* seo */
  jsonLd?: Record<string, unknown>;
}

const {
  title, description, canonical, ogImage,
  badge, heroTitleLine1, heroTitleLine2, heroCopy, trustItems,
  stats, statsHeadline,
  challengesTag = "Key Challenges", challengesHeading, challengesDesc, challenges,
  bentoHeading, bentoSubtitle, bentoTabs,
  stackingHeading, stackingHighlight, stackingCards,
  howItWorksHeading, steps,
  ctaTitle, ctaCopy,
  faqs,
  supportNote, supportCta,
  jsonLd,
} = Astro.props;

const layouts = ["a", "b", "c"];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  showFooterCta={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </Fragment>

  <!-- ① HERO — centered gradient text (IndustryLayout style) -->
  <section class="uc-hero">
    <div class="uc-hero__inner">
      <div class="uc-hero__badge animate-on-scroll" data-animation="fadeInDown">
        <span>{badge}</span>
      </div>
      <h1 class="uc-hero__title animate-on-scroll" data-animation="fadeInUp">
        {heroTitleLine1}<br />
        <span class="uc-hero__highlight">{heroTitleLine2}</span>
      </h1>
      <p class="uc-hero__copy animate-on-scroll" data-animation="fadeInUp">{heroCopy}</p>
      <div class="uc-hero__ctas animate-on-scroll" data-animation="fadeInUp">
        <a href="/book-a-demo/" class="uc-btn uc-btn--primary">
          Book a Demo
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#uc-bento" class="uc-btn uc-btn--outline">Explore Features</a>
      </div>
      <div class="uc-hero__trust animate-on-scroll" data-animation="fadeIn">
        {trustItems.map((t) => (
          <span class="uc-hero__trust-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#375DFB" opacity=".15"/><path d="M5 8l2 2 4-4" stroke="#375DFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ② STATS — dark band with bg-1.webp -->
  <section class="uc-stats">
    <div class="uc-stats__engagement">
      <div class="uc-stats__engagement-text">
        <h2 class="uc-stats__heading animate-on-scroll" data-animation="fadeInDown">
          <span class="uc-stats--white">{statsHeadline.white1} </span>
          <span class="uc-stats--purple">{statsHeadline.accent} </span>
          <span class="uc-stats--white">{statsHeadline.white2} </span>
          <span class="uc-stats--cyan">{statsHeadline.accent2}</span>
        </h2>
      </div>
    </div>
    <div class="uc-stats__grid">
      {stats.map((stat) => (
        <div class="uc-stats__card animate-on-scroll" data-animation="fadeInUp">
          <span class="uc-stats__value">{stat.value}</span>
          <span class="uc-stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ③ CHALLENGES — white bg, numbered glass cards -->
  <section class="uc-challenges">
    <div class="uc-challenges__inner">
      <div class="uc-challenges__header">
        <span class="uc-challenges__tag animate-on-scroll" data-animation="fadeIn">{challengesTag}</span>
        <h2 class="uc-challenges__title animate-on-scroll" data-animation="fadeInUp" set:html={challengesHeading} />
        {challengesDesc && <p class="uc-challenges__desc animate-on-scroll" data-animation="fadeInUp">{challengesDesc}</p>}
      </div>
      <div class="uc-challenges__cards">
        {challenges.map((c, i) => (
          <article class="uc-challenges__card animate-on-scroll" data-animation="fadeInUp">
            <div class="uc-challenges__card-num">{String(i + 1).padStart(2, "0")}</div>
            <span class="uc-challenges__card-icon">{c.icon}</span>
            <h3 class="uc-challenges__card-title">{c.title}</h3>
            <p class="uc-challenges__card-desc">{c.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ④ BENTO GRID — tabbed, light bg with Bg.svg (FeatureV2Layout style) -->
  <section class="uc-bento-section" id="uc-bento">
    <div class="uc-bento">
      <h2 class="uc-bento__title">{bentoHeading}</h2>
      <p class="uc-bento__subtitle">{bentoSubtitle}</p>

      <nav class="uc-bento__nav">
        {bentoTabs.map((t, i) => (
          <button class={`uc-bento__tab ${i === 0 ? "uc-bento__tab--active" : ""}`} data-uc-tab={String(i)}>{t.tab}</button>
        ))}
      </nav>

      {bentoTabs.map((t, tabIdx) => (
        <div class={`uc-bento__panel ${tabIdx === 0 ? "uc-bento__panel--active" : ""}`} data-uc-panel={String(tabIdx)}>
          <div class="uc-bento__grid" data-layout={layouts[tabIdx % 3]}>
            {t.cards.map((card, cardIdx) => {
              const CardTag = card.link ? "a" : "div";
              return (
                <CardTag
                  href={card.link || undefined}
                  class={`uc-bento__card ${cardIdx === 0 ? "uc-bento__card--tall" : "uc-bento__card--sm"} uc-bento__pos-${cardIdx}`}
                >
                  <div class={`uc-bento__card-inner ${cardIdx > 0 ? "uc-bento__card-inner--row" : ""}`}>
                    <div class="uc-bento__card-text">
                      <div class="uc-bento__grid-icon"><div/><div/><div/><div/></div>
                      <h3 class="uc-bento__card-title">{card.title}</h3>
                      <p class="uc-bento__card-desc">{card.desc}</p>
                      {card.link && (
                        <span class="uc-bento__card-link">
                          Learn more
                          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </span>
                      )}
                    </div>
                    {card.illustration && <div class="uc-bento__card-img" set:html={card.illustration} />}
                  </div>
                </CardTag>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ⑤ STACKING CARDS — dark bg, sticky scroll -->
  <section class="uc-stack-shell">
    <div class="uc-stack-section">
      <div class="uc-stack-header">
        <span class="uc-stack-subtitle">Step-by-step workflow</span>
        <h2 class="uc-stack-title">
          {stackingHeading} <span class="uc-stack-hl">{stackingHighlight}</span>
        </h2>
      </div>
      <div class="uc-stack-cards">
        {stackingCards.map((card, i) => (
          <div
            class="uc-stack-card"
            data-card-index={i}
            style={`--card-index: ${i}; top: calc(20px + ${i * 20}px);`}
          >
            <div class="uc-stack-card-content">
              <span class="uc-stack-card-num">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="uc-stack-card-title">{card.title}</h3>
              <p class="uc-stack-card-desc">{card.desc}</p>
              <a href="/book-a-demo/" class="uc-stack-card-btn">Learn More</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑥ HOW IT WORKS — dark section -->
  <section class="uc-how">
    <div class="uc-how__inner">
      <span class="uc-how__eyebrow animate-on-scroll" data-animation="fadeIn">Step by Step</span>
      <h2 class="uc-how__heading animate-on-scroll" data-animation="fadeInUp">{howItWorksHeading}</h2>
      <div class="uc-how__steps">
        {steps.map((step, i) => (
          <div class="uc-how__step animate-on-scroll" data-animation="fadeInUp">
            <span class="uc-how__num">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="uc-how__step-title">{step.title}</h3>
            <p class="uc-how__step-desc">{step.desc}</p>
            {i < steps.length - 1 && <span class="uc-how__arrow">→</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑦ CTA — dark card with glows -->
  <section class="uc-cta">
    <div class="uc-cta__card">
      <div class="uc-cta__glow uc-cta__glow--1"></div>
      <div class="uc-cta__glow uc-cta__glow--2"></div>
      <div class="uc-cta__content">
        <span class="uc-cta__eyebrow animate-on-scroll" data-animation="fadeIn">Get Started Today</span>
        <h2 class="uc-cta__title animate-on-scroll" data-animation="fadeInUp">{ctaTitle}</h2>
        <p class="uc-cta__copy animate-on-scroll" data-animation="fadeInUp">{ctaCopy}</p>
        <div class="uc-cta__proof-row animate-on-scroll" data-animation="fadeInUp">
          <span class="uc-cta__proof-pill">AI-powered platform</span>
          <span class="uc-cta__proof-pill">Free onboarding support</span>
          <span class="uc-cta__proof-pill">No credit card required</span>
        </div>
        <div class="uc-cta__buttons animate-on-scroll" data-animation="fadeInUp">
          <a href="/book-a-demo/" class="uc-btn uc-btn--white">
            Book a Free Demo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#uc-bento" class="uc-btn uc-btn--ghost">Explore Features</a>
        </div>
        <div class="uc-cta__trust animate-on-scroll" data-animation="fadeIn">
          {trustItems.map((t) => (
            <span class="uc-cta__trust-item">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
              {t}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ⑧ FAQ — split layout, sidebar + accordion -->
  <section class="uc-faq">
    <div class="uc-faq__inner">
      <div class="uc-faq__sidebar animate-on-scroll" data-animation="fadeInLeft">
        <span class="uc-faq__eyebrow">Need a custom setup?</span>
        <h2 class="uc-faq__sidebar-title">Frequently Asked Questions</h2>
        <p class="uc-faq__sidebar-desc">{supportNote.desc}</p>
        <div class="uc-faq__support-card">
          <h3 class="uc-faq__support-title">{supportNote.title}</h3>
          <p class="uc-faq__support-desc">Our experts can walk you through a personalized demo and answer any questions.</p>
        </div>
        <a href={supportCta.href} class="uc-btn uc-btn--primary uc-btn--sm">{supportCta.label}</a>
      </div>
      <div class="uc-faq__list">
        {faqs.map((faq, i) => (
          <details class="uc-faq__item animate-on-scroll" data-animation="fadeInUp">
            <summary class="uc-faq__question">
              {faq.q}
              <svg class="uc-faq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div class="uc-faq__answer"><p>{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>

<style is:global>
  /* ══════════════════════════════════════════
     ① HERO — centered gradient + overlays (from IndustryLayout)
     ═══════════════════════════════════════════ */
  .uc-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    text-align: center;
    background:
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat,
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }
  .uc-hero__inner {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    padding: 160px 1.5rem 5rem;
  }
  .uc-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin-bottom: 1.5rem;
  }
  .uc-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 52px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin-bottom: 1.25rem;
  }
  .uc-hero__highlight { display: block; color: var(--brand-blue); }
  .uc-hero__copy {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    max-width: 680px;
    margin: 0 auto 2rem;
  }
  .uc-hero__ctas { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }
  .uc-hero__trust { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
  .uc-hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--subheading-gray);
  }

  /* ── BUTTONS ─────────────────────────────── */
  .uc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    padding: 0.75rem 1.75rem;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
    border: none;
  }
  .uc-btn--primary { background: var(--brand-blue); color: #fff; }
  .uc-btn--primary:hover { filter: brightness(1.1); transform: translateY(-2px); }
  .uc-btn--outline { background: transparent; color: var(--heading-dark); border: 1.5px solid var(--surface-card-border, #e8ecf4); }
  .uc-btn--outline:hover { border-color: var(--brand-blue); color: var(--brand-blue); }
  .uc-btn--white { background: #fff; color: var(--heading-dark); }
  .uc-btn--white:hover { background: #f0f4ff; transform: translateY(-2px); }
  .uc-btn--ghost { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .uc-btn--ghost:hover { background: rgba(255,255,255,0.2); }
  .uc-btn--sm { font-size: 0.875rem; padding: 0.625rem 1.25rem; }

  /* ══════════════════════════════════════════
     ② STATS — dark band with bg-1.webp
     ═══════════════════════════════════════════ */
  .uc-stats {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 100px 1.5rem;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }
  .uc-stats__engagement { width: 100%; padding: 0 0 60px; display: flex; justify-content: center; }
  .uc-stats__engagement-text { width: 65%; max-width: 800px; }
  .uc-stats__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    text-align: center;
    margin: 0;
  }
  .uc-stats--white { color: #fff; }
  .uc-stats--purple { color: #AFA3FF; }
  .uc-stats--cyan { color: #ABFFFF; }
  .uc-stats__grid {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    max-width: 1100px;
    margin: 0 auto;
  }
  .uc-stats__card {
    flex: 0 0 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 2rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    backdrop-filter: blur(8px);
    text-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .uc-stats__card:hover { transform: translateY(-4px); border-color: rgba(55,93,251,0.3); }
  .uc-stats__value { font-family: var(--font-heading); font-size: 2.5rem; font-weight: 700; color: #fff; letter-spacing: -1px; }
  .uc-stats__label { font-family: var(--font-body); font-size: 0.875rem; color: rgba(255,255,255,0.6); }

  /* ══════════════════════════════════════════
     ③ CHALLENGES — white bg, numbered glass cards
     ═══════════════════════════════════════════ */
  .uc-challenges { width: 100%; padding: 80px 1.5rem; background: #fff; }
  .uc-challenges__inner { max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 48px; }
  .uc-challenges__header { text-align: center; max-width: 700px; }
  .uc-challenges__tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-blue);
    margin-bottom: 0.75rem;
  }
  .uc-challenges__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--heading-dark);
    line-height: 1.25;
    margin: 0 0 0.75rem;
  }
  .uc-challenges__title :global(b) { color: var(--brand-blue); font-weight: 700; }
  .uc-challenges__desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0;
  }
  .uc-challenges__cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; width: 100%; }
  .uc-challenges__card {
    position: relative;
    background: var(--surface-light);
    border: 1px solid var(--surface-card-border);
    border-radius: 16px;
    padding: 2rem 1.5rem 1.75rem;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .uc-challenges__card:hover { transform: translateY(-6px); border-color: var(--brand-blue); box-shadow: 0 12px 32px rgba(55,93,251,0.1); }
  .uc-challenges__card-num {
    position: absolute; top: 16px; right: 16px;
    font-family: var(--font-heading); font-size: 0.75rem; font-weight: 700;
    color: rgba(55,93,251,0.2); letter-spacing: 0.05em;
  }
  .uc-challenges__card-icon { font-size: 2rem; display: block; margin-bottom: 1rem; }
  .uc-challenges__card-title {
    font-family: var(--font-heading); font-size: 1rem; font-weight: 700;
    color: var(--heading-dark); margin: 0 0 0.5rem; line-height: 1.35;
  }
  .uc-challenges__card-desc {
    font-family: var(--font-body); font-size: 0.875rem; line-height: 1.65;
    color: var(--subheading-gray); margin: 0;
  }

  /* ══════════════════════════════════════════
     ④ BENTO GRID — tabbed, light bg (from FeatureV2Layout)
     ═══════════════════════════════════════════ */
  .uc-bento-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .uc-bento { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .uc-bento__title {
    font-family: var(--font-heading); font-size: 42px; font-weight: 400;
    line-height: 1.1; letter-spacing: -1px; text-align: center;
    color: var(--heading-dark); margin: 0 0 12px;
