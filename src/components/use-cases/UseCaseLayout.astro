<script>
  /* Bento tab switching */
  const ucTabs = Array.from(document.querySelectorAll('[data-uc-tab]'));
  const ucPanels = Array.from(document.querySelectorAll('[data-uc-panel]'));

  function ucSwitch(index: number) {
    ucTabs.forEach((t) => t.classList.remove('uc-bento__tab--active'));
    ucPanels.forEach((p) => p.classList.remove('uc-bento__panel--active'));
    ucTabs[index]?.classList.add('uc-bento__tab--active');
    ucPanels[index]?.classList.add('uc-bento__panel--active');
  }

  ucTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      ucSwitch(i);
      clearInterval(ucInterval);
    });
  });

  let ucIdx = 0;
  let ucInterval: ReturnType<typeof setInterval>;

  function startUcRotation() {
    ucInterval = setInterval(() => {
      ucIdx = (ucIdx + 1) % ucTabs.length;
      ucSwitch(ucIdx);
    }, 5000);
  }
  startUcRotation();

  const ucBento = document.querySelector('.uc-bento-section');
  if (ucBento) {
    ucBento.addEventListener('mouseenter', () => clearInterval(ucInterval));
    ucBento.addEventListener('mouseleave', () => startUcRotation());
  }

  /* Scroll animations */
  const ucObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          ucObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll(".animate-on-scroll").forEach((el) => ucObserver.observe(el));
</script>
