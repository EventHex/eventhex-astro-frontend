---
// CTA Section — dark gradient card with trust signals (matching event-ticketing pattern)
---

<section class="asc-cta">
  <div class="asc-cta__card">
    <div class="asc-cta__glow asc-cta__glow--1"></div>
    <div class="asc-cta__glow asc-cta__glow--2"></div>
    <div class="asc-cta__content">
      <span class="asc-cta__eyebrow animate-on-scroll" data-animation="fadeIn">Smarter Networking Starts Here</span>
      <h2 class="asc-cta__title animate-on-scroll" data-animation="fadeInUp">Explore EventHex's AI Smart Connect Now!</h2>
      <p class="asc-cta__desc animate-on-scroll" data-animation="fadeInUp">Every interaction counts. Give your attendees AI-powered networking that creates meaningful connections and drives real professional growth.</p>
      <div class="asc-cta__proof-row animate-on-scroll" data-animation="fadeInUp">
        <span class="asc-cta__proof-pill">AI-powered matchmaking</span>
        <span class="asc-cta__proof-pill">Interest-based networking</span>
        <span class="asc-cta__proof-pill">Real-time recommendations</span>
      </div>
      <div class="asc-cta__buttons">
        <a href="/book-a-demo/" class="asc-cta__btn asc-cta__btn--primary">
          Book a Free Demo
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/contact-en/" class="asc-cta__btn asc-cta__btn--secondary">Contact Sales</a>
      </div>
      <div class="asc-cta__trust">
        <span class="asc-cta__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
          No credit card required
        </span>
        <span class="asc-cta__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
          Free onboarding support
        </span>
        <span class="asc-cta__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
          Cancel anytime
        </span>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .asc-cta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }

  .asc-cta__card {
    position: relative;
    border-radius: 24px;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;
    background: #0F1629;
  }

  .asc-cta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .asc-cta__glow--1 {
    width: 400px;
    height: 400px;
    background: rgba(55, 93, 251, 0.2);
    top: -100px;
    left: -50px;
  }

  .asc-cta__glow--2 {
    width: 300px;
    height: 300px;
    background: rgba(159, 129, 255, 0.15);
    bottom: -80px;
    right: -30px;
  }

  .asc-cta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 600px;
  }

  .asc-cta__eyebrow {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .asc-cta__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .asc-cta__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .asc-cta__proof-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .asc-cta__proof-pill {
    display: inline-flex;
    align-items: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: rgba(255, 255, 255, 0.74);
  }

  .asc-cta__buttons { display: flex; gap: 12px; justify-content: center; }

  .asc-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .asc-cta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.35);
  }

  .asc-cta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(55, 93, 251, 0.4);
  }

  .asc-cta__btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .asc-cta__btn--secondary:hover { background: rgba(255, 255, 255, 0.15); }

  .asc-cta__trust {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-top: 8px;
  }

  .asc-cta__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
  }

  @media (max-width: 1024px) {
    .asc-cta__card { padding: 60px 24px; }
    .asc-cta__title { font-size: 36px; }
    .asc-cta__desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .asc-cta { padding: 40px 16px 60px; }
    .asc-cta__card { padding: 48px 20px; border-radius: 20px; }
    .asc-cta__title { font-size: 28px; line-height: 1.2; }
    .asc-cta__desc { font-size: 15px; }
    .asc-cta__proof-row { gap: 8px; }
    .asc-cta__buttons { flex-direction: column; width: 100%; }
    .asc-cta__btn { width: 100%; justify-content: center; }
    .asc-cta__trust { flex-direction: column; gap: 8px; }
  }
</style>
