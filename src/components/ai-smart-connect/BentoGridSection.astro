---
// Tabbed Bento Grid — 3 tabs for AI Smart-Connect workflows
// Pattern from event-ticketing BentoGridSection
---

<section class="asc-bento-section" id="asc-features">
  <div class="ascb" id="ascb-bento">
    <h2 class="ascb-title">
      Smart <b>Matching</b>, Scheduling & <b>Insights</b>
    </h2>
    <p class="ascb-subtitle">
      From interest-based matching to VIP intros to post-event analytics — manage your entire networking workflow from one AI engine.
    </p>

    <nav class="ascb-nav">
      <button class="ascb-tab ascb-tab--active" data-ascb-tab="0">Matchmaking</button>
      <button class="ascb-tab" data-ascb-tab="1">Scheduling</button>
      <button class="ascb-tab" data-ascb-tab="2">Analytics</button>
    </nav>

    <!-- Tab 0: Matchmaking -->
    <div class="ascb-panel ascb-panel--active" data-ascb-panel="0">
      <div class="ascb-grid" data-layout="a">
        <div class="ascb-card ascb-card--tall ascb-pos-0">
          <div class="ascb-card__inner">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="9" cy="7" r="4" stroke="#375DFB" stroke-width="2"/><circle cx="17" cy="9" r="3" stroke="#375DFB" stroke-width="1.5"/><path d="M2 21v-2a5 5 0 015-5h4a5 5 0 015 5v2" stroke="#375DFB" stroke-width="2"/></svg>
              <h3 class="ascb-card__title">Interest-Based Matching</h3>
              <p class="ascb-card__desc">AI analyzes attendee profiles, industries, and interests to create high-relevance networking pairs.</p>
            </div>
            <div class="ascb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <circle cx="70" cy="75" r="22" fill="#375DFB" opacity=".08"/>
                <circle cx="130" cy="75" r="22" fill="#375DFB" opacity=".08"/>
                <path d="M92 75h16" stroke="#375DFB" stroke-width="2" stroke-dasharray="4 4"/>
                <circle cx="70" cy="75" r="8" fill="#375DFB" opacity=".2"/>
                <circle cx="130" cy="75" r="8" fill="#375DFB" opacity=".2"/>
                <text x="100" y="130" text-anchor="middle" font-size="11" fill="#375DFB" opacity=".6">92% match</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-1">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2a10 10 0 100 20 10 10 0 000-20z" stroke="#375DFB" stroke-width="2"/><path d="M8 12l3 3 5-5" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <h3 class="ascb-card__title">Profile Analysis</h3>
              <p class="ascb-card__desc">Deep analysis of attendee data, goals, and professional background for precise matching.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-2">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#375DFB" stroke-width="2"/><circle cx="9" cy="7" r="4" stroke="#375DFB" stroke-width="2"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="#375DFB" stroke-width="2"/></svg>
              <h3 class="ascb-card__title">Purposeful Connections</h3>
              <p class="ascb-card__desc">Match attendees based on complementary goals and professional aspirations.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-3">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <h3 class="ascb-card__title">Real-Time Refinement</h3>
              <p class="ascb-card__desc">AI tracks interactions to continuously improve match accuracy throughout the event.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-4">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#375DFB" stroke-width="2"/></svg>
              <h3 class="ascb-card__title">VIP Introductions</h3>
              <p class="ascb-card__desc">Curated intros to speakers, sponsors, and high-profile guests for premium attendees.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 1: Scheduling -->
    <div class="ascb-panel" data-ascb-panel="1">
      <div class="ascb-grid" data-layout="b">
        <div class="ascb-card ascb-card--tall ascb-pos-0">
          <div class="ascb-card__inner">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M16 2v4M8 2v4M3 10h18" stroke="#375DFB" stroke-width="2"/></svg>
              <h3 class="ascb-card__title">Meeting Scheduler</h3>
              <p class="ascb-card__desc">AI builds personalized meeting schedules based on mutual availability and interest overlap.</p>
            </div>
            <div class="ascb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect x="35" y="45" width="130" height="14" rx="7" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="45" width="78" height="14" rx="7" fill="#375DFB" opacity=".15"/>
                <rect x="35" y="68" width="130" height="14" rx="7" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="68" width="104" height="14" rx="7" fill="#375DFB" opacity=".12"/>
                <rect x="35" y="91" width="130" height="14" rx="7" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="91" width="52" height="14" rx="7" fill="#375DFB" opacity=".18"/>
                <text x="100" y="135" text-anchor="middle" font-size="11" fill="#375DFB" opacity=".5">3 meetings booked</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-1">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#375DFB" stroke-width="2"/><path d="M12 6v6l4 2" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>
              <h3 class="ascb-card__title">Time-Bound Slots</h3>
              <p class="ascb-card__desc">Calendar-aware scheduling that respects attendee availability windows.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-2">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M8 21h8M12 17v4" stroke="#375DFB" stroke-width="2"/></svg>
              <h3 class="ascb-card__title">Industry Grouping</h3>
              <p class="ascb-card__desc">Group sessions with peers in the same sector for deeper industry conversations.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-3">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="#375DFB" stroke-width="2"/></svg>
              <h3 class="ascb-card__title">Conversation Starters</h3>
              <p class="ascb-card__desc">AI-generated prompts based on shared interests and professional backgrounds.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-4">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <h3 class="ascb-card__title">Live Notifications</h3>
              <p class="ascb-card__desc">Real-time alerts when matched connections are nearby during the event.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 2: Analytics -->
    <div class="ascb-panel" data-ascb-panel="2">
      <div class="ascb-grid" data-layout="c">
        <div class="ascb-card ascb-card--tall ascb-pos-0">
          <div class="ascb-card__inner">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M18 20V10M12 20V4M6 20v-6" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>
              <h3 class="ascb-card__title">Networking Analytics</h3>
              <p class="ascb-card__desc">Track match acceptance rates, meeting completion, and connection quality scores.</p>
            </div>
            <div class="ascb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <path d="M40 130l30-40 25 20 30-50 35 30" stroke="#375DFB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="40" cy="130" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="70" cy="90" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="95" cy="110" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="125" cy="60" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="160" cy="90" r="3" fill="#375DFB" opacity=".3"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-1">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="#375DFB" stroke-width="2"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>
              <h3 class="ascb-card__title">Connection Reports</h3>
              <p class="ascb-card__desc">Exportable reports with networking outcomes, follow-ups, and engagement metrics.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-2">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1zM4 22v-7" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <h3 class="ascb-card__title">Feedback Loop</h3>
              <p class="ascb-card__desc">Collect attendee feedback to improve future match recommendations continuously.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-3">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="#375DFB" stroke-width="2"/><path d="M21 21l-4.35-4.35" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>
              <h3 class="ascb-card__title">Satisfaction Scores</h3>
              <p class="ascb-card__desc">Real-time sentiment analysis from networking sessions and meeting outcomes.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-4">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 20V10M18 20V4M6 20v-4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>
              <h3 class="ascb-card__title">ROI Tracking</h3>
              <p class="ascb-card__desc">Measure networking value through follow-up conversion rates and partnership outcomes.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const ascbTabs = Array.from(document.querySelectorAll('[data-ascb-tab]'));
  const ascbPanels = Array.from(document.querySelectorAll('[data-ascb-panel]'));

  function ascbSwitch(index: number) {
    ascbTabs.forEach((t) => t.classList.remove('ascb-tab--active'));
    ascbPanels.forEach((p) => p.classList.remove('ascb-panel--active'));
    ascbTabs[index]?.classList.add('ascb-tab--active');
    ascbPanels[index]?.classList.add('ascb-panel--active');
  }

  ascbTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      ascbSwitch(i);
      clearInterval(ascbInterval);
    });
  });

  let ascbIdx = 0;
  let ascbInterval: ReturnType<typeof setInterval>;

  function startAscbRotation() {
    ascbInterval = setInterval(() => {
      ascbIdx = (ascbIdx + 1) % ascbTabs.length;
      ascbSwitch(ascbIdx);
    }, 5000);
  }

  startAscbRotation();

  const ascbBento = document.querySelector('.asc-bento-section');
  if (ascbBento) {
    ascbBento.addEventListener('mouseenter', () => clearInterval(ascbInterval));
    ascbBento.addEventListener('mouseleave', () => startAscbRotation());
  }
</script>

<style is:global>
  .asc-bento-section {
    padding: 80px 0 60px;
    background: url('https://eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .ascb {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ascb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .ascb-title b { font-weight: 700; }

  .ascb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 600px;
    margin: 0 auto 32px;
  }

  .ascb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 460px;
    gap: 4px;
  }

  .ascb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .ascb-tab--active {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .ascb-panel { display: none; }
  .ascb-panel--active {
    display: block;
    animation: ascbFadeUp 0.4s ease;
  }

  @keyframes ascbFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ascb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 16px;
  }

  .ascb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .ascb-pos-1 { grid-column: 2; grid-row: 1; }
  .ascb-pos-2 { grid-column: 3; grid-row: 1; }
  .ascb-pos-3 { grid-column: 2; grid-row: 2; }
  .ascb-pos-4 { grid-column: 3; grid-row: 2; }

  [data-layout="b"] .ascb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .ascb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .ascb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .ascb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .ascb-pos-4 { grid-column: 2; grid-row: 2; }

  [data-layout="c"] .ascb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .ascb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .ascb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .ascb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .ascb-pos-4 { grid-column: 3; grid-row: 2; }

  .ascb-card {
    background: linear-gradient(180deg, #fff 0%, #f5f8ff 100%);
    border: 1px solid rgba(55, 93, 251, 0.12);
    border-radius: 24px;
    padding: 20px;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .ascb-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(55, 93, 251, 0.08);
  }

  .ascb-card--tall {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .ascb-card__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ascb-card__inner--row {
    flex-direction: row;
    align-items: center;
    gap: 12px;
  }

  .ascb-card__inner--row .ascb-card__text { flex: 1; }

  .ascb-card__text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ascb-card__icon {
    width: 32px;
    height: 32px;
    padding: 4px;
    border-radius: 8px;
    background: rgba(55, 93, 251, 0.08);
    margin-bottom: 4px;
  }

  .ascb-card__title {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--heading-dark);
    margin: 0;
  }

  .ascb-card__desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.55;
    color: var(--subheading-gray);
    margin: 0;
  }

  .ascb-card__img {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    margin-top: 12px;
  }

  .ascb-card__img svg { width: 100%; height: auto; max-width: 200px; }

  @media (max-width: 1024px) {
    .asc-bento-section { padding: 60px 0 48px; }
    .ascb-title { font-size: 36px; }
    .ascb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .ascb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .ascb-pos-1, .ascb-pos-2, .ascb-pos-3, .ascb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .ascb-pos-0,
    [data-layout="c"] .ascb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .ascb-pos-1, [data-layout="b"] .ascb-pos-2,
    [data-layout="b"] .ascb-pos-3, [data-layout="b"] .ascb-pos-4,
    [data-layout="c"] .ascb-pos-1, [data-layout="c"] .ascb-pos-2,
    [data-layout="c"] .ascb-pos-3, [data-layout="c"] .ascb-pos-4 { grid-column: auto; grid-row: auto; }
    .ascb-card--tall { min-height: auto; }
  }

  @media (max-width: 767px) {
    .ascb-title { font-size: 28px; }
    .ascb-subtitle { font-size: 15px; }
    .ascb-nav { flex-direction: column; border-radius: 16px; max-width: 300px; }
    .ascb-tab { border-radius: 12px; }
    .ascb-grid { grid-template-columns: 1fr; }
    .ascb-pos-0, .ascb-pos-1, .ascb-pos-2, .ascb-pos-3, .ascb-pos-4,
    [data-layout="b"] .ascb-pos-0, [data-layout="b"] .ascb-pos-1,
    [data-layout="b"] .ascb-pos-2, [data-layout="b"] .ascb-pos-3,
    [data-layout="b"] .ascb-pos-4,
    [data-layout="c"] .ascb-pos-0, [data-layout="c"] .ascb-pos-1,
    [data-layout="c"] .ascb-pos-2, [data-layout="c"] .ascb-pos-3,
    [data-layout="c"] .ascb-pos-4 {
      grid-column: 1; grid-row: auto;
    }
    .ascb-card__inner--row { flex-direction: column; }
  }
</style>
