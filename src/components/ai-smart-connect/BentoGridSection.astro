---
// Tabbed Bento Grid — 3 tabs for AI Smart-Connect workflows
// Pattern from event-ticketing BentoGridSection
---

<section class="asc-bento-section" id="asc-features">
  <div class="ascb" id="ascb-bento">
    <h2 class="ascb-title">
      Smart <b>Matching</b>, Scheduling & <b>Insights</b>
    </h2>
    <p class="ascb-subtitle">
      From interest-based matching to VIP intros to post-event analytics — manage your entire networking workflow from one AI engine.
    </p>

    <nav class="ascb-nav">
      <button class="ascb-tab ascb-tab--active" data-ascb-tab="0">Matchmaking</button>
      <button class="ascb-tab" data-ascb-tab="1">Scheduling</button>
      <button class="ascb-tab" data-ascb-tab="2">Analytics</button>
    </nav>

    <!-- Tab 0: Matchmaking -->
    <div class="ascb-panel ascb-panel--active" data-ascb-panel="0">
      <div class="ascb-grid" data-layout="a">
        <div class="ascb-card ascb-card--tall ascb-pos-0">
          <div class="ascb-card__inner">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Interest-Based Matching</h3>
              <p class="ascb-card__desc">AI analyzes attendee profiles, industries, and interests to create high-relevance networking pairs.</p>
            </div>
            <div class="ascb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <circle cx="70" cy="75" r="22" fill="#375DFB" opacity=".08"/>
                <circle cx="130" cy="75" r="22" fill="#375DFB" opacity=".08"/>
                <path d="M92 75h16" stroke="#375DFB" stroke-width="2" stroke-dasharray="4 4"/>
                <circle cx="70" cy="75" r="8" fill="#375DFB" opacity=".2"/>
                <circle cx="130" cy="75" r="8" fill="#375DFB" opacity=".2"/>
                <text x="100" y="130" text-anchor="middle" font-size="11" fill="#375DFB" opacity=".6">92% match</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-1">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Profile Analysis</h3>
              <p class="ascb-card__desc">Deep analysis of attendee data, goals, and professional background for precise matching.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-2">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Purposeful Connections</h3>
              <p class="ascb-card__desc">Match attendees based on complementary goals and professional aspirations.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-3">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Real-Time Refinement</h3>
              <p class="ascb-card__desc">AI tracks interactions to continuously improve match accuracy throughout the event.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-4">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">VIP Introductions</h3>
              <p class="ascb-card__desc">Curated intros to speakers, sponsors, and high-profile guests for premium attendees.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 1: Scheduling -->
    <div class="ascb-panel" data-ascb-panel="1">
      <div class="ascb-grid" data-layout="b">
        <div class="ascb-card ascb-card--tall ascb-pos-0">
          <div class="ascb-card__inner">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Meeting Scheduler</h3>
              <p class="ascb-card__desc">AI builds personalized meeting schedules based on mutual availability and interest overlap.</p>
            </div>
            <div class="ascb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect x="35" y="45" width="130" height="14" rx="7" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="45" width="78" height="14" rx="7" fill="#375DFB" opacity=".15"/>
                <rect x="35" y="68" width="130" height="14" rx="7" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="68" width="104" height="14" rx="7" fill="#375DFB" opacity=".12"/>
                <rect x="35" y="91" width="130" height="14" rx="7" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="91" width="52" height="14" rx="7" fill="#375DFB" opacity=".18"/>
                <text x="100" y="135" text-anchor="middle" font-size="11" fill="#375DFB" opacity=".5">3 meetings booked</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-1">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Time-Bound Slots</h3>
              <p class="ascb-card__desc">Calendar-aware scheduling that respects attendee availability windows.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-2">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Industry Grouping</h3>
              <p class="ascb-card__desc">Group sessions with peers in the same sector for deeper industry conversations.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-3">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Conversation Starters</h3>
              <p class="ascb-card__desc">AI-generated prompts based on shared interests and professional backgrounds.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-4">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Live Notifications</h3>
              <p class="ascb-card__desc">Real-time alerts when matched connections are nearby during the event.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 2: Analytics -->
    <div class="ascb-panel" data-ascb-panel="2">
      <div class="ascb-grid" data-layout="c">
        <div class="ascb-card ascb-card--tall ascb-pos-0">
          <div class="ascb-card__inner">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Networking Analytics</h3>
              <p class="ascb-card__desc">Track match acceptance rates, meeting completion, and connection quality scores.</p>
            </div>
            <div class="ascb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <path d="M40 130l30-40 25 20 30-50 35 30" stroke="#375DFB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="40" cy="130" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="70" cy="90" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="95" cy="110" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="125" cy="60" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="160" cy="90" r="3" fill="#375DFB" opacity=".3"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-1">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Connection Reports</h3>
              <p class="ascb-card__desc">Exportable reports with networking outcomes, follow-ups, and engagement metrics.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-2">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Feedback Loop</h3>
              <p class="ascb-card__desc">Collect attendee feedback to improve future match recommendations continuously.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-3">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">Satisfaction Scores</h3>
              <p class="ascb-card__desc">Real-time sentiment analysis from networking sessions and meeting outcomes.</p>
            </div>
          </div>
        </div>

        <div class="ascb-card ascb-card--sm ascb-pos-4">
          <div class="ascb-card__inner ascb-card__inner--row">
            <div class="ascb-card__text">
              <svg class="ascb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="ascb-card__title">ROI Tracking</h3>
              <p class="ascb-card__desc">Measure networking value through follow-up conversion rates and partnership outcomes.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const ascbTabs = Array.from(document.querySelectorAll('[data-ascb-tab]'));
  const ascbPanels = Array.from(document.querySelectorAll('[data-ascb-panel]'));

  function ascbSwitch(index: number) {
    ascbTabs.forEach((t) => t.classList.remove('ascb-tab--active'));
    ascbPanels.forEach((p) => p.classList.remove('ascb-panel--active'));
    ascbTabs[index]?.classList.add('ascb-tab--active');
    ascbPanels[index]?.classList.add('ascb-panel--active');
  }

  ascbTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      ascbSwitch(i);
      clearInterval(ascbInterval);
    });
  });

  let ascbIdx = 0;
  let ascbInterval: ReturnType<typeof setInterval>;

  function startAscbRotation() {
    ascbInterval = setInterval(() => {
      ascbIdx = (ascbIdx + 1) % ascbTabs.length;
      ascbSwitch(ascbIdx);
    }, 5000);
  }

  startAscbRotation();

  const ascbBento = document.querySelector('.asc-bento-section');
  if (ascbBento) {
    ascbBento.addEventListener('mouseenter', () => clearInterval(ascbInterval));
    ascbBento.addEventListener('mouseleave', () => startAscbRotation());
  }
</script>

<style is:global>
  .asc-bento-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .ascb {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ascb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .ascb-title b { font-weight: 700; }

  .ascb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 600px;
    margin: 0 auto 32px;
  }

  .ascb-nav {
    display: flex;
    justify-content: center;
    gap: 0;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    width: fit-content;
    margin: 0 auto 40px;
  }

  .ascb-tab {
    background: transparent;
    border: none;
    border-radius: 50px;
    padding: 10px 32px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #4D5A6B;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(.4,0,.2,1);
    white-space: nowrap;
  }
  .ascb-tab:hover { background: rgba(55,93,251,.08); }

  .ascb-tab--active {
    background: var(--brand-blue) !important;
    color: #fff !important;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .ascb-panel { display: none; }
  .ascb-panel--active {
    display: block;
    animation: ascbFadeUp 0.4s ease;
  }

  @keyframes ascbFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ascb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    height: 460px;
  }

  .ascb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .ascb-pos-1 { grid-column: 2; grid-row: 1; }
  .ascb-pos-2 { grid-column: 3; grid-row: 1; }
  .ascb-pos-3 { grid-column: 2; grid-row: 2; }
  .ascb-pos-4 { grid-column: 3; grid-row: 2; }

  [data-layout="b"] .ascb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .ascb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .ascb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .ascb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .ascb-pos-4 { grid-column: 2; grid-row: 2; }

  [data-layout="c"] .ascb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .ascb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .ascb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .ascb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .ascb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --ascb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .ascb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0;
    animation: ascbCardIn 0.5s ease forwards;
  }
  .ascb-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: conic-gradient(from var(--ascb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .ascb-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(55, 93, 251, 0.12);
    border-color: rgba(55, 93, 251, 0.15);
  }
  .ascb-card:hover::after { opacity: 1; animation: ascbBorder 2.4s linear infinite; }
  @keyframes ascbBorder { to { --ascb-angle: 360deg; } }
  @keyframes ascbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .ascb-pos-1 { animation-delay: 0.06s; }
  .ascb-pos-2 { animation-delay: 0.12s; }
  .ascb-pos-3 { animation-delay: 0.18s; }
  .ascb-pos-4 { animation-delay: 0.24s; }

  .ascb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .ascb-card__inner--row { flex-direction: row; }

  .ascb-card__text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ascb-card--tall .ascb-card__text { padding: 20px 20px 8px; }
  .ascb-card--sm .ascb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }

  .ascb-card__icon {
    width: 32px;
    height: 32px;
