---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "How does AI Smart-Connect match attendees?", a: "AI Smart-Connect analyzes attendee profiles, industries, professional goals, and shared interests to create high-relevance networking pairs. The AI continuously refines matches in real-time as the event progresses, tracking interactions to improve accuracy." },
  { q: "Can attendees customize their networking preferences?", a: "Yes. Attendees can set their networking goals, preferred industries, and availability windows. The AI uses these preferences alongside profile data to create personalized meeting schedules and targeted introductions." },
  { q: "Does AI Smart-Connect work for virtual and hybrid events?", a: "Absolutely. AI Smart-Connect supports in-person, virtual, and hybrid event formats. For virtual events, it facilitates video meetings and chat introductions. For hybrid events, it coordinates both on-site proximity alerts and virtual connections." },
  { q: "How are VIP introductions handled?", a: "Premium attendees receive curated introductions to speakers, sponsors, and high-profile guests. The AI identifies the most relevant VIP connections based on the attendee's industry, goals, and professional background, ensuring exclusive and meaningful exchanges." },
  { q: "What analytics and reporting does AI Smart-Connect provide?", a: "Organizers get detailed reports on match acceptance rates, meeting completion, satisfaction scores, and connection quality metrics. Attendees receive their own networking summary with follow-up recommendations and contact exchange data." },
  { q: "Is there a limit on the number of attendees for AI matching?", a: "No. AI Smart-Connect scales seamlessly from intimate networking sessions to large-scale conferences with thousands of attendees. The AI engine is designed to handle high volumes while maintaining match quality and relevance." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help getting started?"
  title="Frequently Asked Questions"
  description="We help event teams set up AI networking, smart introductions, and attendee engagement flows tailored to their event goals."
/>
