---
// FAQ Section — Light theme with split layout, SEO JSON-LD structured data
// Pattern from event-ticketing FaqLightSection

const faqItems = [
  {
    question: "How does AI Smart-Connect match attendees?",
    answerHtml: "<p>AI Smart-Connect analyzes attendee profiles, industries, professional goals, and shared interests to create high-relevance networking pairs. The AI continuously refines matches in real-time as the event progresses, tracking interactions to improve accuracy.</p>",
  },
  {
    question: "Can attendees customize their networking preferences?",
    answerHtml: "<p>Yes. Attendees can set their networking goals, preferred industries, and availability windows. The AI uses these preferences alongside profile data to create personalized meeting schedules and targeted introductions.</p>",
  },
  {
    question: "Does AI Smart-Connect work for virtual and hybrid events?",
    answerHtml: "<p>Absolutely. AI Smart-Connect supports in-person, virtual, and hybrid event formats. For virtual events, it facilitates video meetings and chat introductions. For hybrid events, it coordinates both on-site proximity alerts and virtual connections.</p>",
  },
  {
    question: "How are VIP introductions handled?",
    answerHtml: "<p>Premium attendees receive curated introductions to speakers, sponsors, and high-profile guests. The AI identifies the most relevant VIP connections based on the attendee's industry, goals, and professional background, ensuring exclusive and meaningful exchanges.</p>",
  },
  {
    question: "What analytics and reporting does AI Smart-Connect provide?",
    answerHtml: "<p>Organizers get detailed reports on match acceptance rates, meeting completion, satisfaction scores, and connection quality metrics. Attendees receive their own networking summary with follow-up recommendations and contact exchange data.</p>",
  },
  {
    question: "Is there a limit on the number of attendees for AI matching?",
    answerHtml: "<p>No. AI Smart-Connect scales seamlessly from intimate networking sessions to large-scale conferences with thousands of attendees. The AI engine is designed to handle high volumes while maintaining match quality and relevance.</p>",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answerHtml.replace(/<[^>]*>/g, '')
    }
  }))
};
---

<section class="ascfaq" id="asc-faq-section">
  <div class="ascfaq__inner">
    <div class="ascfaq__support">
      <span class="ascfaq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need help getting started?</span>
      <h2 class="ascfaq__title animate-on-scroll" data-animation="fadeInUp">Frequently Asked Questions</h2>
      <p class="ascfaq__desc animate-on-scroll" data-animation="fadeInUp">
        Everything you need to know about AI Smart-Connect and how it transforms networking at your events.
      </p>

      <div class="ascfaq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="ascfaq__support-label">Getting started</span>
        <ul class="ascfaq__support-list">
          <li class="ascfaq__support-item">Set up attendee profile collection</li>
          <li class="ascfaq__support-item">Configure matching preferences</li>
          <li class="ascfaq__support-item">Enable real-time networking alerts</li>
        </ul>

        <div class="ascfaq__support-note">
          <strong>Free onboarding support</strong>
          <span>Our team helps you configure AI matching before your event launches.</span>
        </div>

        <a href="/book-a-demo/" class="ascfaq__cta">Set up my event networking</a>
      </div>
    </div>

    <div class="ascfaq__list">
      {faqItems.map((item, index) => (
        <details class="ascfaq__item animate-on-scroll" data-animation="fadeInUp" data-ascfaq-item open={index === 0}>
          <summary class="ascfaq__question">
            <span>{item.question}</span>
            <span class="ascfaq__icon" aria-hidden="true">
              <span class="ascfaq__icon-line ascfaq__icon-line--h"></span>
              <span class="ascfaq__icon-line ascfaq__icon-line--v"></span>
            </span>
          </summary>
          <div class="ascfaq__answer" set:html={item.answerHtml}></div>
        </details>
      ))}
    </div>
  </div>
</section>

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(faqSchema)}</script>`} />

<script>
  const ascfaqItems = Array.from(document.querySelectorAll('[data-ascfaq-item]'));

  ascfaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) return;

      ascfaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .ascfaq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .ascfaq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .ascfaq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .ascfaq__eyebrow {
    display: inline-flex;
    align-items: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .ascfaq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .ascfaq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .ascfaq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .ascfaq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .ascfaq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ascfaq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .ascfaq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .ascfaq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .ascfaq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .ascfaq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .ascfaq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .ascfaq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .ascfaq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ascfaq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .ascfaq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
    transition: color 0.2s ease;
  }

  .ascfaq__question::-webkit-details-marker { display: none; }
  .ascfaq__question::marker { display: none; content: ""; }

  .ascfaq__question:hover { color: #375dfb; }

  .ascfaq__icon {
    position: relative;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    margin-top: 3px;
    color: #375dfb;
  }

  .ascfaq__icon-line {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 999px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .ascfaq__icon-line--h { width: 20px; height: 2px; }
  .ascfaq__icon-line--v { width: 2px; height: 20px; }

  .ascfaq__answer {
    padding: 0 24px 24px;
  }

  .ascfaq__answer :global(p) {
    margin: 0;
    max-width: 92%;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.8;
    color: #5b6477;
  }

  .ascfaq__item[open] {
    background: #fff;
    border-color: rgba(55, 93, 251, 0.2);
    box-shadow: 0 2px 16px rgba(55, 93, 251, 0.06);
  }

  .ascfaq__item[open] .ascfaq__icon-line--v {
    opacity: 0;
    transform: translate(-50%, -50%) scaleY(0.35);
  }

  @media (max-width: 1100px) {
    .ascfaq { padding: 76px 0; }
    .ascfaq__inner { grid-template-columns: 1fr; gap: 28px; }
    .ascfaq__support { position: static; }
  }

  @media (max-width: 1024px) {
    .ascfaq__title { font-size: 40px; }
    .ascfaq__desc { font-size: 16px; }
    .ascfaq__question { padding: 24px 22px; font-size: 20px; }
    .ascfaq__answer { padding: 0 22px 22px; }
  }

  @media (max-width: 767px) {
    .ascfaq { padding: 56px 0; }
    .ascfaq__inner { padding: 0 16px; gap: 24px; }
    .ascfaq__title { font-size: 32px; line-height: 1.08; }
    .ascfaq__desc { font-size: 15px; line-height: 1.7; }
    .ascfaq__support-card { padding: 20px 18px; border-radius: 24px; }
    .ascfaq__support-item { font-size: 15px; }
    .ascfaq__support-note strong { font-size: 18px; }
    .ascfaq__cta { width: 100%; }
    .ascfaq__item { border-radius: 24px; }
    .ascfaq__question { padding: 20px 18px; font-size: 17px; line-height: 1.45; }
    .ascfaq__answer { padding: 0 18px 20px; }
    .ascfaq__answer :global(p) { max-width: 100%; font-size: 15px; line-height: 1.75; }
  }
</style>
