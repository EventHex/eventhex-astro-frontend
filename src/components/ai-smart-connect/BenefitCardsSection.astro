---
// Benefits Section — centered 3-col glassmorphism cards on dark bg
// Pattern from event-ticketing BenefitCardsSection
---

<section class="ascbn-section">
  <div class="ascbn-inner">
    <div class="ascbn-header">
      <span class="ascbn-tag animate-on-scroll" data-animation="fadeIn">Why EventHex</span>
      <h2 class="ascbn-title animate-on-scroll" data-animation="fadeInUp">Why Choose EventHex's AI Networking App?</h2>
      <p class="ascbn-desc animate-on-scroll" data-animation="fadeInUp">
        AI-powered matchmaking, personalized networking, and real-time insights — everything you need for meaningful event connections.
      </p>
    </div>

    <div class="ascbn-grid">
      <div class="ascbn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="ascbn-card__icon">
          <img src="https://eventhex.ai/wp-content/uploads/2025/03/Frame-1000002870.svg" alt="" width="48" height="48" loading="lazy" />
        </div>
        <h3 class="ascbn-card__title">Effortless Connections</h3>
        <p class="ascbn-card__desc">Connects attendees with the right people automatically and with time efficiency. No more random exchanges — just targeted, meaningful introductions.</p>
      </div>

      <div class="ascbn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="ascbn-card__icon">
          <img src="https://eventhex.ai/wp-content/uploads/2025/03/Frame-1000002870-1.svg" alt="" width="48" height="48" loading="lazy" />
        </div>
        <h3 class="ascbn-card__title">Personalized Experiences</h3>
        <p class="ascbn-card__desc">Tailors exclusive networking opportunities to attendees' professional goals and interests. Every recommendation is unique to each participant.</p>
      </div>

      <div class="ascbn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="ascbn-card__icon">
          <img src="https://eventhex.ai/wp-content/uploads/2025/03/Frame-1000002870-2.svg" alt="" width="48" height="48" loading="lazy" />
        </div>
        <h3 class="ascbn-card__title">Industry-Leading Technology</h3>
        <p class="ascbn-card__desc">Stay ahead of everyone with cutting-edge AI technology that revolutionizes networking. Real-time refinement ensures continuously improving match quality.</p>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .ascbn-section {
    width: 100%;
    margin: 0;
    padding: 80px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .ascbn-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .ascbn-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .ascbn-tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ascbn-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .ascbn-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .ascbn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .ascbn-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .ascbn-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .ascbn-card__icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.12);
    border-radius: 14px;
  }

  .ascbn-card__icon img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .ascbn-card__title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .ascbn-card__desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .ascbn-section { padding: 64px 0; }
    .ascbn-title { font-size: 36px; }
    .ascbn-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 767px) {
    .ascbn-section { padding: 52px 0; }
    .ascbn-title { font-size: 30px; line-height: 1.15; }
    .ascbn-desc { font-size: 15px; }
    .ascbn-grid { grid-template-columns: 1fr; }
  }
</style>
