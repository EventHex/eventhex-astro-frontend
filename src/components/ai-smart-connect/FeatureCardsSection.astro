---
// Stacking Cards section — matches event-ticketing FeatureCards pattern
// Dark bg with bg-2.webp, sticky stacking cards for key AI Smart-Connect features
// Content sourced from existing feature sections

const featureCards = [
  {
    title: "Intelligent Matchmaking Based on Shared Interests",
    desc: "AI analyzes shared interests, industries, and profile characteristics to create data-driven attendee matches. Purposeful connections are made based on professional goals, with real-time refinement as the event progresses.",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Group-1000002648.svg",
    alt: "EventHex AI matchmaking based on shared interests visualization",
  },
  {
    title: "Personalized Networking Opportunities",
    desc: "Create time-bound meeting schedules based on mutual availability. Industry-specific grouping aligns attendees with peers in their sector, while premium attendees enjoy exclusive VIP connections with speakers and high-profile guests.",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/iPhone-15.svg",
    alt: "EventHex personalized networking app on smartphone",
  },
  {
    title: "Enhanced Conversation Experience",
    desc: "AI-generated conversation prompts based on shared interests and backgrounds break the ice effortlessly. Dynamic grouping creates opportunities for panel connections and collaborations, with a feedback loop that improves future recommendations.",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/iPhone-15-Pro.svg",
    alt: "EventHex AI conversation starter and dynamic grouping interface",
  },
];
---

<section class="ascf-shell">
  <div class="ascf-section">
    <div class="ascf-header">
      <span class="ascf-subtitle animate-on-scroll" data-animation="fadeInUp">Feature-by-feature</span>
      <h2 class="ascf-title animate-on-scroll" data-animation="fadeInUp">
        AI-Powered Networking in <span class="ascf-highlight">Every Interaction</span>
      </h2>
    </div>

    <div class="ascf-cards" id="ascf-stacking-cards">
      {featureCards.map((card, i) => (
        <div
          class="ascf-card"
          data-card-index={i}
          style={`--card-index: ${i}; top: calc(20px + ${i * 20}px);`}
        >
          <div class="ascf-card-content">
            <h3 class="ascf-card-title">{card.title}</h3>
            <p class="ascf-card-desc">{card.desc}</p>
            <a href="/book-a-demo/" class="ascf-card-btn">Explore More</a>
          </div>
          <div class="ascf-card-image">
            <img src={card.image} alt={card.alt} loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .ascf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .ascf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .ascf-header {
    width: 70%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .ascf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .ascf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .ascf-highlight { color: #AFA3FF; }

  .ascf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .ascf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.8));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .ascf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .ascf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .ascf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .ascf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .ascf-card-btn:hover { transform: scale(1.05); }

  .ascf-card-image {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow: hidden;
  }

  .ascf-card-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .ascf-section { padding: 60px 20px 30px; }
    .ascf-header { width: 80%; }
    .ascf-subtitle { font-size: 16px; }
    .ascf-title { font-size: 40px; line-height: 1em; }
    .ascf-card { height: 450px; }
    .ascf-card-content { flex-basis: 50%; }
    .ascf-card-title { font-size: 28px; }
    .ascf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .ascf-section { padding: 50px 20px 30px; }
    .ascf-header { width: 100%; }
    .ascf-title { font-size: 30px; }
    .ascf-card { flex-direction: column; height: 520px; }
    .ascf-card-content { flex: 0 0 50%; padding: 20px 20px 0; }
    .ascf-card-image { padding: 10px; }
    .ascf-card-title { font-size: 24px; }
    .ascf-card-desc { font-size: 15px; }
    .ascf-cards { padding-bottom: 40px; }
  }
</style>
