---
const tabs = [
  {
    label: "Page Builder",
    hero: {
      eyebrow: "Visual Editor",
      title: "Drag-and-drop page builder with pre-built event sections for every need",
      desc: "Our visual builder gives you agenda, speakers, registration, sponsors, venue sections — ready to customize with your brand and content.",
      points: ["Intuitive drag & drop", "Pre-built event sections", "Real-time preview"],
      visual: "editor",
    },
    cards: [
      {
        eyebrow: "Templates",
        title: "40+ Event Templates",
        desc: "Conference, workshop, gala, expo, and hybrid event templates ready to customize.",
        visual: "templates",
      },
      {
        eyebrow: "Domains",
        title: "Custom Domains",
        desc: "Publish on your own domain or use eventhex.com subdomains with SSL.",
        visual: "domains",
      },
      {
        eyebrow: "Responsive",
        title: "Mobile-First Design",
        desc: "Every page looks perfect on desktop, tablet, and mobile automatically.",
        visual: "responsive",
      },
      {
        eyebrow: "Preview",
        title: "Live Preview",
        desc: "See changes in real-time before publishing to your event audience.",
        visual: "preview",
      },
    ],
  },
  {
    label: "Event Sections",
    hero: {
      eyebrow: "Content Blocks",
      title: "Pre-built sections for agenda, speakers, sponsors, and registration",
      desc: "Add rich content sections with a click — multi-track agendas, speaker profiles, tiered sponsors, and embedded ticket purchase.",
      points: ["Multi-track agendas", "Speaker profile cards", "Inline registration"],
      visual: "sections",
    },
    cards: [
      {
        eyebrow: "Agenda",
        title: "Multi-Track Agenda",
        desc: "Session timelines with speaker details, room assignments, and track filtering.",
        visual: "agenda",
      },
      {
        eyebrow: "Speakers",
        title: "Speaker Profiles",
        desc: "Rich speaker cards with bios, photos, social links, and session assignments.",
        visual: "speakers",
      },
      {
        eyebrow: "Sponsors",
        title: "Sponsor Showcase",
        desc: "Tiered sponsor sections with logos, descriptions, and promotional CTAs.",
        visual: "sponsors",
      },
      {
        eyebrow: "Venue",
        title: "Venue & Maps",
        desc: "Interactive venue details with Google Maps integration and directions.",
        visual: "venue",
      },
    ],
  },
  {
    label: "SEO & Analytics",
    hero: {
      eyebrow: "Search Optimization",
      title: "Auto-optimized for search engines with structured data and analytics",
      desc: "Every page auto-generates meta tags, Open Graph, and structured data — with built-in Google Analytics and UTM tracking.",
      points: ["Auto meta tags", "GA4 integration", "Core Web Vitals optimized"],
      visual: "seo",
    },
    cards: [
      {
        eyebrow: "Tracking",
        title: "Google Analytics",
        desc: "Built-in GA4 and Facebook Pixel tracking for registration attribution.",
        visual: "analytics",
      },
      {
        eyebrow: "Campaigns",
        title: "UTM Tracking",
        desc: "Automatic UTM parameter handling to track registration sources.",
        visual: "utm",
      },
      {
        eyebrow: "Speed",
        title: "Performance Score",
        desc: "Optimized for Core Web Vitals — fast loading and smooth experience.",
        visual: "perf",
      },
      {
        eyebrow: "Social",
        title: "Social Previews",
        desc: "Customizable Open Graph images for link sharing on social platforms.",
        visual: "social",
      },
    ],
  },
];
---

<section class="ewbb-section" id="ewb-bento">
  <div class="ewbb-shell">
    <h2 class="ewbb-title">
      Drag & Drop <b>Website Builder</b>, Event <b>Sections</b> & SEO <b>Tools</b>
    </h2>
    <p class="ewbb-subtitle">
      Build, customize, and optimize event websites with templates, registration widgets, and built-in SEO tools.
    </p>

    <nav class="ewbb-nav" aria-label="Website builder workflows">
      {tabs.map((tab, index) => (
        <button
          class={`ewbb-tab${index === 0 ? " ewbb-tab--active" : ""}`}
          data-ewbb-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`ewbb-panel${tabIndex === 0 ? " ewbb-panel--active" : ""}`}
        data-ewbb-panel={tabIndex}
      >
        <div class="ewbb-grid">
          <article class="ewbb-card ewbb-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="ewbb-card__content">
              <span class="ewbb-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="ewbb-card__title">{tab.hero.title}</h3>
              <p class="ewbb-card__desc">{tab.hero.desc}</p>

              <ul class="ewbb-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`ewbb-art ewbb-art--hero ewbb-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "editor" && (
                <Fragment>
                  <div class="ewbb-canvas">
                    <div class="ewbb-canvas__toolbar">
                      <span></span><span></span><span></span>
                    </div>
                    <div class="ewbb-canvas__sections">
                      <div class="ewbb-canvas__block ewbb-canvas__block--header"></div>
                      <div class="ewbb-canvas__block ewbb-canvas__block--body"></div>
                      <div class="ewbb-canvas__block ewbb-canvas__block--footer"></div>
                    </div>
                  </div>
                  <div class="ewbb-drag-handle">
                    <span></span><span></span><span></span>
                  </div>
                  <div class="ewbb-mini-chip">Drag & Drop</div>
                </Fragment>
              )}

              {tab.hero.visual === "sections" && (
                <Fragment>
                  <div class="ewbb-section-stack">
                    <div class="ewbb-section-block ewbb-section-block--agenda">
                      <div class="ewbb-section-block__bar"></div>
                      <div class="ewbb-section-block__rows"><span></span><span></span><span></span></div>
                    </div>
                    <div class="ewbb-section-block ewbb-section-block--speakers">
                      <div class="ewbb-section-block__bar"></div>
                      <div class="ewbb-section-block__avatars"><span></span><span></span><span></span></div>
                    </div>
                    <div class="ewbb-section-block ewbb-section-block--sponsors">
                      <div class="ewbb-section-block__bar"></div>
                      <div class="ewbb-section-block__logos"><span></span><span></span></div>
                    </div>
                  </div>
                  <div class="ewbb-mini-chip">Content Blocks</div>
                </Fragment>
              )}

              {tab.hero.visual === "seo" && (
                <Fragment>
                  <div class="ewbb-search-result">
                    <div class="ewbb-search-result__url"></div>
                    <div class="ewbb-search-result__title"></div>
                    <div class="ewbb-search-result__desc"><span></span><span></span></div>
                    <div class="ewbb-search-result__tags">
                      <span>meta</span><span>OG</span><span>JSON-LD</span>
                    </div>
                  </div>
                  <div class="ewbb-ga-chip">
                    <strong>GA4</strong>
                    <span>connected</span>
                  </div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="ewbb-card ewbb-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="ewbb-card__content">
                <span class="ewbb-card__eyebrow">{card.eyebrow}</span>
                <h3 class="ewbb-card__title">{card.title}</h3>
                <p class="ewbb-card__desc">{card.desc}</p>
              </div>

              <div class={`ewbb-art ewbb-art--mini ewbb-art--${card.visual}`} aria-hidden="true">
                {card.visual === "templates" && (
                  <Fragment>
                    <div class="ewbb-template-grid">
                      <span></span><span></span><span></span><span></span>
                    </div>
                    <div class="ewbb-mini-chip">40+ templates</div>
                  </Fragment>
                )}

                {card.visual === "domains" && (
                  <Fragment>
                    <div class="ewbb-address-bar">
                      <span class="ewbb-address-bar__lock"></span>
                      <span class="ewbb-address-bar__url"></span>
                    </div>
                    <div class="ewbb-mini-chip">SSL included</div>
                  </Fragment>
                )}

                {card.visual === "responsive" && (
                  <Fragment>
                    <div class="ewbb-devices">
                      <div class="ewbb-device ewbb-device--desktop"></div>
                      <div class="ewbb-device ewbb-device--mobile"></div>
                    </div>
                    <div class="ewbb-mini-chip">Auto-responsive</div>
                  </Fragment>
                )}

                {card.visual === "preview" && (
                  <Fragment>
                    <div class="ewbb-split-pane">
                      <div class="ewbb-split-pane__editor">
                        <span></span><span></span><span></span>
                      </div>
                      <div class="ewbb-split-pane__preview">
                        <span></span><span></span>
                      </div>
                    </div>
                    <div class="ewbb-mini-chip">Live preview</div>
                  </Fragment>
                )}

                {card.visual === "agenda" && (
                  <Fragment>
                    <div class="ewbb-track-timeline">
                      <div class="ewbb-track"><span></span><span></span><span></span></div>
                      <div class="ewbb-track"><span></span><span></span></div>
                      <div class="ewbb-track"><span></span><span></span><span></span></div>
                    </div>
                    <div class="ewbb-mini-chip">3 tracks</div>
                  </Fragment>
                )}

                {card.visual === "speakers" && (
                  <Fragment>
                    <div class="ewbb-avatar-cards">
                      <div class="ewbb-avatar-card"><span class="ewbb-avatar-circle"></span><span class="ewbb-avatar-name"></span></div>
                      <div class="ewbb-avatar-card"><span class="ewbb-avatar-circle"></span><span class="ewbb-avatar-name"></span></div>
                      <div class="ewbb-avatar-card"><span class="ewbb-avatar-circle"></span><span class="ewbb-avatar-name"></span></div>
                    </div>
                    <div class="ewbb-mini-chip">Speaker cards</div>
                  </Fragment>
                )}

                {card.visual === "sponsors" && (
                  <Fragment>
                    <div class="ewbb-tier-logos">
                      <div class="ewbb-tier ewbb-tier--gold"><span></span></div>
                      <div class="ewbb-tier ewbb-tier--silver"><span></span><span></span></div>
                      <div class="ewbb-tier ewbb-tier--bronze"><span></span><span></span><span></span></div>
                    </div>
                    <div class="ewbb-mini-chip">Tiered sponsors</div>
                  </Fragment>
                )}

                {card.visual === "venue" && (
                  <Fragment>
                    <div class="ewbb-map-card">
                      <div class="ewbb-map-pin"></div>
                      <div class="ewbb-map-label"><span></span><span></span></div>
                    </div>
                    <div class="ewbb-mini-chip">Maps integrated</div>
                  </Fragment>
                )}

                {card.visual === "analytics" && (
                  <Fragment>
                    <div class="ewbb-bar-chart">
                      <span style="--h:55%"></span>
                      <span style="--h:80%"></span>
                      <span style="--h:40%"></span>
                      <span style="--h:90%"></span>
                      <span style="--h:65%"></span>
                    </div>
                    <div class="ewbb-mini-chip">GA4 tracking</div>
                  </Fragment>
                )}

                {card.visual === "utm" && (
                  <Fragment>
                    <div class="ewbb-link-chain">
                      <div class="ewbb-link-segment"></div>
                      <div class="ewbb-link-tag">utm_source</div>
                      <div class="ewbb-link-segment"></div>
                      <div class="ewbb-link-tag">utm_medium</div>
                    </div>
                    <div class="ewbb-mini-chip">Auto UTM</div>
                  </Fragment>
                )}

                {card.visual === "perf" && (
                  <Fragment>
                    <div class="ewbb-gauge">
                      <div class="ewbb-gauge__track"></div>
                      <div class="ewbb-gauge__needle"></div>
                      <div class="ewbb-gauge__value">98</div>
                    </div>
                    <div class="ewbb-mini-chip">Core Web Vitals</div>
                  </Fragment>
                )}

                {card.visual === "social" && (
                  <Fragment>
                    <div class="ewbb-og-card">
                      <div class="ewbb-og-card__image"></div>
                      <div class="ewbb-og-card__text">
                        <span></span><span></span>
                      </div>
                    </div>
                    <div class="ewbb-mini-chip">OG preview</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".ewbb-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".ewbb-tab"));
      const panels = Array.from(root.querySelectorAll(".ewbb-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("ewbb-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("ewbb-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .ewbb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .ewbb-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ewbb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .ewbb-title b { font-weight: 700; }

  .ewbb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .ewbb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .ewbb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .ewbb-tab:hover,
  .ewbb-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .ewbb-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .ewbb-panel { display: none; }
  .ewbb-panel--active { display: block; }

  .ewbb-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .ewbb-panel--active .ewbb-card {
    animation: ewbb-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  .ewbb-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .ewbb-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .ewbb-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .ewbb-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .ewbb-card--mini:nth-of-type(2) { grid-area: mini1; }
  .ewbb-card--mini:nth-of-type(3) { grid-area: mini2; }
  .ewbb-card--mini:nth-of-type(4) { grid-area: mini3; }
  .ewbb-card--mini:nth-of-type(5) { grid-area: mini4; }

  .ewbb-card__content { position: relative; z-index: 1; }

  .ewbb-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ewbb-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .ewbb-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .ewbb-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .ewbb-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .ewbb-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .ewbb-art { position: relative; z-index: 1; min-height: 146px; }
  .ewbb-art--hero { min-height: 228px; margin-top: 0.6rem; }
  .ewbb-art--mini { align-self: end; }

  /* === Hero visual: Editor === */
  .ewbb-canvas {
    position: absolute;
    inset: 0 8% auto 0;
    height: 88%;
    padding: 0.8rem;
    border-radius: 1.3rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 22px 46px -36px rgba(17, 28, 56, 0.52);
    animation: ewbb-float 5.2s ease-in-out infinite;
  }

  .ewbb-canvas__toolbar {
    display: flex;
    gap: 0.3rem;
    margin-bottom: 0.6rem;
  }

  .ewbb-canvas__toolbar span {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
  }

  .ewbb-canvas__toolbar span:nth-child(1) { background: #ef4444; }
  .ewbb-canvas__toolbar span:nth-child(2) { background: #f59e0b; }
  .ewbb-canvas__toolbar span:nth-child(3) { background: #22c55e; }

  .ewbb-canvas__sections {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ewbb-canvas__block {
    border-radius: 0.6rem;
    border: 1px dashed rgba(55, 93, 251, 0.18);
  }

  .ewbb-canvas__block--header {
    height: 1.8rem;
    background: linear-gradient(90deg, rgba(55, 93, 251, 0.12), rgba(56, 189, 248, 0.08));
  }

  .ewbb-canvas__block--body {
    height: 3.5rem;
    background: rgba(55, 93, 251, 0.04);
  }

  .ewbb-canvas__block--footer {
    height: 1.4rem;
    background: rgba(55, 93, 251, 0.06);
  }

  .ewbb-drag-handle {
    position: absolute;
    right: 0;
    top: 30%;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 12px 24px -12px rgba(17, 28, 56, 0.35);
    animation: ewbb-float 4s ease-in-out infinite;
    animation-delay: -1s;
  }

  .ewbb-drag-handle span {
    width: 1.4rem;
    height: 0.2rem;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.3);
  }

  /* === Hero visual: Sections === */
  .ewbb-section-stack {
    position: absolute;
    inset: 0 10% auto 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ewbb-section-block {
    padding: 0.7rem;
    border-radius: 1rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    animation: ewbb-float 5s ease-in-out infinite;
  }

  .ewbb-section-block--speakers { animation-delay: -0.6s; }
  .ewbb-section-block--sponsors { animation-delay: -1.2s; }

  .ewbb-section-block__bar {
    height: 0.4rem;
    width: 35%;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
    margin-bottom: 0.4rem;
  }

  .ewbb-section-block__rows { display: flex; flex-direction: column; gap: 0.25rem; }
  .ewbb-section-block__rows span { display: block; height: 0.3rem; border-radius: 999px; background: rgba(55, 93, 251, 0.08); }
  .ewbb-section-block__rows span:nth-child(1) { width: 90%; }
  .ewbb-section-block__rows span:nth-child(2) { width: 70%; }
  .ewbb-section-block__rows span:nth-child(3) { width: 55%; }

  .ewbb-section-block__avatars { display: flex; gap: 0.3rem; }
  .ewbb-section-block__avatars span {
    width: 1.4rem; height: 1.4rem; border-radius: 50%;
    background: linear-gradient(180deg, rgba(55, 93, 251, 0.3), rgba(34, 197, 94, 0.2));
  }

  .ewbb-section-block__logos { display: flex; gap: 0.4rem; }
  .ewbb-section-block__logos span {
    width: 2.2rem; height: 1rem; border-radius: 0.4rem;
    background: rgba(55, 93, 251, 0.1);
  }

  /* === Hero visual: SEO === */
  .ewbb-search-result {
    position: absolute;
    inset: 0 0 2.4rem 0;
    padding: 1rem;
    border-radius: 1.3rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .ewbb-search-result__url {
    height: 0.3rem;
    width: 45%;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.3);
  }

  .ewbb-search-result__title {
    height: 0.5rem;
    width: 70%;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
  }

  .ewbb-search-result__desc { display: flex; flex-direction: column; gap: 0.25rem; }
  .ewbb-search-result__desc span { display: block; height: 0.3rem; border-radius: 999px; background: rgba(55, 93, 251, 0.08); }
  .ewbb-search-result__desc span:first-child { width: 95%; }
  .ewbb-search-result__desc span:last-child { width: 70%; }

  .ewbb-search-result__tags {
    display: flex;
    gap: 0.3rem;
    margin-top: 0.3rem;
