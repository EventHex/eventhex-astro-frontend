---
import { ewbbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Page Builder",
    hero: {
      title: "Drag-and-drop page builder with pre-built event sections for every need",
      desc: "Our visual builder gives you agenda, speakers, registration, sponsors, venue sections — ready to customize with your brand and content.",
      visual: "editor",
    },
    cards: [
      { title: "40+ Event Templates", desc: "Conference, workshop, gala, expo, and hybrid event templates ready to customize.", visual: "templates" },
      { title: "Custom Domains", desc: "Publish on your own domain or use eventhex.com subdomains with SSL.", visual: "domains" },
      { title: "Mobile-First Design", desc: "Every page looks perfect on desktop, tablet, and mobile automatically.", visual: "responsive" },
      { title: "Live Preview", desc: "See changes in real-time before publishing to your event audience.", visual: "preview" },
      { title: "AI Website Generation", desc: "Describe your event and AI generates a complete site — agenda, speakers, registration, and branding — from a single prompt.", visual: "editor" },
    ],
  },
  {
    label: "Event Sections",
    hero: {
      title: "Pre-built sections for agenda, speakers, sponsors, and registration",
      desc: "Add rich content sections with a click — multi-track agendas, speaker profiles, tiered sponsors, and embedded ticket purchase.",
      visual: "sections",
    },
    cards: [
      { title: "Multi-Track Agenda", desc: "Session timelines with speaker details, room assignments, and track filtering.", visual: "agenda" },
      { title: "Speaker Profiles", desc: "Rich speaker cards with bios, photos, social links, and session assignments.", visual: "speakers" },
      { title: "Sponsor Showcase", desc: "Tiered sponsor sections with logos, descriptions, and promotional CTAs.", visual: "sponsors" },
      { title: "Venue & Maps", desc: "Interactive venue details with Google Maps integration and directions.", visual: "venue" },
    ],
  },
  {
    label: "SEO & Analytics",
    hero: {
      title: "Auto-optimized for search engines with structured data and analytics",
      desc: "Every page auto-generates meta tags, Open Graph, and structured data — with built-in Google Analytics and UTM tracking.",
      visual: "seo",
    },
    cards: [
      { title: "Google Analytics", desc: "Built-in GA4 and Facebook Pixel tracking for registration attribution.", visual: "analytics" },
      { title: "UTM Tracking", desc: "Automatic UTM parameter handling to track registration sources.", visual: "utm" },
      { title: "Performance Score", desc: "Optimized for Core Web Vitals — fast loading and smooth experience.", visual: "perf" },
      { title: "Social Previews", desc: "Customizable Open Graph images for link sharing on social platforms.", visual: "social" },
    ],
  },
];

const ICON = '<svg class="ewbb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="ewbb-section" id="ewb-bento">
  <div class="ewbb">
    <h2 class="ewbb-title">
      Drag & Drop <b>Website Builder</b>, Event <b>Sections</b> & SEO <b>Tools</b>
    </h2>
    <p class="ewbb-subtitle">
      Build, customize, and optimize event websites with templates, registration widgets, and built-in SEO tools.
    </p>

    <nav class="ewbb-nav">
      {tabs.map((t, i) => (
        <button class={`ewbb-tab ${i === 0 ? "ewbb-tab--active" : ""}`} data-ewbb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`ewbb-panel ${tabIdx === 0 ? "ewbb-panel--active" : ""}`} data-ewbb-panel={String(tabIdx)}>
        <div class="ewbb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="ewbb-card ewbb-card--tall ewbb-pos-0" style="animation-delay:0s">
            <div class="ewbb-card__inner">
              <div class="ewbb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="ewbb-card__title">{t.hero.title}</h3>
                <p class="ewbb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="ewbb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`ewbb-card ewbb-card--sm ewbb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="ewbb-card__inner ewbb-card__inner--row">
                <div class="ewbb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="ewbb-card__title">{c.title}</h3>
                  <p class="ewbb-card__desc">{c.desc}</p>
                </div>
                <div class="ewbb-card__img ewbb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const ewbbTabs = Array.from(document.querySelectorAll('[data-ewbb-tab]'));
  const ewbbPanels = Array.from(document.querySelectorAll('[data-ewbb-panel]'));
  let ewbbActive = 0;
  let ewbbInterval: ReturnType<typeof setInterval>;

  function setEwbbTab(index: number) {
    ewbbTabs.forEach((t) => t.classList.remove('ewbb-tab--active'));
    ewbbPanels.forEach((p) => p.classList.remove('ewbb-panel--active'));
    ewbbTabs[index]?.classList.add('ewbb-tab--active');
    ewbbPanels[index]?.classList.add('ewbb-panel--active');
    ewbbActive = index;
  }
  function startEwbb() {
    ewbbInterval = setInterval(() => setEwbbTab((ewbbActive + 1) % ewbbTabs.length), 5000);
  }
  ewbbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setEwbbTab(i); clearInterval(ewbbInterval); startEwbb(); }));
  startEwbb();
  const ewbbSection = document.querySelector('.ewbb-section');
  if (ewbbSection) {
    ewbbSection.addEventListener('mouseenter', () => clearInterval(ewbbInterval));
    ewbbSection.addEventListener('mouseleave', () => startEwbb());
  }
</script>

<style>
  .ewbb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .ewbb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .ewbb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .ewbb-title b { font-weight: 700; }
  .ewbb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .ewbb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .ewbb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .ewbb-tab:hover { background: rgba(55,93,251,.08); }
  .ewbb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .ewbb-panel { display: none; }
  .ewbb-panel--active { display: block; animation: ewbbFadeUp 0.4s ease; }
  @keyframes ewbbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .ewbb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .ewbb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .ewbb-pos-1 { grid-column: 2; grid-row: 1; }
  .ewbb-pos-2 { grid-column: 3; grid-row: 1; }
  .ewbb-pos-3 { grid-column: 2; grid-row: 2; }
  .ewbb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .ewbb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .ewbb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .ewbb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .ewbb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .ewbb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .ewbb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .ewbb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .ewbb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .ewbb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .ewbb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --ewbb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .ewbb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: ewbbCardIn 0.5s ease forwards;
  }
  .ewbb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--ewbb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .ewbb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .ewbb-card:hover::after { opacity: 1; animation: ewbbBorder 2.4s linear infinite; }
  @keyframes ewbbBorder { to { --ewbb-angle: 360deg; } }
  @keyframes ewbbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .ewbb-pos-1 { animation-delay: 0.06s; }
  .ewbb-pos-2 { animation-delay: 0.12s; }
  .ewbb-pos-3 { animation-delay: 0.18s; }
  .ewbb-pos-4 { animation-delay: 0.24s; }

  .ewbb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .ewbb-card__inner--row { flex-direction: row; }
  .ewbb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .ewbb-card--tall .ewbb-card__text { padding: 20px 20px 8px; }
  .ewbb-card--sm .ewbb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .ewbb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .ewbb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .ewbb-card--sm .ewbb-card__title { font-size: 17px; }
  .ewbb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .ewbb-card--sm .ewbb-card__desc { font-size: 13px; }

  .ewbb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .ewbb-card--tall .ewbb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .ewbb-card--sm .ewbb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .ewbb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .ewbb-card:hover .ewbb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: ewbbFloat 2.2s ease-in-out infinite;
  }
  @keyframes ewbbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .ewbb-section { padding: 60px 0 48px; }
    .ewbb-title { font-size: 36px; }
    .ewbb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .ewbb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .ewbb-pos-1, .ewbb-pos-2, .ewbb-pos-3, .ewbb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .ewbb-pos-0, [data-layout="c"] .ewbb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .ewbb-pos-1, [data-layout="b"] .ewbb-pos-2, [data-layout="b"] .ewbb-pos-3, [data-layout="b"] .ewbb-pos-4,
    [data-layout="c"] .ewbb-pos-1, [data-layout="c"] .ewbb-pos-2, [data-layout="c"] .ewbb-pos-3, [data-layout="c"] .ewbb-pos-4 { grid-column: auto; grid-row: auto; }
    .ewbb-card--tall .ewbb-card__inner { flex-direction: row; }
    .ewbb-card--tall .ewbb-card__text { flex: 1; }
    .ewbb-card--tall .ewbb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .ewbb-title { font-size: 28px; }
    .ewbb-subtitle { font-size: 15px; }
    .ewbb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .ewbb-tab { border-radius: 12px; }
    .ewbb-grid { grid-template-columns: 1fr; }
    .ewbb-pos-0, .ewbb-pos-1, .ewbb-pos-2, .ewbb-pos-3, .ewbb-pos-4,
    [data-layout="b"] .ewbb-pos-0, [data-layout="b"] .ewbb-pos-1, [data-layout="b"] .ewbb-pos-2, [data-layout="b"] .ewbb-pos-3, [data-layout="b"] .ewbb-pos-4,
    [data-layout="c"] .ewbb-pos-0, [data-layout="c"] .ewbb-pos-1, [data-layout="c"] .ewbb-pos-2, [data-layout="c"] .ewbb-pos-3, [data-layout="c"] .ewbb-pos-4 { grid-column: 1; grid-row: auto; }
    .ewbb-card--sm .ewbb-card__inner, .ewbb-card--tall .ewbb-card__inner { flex-direction: row; }
    .ewbb-card--sm .ewbb-card__text, .ewbb-card--tall .ewbb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .ewbb-card--sm .ewbb-card__img, .ewbb-card--tall .ewbb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ewbb-card { animation: none !important; opacity: 1; transform: none; }
    .ewbb-card:hover::after { animation: none !important; }
    .ewbb-card:hover .ewbb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
