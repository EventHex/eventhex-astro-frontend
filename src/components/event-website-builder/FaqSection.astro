---
const faqs = [
  {
    q: "Do I need coding skills to build an event website?",
    a: "No. EventHex website builder is a visual drag-and-drop tool. You pick a template, customize it with your content and branding, and publish — no code required.",
  },
  {
    q: "Can I use my own domain?",
    a: "Yes. You can publish your event website on your own custom domain or use an eventhex.com subdomain. We handle SSL certificates and DNS configuration.",
  },
  {
    q: "Are the websites mobile responsive?",
    a: "Absolutely. Every template and section is built to be fully responsive — looking great on desktop, tablet, and mobile devices out of the box.",
  },
  {
    q: "Can I embed registration and ticket purchase?",
    a: "Yes. Our registration widget embeds directly into the page — attendees can buy tickets and register without leaving your event website.",
  },
  {
    q: "How many templates are available?",
    a: "We offer 40+ professionally designed templates covering conferences, expos, workshops, galas, hybrid events, and more. Each template can be fully customized.",
  },
  {
    q: "Is there SEO support?",
    a: "Yes. Every page auto-generates meta tags, Open Graph data, and structured data (JSON-LD). Templates are optimized for Core Web Vitals and fast loading.",
  },
  {
    q: "Can multiple team members edit the website?",
    a: "Yes. You can invite team members with role-based permissions — some can edit content while others only review.",
  },
  {
    q: "Can I duplicate a website for a recurring event?",
    a: "Yes. Use the template cloning feature to duplicate any event website as a starting point for your next event — saving hours of setup time.",
  },
];

const checklist = [
  "Zero-code website builder",
  "40+ professional templates",
  "Built-in SEO optimization",
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="ewbfq">
  <div class="ewbfq__inner">
    <div class="ewbfq__support">
      <span class="ewbfq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need help building your event website?</span>
      <h2 class="ewbfq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="ewbfq__desc animate-on-scroll" data-animation="fadeInUp">
        We help event teams design, launch, and optimize event websites that drive registrations and reflect their brand.
      </p>

      <div class="ewbfq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="ewbfq__support-label">Included with every rollout</span>
        <ul class="ewbfq__support-list">
          {checklist.map((item) => (
            <li class="ewbfq__support-item">{item}</li>
          ))}
        </ul>

        <div class="ewbfq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your website layout before launch and keep your event team aligned on branding, content, and registration flow.</span>
        </div>

        <a href="/book-a-demo/" class="ewbfq__cta">Plan my event website</a>
      </div>
    </div>

    <div class="ewbfq__list">
      {faqs.map((faq, index) => (
        <details class="ewbfq__item animate-on-scroll" data-animation="fadeInUp" data-ewb-faq open={index === 0}>
          <summary class="ewbfq__question">
            <span>{faq.q}</span>
            <span class="ewbfq__icon" aria-hidden="true">
              <span class="ewbfq__icon-line ewbfq__icon-line--horizontal"></span>
              <span class="ewbfq__icon-line ewbfq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="ewbfq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const ewbFaqItems = Array.from(document.querySelectorAll('[data-ewb-faq]'));

  ewbFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      ewbFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .ewbfq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .ewbfq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .ewbfq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .ewbfq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .ewbfq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .ewbfq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .ewbfq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .ewbfq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .ewbfq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ewbfq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .ewbfq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .ewbfq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .ewbfq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .ewbfq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .ewbfq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .ewbfq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .ewbfq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ewbfq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .ewbfq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
  }

  .ewbfq__question::-webkit-details-marker,
  .ewbfq__question::marker {
    display: none;
  }

  .ewbfq__icon {
    position: relative;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 4px;
  }

  .ewbfq__icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #375dfb;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .ewbfq__icon-line--vertical {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .ewbfq__item[open] .ewbfq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0);
  }

  .ewbfq__answer {
    padding: 0 24px 24px;
  }

  .ewbfq__answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #5b6477;
  }

  @media (max-width: 1100px) {
    .ewbfq { padding: 76px 0; }
    .ewbfq__inner { grid-template-columns: 1fr; gap: 28px; }
    .ewbfq__support { position: static; }
  }

  @media (max-width: 1024px) {
    .ewbfq__title { font-size: 40px; }
    .ewbfq__desc { font-size: 16px; }
    .ewbfq__question { padding: 24px 22px; font-size: 20px; }
    .ewbfq__answer { padding: 0 22px 22px; }
  }

  @media (max-width: 767px) {
    .ewbfq { padding: 56px 0; }
    .ewbfq__inner { padding: 0 16px; gap: 24px; }
    .ewbfq__title { font-size: 32px; line-height: 1.08; }
    .ewbfq__desc { font-size: 15px; line-height: 1.7; }
    .ewbfq__support-card { padding: 20px 18px; border-radius: 24px; }
    .ewbfq__support-item { font-size: 15px; }
    .ewbfq__support-note strong { font-size: 18px; }
    .ewbfq__cta { width: 100%; }
    .ewbfq__item { border-radius: 24px; }
    .ewbfq__question { padding: 20px 18px; font-size: 17px; line-height: 1.45; }
    .ewbfq__answer { padding: 0 18px 20px; }
    .ewbfq__answer p { font-size: 15px; line-height: 1.75; }
  }
</style>
