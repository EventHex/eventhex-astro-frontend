---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "Do I need coding skills to build an event website?", a: "No. EventHex website builder is a visual drag-and-drop tool. You pick a template, customize it with your content and branding, and publish — no code required." },
  { q: "Can I use my own domain?", a: "Yes. You can publish your event website on your own custom domain or use an eventhex.com subdomain. We handle SSL certificates and DNS configuration." },
  { q: "Are the websites mobile responsive?", a: "Absolutely. Every template and section is built to be fully responsive — looking great on desktop, tablet, and mobile devices out of the box." },
  { q: "Can I embed registration and ticket purchase?", a: "Yes. Our registration widget embeds directly into the page — attendees can buy tickets and register without leaving your event website." },
  { q: "How many templates are available?", a: "We offer 40+ professionally designed templates covering conferences, expos, workshops, galas, hybrid events, and more. Each template can be fully customized." },
  { q: "Is there SEO support?", a: "Yes. Every page auto-generates meta tags, Open Graph data, and structured data (JSON-LD). Templates are optimized for Core Web Vitals and fast loading." },
  { q: "Can multiple team members edit the website?", a: "Yes. You can invite team members with role-based permissions — some can edit content while others only review." },
  { q: "Can I duplicate a website for a recurring event?", a: "Yes. Use the template cloning feature to duplicate any event website as a starting point for your next event — saving hours of setup time." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help building your event website?"
  title="Frequently Asked Questions"
  description="We help event teams design, launch, and optimize event websites that drive registrations and reflect their brand."
/>
