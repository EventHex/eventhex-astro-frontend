---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="#375DFB" stroke-width="2"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="#375DFB" stroke-width="2"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="#375DFB" stroke-width="2"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="#375DFB" stroke-width="2"/></svg>`,
    title: "Zero-code visual builder",
    desc: "Drag-and-drop builder with pre-built event sections — no developers or designers needed.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M7 9h10M7 13h6" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "40+ professional templates",
    desc: "Conference, expo, workshop, and hybrid templates designed for event conversion.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="#375DFB" stroke-width="2"/><path d="M21 21l-4.35-4.35" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M8 11h6M11 8v6" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Built-in SEO & analytics",
    desc: "Auto meta tags, structured data, GA4 integration, and UTM tracking out of the box.",
  },
];
---

<section class="ewbc-full">
  <div class="ewbc-full__inner">
    <div class="ewbc-full__header">
      <span class="ewbc-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Website Builder</span>
      <h2 class="ewbc-full__title animate-on-scroll" data-animation="fadeInUp">Professional Event <b>Websites in Minutes</b></h2>
      <p class="ewbc-full__desc animate-on-scroll" data-animation="fadeInUp">Build, customize, and launch conversion-optimized event websites without writing code or hiring designers.</p>
    </div>

    <div class="ewbc-full__cards">
      {cards.map((card) => (
        <div class="ewbc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="ewbc-full__card-icon" set:html={card.icon}></div>
          <h3 class="ewbc-full__card-title">{card.title}</h3>
          <p class="ewbc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .ewbc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://cms.eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .ewbc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .ewbc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .ewbc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ewbc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .ewbc-full__title b { font-weight: 700; }

  .ewbc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .ewbc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .ewbc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .ewbc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .ewbc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .ewbc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .ewbc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .ewbc-full { padding: 64px 0; }
    .ewbc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .ewbc-full { padding: 52px 0; }
    .ewbc-full__title { font-size: 30px; line-height: 1.15; }
    .ewbc-full__desc { font-size: 15px; }
    .ewbc-full__cards { grid-template-columns: 1fr; }
  }
</style>
