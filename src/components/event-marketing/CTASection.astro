---
// CTA Section — dark gradient card with trust signals (matching event-ticketing pattern)
// CSS prefix: em-cta__
---

<section class="em-cta">
  <div class="em-cta__card">
    <div class="em-cta__glow em-cta__glow--1"></div>
    <div class="em-cta__glow em-cta__glow--2"></div>
    <div class="em-cta__content">
      <span class="em-cta__eyebrow animate-on-scroll" data-animation="fadeIn">Supercharge Your Event Marketing</span>
      <h2 class="em-cta__title animate-on-scroll" data-animation="fadeInUp">Ready to Fill Every Seat?</h2>
      <p class="em-cta__desc animate-on-scroll" data-animation="fadeInUp">Join hundreds of event organizers who send campaigns, target audiences, and track results — all from one marketing platform.</p>
      <div class="em-cta__proof-row animate-on-scroll" data-animation="fadeInUp">
        <span class="em-cta__proof-pill">Email + WhatsApp campaigns</span>
        <span class="em-cta__proof-pill">Smart audience targeting</span>
        <span class="em-cta__proof-pill">Real-time delivery analytics</span>
      </div>
      <div class="em-cta__buttons">
        <a href="/book-a-demo/" class="em-cta__btn em-cta__btn--primary">
          Start Marketing Your Event
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/contact-en/" class="em-cta__btn em-cta__btn--secondary">Contact Sales</a>
      </div>
      <div class="em-cta__trust">
        <span class="em-cta__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
          No credit card required
        </span>
        <span class="em-cta__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
          Free onboarding support
        </span>
        <span class="em-cta__trust-item">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
          Cancel anytime
        </span>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .em-cta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }

  .em-cta__card {
    position: relative;
    border-radius: 24px;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;
    background: linear-gradient(135deg, #0F1629 0%, #1A2744 50%, #0F1629 100%);
    border: 1px solid rgba(55, 93, 251, 0.15);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.3);
  }

  .em-cta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .em-cta__glow--1 {
    width: 320px;
    height: 320px;
    top: -80px;
    left: -60px;
    background: rgba(55, 93, 251, 0.2);
  }

  .em-cta__glow--2 {
    width: 280px;
    height: 280px;
    bottom: -60px;
    right: -40px;
    background: rgba(175, 163, 255, 0.15);
  }

  .em-cta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    max-width: 660px;
  }

  .em-cta__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(175, 163, 255, 0.8);
  }

  .em-cta__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 44px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -1px;
    color: #fff;
  }

  .em-cta__desc {
    margin: 0;
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
  }

  .em-cta__proof-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    padding-top: 6px;
  }

  .em-cta__proof-pill {
    padding: 8px 16px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .em-cta__buttons {
    display: flex;
    gap: 14px;
    padding-top: 10px;
  }

  .em-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 52px;
    padding: 14px 32px;
    border-radius: 12px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s;
  }

  .em-cta__btn--primary {
    color: #fff;
    background: var(--brand-blue);
    box-shadow: 0 12px 28px rgba(55, 93, 251, 0.35);
  }

  .em-cta__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 34px rgba(55, 93, 251, 0.45);
  }

  .em-cta__btn--secondary {
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .em-cta__btn--secondary:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.14);
  }

  .em-cta__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
    padding-top: 4px;
  }

  .em-cta__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 767px) {
    .em-cta { padding: 40px 16px 60px; }
    .em-cta__card { padding: 48px 20px; }
    .em-cta__title { font-size: 30px; }
    .em-cta__desc { font-size: 16px; }
    .em-cta__buttons { flex-direction: column; width: 100%; }
    .em-cta__btn { width: 100%; }
    .em-cta__proof-row { gap: 8px; }
    .em-cta__trust { flex-direction: column; align-items: center; gap: 8px; }
  }
</style>
