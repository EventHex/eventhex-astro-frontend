---
// Benefits Section — centered 3-col glassmorphism cards on dark bg
// Pattern from event-ticketing BenefitCardsSection
// CSS prefix: embn-
---

<section class="embn-section">
  <div class="embn-inner">
    <div class="embn-header">
      <span class="embn-tag animate-on-scroll" data-animation="fadeIn">Why EventHex</span>
      <h2 class="embn-title animate-on-scroll" data-animation="fadeInUp">Why 500+ Organizers Choose EventHex Marketing</h2>
      <p class="embn-desc animate-on-scroll" data-animation="fadeInUp">
        The most complete event marketing platform for modern event organizers.
      </p>
    </div>

    <div class="embn-grid">
      <div class="embn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="embn-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="rgba(52,211,153,0.12)"/><rect x="8" y="12" width="32" height="24" rx="3" stroke="#34D399" stroke-width="2"/><path d="M40 17L24 27 8 17" stroke="#34D399" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h3 class="embn-card__title">Email + WhatsApp</h3>
        <p class="embn-card__desc">One platform for both channels — create, send, and track email and WhatsApp campaigns side by side.</p>
      </div>

      <div class="embn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="embn-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="rgba(129,140,248,0.12)"/><circle cx="18" cy="18" r="6" stroke="#818CF8" stroke-width="2"/><circle cx="32" cy="20" r="5" stroke="#818CF8" stroke-width="1.5"/><path d="M8 40v-3a8 8 0 018-8h4a8 8 0 018 8v3" stroke="#818CF8" stroke-width="2"/></svg>
        </div>
        <h3 class="embn-card__title">Smart Audience Builder</h3>
        <p class="embn-card__desc">Segment by ticket type, date range, and event history. Retarget previous attendees with one click.</p>
      </div>

      <div class="embn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="embn-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="rgba(251,191,36,0.12)"/><rect x="10" y="10" width="28" height="28" rx="4" stroke="#FBBF24" stroke-width="2"/><path d="M18 24l4 4 8-8" stroke="#FBBF24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="embn-card__title">Advocacy Posters</h3>
        <p class="embn-card__desc">Built-in poster builder with share links and analytics — turn attendees into organic promoters.</p>
      </div>

      <div class="embn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="embn-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="rgba(244,114,182,0.12)"/><path d="M32 36V20M24 36V12M16 36v-10" stroke="#F472B6" stroke-width="2.5" stroke-linecap="round"/></svg>
        </div>
        <h3 class="embn-card__title">Real-Time Analytics</h3>
        <p class="embn-card__desc">Track delivery, opens, clicks, bounces, and per-recipient status — all from a live campaign dashboard.</p>
      </div>

      <div class="embn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="embn-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="rgba(56,189,248,0.12)"/><path d="M24 40s14-7 14-17V13l-14-5-14 5v10c0 10 14 17 14 17z" stroke="#38BDF8" stroke-width="2"/></svg>
        </div>
        <h3 class="embn-card__title">Smart Suppression</h3>
        <p class="embn-card__desc">Auto-handle bounces, complaints, and opt-outs to protect your sender reputation and improve deliverability.</p>
      </div>

      <div class="embn-card animate-on-scroll" data-animation="fadeInUp">
        <div class="embn-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="12" fill="rgba(167,139,250,0.12)"/><path d="M14 14h20v20H14z" stroke="#A78BFA" stroke-width="2" rx="3"/><path d="M20 14v20M28 14v20M14 20h20M14 28h20" stroke="#A78BFA" stroke-width="1.5" opacity=".5"/></svg>
        </div>
        <h3 class="embn-card__title">Multi-Provider Support</h3>
        <p class="embn-card__desc">Use Amazon SES, custom SMTP, or your own WhatsApp Business API — full flexibility with your infrastructure.</p>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .embn-section {
    width: 100%;
    margin: 0;
    padding: 80px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .embn-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .embn-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 14px;
    margin-bottom: 48px;
  }

  .embn-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(175, 163, 255, 0.78);
  }

  .embn-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -1px;
    color: #fff;
  }

  .embn-desc {
    margin: 0;
    max-width: 560px;
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
  }

  .embn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .embn-card {
    padding: 28px 24px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  .embn-card:hover {
    transform: translateY(-4px);
    border-color: rgba(55, 93, 251, 0.25);
    box-shadow: 0 16px 40px rgba(55, 93, 251, 0.1);
  }

  .embn-card__icon {
    margin-bottom: 16px;
  }

  .embn-card__icon img,
  .embn-card__icon svg {
    width: 48px;
    height: 48px;
    display: block;
  }

  .embn-card__title {
    margin: 0 0 10px;
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
  }

  .embn-card__desc {
    margin: 0;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 1024px) {
    .embn-grid { grid-template-columns: repeat(2, 1fr); }
    .embn-title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .embn-section { padding: 60px 0; }
    .embn-grid { grid-template-columns: 1fr; }
    .embn-title { font-size: 28px; }
    .embn-desc { font-size: 16px; }
    .embn-card { padding: 24px 20px; }
  }
</style>
