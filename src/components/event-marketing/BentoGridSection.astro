---
// Tabbed Bento Grid — 3 tabs for Event Marketing workflows
// Pattern from event-ticketing/ai-smart-connect BentoGridSection
// CSS prefix: emb-
---

<section class="emb-bento-section" id="em-features">
  <div class="emb" id="emb-bento">
    <h2 class="emb-title">
      <b>Campaign</b> Builder, Audience <b>Targeting</b> & Analytics
    </h2>
    <p class="emb-subtitle">
      From personalized email campaigns to audience retargeting to delivery analytics — manage your entire event marketing workflow from one platform.
    </p>

    <nav class="emb-nav">
      <button class="emb-tab emb-tab--active" data-emb-tab="0">Campaign Builder</button>
      <button class="emb-tab" data-emb-tab="1">Audience Targeting</button>
      <button class="emb-tab" data-emb-tab="2">Analytics</button>
    </nav>

    <!-- Tab 0: Campaign Builder -->
    <div class="emb-panel emb-panel--active" data-emb-panel="0">
      <div class="emb-grid" data-layout="a">
        <div class="emb-card emb-card--tall emb-pos-0">
          <div class="emb-card__inner">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Visual Email Editor</h3>
              <p class="emb-card__desc">Create rich HTML email campaigns with live preview, custom branding, and template variable personalization.</p>
            </div>
            <div class="emb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect x="35" y="40" width="130" height="10" rx="5" fill="#375DFB" opacity=".12"/>
                <rect x="35" y="58" width="100" height="6" rx="3" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="70" width="110" height="6" rx="3" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="82" width="80" height="6" rx="3" fill="#375DFB" opacity=".06"/>
                <rect x="35" y="100" width="60" height="22" rx="8" fill="#375DFB" opacity=".15"/>
                <text x="65" y="115" text-anchor="middle" font-size="9" fill="#375DFB">Send</text>
                <text x="100" y="145" text-anchor="middle" font-size="11" fill="#375DFB" opacity=".5">Email Preview</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-1">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">WhatsApp Broadcasts</h3>
              <p class="emb-card__desc">Send bulk WhatsApp messages with Meta-approved templates, variable mapping, and rich media attachments.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-2">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Template Variables</h3>
              <p class="emb-card__desc">Personalize every message with &#123;firstName&#125;, &#123;event&#125;, &#123;ticket&#125;, and custom registration fields.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-3">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Campaign Scheduling</h3>
              <p class="emb-card__desc">Send now or schedule for later. Campaigns auto-process at your designated time with parallel delivery.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-4">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">File Attachments</h3>
              <p class="emb-card__desc">Attach PDFs, images, and documents to your email campaigns for richer engagement.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 1: Audience Targeting -->
    <div class="emb-panel" data-emb-panel="1">
      <div class="emb-grid" data-layout="b">
        <div class="emb-card emb-card--tall emb-pos-0">
          <div class="emb-card__inner">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Smart Segmentation</h3>
              <p class="emb-card__desc">Build audience segments by ticket type, registration date range, and event history — with auto-calculated counts.</p>
            </div>
            <div class="emb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect x="35" y="42" width="80" height="20" rx="10" fill="#375DFB" opacity=".08" stroke="#375DFB" stroke-opacity=".15" stroke-width="1"/>
                <text x="75" y="56" text-anchor="middle" font-size="9" fill="#375DFB" opacity=".6">VIP Pass</text>
                <rect x="35" y="70" width="95" height="20" rx="10" fill="#375DFB" opacity=".08" stroke="#375DFB" stroke-opacity=".15" stroke-width="1"/>
                <text x="82" y="84" text-anchor="middle" font-size="9" fill="#375DFB" opacity=".6">Jan - Mar 2025</text>
                <rect x="35" y="98" width="105" height="20" rx="10" fill="#375DFB" opacity=".08" stroke="#375DFB" stroke-opacity=".15" stroke-width="1"/>
                <text x="87" y="112" text-anchor="middle" font-size="9" fill="#375DFB" opacity=".6">Tech Summit 2024</text>
                <text x="100" y="145" text-anchor="middle" font-size="11" fill="#375DFB" opacity=".5">2,340 recipients</text>
              </svg>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-1">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Cross-Event Retargeting</h3>
              <p class="emb-card__desc">Target attendees from previous events to re-engage them for your upcoming event campaigns.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-2">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Exclusion Filters</h3>
              <p class="emb-card__desc">Automatically exclude people already registered for your current event from promotional campaigns.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-3">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Saved Audiences</h3>
              <p class="emb-card__desc">Save audience segments for quick reuse. Counts update automatically when new registrations come in.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-4">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Audience Lists</h3>
              <p class="emb-card__desc">Organize and manage predefined audience groups for targeted multi-channel campaigns.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 2: Analytics -->
    <div class="emb-panel" data-emb-panel="2">
      <div class="emb-grid" data-layout="c">
        <div class="emb-card emb-card--tall emb-pos-0">
          <div class="emb-card__inner">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Real-Time Delivery Tracking</h3>
              <p class="emb-card__desc">Monitor sent, delivered, read, and failed statuses per recipient with live progress bars for every campaign.</p>
            </div>
            <div class="emb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="180" viewBox="0 0 200 180" fill="none">
                <rect x="20" y="20" width="160" height="140" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect x="40" y="45" width="40" height="8" rx="4" fill="#375DFB" opacity=".12"/>
                <text x="60" y="51" text-anchor="middle" font-size="7" fill="#375DFB" opacity=".5">94.2%</text>
                <rect x="110" y="45" width="40" height="8" rx="4" fill="#375DFB" opacity=".12"/>
                <text x="130" y="51" text-anchor="middle" font-size="7" fill="#375DFB" opacity=".5">67.8%</text>
                <path d="M40 130l25-35 20 15 30-45 25 25" stroke="#375DFB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="40" cy="130" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="65" cy="95" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="85" cy="110" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="115" cy="65" r="3" fill="#375DFB" opacity=".3"/>
                <circle cx="140" cy="90" r="3" fill="#375DFB" opacity=".3"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-1">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Open & Click Rates</h3>
              <p class="emb-card__desc">Track open rates, click-through rates, bounce rates, and complaint rates with per-email drill-down reports.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-2">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Smart Bounce Suppression</h3>
              <p class="emb-card__desc">Auto-suppress permanent bounces and complaints. Classify emails as critical, transactional, or marketing.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-3">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Automatic Failed Retry</h3>
              <p class="emb-card__desc">Failed messages auto-retry up to 3 times with distributed locking to prevent duplicate sends.</p>
            </div>
          </div>
        </div>

        <div class="emb-card emb-card--sm emb-pos-4">
          <div class="emb-card__inner emb-card__inner--row">
            <div class="emb-card__text">
              <svg class="emb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
              <h3 class="emb-card__title">Recipient Status</h3>
              <p class="emb-card__desc">Per-recipient drill-down showing delivery status, open time, click events, and bounce classification.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const embTabs = Array.from(document.querySelectorAll('[data-emb-tab]'));
  const embPanels = Array.from(document.querySelectorAll('[data-emb-panel]'));

  function embSwitch(index: number) {
    embTabs.forEach((t) => t.classList.remove('emb-tab--active'));
    embPanels.forEach((p) => p.classList.remove('emb-panel--active'));
    embTabs[index]?.classList.add('emb-tab--active');
    embPanels[index]?.classList.add('emb-panel--active');
  }

  embTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      embSwitch(i);
      clearInterval(embInterval);
    });
  });

  let embIdx = 0;
  let embInterval: ReturnType<typeof setInterval>;

  function startEmbRotation() {
    embInterval = setInterval(() => {
      embIdx = (embIdx + 1) % embTabs.length;
      embSwitch(embIdx);
    }, 5000);
  }

  startEmbRotation();

  const embBento = document.querySelector('.emb-bento-section');
  if (embBento) {
    embBento.addEventListener('mouseenter', () => clearInterval(embInterval));
    embBento.addEventListener('mouseleave', () => startEmbRotation());
  }
</script>

<style is:global>
  .emb-bento-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .emb {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .emb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .emb-title b { font-weight: 700; }

  .emb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .emb-nav {
    display: flex;
    justify-content: center;
    gap: 0;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    width: fit-content;
    margin: 0 auto 40px;
  }

  .emb-tab {
    background: transparent;
    border: none;
    border-radius: 50px;
    padding: 10px 32px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #4D5A6B;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(.4,0,.2,1);
    white-space: nowrap;
  }
  .emb-tab:hover { background: rgba(55,93,251,.08); }

  .emb-tab--active {
    background: var(--brand-blue) !important;
    color: #fff !important;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .emb-panel { display: none; }
  .emb-panel--active {
    display: block;
    animation: embFadeUp 0.4s ease;
  }

  @keyframes embFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .emb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    height: 460px;
  }

  .emb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .emb-pos-1 { grid-column: 2; grid-row: 1; }
  .emb-pos-2 { grid-column: 3; grid-row: 1; }
  .emb-pos-3 { grid-column: 2; grid-row: 2; }
  .emb-pos-4 { grid-column: 3; grid-row: 2; }

  [data-layout="b"] .emb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .emb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .emb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .emb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .emb-pos-4 { grid-column: 2; grid-row: 2; }

  [data-layout="c"] .emb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .emb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .emb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .emb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .emb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --emb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .emb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0;
    animation: embCardIn 0.5s ease forwards;
  }
  .emb-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: conic-gradient(from var(--emb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .emb-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(55, 93, 251, 0.12);
    border-color: rgba(55, 93, 251, 0.15);
  }
  .emb-card:hover::after { opacity: 1; animation: embBorder 2.4s linear infinite; }
  @keyframes embBorder { to { --emb-angle: 360deg; } }
  @keyframes embCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .emb-pos-1 { animation-delay: 0.06s; }
  .emb-pos-2 { animation-delay: 0.12s; }
  .emb-pos-3 { animation-delay: 0.18s; }
