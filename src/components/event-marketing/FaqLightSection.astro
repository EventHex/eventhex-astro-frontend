---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "What is event marketing software?", a: "Event marketing software helps organizers promote their events through multiple channels — email campaigns, WhatsApp broadcasts, social media advocacy, and audience retargeting. EventHex combines all these tools in one platform, allowing you to create personalized campaigns, manage audience segments, and track delivery analytics without switching between multiple tools." },
  { q: "Can I send both email and WhatsApp campaigns?", a: "Yes! EventHex supports multi-channel campaigns. You can send personalized email campaigns with HTML templates and attachments, or WhatsApp broadcasts using Meta-approved message templates. Both channels share the same audience management system, so you can reach your audience wherever they are." },
  { q: "How does the audience targeting work?", a: "EventHex's audience builder lets you create segments based on ticket type, registration date range, and event history. You can target attendees from your current event, or retarget attendees from previous events. The system automatically calculates unique phone numbers and email addresses, and you can exclude people already registered for your current event." },
  { q: "What are advocacy posters and how do they work?", a: "Advocacy posters are customizable 'I'm Attending' style graphics that attendees can share on social media to promote your event organically. EventHex provides a drag-and-drop poster builder where you add attendee names, photos, and event branding. Each poster generates a unique shareable link with built-in tracking — you can see clicks, unique visitors, and registrations from shared posters." },
  { q: "Can I schedule campaigns for later delivery?", a: "Absolutely. EventHex offers two scheduling modes: 'Send Now' for immediate delivery, and 'Schedule Later' where you set a specific date and time. Scheduled campaigns are processed automatically at the designated time with parallel processing for fast delivery." },
  { q: "How does EventHex track campaign performance?", a: "EventHex provides real-time delivery tracking for every campaign. For emails, monitor delivery rates, open rates, click-through rates, bounce rates, and complaint rates. For WhatsApp, webhook integrations track sent, delivered, read, and failed statuses per recipient." },
  { q: "Does EventHex handle email bounces automatically?", a: "Yes. EventHex has a smart suppression system that automatically handles email health. Permanent bounces are auto-suppressed to protect your sender reputation. Transient bounces retry up to 3 times." },
  { q: "Can I use my own email server or WhatsApp provider?", a: "Yes. EventHex supports multiple email providers — including Amazon SES, custom SMTP servers, and organization-level email settings. For WhatsApp, you can use EventHex's default provider or configure your own WhatsApp Business account." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with event marketing?"
  title="Frequently Asked Questions"
  description="We help event teams set up multi-channel marketing campaigns, audience targeting, and delivery tracking."
/>
