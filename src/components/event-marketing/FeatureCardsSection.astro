---
// Stacking Cards section — matches event-ticketing FeatureCards pattern
// Dark bg with bg-2.webp, sticky stacking cards for key Event Marketing features
// CSS prefix: emf-

const featureCards = [
  {
    title: "Targeted Social Media Campaigns",
    desc: "Create and send personalized email and WhatsApp campaigns to engage with your audience. Select the style of message personalization in the editor using variables such as users and events. Pre-set the time you want your campaign to start running.",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Frame-2.svg",
    alt: "EventHex targeted social media campaign builder interface",
  },
  {
    title: "Re-Campaign with Saved Audience",
    desc: "Organize and manage predefined audience groups for targeted campaigns. Filter the audience list from the current or previous event. View how many messages are pending and how many are delivered to the selected audience list.",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Marketing-_Campaigns.png",
    alt: "EventHex re-campaign audience management interface",
  },
  {
    title: "Advocacy Posters to Boost Presence",
    desc: "Create 'I'm attending' posters for participants to share and promote your event online. Customize details like name, profile photo, and company logo. Let your audience do the marketing by sharing advocacy posters on their social media handles.",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Group.svg",
    alt: "EventHex advocacy poster creator for event promotion",
  },
];
---

<section class="emf-shell">
  <div class="emf-section">
    <div class="emf-header">
      <span class="emf-subtitle animate-on-scroll" data-animation="fadeInUp">Feature-by-feature</span>
      <h2 class="emf-title animate-on-scroll" data-animation="fadeInUp">
        Multi-Channel Marketing in <span class="emf-highlight">Every Campaign</span>
      </h2>
    </div>

    <div class="emf-cards" id="emf-stacking-cards">
      {featureCards.map((card, i) => (
        <div
          class="emf-card"
          data-card-index={i}
          style={`--card-index: ${i}; top: calc(20px + ${i * 20}px);`}
        >
          <div class="emf-card-content">
            <h3 class="emf-card-title">{card.title}</h3>
            <p class="emf-card-desc">{card.desc}</p>
            <a href="/book-a-demo/" class="emf-card-btn">Explore More</a>
          </div>
          <div class="emf-card-image">
            <img src={card.image} alt={card.alt} loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .emf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .emf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .emf-header {
    width: 70%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .emf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .emf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .emf-highlight { color: #AFA3FF; }

  .emf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .emf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.8));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .emf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .emf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .emf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .emf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .emf-card-btn:hover { transform: scale(1.05); }

  .emf-card-image {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    overflow: hidden;
  }

  .emf-card-image img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .emf-section { padding: 60px 20px 30px; }
    .emf-header { width: 80%; }
    .emf-subtitle { font-size: 16px; }
    .emf-title { font-size: 40px; line-height: 1em; }
    .emf-card { height: 450px; }
    .emf-card-content { flex-basis: 50%; }
    .emf-card-title { font-size: 28px; }
    .emf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .emf-section { padding: 50px 20px 30px; }
    .emf-header { width: 100%; }
    .emf-title { font-size: 30px; }
    .emf-card { flex-direction: column; height: 520px; }
    .emf-card-content { flex: 0 0 50%; padding: 20px 20px 0; }
    .emf-card-image { padding: 10px; }
    .emf-card-title { font-size: 24px; }
    .emf-card-desc { font-size: 15px; }
    .emf-cards { padding-bottom: 40px; }
  }
</style>
