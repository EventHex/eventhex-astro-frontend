---
// AI Event Copilot stats — dark section with engagement heading + stats grid
const stats = [
  { value: "4", label: "Specialized AI Agents" },
  { value: "80%", label: "Time Saved on Repetitive Tasks" },
  { value: "24/7", label: "Agent Availability" },
  { value: "15+", label: "Languages Supported" },
];
---

<section class="aecs-dark">
  <div class="aecs-engagement">
    <div class="aecs-engagement-text">
      <h2 class="aecs-heading animate-on-scroll" data-animation="fadeInDown">
        <span class="aecs-white">Your AI team </span>
        <span class="aecs-purple">always on </span>
        <span class="aecs-white">for</span>
        <br />
        <span class="aecs-cyan">every event task</span>
      </h2>
    </div>
  </div>

  <div class="aecs-stats">
    {stats.map((stat) => (
      <div class="aecs-stat">
        <span class="aecs-stat-value">{stat.value}</span>
        <span class="aecs-stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .aecs-dark {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 70px 0;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .aecs-engagement {
    width: 100%;
    padding: 0 0 60px;
    display: flex;
    justify-content: center;
  }

  .aecs-engagement-text {
    width: 65%;
  }

  .aecs-heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 52px;
    letter-spacing: -1px;
    color: #fff;
    text-align: center;
    margin: 0;
  }

  .aecs-white { color: #fff; }
  .aecs-purple { color: #AFA3FF; }
  .aecs-cyan { color: #ABFFFF; }

  .aecs-stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    padding: 0 20px;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .aecs-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 32px 28px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    flex: 1;
    min-width: 180px;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .aecs-stat:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
  }

  .aecs-stat-value {
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 700;
    line-height: 48px;
    letter-spacing: -1px;
    color: #fff;
  }

  .aecs-stat-label {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 20px;
    color: rgba(255, 255, 255, 0.6);
    text-align: center;
  }

  @media (max-width: 1024px) {
    .aecs-dark { padding: 80px 0; }
    .aecs-engagement { padding: 0 20px 40px; }
    .aecs-engagement-text { width: 85%; }
    .aecs-heading { font-size: 40px; line-height: 1.1em; }
    .aecs-stats { gap: 40px; }
    .aecs-stat-value { font-size: 32px; }
    .aecs-stat-label { font-size: 14px; }
  }

  @media (max-width: 767px) {
    .aecs-dark { padding: 64px 0; }
    .aecs-engagement { padding: 0 15px 30px; }
    .aecs-engagement-text { width: 100%; }
    .aecs-heading { font-size: 25px; line-height: 1.2em; letter-spacing: 0; }
    .aecs-stats {
      flex-wrap: wrap;
      gap: 24px;
      justify-content: center;
    }
    .aecs-stat { width: 40%; padding: 24px 16px; }
    .aecs-stat-value { font-size: 28px; }
    .aecs-stat-label { font-size: 13px; }
  }
</style>
