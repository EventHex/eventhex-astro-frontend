---
// AI Event Copilot — How It Works section (4-step cards on dark bg)
const steps = [
  {
    num: "01",
    title: "Connect Your Event",
    desc: "Link your event data — registrations, sessions, speakers, and content. AI agents sync automatically.",
  },
  {
    num: "02",
    title: "Ask & Instruct",
    desc: "Query data with the Analyst, generate content with the Copywriter, or let the Ticket Agent handle support.",
  },
  {
    num: "03",
    title: "Review & Approve",
    desc: "AI outputs are ready to use but always under your control. Edit, approve, or refine before publishing.",
  },
  {
    num: "04",
    title: "Scale Operations",
    desc: "As your event grows, AI agents handle the increased workload — no additional staff needed.",
  },
];
---

<section class="aechw-full">
  <div class="aechw-full__inner">
    <div class="aechw-full__header">
      <span class="aechw-full__tag animate-on-scroll" data-animation="fadeIn">How AI Copilot Works</span>
      <h2 class="aechw-full__title animate-on-scroll" data-animation="fadeInUp">From Connection to <b>Scaled Operations</b></h2>
      <p class="aechw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Connect your event data, instruct AI agents, review outputs, and scale without additional staff.
      </p>
    </div>

    <div class="aechw-full__cards">
      {steps.map((step) => (
        <article class="aechw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="aechw-full__card-icon">{step.num}</div>
          <h3 class="aechw-full__card-title">{step.title}</h3>
          <p class="aechw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .aechw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .aechw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .aechw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .aechw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .aechw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .aechw-full__title b { font-weight: 700; }

  .aechw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .aechw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .aechw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .aechw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .aechw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .aechw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .aechw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .aechw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .aechw-full { padding: 64px 0; }
    .aechw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .aechw-full { padding: 52px 0; }
    .aechw-full__title { font-size: 30px; line-height: 1.15; }
    .aechw-full__desc { font-size: 15px; }
    .aechw-full__cards { grid-template-columns: 1fr; }
  }
</style>
