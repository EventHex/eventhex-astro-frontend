---
// AI Event Copilot CTA Section — dark gradient card with trust signals
---

<section class="aeccta-cta">
  <div class="aeccta-cta__card">
    <div class="aeccta-cta__glow aeccta-cta__glow--1"></div>
    <div class="aeccta-cta__glow aeccta-cta__glow--2"></div>
    <div class="aeccta-cta__content">
      <span class="aeccta-cta__eyebrow animate-on-scroll" data-animation="fadeIn">Add AI to Your Events</span>
      <h2 class="aeccta-cta__title animate-on-scroll" data-animation="fadeInUp">Ready to Add Four AI Agents to Your Event Team?</h2>
      <p class="aeccta-cta__desc animate-on-scroll" data-animation="fadeInUp">See how four specialized AI agents save 80% of your team's time on data analysis, content creation, and attendee support.</p>
      <div class="aeccta-cta__proof-row animate-on-scroll" data-animation="fadeInUp">
        <span class="aeccta-cta__proof-pill">4 specialized agents</span>
        <span class="aeccta-cta__proof-pill">80% time saved</span>
        <span class="aeccta-cta__proof-pill">Free onboarding support</span>
      </div>
      <div class="aeccta-cta__buttons">
        <a href="/book-a-demo/" class="aeccta-cta__btn aeccta-cta__btn--primary">
          Book a Free Demo
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/event-analytics/" class="aeccta-cta__btn aeccta-cta__btn--secondary">Explore Event Analytics</a>
      </div>
    </div>
    <div class="aeccta-cta__visual animate-on-scroll" data-animation="fadeInUp">
      <img
        src="/feature-images/ai-event-copilot/cta-visual.svg"
        alt="AI Event Copilot — Four specialized AI agents"
        class="aeccta-cta__visual-img"
        width="460"
        height="400"
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .aeccta-cta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }

  .aeccta-cta__card {
    position: relative;
    border-radius: 24px;
    padding: 80px 40px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 40px;
    overflow: hidden;
    background: #0F1629;
  }

  .aeccta-cta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .aeccta-cta__glow--1 {
    width: 400px;
    height: 400px;
    background: rgba(55, 93, 251, 0.2);
    top: -100px;
    left: -50px;
  }

  .aeccta-cta__glow--2 {
    width: 300px;
    height: 300px;
    background: rgba(159, 129, 255, 0.15);
    bottom: -80px;
    right: -30px;
  }

  .aeccta-cta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 20px;
    flex: 1;
    min-width: 0;
  }

  .aeccta-cta__visual {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .aeccta-cta__visual-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    object-fit: contain;
    animation: aecctaFloat 4s ease-in-out infinite;
  }

  @keyframes aecctaFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .aeccta-cta__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .aeccta-cta__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .aeccta-cta__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.3px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .aeccta-cta__proof-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .aeccta-cta__proof-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: rgba(255, 255, 255, 0.74);
  }

  .aeccta-cta__buttons { display: flex; gap: 12px; }

  .aeccta-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.3px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .aeccta-cta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.35);
  }

  .aeccta-cta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(55, 93, 251, 0.4);
  }

  .aeccta-cta__btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .aeccta-cta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  @media (max-width: 1024px) {
    .aeccta-cta__card { padding: 60px 24px; gap: 32px; }
    .aeccta-cta__title { font-size: 36px; }
    .aeccta-cta__desc { font-size: 16px; }
    .aeccta-cta__visual-img { max-width: 340px; }
  }

  @media (max-width: 767px) {
    .aeccta-cta { padding: 40px 16px 60px; }
    .aeccta-cta__card { padding: 48px 20px; border-radius: 20px; flex-direction: column; }
    .aeccta-cta__content { align-items: center; text-align: center; }
    .aeccta-cta__proof-row { justify-content: center; }
    .aeccta-cta__buttons { justify-content: center; }
    .aeccta-cta__title { font-size: 28px; line-height: 1.2em; }
    .aeccta-cta__desc { font-size: 15px; }
    .aeccta-cta__proof-row { gap: 8px; }
    .aeccta-cta__buttons { flex-direction: column; width: 100%; }
    .aeccta-cta__btn { width: 100%; }
    .aeccta-cta__visual-img { max-width: 300px; }
  }
</style>
