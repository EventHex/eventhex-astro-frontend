---
// AI Event Copilot hero — split layout matching speaker-management pattern
---

<section class="aech-hero">
  <div class="aech-hero__shell">
    <div class="aech-hero__grid">
      <div class="aech-hero__content">
        <div class="aech-hero__badge animate-on-scroll" data-animation="fadeInDown">
          <span class="aech-hero__badge-dot"></span>
          <span>AI Event Copilot</span>
        </div>

        <h1 class="aech-hero__title animate-on-scroll" data-animation="fadeInUp">
          Four AI Agents That <b>Work</b>
          <span><b>Alongside You</b></span>
        </h1>

        <p class="aech-hero__desc animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 800ms">
          Meet your AI co-pilots — Analyst, Session Builder, Copywriter, and Ticket Agent.
          They analyze data, build agendas, write marketing content, and support attendees 24/7.
        </p>

        <div class="aech-hero__points animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 950ms">
          <span class="aech-hero__point">4 Specialized AI Agents</span>
          <span class="aech-hero__point">Natural Language Queries</span>
          <span class="aech-hero__point">24/7 Availability</span>
        </div>

        <div class="aech-hero__cta animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 1100ms">
          <a href="/book-a-demo/" class="aech-hero__btn aech-hero__btn--primary">Book a Demo</a>
          <a href="#aec-bento" class="aech-hero__btn aech-hero__btn--secondary">Explore Features</a>
        </div>

        <div class="aech-hero__trust animate-on-scroll" data-animation="fadeIn" style="--anim-duration: 1250ms">
          <span class="aech-hero__trust-item">80% time saved on tasks</span>
          <span class="aech-hero__trust-item">Trusted by 500+ events</span>
        </div>
      </div>

      <div class="aech-hero__visual animate-on-scroll" data-animation="fadeInRight">
        <div class="aech-hero__visual-card">
          <div class="aech-hero__floating aech-hero__floating--top">
            <span class="aech-hero__floating-label">Analyst Agent</span>
            <strong>Natural language data queries</strong>
          </div>

          <img
            src="https://eventhex.ai/wp-content/uploads/2025/01/Instasnap.png"
            alt="EventHex AI Event Copilot dashboard with four agents"
            width="700"
            height="500"
            loading="eager"
          />

          <div class="aech-hero__floating aech-hero__floating--bottom">
            <span class="aech-hero__floating-label">Ticket Agent</span>
            <strong>24/7 automated attendee support</strong>
          </div>

          <div class="aech-hero__metric-row">
            <div class="aech-hero__metric">
              <strong>4</strong>
              <span>AI agents</span>
            </div>
            <div class="aech-hero__metric">
              <strong>80%</strong>
              <span>time saved</span>
            </div>
            <div class="aech-hero__metric">
              <strong>24/7</strong>
              <span>available</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .aech-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    padding: 0 0 220px;
    background:
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }

  .aech-hero__shell {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 160px 0 0;
    background: url('https://eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat;
  }

  .aech-hero__grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .aech-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .aech-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .aech-hero__badge-dot {
    display: none;
  }

  .aech-hero__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 600;
    line-height: 60px;
    letter-spacing: -1px;
    color: var(--heading-dark);
  }

  .aech-hero__title span {
    display: block;
    color: var(--brand-blue);
  }

  .aech-hero__desc {
    margin: 0;
    max-width: 580px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .aech-hero__points {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .aech-hero__point {
    display: inline-flex;
    align-items: center;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #e5ebff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #475467;
    box-shadow: 0 8px 24px rgba(34, 39, 47, 0.05);
  }

  .aech-hero__cta {
    display: flex;
    gap: 14px;
    padding-top: 6px;
  }

  .aech-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, border-color 0.3s;
  }

  .aech-hero__btn--primary {
    color: #fff;
    background: var(--brand-blue);
    box-shadow: 0 10px 24px rgba(55, 93, 251, 0.28);
  }

  .aech-hero__btn--primary:hover {
    transform: translateY(-2px);
    background: var(--brand-blue-hover);
    box-shadow: 0 14px 30px rgba(55, 93, 251, 0.34);
  }

  .aech-hero__btn--secondary {
    color: var(--heading-dark);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #dce4ff;
  }

  .aech-hero__btn--secondary:hover {
    transform: translateY(-2px);
    border-color: #c5d2ff;
    box-shadow: 0 10px 24px rgba(34, 39, 47, 0.06);
  }

  .aech-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .aech-hero__trust-item {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #667085;
  }

  .aech-hero__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
  }

  .aech-hero__visual {
    position: relative;
  }

  .aech-hero__visual-card {
    position: relative;
    padding: 20px 0 36px;
  }

  .aech-hero__visual-card img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
    filter: drop-shadow(0 26px 48px rgba(34, 39, 47, 0.14));
  }

  .aech-hero__floating {
    position: absolute;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.94);
    color: var(--heading-dark);
    border: 1px solid rgba(229, 235, 255, 0.9);
    box-shadow: 0 18px 36px rgba(34, 39, 47, 0.12);
    backdrop-filter: blur(12px);
  }

  .aech-hero__floating--top {
    top: -18px;
    left: -18px;
    max-width: 260px;
  }

  .aech-hero__floating--bottom {
    right: -18px;
    bottom: 94px;
    max-width: 280px;
  }

  .aech-hero__floating-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    line-height: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #667085;
  }

  .aech-hero__floating strong {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.45;
  }

  .aech-hero__metric-row {
    display: none;
  }

  @media (max-width: 1120px) {
    .aech-hero {
      padding: 0 20px 110px;
    }

    .aech-hero__shell {
      padding: 136px 0 0;
    }

    .aech-hero__grid {
      gap: 28px;
      padding: 0 0 40px;
    }

    .aech-hero__desc {
      max-width: 520px;
    }

    .aech-hero__title {
      font-size: 46px;
      line-height: 1.1em;
    }
  }

  @media (max-width: 960px) {
    .aech-hero {
      padding: 0 20px 96px;
    }

    .aech-hero__shell {
      padding: 130px 0 0;
    }

    .aech-hero__grid {
      grid-template-columns: 1fr;
      gap: 34px;
      padding: 0 0 40px;
    }

    .aech-hero__content {
      align-items: center;
      text-align: center;
    }

    .aech-hero__desc {
      max-width: 720px;
    }

    .aech-hero__trust,
    .aech-hero__points,
    .aech-hero__cta {
      justify-content: center;
    }

    .aech-hero__title {
      font-size: 42px;
      line-height: 1.1em;
    }

    .aech-hero__visual-card {
      padding: 26px 0 0;
    }

    .aech-hero__floating--top {
      left: 0;
    }

    .aech-hero__floating--bottom {
      right: 0;
      bottom: 34px;
    }
  }

  @media (max-width: 767px) {
    .aech-hero {
      margin-top: -80px;
      padding: 0 20px 90px;
    }

    .aech-hero__shell {
      padding: 120px 0 0;
    }

    .aech-hero__grid {
      padding: 0 0 30px;
    }

    .aech-hero__title {
      font-size: 30px;
      line-height: 1.2em;
      letter-spacing: 0;
    }

    .aech-hero__desc {
      font-size: 15px;
      line-height: 1.7;
    }

    .aech-hero__badge {
      font-size: 16px;
      line-height: 1.1em;
    }

    .aech-hero__point {
      font-size: 13px;
      padding: 8px 12px;
    }

    .aech-hero__cta {
      width: 100%;
      flex-direction: column;
    }

    .aech-hero__btn {
      width: 100%;
    }

    .aech-hero__trust {
      gap: 10px;
      justify-content: center;
    }

    .aech-hero__floating {
      position: static;
      margin-bottom: 12px;
      max-width: none;
    }

    .aech-hero__visual-card {
      padding: 18px 0 0;
    }
  }
</style>
