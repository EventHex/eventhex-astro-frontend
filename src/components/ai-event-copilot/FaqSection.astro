---
// AI Event Copilot — FAQ Section with JSON-LD structured data
const faqs = [
  {
    q: "What AI agents does EventHex offer?",
    a: "EventHex provides four specialized AI agents: the Analyst Agent for data insights, the Session Agent for agenda building, the Copywriter Agent for content generation, and the Ticket Agent for attendee support."
  },
  {
    q: "How does the Analyst Agent work?",
    a: "Ask questions about your event data in natural language — such as 'What's my ticket conversion rate?' — and the Analyst Agent queries your data and generates visualizations and insights instantly."
  },
  {
    q: "Can the Copywriter Agent generate email campaigns?",
    a: "Yes. The Copywriter Agent generates personalized email sequences, social media posts, session descriptions, and marketing content. You can review and edit before publishing."
  },
  {
    q: "Is the Ticket Agent available to attendees?",
    a: "Yes. The Ticket Agent operates 24/7 as an AI chatbot embedded in your event page or app. It handles registration questions, ticket issues, and event information queries automatically."
  },
  {
    q: "What AI models power EventHex copilots?",
    a: "EventHex AI agents are powered by state-of-the-art language models fine-tuned for event management. The exact models are continuously updated to provide the best performance."
  },
  {
    q: "Can I customize AI agent behavior?",
    a: "Yes. You can configure the Ticket Agent's knowledge base, set content tone for the Copywriter, and define data access permissions for the Analyst — all from the organizer dashboard."
  },
];

const checklist = [
  "Agent configuration",
  "Knowledge base setup",
  "Content tone settings",
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="aecfq-faq" data-aec-faq>
  <div class="aecfq-faq__inner">
    <div class="aecfq-faq__support">
      <span class="aecfq-faq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need help with AI Copilot?</span>
      <h2 class="aecfq-faq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="aecfq-faq__desc animate-on-scroll" data-animation="fadeInUp">
        We help event teams set up and configure AI agents for data analysis, content generation, and attendee support.
      </p>

      <div class="aecfq-faq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="aecfq-faq__support-label">Included with every rollout</span>
        <ul class="aecfq-faq__support-list">
          {checklist.map((item) => (
            <li class="aecfq-faq__support-item">{item}</li>
          ))}
        </ul>

        <div class="aecfq-faq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your AI agent setup before launch and keep your team aligned on data access, content tone, and escalation rules.</span>
        </div>

        <a href="/book-a-demo/" class="aecfq-faq__cta">Plan my AI setup</a>
      </div>
    </div>

    <div class="aecfq-faq__list">
      {faqs.map((faq, index) => (
        <details class="aecfq-faq__item animate-on-scroll" data-animation="fadeInUp" data-aecfq-item open={index === 0}>
          <summary class="aecfq-faq__question">
            <span>{faq.q}</span>
            <span class="aecfq-faq__icon" aria-hidden="true">
              <span class="aecfq-faq__icon-line aecfq-faq__icon-line--horizontal"></span>
              <span class="aecfq-faq__icon-line aecfq-faq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="aecfq-faq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const faqItems = Array.from(document.querySelectorAll('[data-aecfq-item]'));

  faqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      faqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style>
  .aecfq-faq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .aecfq-faq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .aecfq-faq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .aecfq-faq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .aecfq-faq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .aecfq-faq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .aecfq-faq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .aecfq-faq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .aecfq-faq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .aecfq-faq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .aecfq-faq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .aecfq-faq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .aecfq-faq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .aecfq-faq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .aecfq-faq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .aecfq-faq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .aecfq-faq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .aecfq-faq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .aecfq-faq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
    transition: color 0.2s ease;
  }

  .aecfq-faq__question::-webkit-details-marker {
    display: none;
  }

  .aecfq-faq__question::marker {
    display: none;
    content: "";
  }

  .aecfq-faq__question:hover {
    color: #375dfb;
  }

  .aecfq-faq__icon {
    position: relative;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    margin-top: 3px;
    color: #375dfb;
  }

  .aecfq-faq__icon-line {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 999px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .aecfq-faq__icon-line--horizontal {
    width: 20px;
    height: 2px;
  }

  .aecfq-faq__icon-line--vertical {
    width: 2px;
    height: 20px;
  }

  .aecfq-faq__answer {
    padding: 0 24px 24px;
  }

  .aecfq-faq__answer p {
    margin: 0;
    max-width: 92%;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.8;
    color: #5b6477;
  }

  .aecfq-faq__item[open] {
    background: #fff;
    border-color: rgba(55, 93, 251, 0.2);
    box-shadow: 0 2px 16px rgba(55, 93, 251, 0.06);
  }

  .aecfq-faq__item[open] .aecfq-faq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) scaleY(0.35);
  }

  @media (max-width: 1100px) {
    .aecfq-faq {
      padding: 76px 0;
    }

    .aecfq-faq__inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .aecfq-faq__support {
      position: static;
    }
  }

  @media (max-width: 1024px) {
    .aecfq-faq__title {
      font-size: 40px;
    }

    .aecfq-faq__desc {
      font-size: 16px;
    }

    .aecfq-faq__question {
      padding: 24px 22px;
      font-size: 20px;
    }

    .aecfq-faq__answer {
      padding: 0 22px 22px;
    }
  }

  @media (max-width: 767px) {
    .aecfq-faq {
      padding: 56px 0;
    }

    .aecfq-faq__inner {
      padding: 0 16px;
      gap: 24px;
    }

    .aecfq-faq__title {
      font-size: 32px;
      line-height: 1.08;
    }

    .aecfq-faq__desc {
      font-size: 15px;
      line-height: 1.7;
    }

    .aecfq-faq__support-card {
      padding: 20px 18px;
      border-radius: 24px;
    }

    .aecfq-faq__support-item {
      font-size: 15px;
    }

    .aecfq-faq__support-note strong {
      font-size: 18px;
    }

    .aecfq-faq__cta {
      width: 100%;
    }

    .aecfq-faq__item {
      border-radius: 24px;
    }

    .aecfq-faq__question {
      padding: 20px 18px;
      font-size: 17px;
      line-height: 1.45;
    }

    .aecfq-faq__answer {
      padding: 0 18px 20px;
    }

    .aecfq-faq__answer p {
      max-width: 100%;
      font-size: 15px;
      line-height: 1.75;
    }
  }
</style>
