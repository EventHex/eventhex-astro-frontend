---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "What AI agents does EventHex offer?", a: "EventHex provides four specialized AI agents: the Analyst Agent for data insights, the Session Agent for agenda building, the Copywriter Agent for content generation, and the Ticket Agent for attendee support." },
  { q: "How does the Analyst Agent work?", a: "Ask questions about your event data in natural language — such as 'What's my ticket conversion rate?' — and the Analyst Agent queries your data and generates visualizations and insights instantly." },
  { q: "Can the Copywriter Agent generate email campaigns?", a: "Yes. The Copywriter Agent generates personalized email sequences, social media posts, session descriptions, and marketing content. You can review and edit before publishing." },
  { q: "Is the Ticket Agent available to attendees?", a: "Yes. The Ticket Agent operates 24/7 as an AI chatbot embedded in your event page or app. It handles registration questions, ticket issues, and event information queries automatically." },
  { q: "What AI models power EventHex copilots?", a: "EventHex AI agents are powered by state-of-the-art language models fine-tuned for event management. The exact models are continuously updated to provide the best performance." },
  { q: "Can I customize AI agent behavior?", a: "Yes. You can configure the Ticket Agent's knowledge base, set content tone for the Copywriter, and define data access permissions for the Analyst — all from the organizer dashboard." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with AI Copilot?"
  title="Frequently Asked Questions"
  description="We help event teams set up and configure AI agents for data analysis, content generation, and attendee support."
/>
