---
// AI Event Copilot — Coordination Tools (Why Organizers Choose AI Copilot)
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="#375DFB" stroke-width="1.5" fill="none"/><path d="M12 8v4l3 3" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="2" fill="#375DFB" opacity=".3"/><path d="M8 3.5l1.5 1M16 3.5l-1.5 1M12 2v1.5" stroke="#375DFB" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "4 specialized agents",
    desc: "Purpose-built AI for data, content, sessions, and support.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#375DFB" stroke-width="2"/><path d="M12 7v5l3.5 3.5" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "24/7 availability",
    desc: "AI agents work around the clock — no breaks, no delays.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s-8-4.5-8-11V5l8-3 8 3v6c0 6.5-8 11-8 11z" stroke="#375DFB" stroke-width="2" stroke-linejoin="round" fill="none"/><path d="M9 12l2 2 4-4" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Human-in-the-loop",
    desc: "Always review and approve before AI outputs go live.",
  },
];
---

<section class="aecc-coord-full">
  <div class="aecc-coord-full__inner">
    <div class="aecc-coord-full__header">
      <span class="aecc-coord-full__tag animate-on-scroll" data-animation="fadeIn">Why Organizers Choose AI Copilot</span>
      <h2 class="aecc-coord-full__title animate-on-scroll" data-animation="fadeInUp">AI-Powered <b>Event Intelligence</b></h2>
      <p class="aecc-coord-full__desc animate-on-scroll" data-animation="fadeInUp">Four purpose-built AI agents for data analysis, content generation, session planning, and attendee support.</p>
    </div>

    <div class="aecc-coord-full__cards">
      {cards.map((card) => (
        <div class="aecc-coord-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="aecc-coord-full__card-icon" set:html={card.icon}></div>
          <h3 class="aecc-coord-full__card-title">{card.title}</h3>
          <p class="aecc-coord-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .aecc-coord-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .aecc-coord-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .aecc-coord-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .aecc-coord-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .aecc-coord-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .aecc-coord-full__title b { font-weight: 700; }

  .aecc-coord-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .aecc-coord-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .aecc-coord-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .aecc-coord-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .aecc-coord-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .aecc-coord-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .aecc-coord-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .aecc-coord-full { padding: 64px 0; }
    .aecc-coord-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .aecc-coord-full { padding: 52px 0; }
    .aecc-coord-full__title { font-size: 30px; line-height: 1.15; }
    .aecc-coord-full__desc { font-size: 15px; }
    .aecc-coord-full__cards { grid-template-columns: 1fr; }
  }
</style>
