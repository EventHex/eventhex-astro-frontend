<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll("[data-aecb-tab].aecb-tab");
    const panels = document.querySelectorAll("[data-aecb-tab].aecb-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const index = tab.getAttribute("data-aecb-tab");

        tabs.forEach((t) => t.classList.remove("aecb-tab--active"));
        panels.forEach((p) => p.classList.remove("aecb-panel--active"));

        tab.classList.add("aecb-tab--active");
        const panel = document.querySelector(`.aecb-panel[data-aecb-tab="${index}"]`);
        if (panel) panel.classList.add("aecb-panel--active");
      });
    });
  });
</script>

<style is:global>
