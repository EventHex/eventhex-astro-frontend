---
// AI Event Copilot Bento Grid — 3 tabbed panels with CSS-only visuals
---

<section class="aecb-bento-section">
  <div class="aecb" id="aec-bento">
    <h2 class="aecb-title">
      Four AI Agents for <b>Every Event Task</b>
    </h2>
    <p class="aecb-subtitle">
      Purpose-built AI agents for data analysis, session planning, content generation, and attendee support.
    </p>

    <nav class="aecb-nav">
      <button class="aecb-tab aecb-tab--active" data-aecb-tab="0">Analyst Agent</button>
      <button class="aecb-tab" data-aecb-tab="1">Session &amp; Copywriter</button>
      <button class="aecb-tab" data-aecb-tab="2">Ticket &amp; Support Agent</button>
    </nav>

    <!-- Tab 0: Analyst Agent -->
    <div class="aecb-panel aecb-panel--active" data-aecb-tab="0">
      <div class="aecb-grid" data-layout="a">
        <!-- Hero card -->
        <div class="aecb-card aecb-card--tall aecb-pos-0" style="animation-delay: 0s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Data Engine</span>
              <h3 class="aecb-card__title">Natural language data queries with instant charts, trend analysis, and revenue forecasting</h3>
              <p class="aecb-card__desc">Ask questions in plain English — &quot;What&apos;s my conversion rate this week?&quot; — and get instant data visualizations, trend spotting, and predictive insights.</p>
              <ul class="aecb-card__points">
                <li>Natural language queries</li>
                <li>Auto visualization</li>
                <li>Predictive insights</li>
              </ul>
            </div>
            <div class="aecb-card__img">
              <!-- CSS-only analyst dashboard -->
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 200 200" fill="none">
                <style is:inline>
                  @keyframes aecbFadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
                  @keyframes aecbPulse{0%,100%{opacity:.7}50%{opacity:1}}
                  .aecb-a1{animation:aecbFadeUp .6s ease both}
                  .aecb-a2{animation:aecbFadeUp .6s ease .15s both}
                  .aecb-a3{animation:aecbFadeUp .6s ease .3s both}
                  .aecb-a4{animation:aecbPulse 2s ease infinite}
                </style>
                <rect class="aecb-a1" x="15" y="15" width="170" height="170" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <!-- Query input bar -->
                <rect class="aecb-a1" x="25" y="25" width="150" height="24" rx="8" fill="#fff" stroke="#E5EBFF" stroke-width="1"/>
                <rect class="aecb-a1" x="32" y="33" width="80" height="6" rx="3" fill="#B4BAC6"/>
                <circle class="aecb-a4" cx="162" cy="37" r="6" fill="#375DFB" opacity=".3"/>
                <!-- Bar chart -->
                <rect class="aecb-a2" x="30" y="120" width="18" height="45" rx="4" fill="#375DFB" opacity=".8"/>
                <rect class="aecb-a2" x="54" y="100" width="18" height="65" rx="4" fill="#375DFB" opacity=".6"/>
                <rect class="aecb-a2" x="78" y="85" width="18" height="80" rx="4" fill="#375DFB" opacity=".9"/>
                <rect class="aecb-a3" x="102" y="110" width="18" height="55" rx="4" fill="#AFA3FF" opacity=".7"/>
                <rect class="aecb-a3" x="126" y="75" width="18" height="90" rx="4" fill="#10B981" opacity=".7"/>
                <rect class="aecb-a3" x="150" y="95" width="18" height="70" rx="4" fill="#ABFFFF" opacity=".5"/>
                <!-- Trend line -->
                <polyline class="aecb-a3" points="39,115 63,95 87,80 111,105 135,70 159,90" stroke="#375DFB" stroke-width="2" fill="none" stroke-linecap="round"/>
                <circle class="aecb-a4" cx="159" cy="90" r="4" fill="#10B981"/>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mini 1: Data Insights -->
        <div class="aecb-card aecb-card--sm aecb-pos-1" style="animation-delay: 0.06s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Insights</span>
              <h3 class="aecb-card__title">Event Data Insights</h3>
              <p class="aecb-card__desc">Ask questions in natural language and get instant data visualizations.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .ab1{animation:aecbFadeUp .5s ease both}
                  .ab2{animation:aecbFadeUp .5s ease .15s both}
                </style>
                <rect class="ab1" x="15" y="15" width="150" height="130" rx="14" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect class="ab2" x="28" y="90" width="16" height="40" rx="3" fill="#375DFB" opacity=".8"/>
                <rect class="ab2" x="50" y="70" width="16" height="60" rx="3" fill="#375DFB" opacity=".6"/>
                <rect class="ab2" x="72" y="55" width="16" height="75" rx="3" fill="#375DFB" opacity=".9"/>
                <rect class="ab2" x="94" y="80" width="16" height="50" rx="3" fill="#AFA3FF" opacity=".7"/>
                <rect class="ab2" x="116" y="45" width="16" height="85" rx="3" fill="#10B981" opacity=".7"/>
                <text class="ab2" x="32" y="87" font-size="7" fill="#667085" font-family="Inter,sans-serif">120</text>
                <text class="ab2" x="54" y="67" font-size="7" fill="#667085" font-family="Inter,sans-serif">340</text>
                <text class="ab2" x="76" y="52" font-size="7" fill="#667085" font-family="Inter,sans-serif">560</text>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mini 2: Trends -->
        <div class="aecb-card aecb-card--sm aecb-pos-2" style="animation-delay: 0.12s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Trends</span>
              <h3 class="aecb-card__title">Trend Analysis</h3>
              <p class="aecb-card__desc">Spot registration trends, revenue patterns, and engagement signals.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .at1{animation:aecbFadeUp .5s ease both}
                  .at2{animation:aecbFadeUp .5s ease .2s both}
                </style>
                <rect class="at1" x="15" y="15" width="150" height="130" rx="14" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <polyline class="at2" points="30,110 55,95 80,100 105,70 130,50 150,35" stroke="#375DFB" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline class="at2" points="30,115 55,108 80,110 105,90 130,80 150,70" stroke="#AFA3FF" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-dasharray="4 3"/>
                <circle class="at2" cx="150" cy="35" r="4" fill="#10B981"/>
                <rect class="at1" x="130" y="24" width="30" height="14" rx="7" fill="#10B981" opacity=".15"/>
                <text class="at1" x="135" y="34" font-size="7" fill="#10B981" font-family="Inter,sans-serif" font-weight="600">+42%</text>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mini 3: Behavior -->
        <div class="aecb-card aecb-card--sm aecb-pos-3" style="animation-delay: 0.18s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Behavior</span>
              <h3 class="aecb-card__title">Attendee Behavior</h3>
              <p class="aecb-card__desc">Understand audience segments, drop-off points, and preferences.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .av1{animation:aecbFadeUp .5s ease both}
                  .av2{animation:aecbFadeUp .5s ease .15s both}
                  .av3{animation:aecbFadeUp .5s ease .3s both}
                </style>
                <rect class="av1" x="15" y="15" width="150" height="130" rx="14" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <!-- User segments -->
                <circle class="av1" cx="55" cy="60" r="18" fill="#375DFB" opacity=".15"/>
                <circle class="av2" cx="55" cy="60" r="12" fill="#375DFB" opacity=".25"/>
                <text class="av2" x="49" y="64" font-size="8" fill="#375DFB" font-family="Inter,sans-serif" font-weight="600">VIP</text>
                <circle class="av2" cx="105" cy="55" r="14" fill="#AFA3FF" opacity=".2"/>
                <circle class="av2" cx="105" cy="55" r="9" fill="#AFA3FF" opacity=".35"/>
                <text class="av3" x="94" y="59" font-size="7" fill="#7C3AED" font-family="Inter,sans-serif" font-weight="600">General</text>
                <circle class="av3" cx="130" cy="85" r="11" fill="#10B981" opacity=".2"/>
                <circle class="av3" cx="130" cy="85" r="7" fill="#10B981" opacity=".35"/>
                <text class="av3" x="121" y="89" font-size="6" fill="#10B981" font-family="Inter,sans-serif" font-weight="600">Early</text>
                <rect class="av3" x="28" y="100" width="60" height="5" rx="2.5" fill="#D0D5DD"/>
                <rect class="av3" x="28" y="110" width="45" height="5" rx="2.5" fill="#E5EBFF"/>
                <rect class="av3" x="28" y="120" width="35" height="5" rx="2.5" fill="#E5EBFF"/>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mini 4: Forecast -->
        <div class="aecb-card aecb-card--sm aecb-pos-4" style="animation-delay: 0.24s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Forecast</span>
              <h3 class="aecb-card__title">Revenue Forecasting</h3>
              <p class="aecb-card__desc">AI-powered predictions on ticket sales and revenue targets.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .af1{animation:aecbFadeUp .5s ease both}
                  .af2{animation:aecbFadeUp .5s ease .2s both}
                  .af3{animation:aecbPulse 2s ease infinite}
                </style>
                <rect class="af1" x="15" y="15" width="150" height="130" rx="14" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <!-- Solid past line -->
                <polyline class="af2" points="30,110 55,95 80,85 105,70" stroke="#375DFB" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                <!-- Dotted future line -->
                <polyline class="af2" points="105,70 130,50 150,35" stroke="#375DFB" stroke-width="2" fill="none" stroke-linecap="round" stroke-dasharray="5 4"/>
                <circle class="af2" cx="105" cy="70" r="4" fill="#375DFB"/>
                <circle class="af3" cx="150" cy="35" r="5" fill="#10B981"/>
                <!-- Target zone -->
                <rect class="af2" x="120" y="25" width="40" height="20" rx="8" fill="#10B981" opacity=".1" stroke="#10B981" stroke-width="1" stroke-dasharray="3 2"/>
                <text class="af2" x="127" y="38" font-size="7" fill="#10B981" font-family="Inter,sans-serif" font-weight="600">Target</text>
                <!-- Area fill -->
                <polygon class="af1" points="30,110 55,95 80,85 105,70 130,50 150,35 150,130 30,130" fill="#375DFB" opacity=".05"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 1: Session & Copywriter -->
    <div class="aecb-panel" data-aecb-tab="1">
      <div class="aecb-grid" data-layout="b">
        <!-- Hero card -->
        <div class="aecb-card aecb-card--sm aecb-pos-0" style="animation-delay: 0s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Agenda</span>
              <h3 class="aecb-card__title">AI Agenda Builder</h3>
              <p class="aecb-card__desc">Generate optimized session schedules from speaker and topic inputs.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .ag1{animation:aecbFadeUp .5s ease both}
                  .ag2{animation:aecbFadeUp .5s ease .15s both}
                  .ag3{animation:aecbFadeUp .5s ease .3s both}
                </style>
                <rect class="ag1" x="15" y="15" width="150" height="130" rx="14" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <!-- Calendar header -->
                <rect class="ag1" x="25" y="25" width="130" height="22" rx="6" fill="#375DFB" opacity=".1"/>
                <text class="ag1" x="60" y="40" font-size="8" fill="#375DFB" font-family="Inter,sans-serif" font-weight="600">Mon   Tue   Wed</text>
                <!-- Time slots -->
                <rect class="ag2" x="25" y="55" width="62" height="18" rx="6" fill="#375DFB" opacity=".15"/>
                <rect class="ag2" x="25" y="55" width="62" height="18" rx="6" fill="none" stroke="#375DFB" stroke-width="1" opacity=".3"/>
                <text class="ag2" x="33" y="67" font-size="7" fill="#375DFB" font-family="Inter,sans-serif">9:00 Keynote</text>
                <rect class="ag3" x="93" y="55" width="62" height="18" rx="6" fill="#AFA3FF" opacity=".15"/>
                <text class="ag3" x="100" y="67" font-size="7" fill="#7C3AED" font-family="Inter,sans-serif">10:00 Panel</text>
                <rect class="ag2" x="25" y="80" width="130" height="18" rx="6" fill="#10B981" opacity=".1"/>
                <text class="ag2" x="33" y="92" font-size="7" fill="#10B981" font-family="Inter,sans-serif">11:30 Workshop — AI in Events</text>
                <rect class="ag3" x="25" y="105" width="62" height="18" rx="6" fill="#F59E0B" opacity=".15"/>
                <text class="ag3" x="33" y="117" font-size="7" fill="#D97706" font-family="Inter,sans-serif">14:00 Break</text>
                <rect class="ag3" x="93" y="105" width="62" height="18" rx="6" fill="#375DFB" opacity=".12"/>
                <text class="ag3" x="100" y="117" font-size="7" fill="#375DFB" font-family="Inter,sans-serif">15:00 Demo</text>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mini: Description Gen -->
        <div class="aecb-card aecb-card--sm aecb-pos-1" style="animation-delay: 0.06s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Copy</span>
              <h3 class="aecb-card__title">Description Generation</h3>
              <p class="aecb-card__desc">Write compelling session descriptions from minimal prompts.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .ad1{animation:aecbFadeUp .5s ease both}
                  .ad2{animation:aecbFadeUp .5s ease .2s both}
                </style>
                <rect class="ad1" x="15" y="15" width="150" height="130" rx="14" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <rect class="ad1" x="25" y="28" width="80" height="7" rx="3.5" fill="#22272F"/>
                <rect class="ad2" x="25" y="42" width="130" height="5" rx="2.5" fill="#B4BAC6"/>
                <rect class="ad2" x="25" y="52" width="120" height="5" rx="2.5" fill="#D0D5DD"/>
                <rect class="ad2" x="25" y="62" width="100" height="5" rx="2.5" fill="#D0D5DD"/>
                <!-- AI cursor -->
                <rect class="ad2" x="25" y="78" width="90" height="5" rx="2.5" fill="#375DFB" opacity=".2"/>
                <rect class="ad2" x="115" y="76" width="2" height="9" rx="1" fill="#375DFB" opacity=".8">
                  <animate attributeName="opacity" values="1;0.3;1" dur="1s" repeatCount="indefinite"/>
                </rect>
                <rect class="ad2" x="25" y="95" width="110" height="22" rx="11" fill="#375DFB" opacity=".1"/>
                <text class="ad2" x="46" y="109" font-size="8" fill="#375DFB" font-family="Inter,sans-serif" font-weight="600">&#x2728; AI Generated</text>
              </svg>
            </div>
          </div>
        </div>
        <!-- Hero: Content Engine -->
        <div class="aecb-card aecb-card--tall aecb-pos-2" style="animation-delay: 0.12s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Content Engine</span>
              <h3 class="aecb-card__title">AI agenda building, session descriptions, email campaigns, and social media content</h3>
              <p class="aecb-card__desc">Generate optimized session schedules from speaker inputs. Write session descriptions, email sequences, and social posts in seconds — in 15+ languages.</p>
              <ul class="aecb-card__points">
                <li>AI agenda builder</li>
                <li>Email campaign copy</li>
                <li>Multi-language content</li>
              </ul>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="200" height="200" viewBox="0 0 200 200" fill="none">
                <style is:inline>
                  .ac1{animation:aecbFadeUp .6s ease both}
                  .ac2{animation:aecbFadeUp .6s ease .15s both}
                  .ac3{animation:aecbFadeUp .6s ease .3s both}
                </style>
                <rect class="ac1" x="15" y="15" width="170" height="170" rx="16" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <!-- Editor UI -->
                <rect class="ac1" x="25" y="25" width="150" height="20" rx="6" fill="#fff" stroke="#E5EBFF" stroke-width="1"/>
                <circle class="ac1" cx="35" cy="35" r="4" fill="#FF5F57"/>
                <circle class="ac1" cx="47" cy="35" r="4" fill="#FEBC2E"/>
                <circle class="ac1" cx="59" cy="35" r="4" fill="#28C840"/>
                <!-- Content lines -->
                <rect class="ac2" x="30" y="55" width="100" height="7" rx="3.5" fill="#22272F"/>
                <rect class="ac2" x="30" y="68" width="140" height="5" rx="2.5" fill="#B4BAC6"/>
                <rect class="ac2" x="30" y="78" width="130" height="5" rx="2.5" fill="#D0D5DD"/>
                <rect class="ac2" x="30" y="88" width="110" height="5" rx="2.5" fill="#D0D5DD"/>
                <!-- Email section -->
                <rect class="ac3" x="30" y="105" width="140" height="30" rx="8" fill="#375DFB" opacity=".08"/>
                <rect class="ac3" x="40" y="112" width="50" height="5" rx="2.5" fill="#375DFB" opacity=".4"/>
                <rect class="ac3" x="40" y="122" width="80" height="4" rx="2" fill="#375DFB" opacity=".2"/>
                <!-- Social card -->
                <rect class="ac3" x="30" y="145" width="65" height="30" rx="8" fill="#1DA1F2" opacity=".1"/>
                <rect class="ac3" x="38" y="153" width="40" height="4" rx="2" fill="#1DA1F2" opacity=".35"/>
                <rect class="ac3" x="38" y="161" width="50" height="4" rx="2" fill="#1DA1F2" opacity=".2"/>
                <rect class="ac3" x="105" y="145" width="65" height="30" rx="8" fill="#0A66C2" opacity=".1"/>
                <rect class="ac3" x="113" y="153" width="40" height="4" rx="2" fill="#0A66C2" opacity=".35"/>
                <rect class="ac3" x="113" y="161" width="50" height="4" rx="2" fill="#0A66C2" opacity=".2"/>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mini: Email Copy -->
        <div class="aecb-card aecb-card--sm aecb-pos-3" style="animation-delay: 0.18s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Email</span>
              <h3 class="aecb-card__title">Email Campaign Copy</h3>
              <p class="aecb-card__desc">Generate personalized email sequences for promotions.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .ae1{animation:aecbFadeUp .5s ease both}
                  .ae2{animation:aecbFadeUp .5s ease .2s both}
                </style>
                <rect class="ae1" x="15" y="15" width="150" height="130" rx="14" fill="#F5F8FF" stroke="#E5EBFF" stroke-width="1.5"/>
                <!-- Email template -->
                <rect class="ae1" x="25" y="25" width="130" height="110" rx="10" fill="#fff" stroke="#E5EBFF" stroke-width="1"/>
                <rect class="ae2" x="35" y="35" width="70" height="6" rx="3" fill="#22272F"/>
                <rect class="ae2" x="35" y="47" width="110" height="4" rx="2" fill="#B4BAC6"/>
                <rect class="ae2" x="35" y="56" width="100" height="4" rx="2" fill="#D0D5DD"/>
                <!-- Personalization token -->
                <rect class="ae2" x="35" y="70" width="60" height="16" rx="8" fill="#375DFB" opacity=".1"/>
                <text class="ae2" x="42" y="81" font-size="7" fill="#375DFB" font-family="Inter,sans-serif" font-weight="500">&#123;firstName&#125;</text>
                <rect class="ae2" x="35" y="95" width="110" height="4" rx="2" fill="#D0D5DD"/>
                <rect class="ae2" x="35" y="105" width="60" height="18" rx="9" fill="#375DFB" opacity=".15"/>
                <text class="ae2" x="47" y="117" font-size="7" fill="#375DFB" font-family="Inter,sans-serif" font-weight="600">Register Now</text>
              </svg>
            </div>
          </div>
        </div>
        <!-- Mini: Social Post -->
        <div class="aecb-card aecb-card--sm aecb-pos-4" style="animation-delay: 0.24s">
          <div class="aecb-card__inner">
            <div class="aecb-card__text">
              <span class="aecb-card__eyebrow">Social</span>
              <h3 class="aecb-card__title">Social Post Creation</h3>
              <p class="aecb-card__desc">Create platform-optimized social media content in seconds.</p>
            </div>
            <div class="aecb-card__img">
              <svg xmlns="http://www.w3.org/2000/svg" width="180" height="160" viewBox="0 0 180 160" fill="none">
                <style is:inline>
                  .as1{animation:aecbFadeUp .5s ease both}
