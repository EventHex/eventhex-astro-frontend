---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "How does InstaRecap generate session summaries?", a: "InstaRecap uses AI speech-to-text transcription combined with NLP to process session audio in real-time. It extracts key takeaways, notable quotes, and topic classifications to create a comprehensive session recap automatically." },
  { q: "Does InstaRecap work with virtual events?", a: "Yes. InstaRecap integrates with major virtual platforms and AV systems. Whether your sessions are in-person, virtual, or hybrid, InstaRecap processes the audio and generates recaps seamlessly." },
  { q: "How quickly are recaps available after a session?", a: "Recaps are typically available within minutes of a session ending. For live events, real-time transcription means the recap is nearly complete by the time the session wraps up." },
  { q: "Can speakers access their own session data?", a: "Yes. Each speaker gets a dedicated dashboard showing their session analytics, audience feedback, ratings, and top questions. They also get pre-formatted social cards to share their session highlights." },
  { q: "What languages does InstaRecap support?", a: "InstaRecap supports transcription and recap generation in 25+ languages, making it ideal for international conferences and multi-language events." },
  { q: "Are the recap pages SEO optimized?", a: "Yes. Every session recap page is automatically optimized with structured data, meta tags, and clean URLs — driving long-tail search traffic back to your event content." },
  { q: "Can I customize the recap page branding?", a: "Absolutely. Recap pages are fully branded with your event logo, colors, and sponsor placements. They match your event's visual identity." },
  { q: "Is attendee data shared in the recaps?", a: "No. Recaps focus on session content — summaries, speaker quotes, and engagement metrics. Individual attendee data is never exposed in public recap pages." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need a custom recap setup?"
  title="Frequently Asked Questions"
  description="We help event teams shape AI transcription, recap delivery, and speaker analytics around how their live event operations actually run."
/>
