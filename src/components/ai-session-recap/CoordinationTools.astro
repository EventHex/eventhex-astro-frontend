---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="#375DFB" stroke-width="2"/><path d="M8 12h8M8 8h5M8 16h6" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "AI-powered transcription",
    desc: "Real-time speech-to-text with 98%+ accuracy, handling accents, jargon, and multi-speaker detection across all session formats.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="14" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M3 10h18" stroke="#375DFB" stroke-width="2"/><path d="M8 14h4M8 17h2" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Automated recap delivery",
    desc: "Session recaps with summaries, key takeaways, and speaker quotes delivered via email digest and branded public pages.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="9" cy="8" r="3" stroke="#375DFB" stroke-width="2"/><path d="M3 20a6 6 0 0112 0" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M16 11l2 2 4-4" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Speaker and sponsor value",
    desc: "Give speakers session analytics and social cards while placing sponsor content alongside high-engagement recap pages.",
  },
];
---

<section class="asrc-full">
  <div class="asrc-full__inner">
    <div class="asrc-full__header">
      <span class="asrc-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose InstaRecap</span>
      <h2 class="asrc-full__title animate-on-scroll" data-animation="fadeInUp">Effortless Session <b>Recap Delivery</b></h2>
      <p class="asrc-full__desc animate-on-scroll" data-animation="fadeInUp">Keep transcription, recap generation, speaker analytics, and attendee delivery aligned without adding more tools to the event-day stack.</p>
    </div>

    <div class="asrc-full__cards">
      {cards.map((card) => (
        <div class="asrc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="asrc-full__card-icon" set:html={card.icon}></div>
          <h3 class="asrc-full__card-title">{card.title}</h3>
          <p class="asrc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .asrc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .asrc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .asrc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .asrc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .asrc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .asrc-full__title b { font-weight: 700; }

  .asrc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .asrc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .asrc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .asrc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .asrc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .asrc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .asrc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .asrc-full { padding: 64px 0; }
    .asrc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .asrc-full { padding: 52px 0; }
    .asrc-full__title { font-size: 30px; line-height: 1.15; }
    .asrc-full__desc { font-size: 15px; }
    .asrc-full__cards { grid-template-columns: 1fr; }
  }
</style>
