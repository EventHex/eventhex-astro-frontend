---
import { asrbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "AI Summaries",
    hero: {
      title: "Auto-generate session summaries, key takeaways, and speaker quotes in real-time",
      desc: "InstaRecap processes live audio, extracts core insights, and assembles structured recaps without manual note-taking or post-event editing.",
      visual: "summary",
    },
    cards: [
      { title: "Auto Session Summaries", desc: "Full session recaps generated from audio transcription with structured highlights and topic breakdowns.", visual: "doc" },
      { title: "Key Takeaways", desc: "AI identifies the most actionable points from each session and surfaces them in a scannable list.", visual: "takeaway" },
      { title: "Speaker Quotes", desc: "Notable quotes are automatically tagged to the correct speaker with timestamp references.", visual: "quote" },
      { title: "Topic Classification", desc: "Sessions are auto-tagged by topic, track, and theme for searchable post-event content libraries.", visual: "tag" },
    ],
  },
  {
    label: "Engagement Analytics",
    hero: {
      title: "Track session engagement from ratings and attendance to Q&A highlights",
      desc: "Give organizers and speakers a complete picture of how each session performed with real-time engagement data and post-session analytics.",
      visual: "analytics",
    },
    cards: [
      { title: "Session Ratings", desc: "Collect and display attendee ratings per session for immediate speaker and organizer feedback.", visual: "rating" },
      { title: "Attendance Tracking", desc: "Real-time and post-event attendance numbers per session, room, and track.", visual: "attend" },
      { title: "Q&A Highlights", desc: "Top questions from each session surfaced automatically in the recap alongside speaker responses.", visual: "qa" },
      { title: "Engagement Heatmap", desc: "Visual timeline showing when audience engagement peaked during each session.", visual: "heatmap" },
    ],
  },
  {
    label: "Distribution",
    hero: {
      title: "Distribute session recaps through email, web pages, social, and API",
      desc: "Every recap becomes a multi-channel content asset — delivered as email digests, shareable web pages, social snippets, and downloadable PDFs.",
      visual: "distribute",
    },
    cards: [
      { title: "Email Digest", desc: "Attendees receive personalized recap emails with summaries and links to full session pages.", visual: "email" },
      { title: "Social Snippets", desc: "Pre-formatted session highlight cards optimized for LinkedIn, X, and Instagram sharing.", visual: "social" },
      { title: "PDF Reports", desc: "Export branded session recap PDFs for sponsors, speakers, and internal stakeholders.", visual: "pdf" },
      { title: "API Access", desc: "Programmatic access to recap data, transcripts, and analytics for custom integrations.", visual: "api" },
    ],
  },
];

const ICON = '<svg class="asrb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="asrb-section" id="asr-bento">
  <div class="asrb">
    <h2 class="asrb-title">
      AI <b>Transcription</b>, Session Analytics & <b>Distribution</b>
    </h2>
    <p class="asrb-subtitle">
      Process session audio in real-time, extract insights, and distribute recap content across
      email, web, and social without leaving the EventHex workflow.
    </p>

    <nav class="asrb-nav">
      {tabs.map((t, i) => (
        <button class={`asrb-tab ${i === 0 ? "asrb-tab--active" : ""}`} data-asrb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`asrb-panel ${tabIdx === 0 ? "asrb-panel--active" : ""}`} data-asrb-panel={String(tabIdx)}>
        <div class="asrb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="asrb-card asrb-card--tall asrb-pos-0" style="animation-delay:0s">
            <div class="asrb-card__inner">
              <div class="asrb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="asrb-card__title">{t.hero.title}</h3>
                <p class="asrb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="asrb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`asrb-card asrb-card--sm asrb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="asrb-card__inner asrb-card__inner--row">
                <div class="asrb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="asrb-card__title">{c.title}</h3>
                  <p class="asrb-card__desc">{c.desc}</p>
                </div>
                <div class="asrb-card__img asrb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const asrbTabs = Array.from(document.querySelectorAll('[data-asrb-tab]'));
  const asrbPanels = Array.from(document.querySelectorAll('[data-asrb-panel]'));
  let asrbActive = 0;
  let asrbInterval: ReturnType<typeof setInterval>;

  function setAsrbTab(index: number) {
    asrbTabs.forEach((t) => t.classList.remove('asrb-tab--active'));
    asrbPanels.forEach((p) => p.classList.remove('asrb-panel--active'));
    asrbTabs[index]?.classList.add('asrb-tab--active');
    asrbPanels[index]?.classList.add('asrb-panel--active');
    asrbActive = index;
  }
  function startAsrb() {
    asrbInterval = setInterval(() => setAsrbTab((asrbActive + 1) % asrbTabs.length), 5000);
  }
  asrbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setAsrbTab(i); clearInterval(asrbInterval); startAsrb(); }));
  startAsrb();
  const asrbSection = document.querySelector('.asrb-section');
  if (asrbSection) {
    asrbSection.addEventListener('mouseenter', () => clearInterval(asrbInterval));
    asrbSection.addEventListener('mouseleave', () => startAsrb());
  }
</script>

<style>
  .asrb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .asrb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .asrb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .asrb-title b { font-weight: 700; }
  .asrb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .asrb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .asrb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .asrb-tab:hover { background: rgba(55,93,251,.08); }
  .asrb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .asrb-panel { display: none; }
  .asrb-panel--active { display: block; animation: asrbFadeUp 0.4s ease; }
  @keyframes asrbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .asrb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .asrb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .asrb-pos-1 { grid-column: 2; grid-row: 1; }
  .asrb-pos-2 { grid-column: 3; grid-row: 1; }
  .asrb-pos-3 { grid-column: 2; grid-row: 2; }
  .asrb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .asrb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .asrb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .asrb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .asrb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .asrb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .asrb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .asrb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .asrb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .asrb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .asrb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --asrb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .asrb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: asrbCardIn 0.5s ease forwards;
  }
  .asrb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--asrb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .asrb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .asrb-card:hover::after { opacity: 1; animation: asrbBorder 2.4s linear infinite; }
  @keyframes asrbBorder { to { --asrb-angle: 360deg; } }
  @keyframes asrbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .asrb-pos-1 { animation-delay: 0.06s; }
  .asrb-pos-2 { animation-delay: 0.12s; }
  .asrb-pos-3 { animation-delay: 0.18s; }
  .asrb-pos-4 { animation-delay: 0.24s; }

  .asrb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .asrb-card__inner--row { flex-direction: row; }
  .asrb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .asrb-card--tall .asrb-card__text { padding: 20px 20px 8px; }
  .asrb-card--sm .asrb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .asrb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .asrb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .asrb-card--sm .asrb-card__title { font-size: 17px; }
  .asrb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .asrb-card--sm .asrb-card__desc { font-size: 13px; }

  .asrb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .asrb-card--tall .asrb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .asrb-card--sm .asrb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .asrb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .asrb-card:hover .asrb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: asrbFloat 2.2s ease-in-out infinite;
  }
  @keyframes asrbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .asrb-section { padding: 60px 0 48px; }
    .asrb-title { font-size: 36px; }
    .asrb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .asrb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .asrb-pos-1, .asrb-pos-2, .asrb-pos-3, .asrb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .asrb-pos-0, [data-layout="c"] .asrb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .asrb-pos-1, [data-layout="b"] .asrb-pos-2, [data-layout="b"] .asrb-pos-3, [data-layout="b"] .asrb-pos-4,
    [data-layout="c"] .asrb-pos-1, [data-layout="c"] .asrb-pos-2, [data-layout="c"] .asrb-pos-3, [data-layout="c"] .asrb-pos-4 { grid-column: auto; grid-row: auto; }
    .asrb-card--tall .asrb-card__inner { flex-direction: row; }
    .asrb-card--tall .asrb-card__text { flex: 1; }
    .asrb-card--tall .asrb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .asrb-title { font-size: 28px; }
    .asrb-subtitle { font-size: 15px; }
    .asrb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .asrb-tab { border-radius: 12px; }
    .asrb-grid { grid-template-columns: 1fr; }
    .asrb-pos-0, .asrb-pos-1, .asrb-pos-2, .asrb-pos-3, .asrb-pos-4,
    [data-layout="b"] .asrb-pos-0, [data-layout="b"] .asrb-pos-1, [data-layout="b"] .asrb-pos-2, [data-layout="b"] .asrb-pos-3, [data-layout="b"] .asrb-pos-4,
    [data-layout="c"] .asrb-pos-0, [data-layout="c"] .asrb-pos-1, [data-layout="c"] .asrb-pos-2, [data-layout="c"] .asrb-pos-3, [data-layout="c"] .asrb-pos-4 { grid-column: 1; grid-row: auto; }
    .asrb-card--sm .asrb-card__inner, .asrb-card--tall .asrb-card__inner { flex-direction: row; }
    .asrb-card--sm .asrb-card__text, .asrb-card--tall .asrb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .asrb-card--sm .asrb-card__img, .asrb-card--tall .asrb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .asrb-card { animation: none !important; opacity: 1; transform: none; }
    .asrb-card:hover::after { animation: none !important; }
    .asrb-card:hover .asrb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
