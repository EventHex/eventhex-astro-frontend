---
const steps = [
  {
    num: "01",
    title: "Connect Audio Source",
    desc: "Link session audio from AV setup or virtual platform. InstaRecap starts transcribing in real-time.",
  },
  {
    num: "02",
    title: "AI Processes Session",
    desc: "AI generates transcripts, extracts key takeaways, identifies speaker quotes, and classifies topics.",
  },
  {
    num: "03",
    title: "Recap Page Created",
    desc: "Each session gets a branded, SEO-optimized recap page with summary, highlights, and engagement data.",
  },
  {
    num: "04",
    title: "Distribute and Share",
    desc: "Auto-send recap emails to attendees, share social snippets, and export PDF reports for sponsors.",
  },
];
---

<section class="asrhw-full">
  <div class="asrhw-full__inner">
    <div class="asrhw-full__header">
      <span class="asrhw-full__tag animate-on-scroll" data-animation="fadeIn">How InstaRecap Works</span>
      <h2 class="asrhw-full__title animate-on-scroll" data-animation="fadeInUp">From Audio to <b>Searchable Recap Pages</b></h2>
      <p class="asrhw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Connect your session audio, let AI do the heavy lifting, and deliver branded recap content to every attendee and stakeholder automatically.
      </p>
    </div>

    <div class="asrhw-full__cards">
      {steps.map((step) => (
        <article class="asrhw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="asrhw-full__card-icon">{step.num}</div>
          <h3 class="asrhw-full__card-title">{step.title}</h3>
          <p class="asrhw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .asrhw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .asrhw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .asrhw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .asrhw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .asrhw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .asrhw-full__title b { font-weight: 700; }

  .asrhw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .asrhw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .asrhw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .asrhw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .asrhw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .asrhw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .asrhw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .asrhw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .asrhw-full { padding: 64px 0; }
    .asrhw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .asrhw-full { padding: 52px 0; }
    .asrhw-full__title { font-size: 30px; line-height: 1.15; }
    .asrhw-full__desc { font-size: 15px; }
    .asrhw-full__cards { grid-template-columns: 1fr; }
  }
</style>
