---
const featureCards = [
  {
    eyebrow: "AI transcription",
    title: "From session audio to actionable insights in minutes",
    desc: "InstaRecap transcribes session audio in real-time, processes speaker content through NLP, and delivers structured summaries before attendees leave the venue.",
    items: [
      "Real-time speech-to-text transcription",
      "Instant AI processing after session end",
      "Multi-language support for 25+ languages",
    ],
    visual: "transcribe",
  },
  {
    eyebrow: "Content engine",
    title: "Turn sessions into evergreen searchable content",
    desc: "Every session becomes a branded, SEO-optimized recap page with summaries, key takeaways, and engagement data — driving long-tail search traffic back to your event.",
    items: [
      "SEO-optimized recap pages with structured data",
      "Email digests auto-sent to attendees",
      "Engagement reports for organizers and sponsors",
    ],
    visual: "content",
  },
  {
    eyebrow: "Speaker intelligence",
    title: "Give speakers their own session analytics dashboard",
    desc: "Each speaker gets a dedicated view of session ratings, audience feedback, top questions, and pre-formatted social cards to share their best moments.",
    items: [
      "Speaker-specific analytics dashboard",
      "Audience feedback and session ratings",
      "Pre-formatted social sharing cards",
    ],
    visual: "speaker",
  },
  {
    eyebrow: "Attendee delivery",
    title: "Deliver personalized session recaps to every attendee",
    desc: "Attendees receive curated email digests with session summaries, bookmarkable moments, and downloadable PDFs — delivered automatically after each session.",
    items: [
      "Personalized email digest per attendee",
      "Bookmarkable moments and key quotes",
      "Downloadable branded PDF reports",
    ],
    visual: "delivery",
  },
];
---

<section class="asrf-shell">
  <div class="asrf-section">
    <div class="asrf-header">
      <span class="asrf-subtitle">Key features that turn session audio into post-event content</span>
      <h2 class="asrf-title">
        Everything You Need to <span class="asrf-highlight">Transcribe, Summarize, and Distribute</span><br />
        Session Recaps
      </h2>
    </div>

    <div class="asrf-cards" id="asrf-stacking-cards">
      {featureCards.map((card, index) => (
        <div class="asrf-card" data-card-index={index} style={`--card-index: ${index}; top: calc(20px + ${index * 20}px);`}>
          <div class="asrf-card-content">
            <span class="asrf-card-eyebrow">{card.eyebrow}</span>
            <h3 class="asrf-card-title">{card.title}</h3>
            <p class="asrf-card-desc">{card.desc}</p>
            <ul class="asrf-card-items">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href="/book-a-demo/" class="asrf-card-btn">Explore More</a>
          </div>

          <div class={`asrf-card-visual asrf-card-visual--${card.visual}`}>
            {card.visual === "transcribe" && (
              <Fragment>
                <div class="asrf-waveform">
                  <span></span><span></span><span></span><span></span><span></span>
                  <span></span><span></span><span></span><span></span><span></span>
                </div>
                <div class="asrf-transcript-card">
                  <div class="asrf-transcript-head"></div>
                  <div class="asrf-transcript-lines">
                    <span></span><span></span><span></span>
                  </div>
                </div>
                <div class="asrf-visual-pill">Live transcription</div>
              </Fragment>
            )}

            {card.visual === "content" && (
              <Fragment>
                <div class="asrf-page-preview">
                  <div class="asrf-page-header"></div>
                  <div class="asrf-page-body">
                    <span></span><span></span><span></span><span></span>
                  </div>
                </div>
                <div class="asrf-seo-badge">SEO optimized</div>
                <div class="asrf-email-chip">
                  <strong>Email digest</strong>
                  <span>Auto-sent</span>
                </div>
              </Fragment>
            )}

            {card.visual === "speaker" && (
              <Fragment>
                <div class="asrf-dashboard">
                  <div class="asrf-dashboard-avatar"></div>
                  <div class="asrf-dashboard-stats">
                    <div><strong>4.8</strong><span>Rating</span></div>
                    <div><strong>342</strong><span>Attended</span></div>
                  </div>
                </div>
                <div class="asrf-social-card">
                  <span>Share card</span>
                  <strong>Ready for LinkedIn</strong>
                </div>
              </Fragment>
            )}

            {card.visual === "delivery" && (
              <Fragment>
                <div class="asrf-inbox">
                  <div class="asrf-inbox-item asrf-inbox-item--one">
                    <span class="asrf-inbox-dot"></span>
                    <div><strong>Session recap</strong><span>AI keynote highlights</span></div>
                  </div>
                  <div class="asrf-inbox-item asrf-inbox-item--two">
                    <span class="asrf-inbox-dot"></span>
                    <div><strong>PDF ready</strong><span>Download your report</span></div>
                  </div>
                </div>
                <div class="asrf-visual-pill">Personalized delivery</div>
              </Fragment>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .asrf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .asrf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .asrf-header {
    width: 72%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .asrf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .asrf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .asrf-highlight { color: #AFA3FF; }

  .asrf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .asrf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.88));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .asrf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .asrf-card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(175, 163, 255, 0.12);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #afa3ff;
  }

  .asrf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .asrf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .asrf-card-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .asrf-card-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .asrf-card-items li::before {
    content: "";
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
  }

  .asrf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .asrf-card-btn:hover { transform: scale(1.05); }

  .asrf-card-visual {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
    background: radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 52%);
  }

  /* Transcribe visual */
  .asrf-waveform {
    position: absolute;
    left: 40px;
    top: 60px;
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 80px;
  }

  .asrf-waveform span {
    width: 4px;
    border-radius: 999px;
    background: linear-gradient(180deg, #375dfb, #38bdf8);
    animation: asrf-wave 1.6s ease-in-out infinite;
  }

  .asrf-waveform span:nth-child(1) { height: 30px; animation-delay: 0s; }
  .asrf-waveform span:nth-child(2) { height: 50px; animation-delay: 0.1s; }
  .asrf-waveform span:nth-child(3) { height: 70px; animation-delay: 0.2s; }
  .asrf-waveform span:nth-child(4) { height: 40px; animation-delay: 0.3s; }
  .asrf-waveform span:nth-child(5) { height: 60px; animation-delay: 0.4s; }
  .asrf-waveform span:nth-child(6) { height: 45px; animation-delay: 0.5s; }
  .asrf-waveform span:nth-child(7) { height: 75px; animation-delay: 0.6s; }
  .asrf-waveform span:nth-child(8) { height: 35px; animation-delay: 0.7s; }
  .asrf-waveform span:nth-child(9) { height: 55px; animation-delay: 0.8s; }
  .asrf-waveform span:nth-child(10) { height: 25px; animation-delay: 0.9s; }

  .asrf-transcript-card {
    position: absolute;
    right: 36px;
    top: 88px;
    width: 220px;
    padding: 18px;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 22px 46px -36px rgba(17, 28, 56, 0.52);
  }

  .asrf-transcript-head {
    height: 8px;
    width: 50%;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
    margin-bottom: 12px;
  }

  .asrf-transcript-lines { display: flex; flex-direction: column; gap: 8px; }
  .asrf-transcript-lines span { display: block; height: 6px; border-radius: 999px; background: rgba(55, 93, 251, 0.08); }
  .asrf-transcript-lines span:nth-child(1) { width: 90%; }
  .asrf-transcript-lines span:nth-child(2) { width: 75%; }
  .asrf-transcript-lines span:nth-child(3) { width: 60%; }

  .asrf-visual-pill {
    position: absolute;
    right: 32px;
    bottom: 36px;
    display: inline-flex;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: #183465;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
  }

  /* Content visual */
  .asrf-page-preview {
    position: absolute;
    left: 34px;
    top: 60px;
    right: 120px;
    padding: 18px;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 20px 40px -28px rgba(17, 28, 56, 0.5);
  }

  .asrf-page-header {
    height: 10px;
    width: 55%;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
    margin-bottom: 14px;
  }

  .asrf-page-body { display: flex; flex-direction: column; gap: 8px; }
  .asrf-page-body span { display: block; height: 6px; border-radius: 999px; background: rgba(55, 93, 251, 0.08); }
  .asrf-page-body span:nth-child(1) { width: 95%; }
  .asrf-page-body span:nth-child(2) { width: 80%; }
  .asrf-page-body span:nth-child(3) { width: 65%; }
  .asrf-page-body span:nth-child(4) { width: 85%; }

  .asrf-seo-badge {
    position: absolute;
    left: 34px;
    bottom: 90px;
    display: inline-flex;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.14);
    color: #16a34a;
    font-size: 13px;
    font-weight: 700;
  }

  .asrf-email-chip {
    position: absolute;
    right: 34px;
    bottom: 46px;
    display: grid;
    gap: 4px;
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(20, 33, 59, 0.95);
    color: #f8fbff;
    box-shadow: 0 20px 40px -26px rgba(17, 28, 56, 0.7);
  }

  .asrf-email-chip strong { font-size: 15px; }
  .asrf-email-chip span { color: rgba(248, 251, 255, 0.76); font-size: 13px; }

  /* Speaker visual */
  .asrf-dashboard {
    position: absolute;
    left: 34px;
    top: 70px;
    right: 80px;
    padding: 20px;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 20px 40px -28px rgba(17, 28, 56, 0.5);
  }

  .asrf-dashboard-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(55, 93, 251, 0.34), rgba(34, 197, 94, 0.24));
    flex-shrink: 0;
  }

  .asrf-dashboard-stats {
    display: flex;
    gap: 20px;
  }

  .asrf-dashboard-stats div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .asrf-dashboard-stats strong { color: #183465; font-size: 20px; }
  .asrf-dashboard-stats span { color: #607390; font-size: 13px; }

  .asrf-social-card {
    position: absolute;
    right: 34px;
    bottom: 60px;
    display: grid;
    gap: 4px;
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(20, 33, 59, 0.95);
    color: #f8fbff;
    box-shadow: 0 20px 40px -26px rgba(17, 28, 56, 0.7);
  }

  .asrf-social-card span { color: rgba(248, 251, 255, 0.76); font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; }
  .asrf-social-card strong { font-size: 15px; }

  /* Delivery visual */
  .asrf-inbox {
    position: absolute;
    left: 34px;
    top: 80px;
    right: 80px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .asrf-inbox-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 18px 36px -28px rgba(17, 28, 56, 0.4);
  }

  .asrf-inbox-item--two { margin-left: 20px; }

  .asrf-inbox-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #375dfb;
    flex-shrink: 0;
  }

  .asrf-inbox-item div { display: flex; flex-direction: column; gap: 2px; }
  .asrf-inbox-item strong { color: #183465; font-size: 14px; }
  .asrf-inbox-item span { color: #607390; font-size: 12px; }

  @keyframes asrf-wave {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }

  @media (max-width: 1024px) {
    .asrf-section { padding: 60px 20px 30px; }
    .asrf-header { width: 80%; }
    .asrf-subtitle { font-size: 16px; }
    .asrf-title { font-size: 40px; line-height: 1em; }
    .asrf-card { height: 450px; }
    .asrf-card-content { flex-basis: 50%; }
    .asrf-card-title { font-size: 28px; }
    .asrf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .asrf-section { padding: 50px 20px 30px; }
    .asrf-header { width: 100%; }
    .asrf-title { font-size: 30px; }
    .asrf-card { flex-direction: column; height: 620px; }
    .asrf-card-content { flex: 0 0 55%; padding: 20px 20px 0; }
    .asrf-card-visual { min-height: 260px; padding: 12px; }
    .asrf-card-title { font-size: 24px; }
    .asrf-card-desc { font-size: 15px; }
    .asrf-cards { padding-bottom: 40px; }
    .asrf-waveform { left: 20px; top: 30px; }
    .asrf-transcript-card { right: 18px; top: 50px; width: 180px; }
    .asrf-page-preview { left: 20px; right: 80px; }
    .asrf-dashboard { left: 20px; right: 40px; }
    .asrf-inbox { left: 20px; right: 40px; }
    .asrf-social-card,
    .asrf-email-chip { right: 18px; }
  }
</style>
