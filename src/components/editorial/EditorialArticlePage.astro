---
import EditorialCard from "./EditorialCard.astro";
import type { EditorialEntry } from "../../lib/editorial";

interface Props {
  item: EditorialEntry | null;
  relatedItems?: EditorialEntry[];
  collectionHref: string;
  collectionLabel: string;
  canonicalUrl: string;
}

const { item, relatedItems = [], collectionHref, collectionLabel, canonicalUrl } = Astro.props;

const shareUrl = encodeURIComponent(canonicalUrl);
const shareTitle = encodeURIComponent(item?.title ?? collectionLabel);
const shareLinks = item
  ? [
      { label: "LinkedIn", icon: "in", href: `https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}` },
      { label: "X", icon: "𝕏", href: `https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareTitle}` },
      { label: "Facebook", icon: "f", href: `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}` },
    ]
  : [];
---

{/* Astro scoped styles require elements to be static — we split conditionals into two top-level blocks */}

{item && (
<article class="art" itemscope itemtype="https://schema.org/BlogPosting">
  <header class="art-hero">
    <div class="art-hero__inner">
      <nav class="art-breadcrumb" aria-label="Breadcrumb">
        <a href="/">EventHex</a>
        <span class="art-breadcrumb__sep" aria-hidden="true">/</span>
        <a href={collectionHref}>{collectionLabel}</a>
        <span class="art-breadcrumb__sep" aria-hidden="true">/</span>
        <span class="art-breadcrumb__current" aria-current="page">{item.title}</span>
      </nav>

      <div class="art-hero__meta">
        <span class="art-hero__category">{item.category}</span>
        <time datetime={item.date} itemprop="datePublished">{item.formattedDate}</time>
        <span>{item.readingTime} min read</span>
      </div>

      <h1 class="art-hero__title" itemprop="headline">{item.title}</h1>
      <p class="art-hero__lead" itemprop="description">{item.description}</p>

      <div class="art-hero__author">
        <div class="art-hero__author-avatar" aria-hidden="true">
          {item.author.charAt(0)}
        </div>
        <div class="art-hero__author-text">
          <span class="art-hero__author-name" itemprop="author" itemscope itemtype="https://schema.org/Person">
            <span itemprop="name">{item.author}</span>
          </span>
          <span class="art-hero__author-role">EventHex Editorial</span>
        </div>
      </div>
    </div>
  </header>

  {item.image && (
    <div class="art-cover">
      <img
        src={item.image.src}
        alt={item.image.alt}
        width={item.image.width}
        height={item.image.height}
        loading="eager"
        itemprop="image"
      />
    </div>
  )}

  <div class="art-grid">
    <div class="art-body" itemprop="articleBody">
      <div class="art-prose" set:html={item.contentHtml} />

      <footer class="art-body__footer">
        <div class="art-body__share">
          <span class="art-body__share-label">Share this article</span>
          <div class="art-body__share-links">
            {shareLinks.map(link => (
              <a href={link.href} target="_blank" rel="noreferrer" class="art-share-btn" aria-label={`Share on ${link.label}`}>
                <span class="art-share-btn__icon">{link.icon}</span>
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </footer>
    </div>

    <aside class="art-aside">
      <div class="art-aside__sticky">
        {item.headings.length > 0 && (
          <nav class="art-toc" aria-label="Table of contents">
            <h2 class="art-aside__heading">Contents</h2>
            <ul class="art-toc__list">
              {item.headings.map(h => (
                <li class:list={["art-toc__item", h.level === 3 && "art-toc__item--sub"]}>
                  <a href={`#${h.id}`} class="art-toc__link" data-toc-link>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <div class="art-aside-cta">
          <p class="art-aside-cta__eyebrow">Ready to level up?</p>
          <h3 class="art-aside-cta__title">See EventHex in action</h3>
          <p class="art-aside-cta__desc">Discover how AI streamlines every part of your event workflow.</p>
          <a href="/book-a-demo/" class="art-aside-cta__btn">Request a demo</a>
        </div>
      </div>
    </aside>
  </div>

  {relatedItems.length > 0 && (
    <section class="art-related">
      <div class="art-related__inner">
        <div class="art-related__header">
          <h2 class="art-related__title">Continue reading</h2>
          <a href={collectionHref} class="art-related__all">View all →</a>
        </div>
        <div class="art-related__grid">
          {relatedItems.map(r => <EditorialCard item={r} showDescription={false} />)}
        </div>
      </div>
    </section>
  )}
</article>
)}

{!item && (
<section class="art-404">
  <h1>Article not found</h1>
  <p>The page you're looking for doesn't exist or may have been moved.</p>
  <a href={collectionHref} class="art-404__btn">Browse {collectionLabel}</a>
</section>
)}

<script>
  // TOC scroll-spy: highlight the current heading in the sidebar
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (tocLinks.length > 0) {
    const headingIds = Array.from(tocLinks).map(link => link.getAttribute('href')!.slice(1));
    const headings = headingIds
      .map(id => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    const activate = (id: string) => {
      tocLinks.forEach(link => {
        const isActive = link.getAttribute('href') === `#${id}`;
        link.classList.toggle('is-active', isActive);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activate(entry.target.id);
            break;
          }
        }
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headings.forEach(h => observer.observe(h));
  }
</script>

<style>
  /* ── Hero ── */
  .art-hero {
    position: relative;
    margin-top: -90px;
    background:
      radial-gradient(circle at 18% 30%, rgba(175, 163, 255, 0.14), transparent 28%),
      radial-gradient(circle at 80% 24%, rgba(171, 255, 255, 0.14), transparent 30%),
      url('https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }

  .art-hero__inner {
    max-width: 1000px;
    margin: 0 auto;
    background: url('https://eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat;
    padding: 180px 24px 80px;
  }

  .art-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--label-gray, #868c98);
    margin-bottom: 2rem;
  }
  .art-breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }
  .art-breadcrumb a:hover { color: var(--brand-blue); }
  .art-breadcrumb__sep { opacity: 0.5; }
  .art-breadcrumb__current {
    color: var(--body-gray, #525866);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 40ch;
  }

  .art-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--body-gray, #525866);
    margin-bottom: 1.25rem;
  }
  .art-hero__category {
    color: var(--brand-blue, #375dfb);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.75rem;
    background: rgba(55, 93, 251, 0.08);
    border-radius: 6px;
    font-size: 0.75rem;
  }

  /* Fix #2: Match site hero typography — 42px/600 Manrope */
  .art-hero__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 600;
    line-height: 50px;
    letter-spacing: -0.5px;
    color: var(--heading-dark, #22272f);
    margin-bottom: 1.25rem;
  }

  .art-hero__lead {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray, #475467);
    margin-bottom: 2.5rem;
    max-width: 640px;
  }

  .art-hero__author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .art-hero__author-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--brand-blue, #375dfb);
    color: #fff;
    display: grid;
    place-items: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
  }
  .art-hero__author-text {
    display: flex;
    flex-direction: column;
  }
  .art-hero__author-name {
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--heading-dark);
    font-size: 0.9375rem;
  }
  .art-hero__author-role {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--label-gray, #868c98);
  }

  /* Fix #4: Cover image — unified width, no awkward translateY */
  .art-cover {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px;
    margin-top: -40px;
  }
  .art-cover img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
    box-shadow: 0 16px 48px rgba(15, 23, 42, 0.1);
  }

  /* Fix #1 & #4: Unified grid width (1000px) with wider sidebar */
  .art-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 4rem;
    max-width: 1000px;
    margin: 0 auto;
    padding: 3.5rem 24px 5rem;
  }

  /* Fix #5: Darken body text for readability */
  .art-prose {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.85;
    color: #374151;
  }
  .art-prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    line-height: 1.25;
    color: var(--heading-dark, #22272F);
    margin: 2.75rem 0 1rem;
    scroll-margin-top: 6rem;
  }
  /* Fix #10: H3 with left accent border */
  .art-prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--heading-dark, #22272F);
    margin: 2.25rem 0 0.75rem;
    padding-left: 14px;
    border-left: 3px solid var(--brand-blue, #375DFB);
    scroll-margin-top: 6rem;
  }
  .art-prose :global(p) {
    margin-bottom: 1.35rem;
  }
  /* Fix #7: Collapse paragraph spacing inside list items */
  .art-prose :global(li > p) {
    margin-bottom: 0;
  }
  .art-prose :global(li > p + p) {
    margin-top: 0.5rem;
  }
  .art-prose :global(a) {
    color: var(--brand-blue);
    text-decoration: underline;
    text-decoration-color: rgba(55, 93, 251, 0.3);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }
  .art-prose :global(a:hover) {
    text-decoration-color: var(--brand-blue);
  }
  .art-prose :global(img),
  .art-prose :global(figure) {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 2rem 0;
  }
  .art-prose :global(ul),
  .art-prose :global(ol) {
    margin-bottom: 1.35rem;
    padding-left: 1.35rem;
  }
  .art-prose :global(li) {
    margin-bottom: 0.5rem;
  }
  .art-prose :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 3px solid var(--brand-blue);
    background: var(--surface-light, #f5f8ff);
    border-radius: 0 10px 10px 0;
    font-style: italic;
    color: var(--heading-dark);
    font-size: 1.125rem;
  }
  .art-prose :global(pre) {
    margin: 2rem 0;
    padding: 1.25rem;
    border-radius: 10px;
    background: #1e293b;
    color: #e2e8f0;
    overflow-x: auto;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .art-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9375rem;
  }
  .art-prose :global(th),
  .art-prose :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--surface-card-border, #e8ecf2);
    text-align: left;
  }
  .art-prose :global(th) {
    font-weight: 600;
    color: var(--heading-dark);
  }

  .art-body__footer {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--surface-card-border, #e8ecf2);
  }
  .art-body__share-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--label-gray, #868c98);
    margin-bottom: 1rem;
  }
  .art-body__share-links {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .art-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--surface-card-border, #e8ecf2);
    background: #fff;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--body-gray, #525866);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .art-share-btn:hover {
    border-color: var(--brand-blue);
    color: var(--brand-blue);
  }
  .art-share-btn__icon {
    font-weight: 800;
    font-size: 0.9375rem;
    line-height: 1;
  }

  /* ── Sidebar ── */
  .art-aside__sticky {
    position: sticky;
    top: 5.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .art-aside__heading {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--label-gray, #868c98);
    margin-bottom: 0.875rem;
  }

  .art-toc__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  /* Fix #8: TOC scroll-spy active state */
  .art-toc__link {
    display: block;
    padding: 0.375rem 0.75rem;
    border-left: 2px solid transparent;
    border-radius: 0 6px 6px 0;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--body-gray, #525866);
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .art-toc__link:hover {
    background: rgba(55, 93, 251, 0.06);
    color: var(--brand-blue);
  }
  .art-toc__link:global(.is-active) {
    border-left-color: var(--brand-blue, #375DFB);
    color: var(--brand-blue, #375DFB);
    background: rgba(55, 93, 251, 0.06);
    font-weight: 600;
  }
  .art-toc__item--sub .art-toc__link {
    padding-left: 1.5rem;
    font-size: 0.78125rem;
    color: var(--label-gray, #868c98);
  }

  /* Fix #9: Dark card CTA matching site pattern */
  .art-aside-cta {
    padding: 1.5rem;
    border-radius: 14px;
    border: 1px solid var(--dark-card-border, rgba(172, 161, 241, 0.51));
    background:
      radial-gradient(circle at top right, rgba(171, 255, 255, 0.18), transparent 60%),
      radial-gradient(circle at bottom left, rgba(159, 129, 255, 0.15), transparent 50%),
      var(--dark-card-bg, #333864);
  }
  .art-aside-cta__eyebrow {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-cyan, #ABFFFF);
    margin-bottom: 0.5rem;
  }
  .art-aside-cta__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }
  .art-aside-cta__desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1.25rem;
  }
  .art-aside-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    background: var(--brand-blue, #375DFB);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s, background 0.2s;
  }
  .art-aside-cta__btn:hover {
    transform: translateY(-1px);
    background: var(--brand-blue-hover, #1C46D4);
  }

  /* Fix #9: Related section with subtle bg */
  .art-related {
    background: var(--surface-light, #F5F8FF);
    padding: 0 0 4rem;
  }
  .art-related__inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .art-related__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
    padding-top: 3.5rem;
  }
  .art-related__title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.5px;
    color: var(--heading-dark);
  }
  .art-related__all {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--brand-blue);
    text-decoration: none;
    white-space: nowrap;
  }
  .art-related__all:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .art-related__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── 404 ── */
  .art-404 {
    text-align: center;
    padding: 10rem 1.5rem;
  }
  .art-404 h1 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin-bottom: 1rem;
  }
  .art-404 p {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--subheading-gray);
    margin-bottom: 2.5rem;
  }
  .art-404__btn {
    display: inline-flex;
    padding: 0.75rem 1.75rem;
    border-radius: 10px;
    background: var(--brand-blue);
    color: #fff;
    font-family: var(--font-body);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .art-404__btn:hover { background: var(--brand-blue-hover, #1c46d4); }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .art-hero__inner {
      padding: 140px 20px 60px;
    }
    .art-hero__title {
      font-size: 36px;
      line-height: 44px;
    }
    .art-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .art-aside__sticky {
      position: static;
    }
    .art-related__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .art-hero__inner {
      padding: 120px 16px 50px;
    }
    .art-hero__title {
      font-size: 28px;
      line-height: 36px;
      letter-spacing: 0;
    }
    .art-hero__lead {
      font-size: 16px;
      line-height: 24px;
    }
    .art-cover {
      padding: 0 16px;
      margin-top: -24px;
    }
    .art-grid {
      padding: 2.5rem 16px 4rem;
    }
    .art-related {
      padding: 0 0 3rem;
    }
    .art-related__inner {
      padding: 0 16px;
    }
    .art-related__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
