---
import type { EditorialEntry } from "../../lib/editorial";

interface Props {
  item: EditorialEntry;
  variant?: "feature" | "stack" | "standard";
  showDescription?: boolean;
}

const { item, variant = "standard", showDescription = true } = Astro.props;
---

<article class={`editorial-card editorial-card--${variant}`}>
  <a class="editorial-card__media" href={item.href} aria-label={`Open ${item.title}`}>
    {item.image ? (
      <img
        src={item.image.src}
        alt={item.image.alt}
        loading="lazy"
        width={item.image.width}
        height={item.image.height}
      />
    ) : (
      <div class="editorial-card__media-fallback">
        <span>{item.category}</span>
      </div>
    )}
  </a>

  <div class="editorial-card__body">
    <div class="editorial-card__meta">
      <span class="editorial-card__pill">{item.category}</span>
      <span class="editorial-card__date">{item.formattedDate}</span>
    </div>

    <h3 class="editorial-card__title">
      <a href={item.href}>{item.title}</a>
    </h3>

    {showDescription && <p class="editorial-card__description">{item.description}</p>}

    <div class="editorial-card__footer">
      <span class="editorial-card__author">{item.author}</span>
      <a href={item.href} class="editorial-card__arrow" aria-label={`Read ${item.title}`}>
        <svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="17" cy="17" r="16.5" stroke="#E8ECF2"/>
          <path d="M14 11l6 6-6 6" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  /* ── Standard card — matches home blog card pattern ── */
  .editorial-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 20px;
    border: 1px solid #CBCDD1;
    background: #ffffff;
    padding: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .editorial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  /* ── Media / image ── */
  .editorial-card__media {
    display: block;
    height: 220px;
    overflow: hidden;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(55, 93, 251, 0.14), rgba(171, 255, 255, 0.22));
  }

  .editorial-card__media img,
  .editorial-card__media-fallback {
    width: 100%;
    height: 100%;
  }

  .editorial-card__media img {
    display: block;
    object-fit: cover;
  }

  .editorial-card__media-fallback {
    display: grid;
    place-items: end start;
    padding: 20px;
    background:
      radial-gradient(circle at top right, rgba(171, 255, 255, 0.7), transparent 42%),
      linear-gradient(160deg, rgba(55, 93, 251, 0.18), rgba(245, 248, 255, 0.92));
  }

  .editorial-card__media-fallback span {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 8px 12px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-blue, #375DFB);
    background: rgba(255, 255, 255, 0.85);
  }

  /* ── Body ── */
  .editorial-card__body {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 16px 4px 4px;
    flex: 1;
  }

  /* ── Meta row ── */
  .editorial-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .editorial-card__pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
    color: #000000;
  }

  .editorial-card__date {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--body-gray, #525866);
  }

  /* ── Title ── */
  .editorial-card__title {
    margin: 0;
    padding: 16px 0;
    min-height: 90px;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 30px;
    color: #000000;
  }

  .editorial-card__title a {
    color: inherit;
    text-decoration: none;
  }

  /* ── Description ── */
  .editorial-card__description {
    margin: 0 0 16px;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--body-gray, #525866);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Footer ── */
  .editorial-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
  }

  .editorial-card__author {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--body-gray, #525866);
  }

  .editorial-card__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .editorial-card:hover .editorial-card__arrow {
    transform: translateX(4px);
  }

  /* ══════════════════════════════════════
     FEATURE variant — wide two-column
     ══════════════════════════════════════ */
  .editorial-card--feature {
    flex-direction: row;
    padding: 20px;
    border-radius: 24px;
  }

  .editorial-card--feature .editorial-card__media {
    flex: 0 0 52%;
    height: auto;
    min-height: 340px;
    border-radius: 16px;
  }

  .editorial-card--feature .editorial-card__body {
    padding: 20px 8px 8px 28px;
    justify-content: center;
  }

  .editorial-card--feature .editorial-card__title {
    font-size: clamp(24px, 2.5vw, 32px);
    line-height: 1.2;
    min-height: auto;
    padding: 20px 0;
  }

  .editorial-card--feature .editorial-card__description {
    font-size: 16px;
    -webkit-line-clamp: 3;
  }

  /* ══════════════════════════════════════
     STACK variant — horizontal compact
     ══════════════════════════════════════ */
  .editorial-card--stack {
    flex-direction: row;
    padding: 16px;
  }

  .editorial-card--stack .editorial-card__media {
    flex: 0 0 180px;
    height: auto;
    min-height: 100%;
  }

  .editorial-card--stack .editorial-card__body {
    padding: 8px 4px 4px 16px;
    gap: 0;
  }

  .editorial-card--stack .editorial-card__title {
    font-size: 18px;
    line-height: 26px;
    min-height: auto;
    padding: 10px 0;
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .editorial-card--feature,
    .editorial-card--stack {
      flex-direction: column;
    }

    .editorial-card--feature .editorial-card__media,
    .editorial-card--stack .editorial-card__media {
      flex: none;
      min-height: 240px;
      height: 240px;
    }

    .editorial-card--feature .editorial-card__body {
      padding: 16px 4px 4px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .editorial-card {
      border-radius: 16px;
      padding: 14px;
    }

    .editorial-card__media {
      height: 200px;
    }

    .editorial-card__title {
      font-size: 20px;
      line-height: 1.3;
      min-height: auto;
      padding: 12px 0;
    }

    .editorial-card__body {
      padding: 12px 2px 2px;
    }
  }
</style>