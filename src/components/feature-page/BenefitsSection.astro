---
// Shared Benefits/Why Choose cards section
// Used by: Centralized Dashboard, AI Smart-Connect, etc.

interface BenefitCard {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  cards: BenefitCard[];
}

const { sectionTitle, cards } = Astro.props;
---

<section class="fp-benefits">
  <div class="fp-benefits__inner">
    <div class="fp-benefits__header">
      <h2 class="fp-benefits__title">{sectionTitle}</h2>
    </div>
    <div class="fp-benefits__grid">
      {cards.map((card) => (
        <div class="fp-benefits__card">
          <div class="fp-benefits__card-icon">
            <img src={card.icon} alt="" width="48" height="48" loading="lazy" />
          </div>
          <h3 class="fp-benefits__card-title">{card.title}</h3>
          <p class="fp-benefits__card-desc">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .fp-benefits {
    padding: 80px 20px;
  }

  .fp-benefits__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }

  .fp-benefits__header {
    flex-shrink: 0;
    width: 40%;
  }

  .fp-benefits__title {
    font-family: "Manrope", var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 60px;
    letter-spacing: -1px;
    color: #000000;
    margin: 0;
    position: sticky;
    top: 100px;
  }

  .fp-benefits__grid {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .fp-benefits__card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .fp-benefits__card-icon {
    width: 48px;
    height: 48px;
  }

  .fp-benefits__card-icon img {
    width: 100%;
    height: 100%;
    display: block;
  }

  .fp-benefits__card-title {
    font-family: "Manrope", var(--font-heading);
    font-size: 24px;
    font-weight: 600;
    color: #000000;
    margin: 0;
    line-height: 1.3;
  }

  .fp-benefits__card-desc {
    font-family: "Inter", var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 26px;
    color: #475467;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .fp-benefits {
      padding: 60px 20px;
    }

    .fp-benefits__inner {
      flex-direction: column;
      gap: 40px;
    }

    .fp-benefits__header {
      width: 100%;
    }

    .fp-benefits__title {
      font-size: 35px;
      line-height: 1.1;
      position: static;
    }
  }

  @media (max-width: 767px) {
    .fp-benefits {
      padding: 40px 20px;
    }

    .fp-benefits__title {
      font-size: 30px;
    }
  }
</style>
