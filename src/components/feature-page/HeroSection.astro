---
// Shared Hero Section for feature pages
// Used by: Event Marketing, Event Registration, Sponsor Management, Exhibitor Management, etc.

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaText?: string;
  ctaHref?: string;
  image: string;
  imageAlt: string;
}

const {
  eyebrow,
  title,
  description,
  ctaText = "Get a demo",
  ctaHref = "/book-a-demo/",
  image,
  imageAlt,
} = Astro.props;
---

<section class="fp-hero">
  <div class="fp-hero__card">
    <div class="fp-hero__content">
      <h3 class="fp-hero__eyebrow">{eyebrow}</h3>
      <div class="fp-hero__title-wrap">
        <h1 class="fp-hero__title">{title}</h1>
      </div>
      <h2 class="fp-hero__desc">{description}</h2>
      <a href={ctaHref} class="fp-hero__btn">{ctaText}</a>
    </div>
    <div class="fp-hero__media">
      <img src={image} alt={imageAlt} width="720" height="540" loading="eager" />
    </div>
  </div>
</section>

<style>
  .fp-hero {
    padding: 20px 10px 10px;
    max-width: 1300px;
    margin: 0 auto;
  }

  .fp-hero__card {
    display: flex;
    flex-direction: row;
    align-items: center;
    background:
      url("https://eventhex.ai/wp-content/uploads/2025/03/Frame-48096154-1.png") center / cover no-repeat,
      url("https://eventhex.ai/wp-content/uploads/2025/03/Rectangle-1205.jpg") center / cover no-repeat;
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 49px;
    padding: 60px 40px;
    overflow: hidden;
  }

  .fp-hero__content {
    width: 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
  }

  .fp-hero__eyebrow {
    font-family: "Inter", var(--font-body);
    font-size: 22px;
    font-weight: 400;
    color: #375DFB;
    margin: 0;
  }

  .fp-hero__title-wrap {
    max-width: 50%;
  }

  .fp-hero__title {
    font-family: "Manrope", var(--font-heading);
    font-size: 50px;
    font-weight: 400;
    line-height: 58px;
    letter-spacing: -1px;
    color: #000000;
    margin: 0;
  }

  .fp-hero__desc {
    font-family: "Inter", var(--font-body);
    font-size: 20px;
    font-weight: 400;
    line-height: 26px;
    color: #475467;
    margin: 0;
    max-width: 56%;
  }

  .fp-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    background-color: #375DFB;
    color: #ffffff;
    font-family: "Inter", var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    border-radius: 10px;
    text-decoration: none;
    transition: background-color 0.2s;
    width: fit-content;
  }

  .fp-hero__btn:hover {
    background-color: #1C46D4;
  }

  .fp-hero__media {
    width: 55%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .fp-hero__media img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 1024px) {
    .fp-hero {
      padding: 20px;
    }

    .fp-hero__card {
      padding: 30px;
    }

    .fp-hero__content {
      width: 50%;
    }

    .fp-hero__media {
      width: 50%;
    }

    .fp-hero__eyebrow {
      font-size: 20px;
    }

    .fp-hero__title {
      font-size: 35px;
      line-height: 1.1;
    }

    .fp-hero__title-wrap {
      max-width: 100%;
    }

    .fp-hero__desc {
      font-size: 18px;
      max-width: 100%;
    }
  }

  @media (max-width: 767px) {
    .fp-hero__card {
      flex-direction: column;
      padding: 40px 20px 20px;
      border-radius: 30px;
    }

    .fp-hero__content {
      width: 100%;
    }

    .fp-hero__media {
      width: 100%;
    }

    .fp-hero__title {
      font-size: 30px;
      line-height: 1.2;
    }

    .fp-hero__btn {
      font-size: 12px;
      padding: 5px;
    }
  }
</style>
