---
// Shared Feature Split Section for feature pages
// Used by: Event Marketing, Event Registration, Sponsor Management, etc.

interface FeatureItem {
  title: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  items: FeatureItem[];
  image: string;
  imageAlt: string;
  imageLeft?: boolean;
  dark?: boolean;
  backgroundImage?: string;
  backgroundColor?: string;
  imageOverflow?: boolean;
}

const {
  sectionTitle,
  items,
  image,
  imageAlt,
  imageLeft = true,
  dark = false,
  backgroundImage = "",
  backgroundColor = "transparent",
  imageOverflow = false,
} = Astro.props;

const sectionStyle = [
  backgroundColor !== "transparent" ? `background-color: ${backgroundColor}` : "",
  backgroundImage ? `background-image: url("${backgroundImage}")` : "",
  backgroundImage ? "background-repeat: no-repeat; background-size: cover" : "",
].filter(Boolean).join("; ");
---

<section
  class:list={[
    "fp-feature",
    imageLeft ? "fp-feature--img-left" : "fp-feature--img-right",
    dark && "fp-feature--dark",
    imageOverflow && "fp-feature--overflow",
  ]}
  style={sectionStyle}
>
  <div class="fp-feature__inner">
    {imageLeft ? (
      <>
        <div class="fp-feature__media">
          <img src={image} alt={imageAlt} width="600" height="450" loading="lazy" />
        </div>
        <div class="fp-feature__content">
          <h2 class="fp-feature__title">{sectionTitle}</h2>
          <ul class="fp-feature__list">
            {items.map((item) => (
              <li class="fp-feature__item">
                <span class="fp-feature__icon">
                  <img src="https://eventhex.ai/wp-content/uploads/2025/03/Vector-4.svg" alt="" width="16" height="16" loading="lazy" />
                </span>
                <div class="fp-feature__item-text">
                  <strong class="fp-feature__item-title">{item.title}</strong>
                  <span class="fp-feature__item-desc">{item.description}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </>
    ) : (
      <>
        <div class="fp-feature__content">
          <h2 class="fp-feature__title">{sectionTitle}</h2>
          <ul class="fp-feature__list">
            {items.map((item) => (
              <li class="fp-feature__item">
                <span class="fp-feature__icon">
                  <img src="https://eventhex.ai/wp-content/uploads/2025/03/Vector-4.svg" alt="" width="16" height="16" loading="lazy" />
                </span>
                <div class="fp-feature__item-text">
                  <strong class="fp-feature__item-title">{item.title}</strong>
                  <span class="fp-feature__item-desc">{item.description}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="fp-feature__media">
          <img src={image} alt={imageAlt} width="600" height="450" loading="lazy" />
        </div>
      </>
    )}
  </div>
</section>

<style>
  .fp-feature {
    padding: 80px 0;
    overflow: hidden;
  }

  .fp-feature--dark {
    border-top: 1px solid rgba(172, 161, 241, 0.51);
    border-bottom: 1px solid rgba(172, 161, 241, 0.51);
  }

  .fp-feature__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    gap: 0;
  }

  .fp-feature__media {
    width: 52%;
    display: flex;
    align-items: center;
  }

  .fp-feature--img-right .fp-feature__media {
    width: 50%;
    justify-content: flex-end;
  }

  .fp-feature--overflow .fp-feature__media img {
    margin-right: -157px;
  }

  .fp-feature__media img {
    width: 100%;
    height: auto;
    display: block;
  }

  .fp-feature__content {
    width: 48%;
    display: flex;
    flex-direction: column;
    gap: 20px;
    justify-content: center;
  }

  .fp-feature--img-right .fp-feature__content {
    width: 50%;
  }

  .fp-feature__title {
    font-family: "Manrope", var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 60px;
    letter-spacing: -1px;
    color: #000000;
    margin: 0;
  }

  .fp-feature--dark .fp-feature__title {
    color: #ffffff;
  }

  .fp-feature__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .fp-feature__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .fp-feature__icon {
    flex-shrink: 0;
    margin-top: 6px;
    width: 16px;
    height: 16px;
  }

  .fp-feature__icon img {
    width: 16px;
    height: 16px;
    display: block;
  }

  .fp-feature__item-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .fp-feature__item-title {
    font-family: "Inter", var(--font-body);
    font-size: 20px;
    font-weight: 700;
    color: #000000;
    line-height: 1.3;
  }

  .fp-feature--dark .fp-feature__item-title {
    color: #ffffff;
  }

  .fp-feature__item-desc {
    font-family: "Inter", var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    color: #475467;
  }

  .fp-feature--dark .fp-feature__item-desc {
    color: #ffffff;
  }

  @media (max-width: 1024px) {
    .fp-feature {
      padding: 60px 20px;
    }

    .fp-feature__title {
      font-size: 35px;
      line-height: 1.1;
    }

    .fp-feature--overflow .fp-feature__media img {
      margin-right: -20px;
    }
  }

  @media (max-width: 767px) {
    .fp-feature {
      padding: 40px 20px;
    }

    .fp-feature__inner {
      flex-direction: column;
      gap: 20px;
    }

    .fp-feature--img-right .fp-feature__inner {
      flex-direction: column-reverse;
    }

    .fp-feature__media,
    .fp-feature__content,
    .fp-feature--img-right .fp-feature__media,
    .fp-feature--img-right .fp-feature__content {
      width: 100%;
    }

    .fp-feature__title {
      font-size: 30px;
      line-height: 1.2;
    }

    .fp-feature--overflow .fp-feature__media img {
      margin-right: -20px;
      width: 75%;
    }
  }
</style>
