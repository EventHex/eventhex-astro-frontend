---
const WP = "https://cms.eventhex.ai/wp-content";

const tabs = [
  {
    id: 0,
    label: "Pre-Event",
    layout: "c",
    cards: [
      { title: "Event Builder", desc: "Build Your Event's Website with Just a Few Clicks!", image: `${WP}/uploads/2025/03/AI-Website-Builder.svg`, size: "sm" },
      { title: "Event Ticketing", desc: "Manage Ticket Sales and Monetize Your Event", image: `${WP}/uploads/2025/03/Event-Ticketing.svg`, size: "sm" },
      { title: "Sponsor Management", desc: "Manage registration & monitor payments", image: `${WP}/uploads/2025/03/Sponsor-Management.svg`, size: "sm" },
      { title: "AI Form Builder", desc: "Speak to Your Device to Build and Fill Forms", image: `${WP}/uploads/2025/03/AI-Form-Builder.svg`, size: "sm" },
      { title: "Event Marketing", desc: "Use Built-In Email & WhatsApp Campaign Modules to Effectively Market Your Event", image: `${WP}/uploads/2025/03/Event-Marketing.svg`, size: "tall" },
    ],
  },
  {
    id: 1,
    label: "Event Day",
    layout: "b",
    cards: [
      { title: "Centralized Dashboard", desc: "Command All Your Event from a Single Dashboard", image: `${WP}/uploads/2025/03/CentralizedDashboard.svg`, size: "tall" },
      { title: "Attendee App", desc: "Build A Website with AI Completely No Code!", image: `${WP}/uploads/2025/03/Attendee-App.svg`, size: "sm" },
      { title: "AI Smart-Connect", desc: "Deliver Personalized Networking Opportunities for Attendees Based on Shared Interests", image: `${WP}/uploads/2025/03/AI-Smart-Connect.svg`, size: "sm" },
      { title: "Speaker Management", desc: "Organize all speaker-related information with ease", image: `${WP}/uploads/2025/03/Speaker-Management.svg`, size: "sm" },
      { title: "Session Management", desc: "Coordinate all sessions from a single dashboard", image: `${WP}/uploads/2025/03/SessionManagement.svg`, size: "sm" },
    ],
  },
  {
    id: 2,
    label: "Post-Event",
    layout: "a",
    cards: [
      { title: "AI-Photo Distributor", desc: "Lets your attendees find their photos by just uploading their selfie!", image: `${WP}/uploads/2025/03/AI-Photo-Distributor.svg`, size: "sm" },
      { title: "Smart Analytics", desc: "Make sure your next event surpasses the last", image: `${WP}/uploads/2025/03/Smart-Analytics.svg`, size: "sm" },
      { title: "AI Note Maker", desc: "Delivers Personalized Session Notes, Takeaways & Highlights", image: `${WP}/uploads/2025/03/AI-Note-Maker.svg`, size: "tall" },
      { title: "Attendee Retargeting", desc: "Use Past Event Data to Effectively Re-campaign for the next", image: `${WP}/uploads/2025/03/Attendee.svg`, size: "sm" },
      { title: "Instant Feedback", desc: "Capitalize on Attendee Reviews to Note Areas for Improvement", image: `${WP}/uploads/2025/03/Instant-Feedback.svg`, size: "sm" },
    ],
  },
];
---

<!-- Features Section - white bg with Bg.svg -->
<section
  class="bg-cover bg-center bg-no-repeat py-[80px]"
  style="background-image: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg');"
>
  <div class="max-w-[1200px] mx-auto px-5">
    <!-- Title -->
    <h2 class="font-heading text-[48px] font-bold leading-[1.15] tracking-[-1px] text-eh-heading text-center mb-8">
      Countless Events, One<br />AI-Powered Platform
    </h2>

    <!-- Tabs -->
    <div class="flex justify-center mb-10">
      <div class="inline-flex gap-0 bg-eh-tab-bg rounded-full p-1">
        {tabs.map((tab) => (
          <button
            data-tab={tab.id}
            class:list={[
              "ehf-tab-btn px-8 py-2.5 text-[15px] font-medium rounded-full transition-all cursor-pointer whitespace-nowrap",
              tab.id === 0
                ? "bg-eh-blue text-white shadow-md shadow-eh-blue/30"
                : "text-eh-desc hover:bg-white/50",
            ]}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Tab Panels -->
    {tabs.map((tab) => (
      <div
        data-panel={tab.id}
        class:list={[
          "ehf-panel",
          tab.id !== 0 && "hidden",
        ]}
      >
        <div class={`ehf-grid ehf-layout-${tab.layout}`}>
          {tab.cards.map((card, i) => (
            <div class={`ehf-card ${card.size === "tall" ? "ehf-card--tall" : "ehf-card--sm"} ehf-pos-${i}`} style={`animation-delay: ${i * 0.06}s`}>
              <div class="ehf-card__inner">
                <div class="ehf-card__text">
                  <svg class="mb-2 flex-shrink-0" width="24" height="24" viewBox="0 0 32 32" fill="none">
                    <rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6" />
                    <rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6" />
                    <rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6" />
                    <rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6" />
                  </svg>
                  <h3 class="font-heading text-[22px] font-bold text-eh-heading leading-tight mb-1.5">{card.title}</h3>
                  <p class="text-[14px] text-eh-desc leading-relaxed">{card.desc}</p>
                </div>
                <div class="ehf-card__img">
                  <img src={card.image} alt={card.title} loading="lazy" />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .ehf-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    height: 460px;
  }
  .ehf-panel:not(.hidden) .ehf-grid {
    animation: ehfFadeUp 0.35s ease both;
  }
  @keyframes ehfFadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Layout A */
  .ehf-layout-a .ehf-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .ehf-layout-a .ehf-pos-1 { grid-column: 2; grid-row: 1; }
  .ehf-layout-a .ehf-pos-2 { grid-column: 3; grid-row: 1; }
  .ehf-layout-a .ehf-pos-3 { grid-column: 2; grid-row: 2; }
  .ehf-layout-a .ehf-pos-4 { grid-column: 3; grid-row: 2; }

  /* Layout B */
  .ehf-layout-b .ehf-pos-0 { grid-column: 1; grid-row: 1; }
  .ehf-layout-b .ehf-pos-1 { grid-column: 1; grid-row: 2; }
  .ehf-layout-b .ehf-pos-2 { grid-column: 2; grid-row: 1 / 3; }
  .ehf-layout-b .ehf-pos-3 { grid-column: 3; grid-row: 1; }
  .ehf-layout-b .ehf-pos-4 { grid-column: 3; grid-row: 2; }

  /* Layout C */
  .ehf-layout-c .ehf-pos-0 { grid-column: 1; grid-row: 1; }
  .ehf-layout-c .ehf-pos-1 { grid-column: 2; grid-row: 1; }
  .ehf-layout-c .ehf-pos-2 { grid-column: 1; grid-row: 2; }
  .ehf-layout-c .ehf-pos-3 { grid-column: 2; grid-row: 2; }
  .ehf-layout-c .ehf-pos-4 { grid-column: 3; grid-row: 1 / 3; }

  .ehf-card {
    background: #F5F8FF;
    border: 1px solid #E8ECF2;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0;
    animation: ehfCardIn 0.5s ease forwards;
  }
  .ehf-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(55, 93, 251, 0.08);
    border-color: rgba(55, 93, 251, 0.15);
  }
  @keyframes ehfCardIn {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Small card - horizontal layout */
  .ehf-card--sm .ehf-card__inner {
    display: flex;
    height: 100%;
  }
  .ehf-card--sm .ehf-card__text {
    padding: 20px 8px 20px 20px;
    flex: 1 1 55%;
    display: flex;
    flex-direction: column;
  }
  .ehf-card--sm .ehf-card__img {
    flex: 0 0 42%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 8px 8px 0 0;
    overflow: hidden;
  }

  /* Tall card - vertical layout */
  .ehf-card--tall .ehf-card__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .ehf-card--tall .ehf-card__text {
    padding: 20px 20px 8px;
  }
  .ehf-card--tall .ehf-card__img {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0 12px;
    overflow: hidden;
    min-height: 0;
  }

  .ehf-card__img img {
    max-width: 100%;
    max-height: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 1024px) {
    .ehf-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      height: auto;
    }
    .ehf-grid[class*="ehf-layout"] .ehf-pos-0,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-1,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-2,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-3,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-4 {
      grid-column: auto;
      grid-row: auto;
    }
    .ehf-card--tall {
      grid-column: 1 / 3 !important;
    }
    .ehf-card--tall .ehf-card__inner {
      flex-direction: row;
    }
    .ehf-card--tall .ehf-card__text {
      flex: 1;
      padding: 20px;
    }
    .ehf-card--tall .ehf-card__img {
      flex: 0 0 36%;
      padding: 12px;
    }
  }

  @media (max-width: 640px) {
    .ehf-grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 12px;
      padding-bottom: 8px;
      height: auto;
    }
    .ehf-grid::-webkit-scrollbar { display: none; }
    .ehf-grid[class*="ehf-layout"] .ehf-pos-0,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-1,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-2,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-3,
    .ehf-grid[class*="ehf-layout"] .ehf-pos-4 {
      flex: 0 0 78%;
      max-width: 78%;
      scroll-snap-align: start;
    }
    .ehf-card--sm .ehf-card__inner,
    .ehf-card--tall .ehf-card__inner {
      flex-direction: column;
    }
    .ehf-card--sm .ehf-card__text,
    .ehf-card--tall .ehf-card__text {
      padding: 20px 20px 8px;
      flex: none;
    }
    .ehf-card--sm .ehf-card__img,
    .ehf-card--tall .ehf-card__img {
      flex: none;
      height: 160px;
      padding: 0 16px 12px;
    }
    .ehf-card { animation-delay: 0s !important; }
  }
</style>

<script>
  const tabBtns = document.querySelectorAll(".ehf-tab-btn");
  const panels = document.querySelectorAll(".ehf-panel");

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tabId = btn.getAttribute("data-tab");

      tabBtns.forEach((b) => {
        b.classList.remove("bg-eh-blue", "text-white", "shadow-md", "shadow-eh-blue/30");
        b.classList.add("text-eh-desc");
      });
      btn.classList.add("bg-eh-blue", "text-white", "shadow-md", "shadow-eh-blue/30");
      btn.classList.remove("text-eh-desc");

      panels.forEach((p) => {
        if (p.getAttribute("data-panel") === tabId) {
          p.classList.remove("hidden");
        } else {
          p.classList.add("hidden");
        }
      });
    });
  });
</script>
