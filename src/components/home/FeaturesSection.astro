---

<section class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900">
        Countless Events, One
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600">AI-Powered</span>
        Platform
      </h2>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        Everything you need to plan, execute, and analyze your events — all in one place.
      </p>
    </div>

    <!-- Tabs -->
    <div class="flex justify-center mb-12">
      <div class="inline-flex bg-white rounded-full p-1.5 shadow-sm border border-gray-200">
        {tabs.map((tab, i) => (
          <button
            data-tab={tab.id}
            class:list={[
              "tab-btn px-6 py-2.5 text-sm font-semibold rounded-full transition-all",
              i === 0 ? "bg-indigo-600 text-white shadow-md" : "text-gray-600 hover:text-gray-900",
            ]}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Tab Content -->
    {tabs.map((tab, i) => (
      <div
        data-tab-content={tab.id}
        class:list={["tab-content grid md:grid-cols-3 gap-6 lg:gap-8", i !== 0 && "hidden"]}
      >
        {tab.features.map((feature) => (
          <div class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-lg hover:border-indigo-100 transition-all duration-300">
            <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center mb-5 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<script>
  const btns = document.querySelectorAll(".tab-btn");
  const contents = document.querySelectorAll(".tab-content");

  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tabId = btn.getAttribute("data-tab");

      btns.forEach((b) => {
        b.classList.remove("bg-indigo-600", "text-white", "shadow-md");
        b.classList.add("text-gray-600");
      });
      btn.classList.add("bg-indigo-600", "text-white", "shadow-md");
      btn.classList.remove("text-gray-600");

      contents.forEach((c) => {
        if (c.getAttribute("data-tab-content") === tabId) {
          c.classList.remove("hidden");
        } else {
          c.classList.add("hidden");
        }
      });
    });
  });
</script>
