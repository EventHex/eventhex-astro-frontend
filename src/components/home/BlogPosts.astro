---
import { getPosts, getMedia } from "../../lib/wordpress";

const posts = await getPosts({ per_page: "6" });
const postsWithImages = await Promise.all(
  posts.map(async (post) => {
    let imageUrl = "";
    if (post.featured_media) {
      try {
        const media = await getMedia(post.featured_media);
        imageUrl = media.source_url;
      } catch {
        imageUrl = "";
      }
    }
    return { ...post, imageUrl };
  })
);
---

<!-- Blog + CTA Section - Dark background -->
<section
  class="bg-cover bg-center bg-no-repeat pt-[60px] pb-[60px]"
  style="background-image: url('https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11.webp');"
>
  <div class="max-w-[1200px] mx-auto px-5">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <a
        href="/blog/"
        class="text-eh-heading/60 text-[14px] font-medium hover:text-eh-blue transition-colors"
      >
        Explore More
      </a>
    </div>
    <h2 class="font-heading text-[36px] md:text-[48px] font-bold text-eh-heading mb-10">
      Your Countless Events Begin Here
    </h2>

    <!-- Blog Posts Carousel -->
    <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide">
      {postsWithImages.map((post) => (
        <a href={`/blog/${post.slug}/`} class="group flex-shrink-0 w-[350px] snap-start">
          <article class="bg-white rounded-[20px] overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 h-full">
            {post.imageUrl && (
              <div class="aspect-[16/10] overflow-hidden">
                <img
                  src={post.imageUrl}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-5">
              <time class="text-[13px] text-eh-desc" datetime={post.date}>
                {new Date(post.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              <h3
                class="mt-2 text-[18px] font-bold text-eh-heading group-hover:text-eh-blue transition-colors line-clamp-2 font-heading"
                set:html={post.title.rendered}
              />
              <div
                class="mt-2 text-[14px] text-eh-desc line-clamp-2"
                set:html={post.excerpt.rendered}
              />
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
