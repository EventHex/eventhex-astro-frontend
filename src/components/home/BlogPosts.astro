---
import { getPosts, getMedia } from "../../lib/wordpress";

const posts = await getPosts({ per_page: "6" });
const postsWithImages = await Promise.all(
  posts.map(async (post) => {
    let imageUrl = "";
    if (post.featured_media) {
      try {
        const media = await getMedia(post.featured_media);
        imageUrl = media.source_url;
      } catch {
        imageUrl = "";
      }
    }
    return { ...post, imageUrl };
  })
);
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12">
      <div>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
          Latest from the Blog
        </h2>
        <p class="mt-2 text-lg text-gray-600">
          Your Countless Events Begin Here
        </p>
      </div>
      <a
        href="/blog/"
        class="mt-4 sm:mt-0 inline-flex items-center text-indigo-600 hover:text-indigo-700 font-semibold transition-colors"
      >
        View all posts
        <svg class="ml-1 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {postsWithImages.map((post) => (
        <a href={`/blog/${post.slug}/`} class="group">
          <article class="bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-lg transition-all duration-300">
            {post.imageUrl && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={post.imageUrl}
                  alt={post.title.rendered}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6">
              <time class="text-sm text-gray-500" datetime={post.date}>
                {new Date(post.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              <h3
                class="mt-2 text-lg font-bold text-gray-900 group-hover:text-indigo-600 transition-colors line-clamp-2"
                set:html={post.title.rendered}
              />
              <div
                class="mt-2 text-sm text-gray-600 line-clamp-2"
                set:html={post.excerpt.rendered}
              />
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>
