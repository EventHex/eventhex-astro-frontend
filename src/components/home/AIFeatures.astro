---
const aiCards = [
  {
    title: "AI Website Builder",
    desc: "Easily design, create, and customize stunning event websites with EventHex's innovative website builder–no technical expertise required!",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/01/AI-website.png",
  },
  {
    title: "AI Voice Form",
    desc: "Use EventHex's advanced AI-powered voice recording for the interactive creation and filling of forms–auto-translation supported!",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/01/AI-voice-form.png",
  },
  {
    title: "InstaSnap AI",
    desc: "EventHex's photo-distributing system that helps attendees find, edit, and share their photos by just uploading a selfie",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png",
  },
  {
    title: "AI Bot",
    desc: "Customizable AI bot designed to help attendees navigate through the event details and interactively respond to their queries",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/01/AI-bot.png",
  },
  {
    title: "AI Smart-Connect Networking",
    desc: "AI-driven networking system that intelligently connects attendees and personalizes networking opportunities through the mobile app",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/01/smart-connect.png",
  },
];
---

<!-- AI Features Section - Dark background -->
<section
  class="bg-black bg-cover bg-no-repeat pt-[60px] pb-0"
  style="background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp'); background-position: center left;"
>
  <div class="max-w-[1200px] mx-auto px-5">
    <!-- Header -->
    <div class="text-center mb-8">
      <p class="text-white/70 text-[18px] mb-4">
        Harness the power of AI to revolutionize your events
      </p>
      <h2 class="font-heading text-[42px] md:text-[52px] font-bold text-white leading-[1.1]">
        Simply The Best <span class="text-eh-purple">AI-Powered</span><br />
        Event Management Software
      </h2>
    </div>

    <!-- AI Feature Cards -->
    <div class="pt-[30px]">
      {aiCards.map((card) => (
        <div class="bg-eh-card-dark border border-eh-card-border rounded-[20px] mb-[60px] overflow-hidden" style="padding-top: 30px;">
          <div class="flex flex-col md:flex-row items-stretch h-[500px] md:h-[450px] lg:h-[500px]">
            <div class="flex-1 p-8 md:p-12 flex flex-col justify-center" style="flex: 0 0 45%;">
              <h3 class="font-heading text-[35px] font-medium text-eh-purple mb-4 leading-tight">{card.title}</h3>
              <p class="text-white text-[18px] font-normal leading-relaxed opacity-90 font-body mb-6">{card.desc}</p>
              <a href="#" class="inline-flex items-center px-6 py-2.5 text-[15px] font-medium text-eh-btn-text bg-eh-btn-purple rounded-[10px] w-fit hover:brightness-110 transition">
                Explore More
              </a>
            </div>
            <div class="flex-1 flex items-center justify-center p-6">
              <img src={card.image} alt={card.title} class="max-w-full max-h-[400px] object-contain" loading="lazy" />
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Testimonial 2 - Rifath Rahman -->
    <div class="pt-[60px] pb-[50px]">
      <p class="eh-animate text-center mx-auto" data-animation="fadeInLeft" style="font-family: 'Inter', sans-serif; font-size: 30px; line-height: 37px; font-weight: 300; letter-spacing: -1px; color: #FFFFFF; max-width: 75%;">
        "Eventhex.ai is a game changer in the event tech space. We had first-hand experience using their platform for the Youth Business Conclave. Personally, I was impressed by their UI/UX capabilities. We highly recommend this team to anyone looking for an innovative event tech solution!"
      </p>
      <div class="flex items-center justify-center gap-6 mt-[50px]">
        <img
          src="https://cms.eventhex.ai/wp-content/uploads/2025/01/Group-2233.png"
          alt="Youth Business Conclave"
          class="h-[60px] w-auto brightness-0 invert"
          loading="lazy"
        />
        <img
          src="https://cms.eventhex.ai/wp-content/uploads/2025/01/Rifath-Rahman.jpeg"
          alt="Rifath Rahman"
          class="w-[80px] h-[80px] rounded-xl object-cover"
          loading="lazy"
        />
        <div>
          <p class="text-white font-heading text-[22px] font-medium">Rifath Rahman</p>
          <p class="text-white/70 text-[16px]">President, SOLID Business Club</p>
        </div>
      </div>
    </div>
  </div>
</section>
