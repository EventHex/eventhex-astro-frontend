---
const aiFeatures = [
  {
    title: "AI Website Builder",
    description: "Generate beautiful event websites in seconds. AI creates layouts, content, and designs tailored to your event.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
    gradient: "from-blue-500 to-cyan-500",
  },
  {
    title: "AI Voice Form",
    description: "Let attendees fill forms using voice commands. AI transcribes and populates fields automatically.",
    icon: "M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z",
    gradient: "from-violet-500 to-purple-500",
  },
  {
    title: "InstaSnap AI",
    description: "AI-powered photo recognition delivers event photos directly to attendees using facial recognition technology.",
    icon: "M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z M15 13a3 3 0 11-6 0 3 3 0 016 0z",
    gradient: "from-pink-500 to-rose-500",
  },
  {
    title: "AI Bot",
    description: "24/7 AI chatbot for attendee support. Answers questions, provides directions, and handles registrations.",
    icon: "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z",
    gradient: "from-amber-500 to-orange-500",
  },
  {
    title: "AI Smart-Connect",
    description: "AI matches attendees based on interests, goals, and profiles to create meaningful networking connections.",
    icon: "M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1",
    gradient: "from-emerald-500 to-teal-500",
  },
];
---

<section class="py-20 lg:py-28 bg-white relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-gradient-to-b from-indigo-50 to-transparent rounded-full blur-3xl opacity-50"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-violet-100 text-violet-700 rounded-full text-sm font-medium mb-4">
        Powered by AI
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900">
        Simply The Best <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600">AI-Powered</span><br />
        Event Management Software
      </h2>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        Harness the power of artificial intelligence to automate, enhance, and transform every aspect of your events.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {aiFeatures.map((feature) => (
        <div class="group relative bg-white rounded-2xl p-8 border border-gray-100 hover:border-transparent hover:shadow-xl transition-all duration-300 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-5 transition-opacity duration-300"
            style={`background: linear-gradient(135deg, var(--tw-gradient-from), var(--tw-gradient-to));`}
          ></div>
          <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${feature.gradient} flex items-center justify-center mb-6 text-white shadow-lg`}>
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">{feature.title}</h3>
          <p class="text-gray-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
