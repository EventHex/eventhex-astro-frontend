---
const clients = [
  { name: "Hala Jeddha", image: "https://eventhex.ai/wp-content/uploads/2024/12/hala-2.png" },
  { name: "ISRO", image: "https://eventhex.ai/wp-content/uploads/2024/12/Isro-logo.png" },
  { name: "YBC", image: "https://eventhex.ai/wp-content/uploads/2024/09/YBC.png" },
  { name: "COK", image: "https://eventhex.ai/wp-content/uploads/2024/09/COK.png" },
  { name: "KEDDA", image: "https://eventhex.ai/wp-content/uploads/2024/09/KEDDA.png" },
  { name: "MLF", image: "https://eventhex.ai/wp-content/uploads/2024/09/MLF.svg" },
  { name: "DE-CONQUISTA", image: "https://eventhex.ai/wp-content/uploads/2024/09/DE.png" },
  { name: "DIGNITY", image: "https://eventhex.ai/wp-content/uploads/2024/09/DIGNITY.png" },
];
---

<section class="py-16 bg-white border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-semibold uppercase tracking-wider text-gray-400 mb-8">
      Trusted by leading organizations worldwide
    </p>
    <div class="relative overflow-hidden" id="logo-carousel">
      <div class="flex gap-12 items-center animate-scroll">
        {[...clients, ...clients].map((client) => (
          <div class="flex-shrink-0">
            <img
              src={client.image}
              alt={client.name}
              class="h-10 sm:h-12 w-auto object-contain grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-scroll {
    animation: scroll 30s linear infinite;
  }
  .animate-scroll:hover {
    animation-play-state: paused;
  }
</style>
