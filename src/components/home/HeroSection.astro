---
---

<!-- Hero Section - light background with texture image -->
<section
  class="relative bg-cover bg-center bg-no-repeat"
  style="background-image: url('https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp'); margin-top: -90px; padding-bottom: 220px;"
>
  <div
    class="relative bg-cover bg-center bg-no-repeat pt-[160px] md:pt-[130px] lg:pt-[160px] pb-0"
    style="background-image: url('https://eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp');"
  >
    <div class="max-w-[1200px] mx-auto px-5">
      <div class="flex flex-col items-center gap-[32px] max-w-[670px] md:max-w-[500px] lg:max-w-[670px] mx-auto text-center pb-[60px]">
        <!-- Subtitle -->
        <p class="eh-animate" data-animation="fadeIn" data-duration="slow" data-delay="300" style="font-family: 'Inter', sans-serif; font-size: 18px; line-height: 24px; font-weight: 400; letter-spacing: -0.48px; color: #475467;">
          Simplify Events | Amplify  Results
        </p>
        <!-- Main Title -->
        <h1 class="font-heading eh-animate" data-animation="fadeIn" style="font-size: 52px; line-height: 60px; font-weight: 600; letter-spacing: -1px; color: #22272F; max-width: 748px; text-align: center;">
          The AI-Powered Event Management Platform
          for Every Event
        </h1>
        <!-- CTA Button -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/book-a-demo/"
            class="eh-btn-grow inline-flex items-center justify-center px-8 py-3.5 text-white bg-eh-blue hover:bg-[#1C46D4] rounded-[10px] transition-all shadow-lg shadow-eh-blue/20"
            style="font-family: 'Inter', sans-serif; font-size: 15px; line-height: 24px; font-weight: 600; letter-spacing: -0.48px;"
          >
            Request a demo
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Dashboard Image - overlaps into dark section -->
<section
  class="relative bg-cover bg-center bg-no-repeat"
  style="background-image: url('https://eventhex.ai/wp-content/uploads/2024/12/bg-1.webp'); padding-top: 250px; padding-bottom: 60px;"
>
  <div class="max-w-[1200px] mx-auto px-5" style="margin-top: -470px;">
    <img
      src="https://eventhex.ai/wp-content/uploads/2025/01/Frame-1000003133.png"
      alt="EventHex Dashboard"
      class="w-full rounded-2xl eh-animate"
      data-animation="fadeInLeft"
      data-duration="slow"
      data-delay="800"
      loading="eager"
    />
  </div>

  <!-- Engagement text -->
  <div class="max-w-[1200px] mx-auto px-5 pt-[80px] md:pt-[40px] lg:pt-[80px] pb-[50px]">
    <h3 class="font-heading eh-animate text-center mx-auto leading-[52px] md:leading-[1.1] font-normal tracking-[-1px] text-white" data-animation="fadeInDown" style="font-size: 48px; max-width: 65%;">
      EventHex boosts retention through<span style="color:#AFA3FF;"> enhanced attendee engagement</span> and<span style="color:#ABFFFF;">  personalized user experiences</span>
    </h3>
    <div class="flex justify-center mt-6">
      <img
        src="https://eventhex.ai/wp-content/uploads/2024/12/Layer_1.svg"
        alt="Decorative"
        class="h-[40px] opacity-60"
        loading="lazy"
      />
    </div>
  </div>

  <!-- Trusted By -->
  <div class="max-w-[1200px] mx-auto px-5 pb-[60px]">
    <h3 class="text-white font-heading text-[18px] font-medium text-center mb-6 opacity-80">
      Trusted by
    </h3>
    <div class="relative overflow-hidden">
      <div class="flex gap-12 items-center justify-center animate-scroll">
        {[
          { name: "Hala Jeddha", img: "https://eventhex.ai/wp-content/uploads/2024/12/hala-2.png" },
          { name: "ISRO", img: "https://eventhex.ai/wp-content/uploads/2024/12/Isro-logo.png" },
          { name: "YBC", img: "https://eventhex.ai/wp-content/uploads/2024/09/YBC.png" },
          { name: "COK", img: "https://eventhex.ai/wp-content/uploads/2024/09/COK.png" },
          { name: "KEDDA", img: "https://eventhex.ai/wp-content/uploads/2024/09/KEDDA.png" },
          { name: "MLF", img: "https://eventhex.ai/wp-content/uploads/2024/09/MLF.svg" },
          { name: "DE-CONQUISTA", img: "https://eventhex.ai/wp-content/uploads/2024/09/DE.png" },
          { name: "DIGNITY", img: "https://eventhex.ai/wp-content/uploads/2024/09/DIGNITY.png" },
        ].flatMap(c => [c, c]).map((client) => (
          <div class="flex-shrink-0">
            <img
              src={client.img}
              alt={client.name}
              class="h-[40px] w-auto object-contain brightness-0 invert opacity-60 hover:opacity-100 transition-opacity"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Stacking Cards - Platform Features -->
  <div class="max-w-[1200px] mx-auto px-5 pb-[30px]">
    {[
      {
        title: "Retention-First Approach",
        desc: "Boost attendee retention with EventHex's unique Campaign feature. Now easily integrate centralized data with communication features to network and market with attendees from previous events for your upcoming events.",
        image: "https://eventhex.ai/wp-content/uploads/2024/12/Frame-1000002980-1.png",
      },
      {
        title: "Unified Management",
        desc: "Oversee multiple events from a platform that integrates all management functionalities into a single dashboard. Avoid the stress of traditional fragmented tools and let our AI-powered event planning software save you time & cost with every event.",
        image: "https://eventhex.ai/wp-content/uploads/2024/12/%F0%9F%8C%81IMAGE-1.png",
      },
      {
        title: "Personalized Experience",
        desc: "EventHex provides a customized event experience for each attendee, toning content, recommendations, and networking opportunities to their preferences and interests. Let AI engage and personalize, making your events a unique experience for all.",
        image: "https://eventhex.ai/wp-content/uploads/2024/12/%F0%9F%8C%81IMAGE-2.png",
      },
      {
        title: "AI Tools Integration",
        desc: "Seamlessly integrate a wide range of AI-based tools into your events. Centralized Data Management prevents data loss and eliminates inconsistencies, making integration safe, smooth, and secure, no matter how numerous the events.",
        image: "https://eventhex.ai/wp-content/uploads/2024/12/AI-tool.png",
      },
      {
        title: "Actionable Analytics",
        desc: "Retrieve data-driven insights to evaluate every event's performance and identify areas for improvement for upcoming events. EventHex's analytical tools help you make strategic decisions to ensure every event surpasses the last.",
        image: "https://eventhex.ai/wp-content/uploads/2024/12/%F0%9F%8C%81IMAGE-3.png",
      },
    ].map((card) => (
      <div class="bg-eh-card-dark border border-eh-card-border rounded-[20px] mb-[60px] overflow-hidden" style="padding-top: 30px;">
        <div class="flex flex-col md:flex-row items-stretch h-[500px] md:h-[450px] lg:h-[500px]">
          <div class="flex-1 p-8 md:p-12 flex flex-col justify-center" style="flex: 0 0 45%;">
            <h3 class="font-heading text-[35px] font-medium text-eh-purple mb-4 leading-tight">{card.title}</h3>
            <p class="text-white text-[18px] font-normal leading-relaxed opacity-90 font-body mb-6">{card.desc}</p>
            <a href="#" class="inline-flex items-center px-6 py-2.5 text-[15px] font-medium text-eh-btn-text bg-eh-btn-purple rounded-[10px] w-fit hover:brightness-110 transition">
              Explore More
            </a>
          </div>
          <div class="flex-1 flex items-center justify-center p-6">
            <img src={card.image} alt={card.title} class="max-w-full max-h-[400px] object-contain" loading="lazy" />
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Testimonial 1 - Amy Carey -->
  <div class="max-w-[1200px] mx-auto px-5 pt-[60px] pb-[50px]">
    <p class="eh-animate text-center mx-auto" data-animation="fadeInLeft" style="font-family: 'Inter', sans-serif; font-size: 30px; line-height: 37px; font-weight: 300; letter-spacing: -1px; color: #FFFFFF; max-width: 75%;">
      "We approached EventHex knowing teething problems might arise with a newer platform, but after a successful two-event trial, we're eager to sign a two-year partnership. The standout feature isn't just the tech—it's the amazing support team, with rapid problem-solving, intuitive user experience, and a growth mindset that treats clients as true partners. I happily recommend EventHex."
    </p>
    <div class="flex items-center justify-center gap-6 mt-[50px]">
      <img
        src="https://eventhex.ai/wp-content/uploads/2026/03/wellbeing.svg"
        alt="Wellbeing at Work"
        class="h-[60px] w-auto brightness-0 invert"
        loading="lazy"
      />
      <img
        src="https://eventhex.ai/wp-content/uploads/2026/03/Amy.png"
        alt="Amy Carey"
        class="w-[80px] h-[80px] rounded-xl object-cover"
        loading="lazy"
      />
      <div>
        <p class="text-white font-heading text-[22px] font-medium">Amy Carey</p>
        <p class="text-white/70 text-[16px]">Wellbeing at work UK</p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-scroll {
    animation: scroll 30s linear infinite;
  }
  .animate-scroll:hover {
    animation-play-state: paused;
  }

  /* Responsive overrides from Elementor */
  @media (max-width: 1024px) {
    /* Tablet: hero subtitle 16px, h1 40px, engagement text 40px */
  }
  @media (max-width: 767px) {
    /* Mobile: hero subtitle 16px, h1 30px, engagement text 30px, padding adjustments */
  }
</style>
