---
---

<section class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-white to-violet-50">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-20 left-10 w-72 h-72 bg-indigo-200 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-violet-200 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20 lg:pt-24 lg:pb-28">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-100 text-indigo-700 rounded-full text-sm font-medium mb-6">
          <span class="w-2 h-2 bg-indigo-500 rounded-full animate-pulse"></span>
          AI-Powered Platform
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 leading-tight">
          The AI-Powered
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600">
            Event Management
          </span>
          Platform
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          For every event — conferences, exhibitions, hackathons, and more. Streamline your entire event lifecycle with AI.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="/contact-en/"
            class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-indigo-600 hover:bg-indigo-700 rounded-full transition-all hover:shadow-lg hover:shadow-indigo-200"
          >
            Request a demo
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/about-us/"
            class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-gray-700 bg-white hover:bg-gray-50 border border-gray-200 rounded-full transition-all"
          >
            Learn more
          </a>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-r from-indigo-400 to-violet-400 rounded-2xl blur-2xl opacity-20"></div>
        <img
          src="https://eventhex.ai/wp-content/uploads/2025/01/Frame-1000003133.png"
          alt="EventHex Dashboard"
          class="relative rounded-2xl shadow-2xl w-full"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
