---
const testimonials = [
  {
    name: "Amy Carey",
    role: "Event Director",
    image: "https://eventhex.ai/wp-content/uploads/2026/03/Amy.png",
    quote: "EventHex transformed how we manage our conferences. The AI features saved us countless hours of manual work.",
  },
  {
    name: "Rifath Rahman",
    role: "Conference Organizer",
    image: "https://eventhex.ai/wp-content/uploads/2025/01/Rifath-Rahman.jpeg",
    quote: "The best event management platform we've ever used. Smart-Connect alone made our networking sessions 10x more effective.",
  },
  {
    name: "Noushad EP",
    role: "Exhibition Manager",
    image: "https://eventhex.ai/wp-content/uploads/2025/01/Noushad-EP.jpeg",
    quote: "From registration to post-event analytics, EventHex handles everything seamlessly. Our attendees love the experience.",
  },
];
---

<section class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
        What Our Clients Say
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Trusted by event professionals around the world
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <!-- Quote -->
          <p class="text-gray-600 leading-relaxed mb-6">"{t.quote}"</p>
          <!-- Author -->
          <div class="flex items-center gap-3">
            <img
              src={t.image}
              alt={t.name}
              class="w-12 h-12 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="font-semibold text-gray-900">{t.name}</p>
              <p class="text-sm text-gray-500">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
