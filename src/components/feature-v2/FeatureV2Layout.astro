    grid-template-rows: 1fr 1fr;
    gap: 14px;
    height: 460px;
  }
  .fv2-bento__pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .fv2-bento__pos-1 { grid-column: 2; grid-row: 1; }
  .fv2-bento__pos-2 { grid-column: 3; grid-row: 1; }
  .fv2-bento__pos-3 { grid-column: 2; grid-row: 2; }
  .fv2-bento__pos-4 { grid-column: 3; grid-row: 2; }

  [data-layout="b"] .fv2-bento__pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .fv2-bento__pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .fv2-bento__pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .fv2-bento__pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .fv2-bento__pos-4 { grid-column: 2; grid-row: 2; }

  [data-layout="c"] .fv2-bento__pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .fv2-bento__pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .fv2-bento__pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .fv2-bento__pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .fv2-bento__pos-4 { grid-column: 3; grid-row: 2; }

  @property --fv2-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .fv2-bento__card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0;
    animation: fv2BentoCardIn 0.5s ease forwards;
  }
  .fv2-bento__card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: conic-gradient(from var(--fv2-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .fv2-bento__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(55,93,251,0.12);
    border-color: rgba(55,93,251,0.15);
  }
  .fv2-bento__card:hover::after { opacity: 1; animation: fv2BentoBorder 2.4s linear infinite; }
  @keyframes fv2BentoBorder { to { --fv2-angle: 360deg; } }
  @keyframes fv2BentoCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

  /* ── Card icon — top-left of card text ── */
  .fv2-bento__icon { margin-bottom: 8px; flex-shrink: 0; }

  /* ── Tall card: text on top, illustration below ── */
