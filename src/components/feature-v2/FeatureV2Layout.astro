  .fv2-bento__card-img :global(svg) { width: 100%; height: auto; filter: drop-shadow(0 8px 16px rgba(31,52,128,.12)); transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease; }
  .fv2-bento__card:hover .fv2-bento__card-img :global(svg) { transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18)); animation: fv2BentoFloat 2.2s ease-in-out infinite; }
  @keyframes fv2BentoFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  .fv2-bento__card-text { display: flex; flex-direction: column; gap: 6px; }
