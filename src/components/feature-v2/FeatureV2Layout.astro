<script>
  /* Bento tab switching */
  const fv2Tabs = Array.from(document.querySelectorAll('[data-fv2-tab]'));
  const fv2Panels = Array.from(document.querySelectorAll('[data-fv2-panel]'));

  function fv2Switch(index: number) {
    fv2Tabs.forEach((t) => t.classList.remove('fv2-bento__tab--active'));
    fv2Panels.forEach((p) => p.classList.remove('fv2-bento__panel--active'));
    fv2Tabs[index]?.classList.add('fv2-bento__tab--active');
    fv2Panels[index]?.classList.add('fv2-bento__panel--active');
  }

  fv2Tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      fv2Switch(i);
      clearInterval(fv2Interval);
    });
  });

  let fv2Idx = 0;
  let fv2Interval: ReturnType<typeof setInterval>;

  function startFv2Rotation() {
    fv2Interval = setInterval(() => {
      fv2Idx = (fv2Idx + 1) % fv2Tabs.length;
      fv2Switch(fv2Idx);
    }, 5000);
  }
  startFv2Rotation();

  const fv2Bento = document.querySelector('.fv2-bento-section');
  if (fv2Bento) {
    fv2Bento.addEventListener('mouseenter', () => clearInterval(fv2Interval));
    fv2Bento.addEventListener('mouseleave', () => startFv2Rotation());
  }

  /* Scroll animations */
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll(".animate-on-scroll").forEach((el) => observer.observe(el));
</script>
