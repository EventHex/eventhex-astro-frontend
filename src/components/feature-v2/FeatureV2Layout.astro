---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import LottiePlayer from "../LottiePlayer.astro";

/* ── TYPE DEFINITIONS ──────────────────────────────────────── */
interface StatItem { value: string; label: string }

interface BentoCard { title: string; desc: string; illustration?: string }
interface BentoTab { tab: string; cards: BentoCard[] }

interface StackingCard {
  title: string;
  desc: string;
  image: string;
  alt: string;
}

interface StepItem { title: string; desc: string }
interface FaqItem { q: string; a: string }
interface WhyCard { title: string; desc: string; icon?: string }

interface Props {
  pageTitle: string;
  pageDescription: string;
  canonical: string;
  ogImage?: string;
  /* hero */
  badge: string;
  heroTitleLine1: string;
  heroTitleLine2: string;
  heroCopy: string;
  trustItems: string[];
  heroAnimation?: string;
  heroImage?: string;
  /* stats */
  stats: StatItem[];
  statsHeadline: { white1: string; accent: string; white2: string; accent2: string };
  /* bento grid */
  bentoHeading: string;
  bentoSubtitle: string;
  bentoTabs: BentoTab[];
  /* stacking cards */
  stackingHeading: string;
  stackingHighlight: string;
  stackingCards: StackingCard[];
  /* how it works */
  howItWorksHeading: string;
  howItWorksImage?: string;
  howItWorksAnimation?: string;
  steps: StepItem[];
  /* cta */
  ctaTitle: string;
  ctaCopy: string;
  ctaImage?: string;
  /* why cards */
  whyHeading: string;
  whyCards: WhyCard[];
  /* faq */
  faqs: FaqItem[];
  /* seo */
  jsonLd?: Record<string, unknown>;
}

const {
  pageTitle, pageDescription, canonical, ogImage,
  badge, heroTitleLine1, heroTitleLine2, heroCopy, trustItems,
  heroAnimation, heroImage,
  stats, statsHeadline,
  bentoHeading, bentoSubtitle, bentoTabs,
  stackingHeading, stackingHighlight, stackingCards,
  howItWorksHeading, howItWorksImage, howItWorksAnimation, steps,
  ctaTitle, ctaCopy, ctaImage,
  whyHeading, whyCards,
  faqs,
  jsonLd,
} = Astro.props;

/* unique prefix so multiple pages can coexist */
const uid = pageTitle.replace(/[^a-zA-Z]/g, '').slice(0, 8).toLowerCase();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

/* alternate bento layouts: tab 0 = left tall, tab 1 = right tall, tab 2 = center tall */
const layouts = ["a", "b", "c"];
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  ogImage={ogImage}
  showFooterCta={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </Fragment>

  <!-- ① HERO — full viewport, bleeds into header -->
  <section class={`fv2-hero ${(heroAnimation || heroImage) ? 'fv2-hero--split' : ''}`}>
    <div class={`fv2-hero__inner ${(heroAnimation || heroImage) ? 'fv2-hero__inner--split' : ''}`}>
      <div class="fv2-hero__text">
        <span class="fv2-hero__badge animate-on-scroll" data-animation="fadeIn">{badge}</span>
        <h1 class="fv2-hero__title animate-on-scroll" data-animation="fadeInUp">
          {heroTitleLine1}<br />
          <span class="fv2-hero__highlight">{heroTitleLine2}</span>
        </h1>
        <p class="fv2-hero__copy animate-on-scroll" data-animation="fadeInUp">{heroCopy}</p>
        <div class="fv2-hero__ctas animate-on-scroll" data-animation="fadeInUp">
          <a href="/book-a-demo/" class="fv2-btn fv2-btn--primary">
            Book a Demo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#fv2-bento" class="fv2-btn fv2-btn--outline">Explore Features</a>
        </div>
      </div>
      {heroAnimation && (
        <div class="fv2-hero__animation animate-on-scroll" data-animation="fadeIn">
          <LottiePlayer src={heroAnimation} />
        </div>
      )}
      {heroImage && !heroAnimation && (
        <div class="fv2-hero__visual animate-on-scroll" data-animation="fadeIn">
          <img src={heroImage} alt={heroTitleLine1} class="fv2-hero__svg fv2-hero__svg--float" width="560" height="460" loading="eager" />
        </div>
      )}
    </div>
  </section>

  <!-- trust strip -->
  <section class="fv2-trust-strip">
    <div class="fv2-trust-strip__inner">
      {trustItems.map((t) => (
        <span class="fv2-trust-strip__item">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#375DFB" opacity=".15"/><path d="M5 8l2 2 4-4" stroke="#375DFB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {t}
        </span>
      ))}
    </div>
  </section>

  <!-- ② STATS — dark band -->
  <section class="fv2-stats">
    <div class="fv2-stats__engagement">
      <div class="fv2-stats__engagement-text">
        <h2 class="fv2-stats__heading animate-on-scroll" data-animation="fadeInDown">
          <span class="fv2-stats--white">{statsHeadline.white1} </span>
          <span class="fv2-stats--purple">{statsHeadline.accent}</span>
          <br />
          <span class="fv2-stats--white">{statsHeadline.white2} </span>
          <span class="fv2-stats--cyan">{statsHeadline.accent2}</span>
        </h2>
      </div>
    </div>
    <div class="fv2-stats__grid">
      {stats.map((stat) => (
        <div class="fv2-stats__card animate-on-scroll" data-animation="fadeInUp">
          <span class="fv2-stats__value">{stat.value}</span>
          <span class="fv2-stats__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ③ BENTO GRID — tabbed, light bg -->
  <section class="fv2-bento-section" id="fv2-bento">
    <div class="fv2-bento">
      <h2 class="fv2-bento__title">{bentoHeading}</h2>
      <p class="fv2-bento__subtitle">{bentoSubtitle}</p>

      <nav class="fv2-bento__nav">
        {bentoTabs.map((t, i) => (
          <button class={`fv2-bento__tab ${i === 0 ? "fv2-bento__tab--active" : ""}`} data-fv2-tab={String(i)}>{t.tab}</button>
        ))}
      </nav>

      {bentoTabs.map((t, tabIdx) => (
        <div class={`fv2-bento__panel ${tabIdx === 0 ? "fv2-bento__panel--active" : ""}`} data-fv2-panel={String(tabIdx)}>
          <div class="fv2-bento__grid" data-layout={layouts[tabIdx % 3]}>
            {t.cards.map((card, cardIdx) => (
              <div class={`fv2-bento__card ${cardIdx === 0 ? "fv2-bento__card--tall" : "fv2-bento__card--sm"} fv2-bento__pos-${cardIdx}`} style={`animation-delay:${(cardIdx * 0.06).toFixed(2)}s`}>
                <div class={`fv2-bento__card-inner ${cardIdx > 0 ? "fv2-bento__card-inner--row" : ""}`}>
                  <div class="fv2-bento__card-text">
                    <svg class="fv2-bento__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>
                    <h3 class="fv2-bento__card-title">{card.title}</h3>
                    <p class="fv2-bento__card-desc">{card.desc}</p>
                  </div>
                  {card.illustration && <div class="fv2-bento__card-img" set:html={card.illustration} />}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ④ STACKING CARDS — dark bg, sticky scroll -->
  <section class="fv2-stack-shell">
    <div class="fv2-stack-section">
      <div class="fv2-stack-header">
        <span class="fv2-stack-subtitle">Feature-by-feature</span>
        <h2 class="fv2-stack-title">
          {stackingHeading} <br/><span class="fv2-stack-hl">{stackingHighlight}</span>
        </h2>
      </div>
      <div class="fv2-stack-cards">
        {stackingCards.map((card, i) => (
          <div
            class="fv2-stack-card"
            data-card-index={i}
            style={`--card-index: ${i}; top: calc(20px + ${i * 20}px);`}
          >
            <div class="fv2-stack-card-content">
              <h3 class="fv2-stack-card-title">{card.title}</h3>
              <p class="fv2-stack-card-desc">{card.desc}</p>
              <a href="/book-a-demo/" class="fv2-stack-card-btn">Explore More</a>
            </div>
            <div class="fv2-stack-card-image">
              <img src={card.image} alt={card.alt} loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑤ HOW IT WORKS — white split layout -->
  <section class="fv2-how">
    <div class="fv2-how__inner">
      <div class="fv2-how__header">
        <span class="fv2-how__eyebrow animate-on-scroll" data-animation="fadeIn">Step by Step</span>
        <h2 class="fv2-how__heading animate-on-scroll" data-animation="fadeInUp">{howItWorksHeading}</h2>
      </div>
      <div class="fv2-how__split">
        <div class="fv2-how__left">
          <div class="fv2-how__image animate-on-scroll" data-animation="fadeInUp">
            {howItWorksAnimation ? (
              <LottiePlayer src={howItWorksAnimation} class="fv2-how__lottie" />
            ) : howItWorksImage ? (
              <img src={howItWorksImage} alt={howItWorksHeading} class="fv2-how__svg--float" loading="lazy" />
            ) : (
              <div class="fv2-how__placeholder">
                <svg width="120" height="120" viewBox="0 0 120 120" fill="none">
                  <rect width="120" height="120" rx="24" fill="#F0F2F5"/>
                  <path d="M40 85V35l45 25-45 25z" fill="#375DFB" opacity="0.3"/>
                </svg>
              </div>
            )}
          </div>
        </div>
        <div class="fv2-how__steps">
          {steps.map((step, i) => (
            <div class="fv2-how__step animate-on-scroll" data-animation="fadeInUp" data-delay={String(i * 100)}>
              <span class="fv2-how__num">{String(i + 1).padStart(2, "0")}</span>
              <div class="fv2-how__step-text">
                <h3 class="fv2-how__step-title">{step.title}</h3>
                <p class="fv2-how__step-desc">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ⑥ WHY CHOOSE — white section -->
  <section class="fv2-why">
    <div class="fv2-why__inner">
      <h2 class="fv2-why__heading animate-on-scroll" data-animation="fadeInUp">{whyHeading}</h2>
      <div class="fv2-why__grid">
        {whyCards.map((card, i) => (
          <div class={`fv2-why__card fv2-why__card--${i} animate-on-scroll`} data-animation="fadeInUp" data-delay={String(i * 80)}>
            {card.icon && <div class="fv2-why__icon" set:html={card.icon} />}
            <div class="fv2-why__card-text">
              <h3 class="fv2-why__card-title">{card.title}</h3>
              <p class="fv2-why__card-desc">{card.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ⑦ CTA — dark card with glows -->
  <section class="fv2-cta">
    <div class="fv2-cta__card">
      <div class="fv2-cta__glow fv2-cta__glow--1"></div>
      <div class="fv2-cta__glow fv2-cta__glow--2"></div>
      <div class="fv2-cta__split">
        <div class="fv2-cta__content">
          <span class="fv2-cta__eyebrow animate-on-scroll" data-animation="fadeIn">Get Started Today</span>
          <h2 class="fv2-cta__title animate-on-scroll" data-animation="fadeInUp">{ctaTitle}</h2>
          <p class="fv2-cta__copy animate-on-scroll" data-animation="fadeInUp">{ctaCopy}</p>
          <div class="fv2-cta__proof-row animate-on-scroll" data-animation="fadeInUp">
            <span class="fv2-cta__proof-pill">AI-powered platform</span>
            <span class="fv2-cta__proof-pill">Free onboarding support</span>
            <span class="fv2-cta__proof-pill">No credit card required</span>
          </div>
          <div class="fv2-cta__buttons animate-on-scroll" data-animation="fadeInUp">
            <a href="/book-a-demo/" class="fv2-btn fv2-btn--white">
              Book a Free Demo
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fv2-bento" class="fv2-btn fv2-btn--ghost">Explore Features</a>
          </div>
          {!ctaImage && (
            <div class="fv2-cta__trust animate-on-scroll" data-animation="fadeIn">
              {trustItems.map((t) => (
                <span class="fv2-cta__trust-item">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6.5 12.5l-4-4 1.4-1.4 2.6 2.6 5.6-5.6 1.4 1.4-7 7z" fill="rgba(255,255,255,0.5)"/></svg>
                  {t}
                </span>
              ))}
            </div>
          )}
        </div>
        <div class="fv2-cta__animation">
          {ctaImage ? (
            <img src={ctaImage} alt={ctaTitle} class="fv2-cta__svg fv2-cta__svg--float" width="560" height="460" loading="lazy" />
          ) : (
            <LottiePlayer src="/animations/cta-animation.json" class="fv2-cta__lottie" />
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ⑧ FAQ — split layout, sidebar + accordion -->
  <section class="fv2-faq">
    <div class="fv2-faq__inner">
      <div class="fv2-faq__sidebar animate-on-scroll" data-animation="fadeInLeft">
        <span class="fv2-faq__eyebrow">Need Help?</span>
        <h2 class="fv2-faq__sidebar-title">Frequently Asked Questions</h2>
        <p class="fv2-faq__sidebar-desc">
          Everything you need to know about this feature and how it works with EventHex.
        </p>
        <div class="fv2-faq__support-card">
          <h3 class="fv2-faq__support-title">Talk to Our Team</h3>
          <p class="fv2-faq__support-desc">Our experts can walk you through a personalized demo and answer any questions.</p>
        </div>
        <a href="/book-a-demo/" class="fv2-btn fv2-btn--primary fv2-btn--sm">Book a Demo</a>
      </div>
      <div class="fv2-faq__list">
        {faqs.map((faq, i) => (
          <details class="fv2-faq__item animate-on-scroll" data-animation="fadeInUp" data-delay={String(i * 60)}>
            <summary class="fv2-faq__question">
              {faq.q}
              <svg class="fv2-faq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </summary>
            <div class="fv2-faq__answer"><p>{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>

<style is:global>
  /* ══════════════════════════════════════════
     ① HERO — full viewport, bleeds into header
     ═══════════════════════════════════════════ */
  .fv2-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    text-align: center;
    background:
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat,
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }
  .fv2-hero__inner {
    position: relative;
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    padding: 160px 1.5rem 5rem;
    z-index: 1;
  }
  /* Split hero layout */
  .fv2-hero--split { justify-content: flex-start; }
  .fv2-hero__inner--split {
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 1200px;
    text-align: left;
    padding: 160px 2rem 5rem;
  }
  .fv2-hero__inner--split .fv2-hero__text { flex: 1; min-width: 0; }
  .fv2-hero__inner--split .fv2-hero__copy { margin-left: 0; margin-right: 0; }
  .fv2-hero__inner--split .fv2-hero__ctas { justify-content: flex-start; }
  .fv2-hero__inner--split .fv2-hero__trust { justify-content: flex-start; }
  .fv2-hero__animation {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fv2-hero__animation .lottie-container {
    width: 100%;
    max-width: 640px;
  }
  .fv2-hero__visual {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fv2-hero__svg {
    width: 100%;
    max-width: 560px;
    height: auto;
    object-fit: contain;
  }
  .fv2-hero__svg--float {
    animation: fv2HeroFloat 4s ease-in-out infinite;
  }
  @keyframes fv2HeroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .fv2-hero__badge {
    display: inline-flex;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    margin-bottom: 1.5rem;
  }
  .fv2-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 52px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0 0 1.25rem;
  }
  .fv2-hero__highlight {
    display: block;
    color: var(--brand-blue);
  }
  .fv2-hero__copy {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
    max-width: 680px;
    margin: 0 auto 2rem;
  }
  .fv2-hero__ctas {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .fv2-hero__trust {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .fv2-hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--subheading-gray);
  }

  /* ── TRUST STRIP ─────────────────────────── */
  .fv2-trust-strip {
    background: var(--surface-light);
    padding: 1.25rem 1.5rem;
  }
  .fv2-trust-strip__inner {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
  }
  .fv2-trust-strip__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--heading-dark);
  }

  /* ── BUTTONS ─────────────────────────────── */
  .fv2-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    padding: 0.75rem 1.75rem;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
    border: none;
  }
  .fv2-btn--primary { background: var(--brand-blue); color: #fff; }
  .fv2-btn--primary:hover { filter: brightness(1.1); transform: translateY(-2px); }
  .fv2-btn--outline { background: transparent; color: var(--heading-dark); border: 1.5px solid var(--surface-card-border, #e8ecf4); }
  .fv2-btn--outline:hover { border-color: var(--brand-blue); color: var(--brand-blue); }
  .fv2-btn--white { background: #fff; color: var(--heading-dark); }
  .fv2-btn--white:hover { background: #f0f4ff; transform: translateY(-2px); }
  .fv2-btn--ghost { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.2); }
  .fv2-btn--ghost:hover { background: rgba(255,255,255,0.2); }
  .fv2-btn--sm { font-size: 0.875rem; padding: 0.625rem 1.25rem; }

  /* ══════════════════════════════════════════
     ② STATS — dark band
     ═══════════════════════════════════════════ */
  .fv2-stats {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 100px 1.5rem;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }
  .fv2-stats__engagement { width: 100%; padding: 0 0 60px; display: flex; justify-content: center; }
  .fv2-stats__engagement-text { width: 65%; max-width: 800px; }
  .fv2-stats__heading {
    font-family: var(--font-heading);
