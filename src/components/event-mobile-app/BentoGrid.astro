---
const tabs = [
  {
    label: "Attendee Experience",
    hero: {
      eyebrow: "Core App Experience",
      title: "Give every attendee a personalized event companion in their pocket",
      desc: "From live agenda and AI networking to interactive maps and push notifications — the app keeps attendees engaged and informed throughout the event.",
      points: ["Personalized agenda builder", "AI-powered smart matching", "Offline-ready content"],
      visual: "agenda",
    },
    cards: [
      {
        eyebrow: "Smart matching",
        title: "AI Smart Connect",
        desc: "Match attendees by shared interests, industry, and goals with one-tap meeting requests.",
        visual: "connect",
      },
      {
        eyebrow: "Venue navigation",
        title: "Interactive Maps",
        desc: "Indoor venue maps with booth locations, session rooms, and turn-by-turn wayfinding.",
        visual: "maps",
      },
      {
        eyebrow: "Real-time alerts",
        title: "Push Notifications",
        desc: "Session reminders, networking match alerts, and organizer announcements delivered instantly.",
        visual: "push",
      },
      {
        eyebrow: "Networking identity",
        title: "Attendee Profiles",
        desc: "Rich profiles with bio, interests, and social links — making every connection meaningful.",
        visual: "profiles",
      },
    ],
  },
  {
    label: "Engagement Tools",
    hero: {
      eyebrow: "Live Interaction Suite",
      title: "Keep attendees actively participating with real-time interactive features",
      desc: "Live polls, Q&A, gamification, and activity feeds turn passive attendees into active participants who drive event energy.",
      points: ["Real-time poll results", "Moderated Q&A sessions", "Points and leaderboards"],
      visual: "polls",
    },
    cards: [
      {
        eyebrow: "Audience interaction",
        title: "Q&A Module",
        desc: "Attendees submit and upvote questions during sessions with speaker-side moderation controls.",
        visual: "qa",
      },
      {
        eyebrow: "Social wall",
        title: "Activity Feed",
        desc: "A live feed of photos, posts, and highlights shared by attendees during the event.",
        visual: "feed",
      },
      {
        eyebrow: "Motivation engine",
        title: "Gamification",
        desc: "Points, badges, and leaderboards that reward attendance, networking, and session participation.",
        visual: "gamify",
      },
      {
        eyebrow: "Session insights",
        title: "Session Feedback",
        desc: "Post-session rating prompts with quick feedback that helps organizers improve in real time.",
        visual: "feedback",
      },
    ],
  },
  {
    label: "Organizer Controls",
    hero: {
      eyebrow: "Admin Dashboard",
      title: "Monitor adoption, manage sponsors, and control content from one dashboard",
      desc: "Real-time analytics, sponsor placement configuration, content moderation, and QR check-in — all managed without leaving the organizer panel.",
      points: ["Live adoption metrics", "Sponsor revenue tools", "Contactless check-in"],
      visual: "analytics",
    },
    cards: [
      {
        eyebrow: "Revenue layer",
        title: "Sponsor Placements",
        desc: "Banners, splash screens, sponsored sessions, and push notification sponsorships from one config.",
        visual: "sponsor",
      },
      {
        eyebrow: "Safety controls",
        title: "Content Moderation",
        desc: "Review and approve activity feed posts, Q&A questions, and user-generated content before it goes live.",
        visual: "moderate",
      },
      {
        eyebrow: "Gate management",
        title: "QR Check-In",
        desc: "Contactless QR-based check-in with offline fallback and real-time attendance tracking.",
        visual: "qr",
      },
      {
        eyebrow: "Resilience",
        title: "Offline Mode",
        desc: "Core features cached locally — agenda, maps, and profiles work without internet connectivity.",
        visual: "offline",
      },
    ],
  },
];
---

<section class="emab-section" id="ema-bento">
  <div class="emab-shell">
    <h2 class="emab-title">
      Attendee <b>Experience</b>, Engagement & <b>Organizer Control</b>
    </h2>
    <p class="emab-subtitle">
      Deliver a branded mobile experience with AI networking, live engagement tools, and full organizer
      control — all from one event app platform.
    </p>

    <nav class="emab-nav" aria-label="Event mobile app workflows">
      {tabs.map((tab, index) => (
        <button
          class={`emab-tab${index === 0 ? " emab-tab--active" : ""}`}
          data-emab-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`emab-panel${tabIndex === 0 ? " emab-panel--active" : ""}`}
        data-emab-panel={tabIndex}
      >
        <div class="emab-grid">
          <article class="emab-card emab-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="emab-card__content">
              <span class="emab-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="emab-card__title">{tab.hero.title}</h3>
              <p class="emab-card__desc">{tab.hero.desc}</p>

              <ul class="emab-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`emab-art emab-art--hero emab-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "agenda" && (
                <Fragment>
                  <div class="emab-phone">
                    <div class="emab-phone__screen">
                      <div class="emab-agenda-rows">
                        <span class="emab-agenda-row emab-agenda-row--active">
                          <i>9:00</i><b>Opening Keynote</b>
                        </span>
                        <span class="emab-agenda-row">
                          <i>10:30</i><b>AI Workshop</b>
                        </span>
                        <span class="emab-agenda-row">
                          <i>12:00</i><b>Networking Lunch</b>
                        </span>
                      </div>
                    </div>
                  </div>
                  <div class="emab-pill emab-pill--floating">My Schedule</div>
                  <div class="emab-match-chip">3 sessions bookmarked</div>
                </Fragment>
              )}

              {tab.hero.visual === "polls" && (
                <Fragment>
                  <div class="emab-poll-card">
                    <strong>Live Poll</strong>
                    <div class="emab-poll-bars">
                      <span class="emab-poll-bar" style="--bar-w:72%"><i>AI Trends</i><b>72%</b></span>
                      <span class="emab-poll-bar" style="--bar-w:28%"><i>WebDev</i><b>28%</b></span>
                    </div>
                    <small>248 votes</small>
                  </div>
                  <div class="emab-pill emab-pill--warm">Live now</div>
                </Fragment>
              )}

              {tab.hero.visual === "analytics" && (
                <Fragment>
                  <div class="emab-dashboard">
                    <div class="emab-dash-stat">
                      <strong>85%</strong>
                      <span>Adoption</span>
                    </div>
                    <div class="emab-dash-stat">
                      <strong>4.2K</strong>
                      <span>Active Users</span>
                    </div>
                    <div class="emab-dash-chart">
                      <span class="emab-bar" style="--h:40%"></span>
                      <span class="emab-bar" style="--h:65%"></span>
                      <span class="emab-bar" style="--h:80%"></span>
                      <span class="emab-bar" style="--h:55%"></span>
                      <span class="emab-bar" style="--h:90%"></span>
                    </div>
                  </div>
                  <div class="emab-pill emab-pill--floating">Real-time dashboard</div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="emab-card emab-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="emab-card__content">
                <span class="emab-card__eyebrow">{card.eyebrow}</span>
                <h3 class="emab-card__title">{card.title}</h3>
                <p class="emab-card__desc">{card.desc}</p>
              </div>

              <div class={`emab-art emab-art--mini emab-art--${card.visual}`} aria-hidden="true">
                {card.visual === "connect" && (
                  <Fragment>
                    <div class="emab-nodes">
                      <span></span><span></span><span></span><span></span><span></span>
                    </div>
                    <div class="emab-meter">
                      <div><i></i></div>
                      <strong>92%</strong>
                    </div>
                  </Fragment>
                )}

                {card.visual === "maps" && (
                  <Fragment>
                    <div class="emab-map-grid">
                      <span></span><span></span><span></span>
                      <span></span><span class="emab-map-pin"></span><span></span>
                    </div>
                    <div class="emab-pill emab-pill--small">Hall B → Room 3</div>
                  </Fragment>
                )}

                {card.visual === "push" && (
                  <Fragment>
                    <div class="emab-device"></div>
                    <div class="emab-notice">
                      <strong>Session starts</strong>
                      <span>in 10 min</span>
                    </div>
                  </Fragment>
                )}

                {card.visual === "profiles" && (
                  <Fragment>
                    <div class="emab-person-card">
                      <span class="emab-person-avatar"></span>
                      <strong>Sarah M.</strong>
                      <small>Product • AI Enthusiast</small>
                    </div>
                  </Fragment>
                )}

                {card.visual === "qa" && (
                  <Fragment>
                    <div class="emab-qa-stack">
                      <span class="emab-qa-item"><b>▲ 24</b> How does the AI match…</span>
                      <span class="emab-qa-item"><b>▲ 18</b> Can we integrate with…</span>
                    </div>
                  </Fragment>
                )}

                {card.visual === "feed" && (
                  <Fragment>
                    <div class="emab-feed-rows">
                      <span></span><span></span><span></span>
                    </div>
                    <div class="emab-feed-badge">12 new posts</div>
                  </Fragment>
                )}

                {card.visual === "gamify" && (
                  <Fragment>
                    <div class="emab-leaderboard">
                      <span class="emab-lb-row"><i>🥇</i><b>Alex K.</b><em>820 pts</em></span>
                      <span class="emab-lb-row"><i>🥈</i><b>Priya S.</b><em>715 pts</em></span>
                      <span class="emab-lb-row"><i>🥉</i><b>David L.</b><em>690 pts</em></span>
                    </div>
                  </Fragment>
                )}

                {card.visual === "feedback" && (
                  <Fragment>
                    <div class="emab-stars">
                      <span>★</span><span>★</span><span>★</span><span>★</span><span class="emab-star-dim">★</span>
                    </div>
                    <div class="emab-pill emab-pill--small">4.2 avg rating</div>
                  </Fragment>
                )}

                {card.visual === "sponsor" && (
                  <Fragment>
                    <div class="emab-sponsor-slots">
                      <span class="emab-slot">Banner</span>
                      <span class="emab-slot">Splash</span>
                      <span class="emab-slot">Push</span>
                    </div>
                  </Fragment>
                )}

                {card.visual === "moderate" && (
                  <Fragment>
                    <div class="emab-mod-queue">
                      <span><b>✓</b> Approved</span>
                      <span><b>⏳</b> Pending</span>
                      <span><b>✕</b> Flagged</span>
                    </div>
                  </Fragment>
                )}

                {card.visual === "qr" && (
                  <Fragment>
                    <div class="emab-qr-frame">
                      <div class="emab-qr-grid">
                        <span></span><span></span><span></span><span></span>
                        <span></span><span></span><span></span><span></span>
                        <span></span><span></span><span></span><span></span>
                        <span></span><span></span><span></span><span></span>
                      </div>
                    </div>
                    <div class="emab-pill emab-pill--small">Scan to check in</div>
                  </Fragment>
                )}

                {card.visual === "offline" && (
                  <Fragment>
                    <div class="emab-offline-icon">
                      <svg width="36" height="36" viewBox="0 0 24 24" fill="none"><path d="M1 1l22 22M9 9a6 6 0 008.5 8.5M4.93 4.93A10 10 0 0020.07 20.07" stroke="#7fb4ff" stroke-width="2" stroke-linecap="round"/></svg>
                    </div>
                    <div class="emab-pill emab-pill--small">Cached locally</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".emab-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".emab-tab"));
      const panels = Array.from(root.querySelectorAll(".emab-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("emab-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("emab-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .emab-section {
    padding: 80px 0 60px;
    background: url('https://eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .emab-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .emab-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .emab-title b {
    font-weight: 700;
  }

  .emab-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .emab-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .emab-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .emab-tab:hover,
  .emab-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .emab-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .emab-panel {
    display: none;
  }

  .emab-panel--active {
    display: block;
  }

  .emab-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .emab-panel--active .emab-card {
    animation: emab-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  @keyframes emab-fade-up {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .emab-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .emab-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .emab-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .emab-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .emab-card--mini:nth-of-type(2) { grid-area: mini1; }
  .emab-card--mini:nth-of-type(3) { grid-area: mini2; }
  .emab-card--mini:nth-of-type(4) { grid-area: mini3; }
  .emab-card--mini:nth-of-type(5) { grid-area: mini4; }

  .emab-card__content {
    position: relative;
    z-index: 1;
  }

  .emab-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .emab-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .emab-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .emab-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .emab-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .emab-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  /* --- Art areas --- */
  .emab-art {
    position: relative;
    z-index: 1;
    min-height: 146px;
  }

  .emab-art--hero {
    min-height: 228px;
    margin-top: 0.6rem;
  }

  .emab-art--mini {
    align-self: end;
  }

  /* Phone shell */
  .emab-phone {
    position: absolute;
    inset: 0 auto 0 0;
    width: min(54%, 240px);
    padding: 0.75rem;
    border-radius: 2rem;
    background: linear-gradient(180deg, #1a2340 0%, #243873 100%);
    box-shadow: 0 28px 50px -32px rgba(12, 22, 52, 0.85);
  }

  .emab-phone__screen {
    position: relative;
    height: 100%;
    border-radius: 1.45rem;
    background: linear-gradient(180deg, #eef4ff 0%, #dfe8ff 100%);
    overflow: hidden;
    padding: 1rem 0.75rem;
  }

  /* Agenda rows */
  .emab-agenda-rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .emab-agenda-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(55, 93, 251, 0.08);
  }

  .emab-agenda-row--active {
    background: rgba(55, 93, 251, 0.1);
    border-color: rgba(55, 93, 251, 0.25);
  }

  .emab-agenda-row i {
    font-style: normal;
    font-size: 11px;
    font-weight: 700;
    color: #375dfb;
    min-width: 32px;
  }

  .emab-agenda-row b {
    font-size: 12px;
    font-weight: 600;
    color: #14213b;
  }

  /* Pills */
  .emab-pill {
    position: absolute;
    display: inline-flex;
    padding: 10px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
  }

  .emab-pill--floating {
    right: 20px;
    top: 20px;
    background: rgba(255, 255, 255, 0.94);
    color: #183465;
  }

  .emab-pill--warm {
    right: 20px;
    bottom: 20px;
    background: linear-gradient(90deg, rgba(245, 158, 11, 0.18), rgba(245, 158, 11, 0.08));
    color: #a16207;
  }

  .emab-pill--small {
    position: relative;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: #183465;
    font-size: 12px;
    font-weight: 600;
    box-shadow: none;
    margin-top: 8px;
    display: inline-flex;
  }

  .emab-match-chip {
    position: absolute;
    right: 20px;
    bottom: 20px;
    display: inline-flex;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.12);
    color: #15803d;
    font-size: 12px;
    font-weight: 700;
  }

  /* Poll card */
  .emab-poll-card {
    position: absolute;
    left: 24px;
    top: 24px;
    right: 24px;
    padding: 20px;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 22px 46px -36px rgba(17, 28, 56, 0.52);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .emab-poll-card strong {
    color: #183465;
    font-size: 16px;
  }

  .emab-poll-card small {
    color: #607390;
    font-size: 12px;
  }

  .emab-poll-bars {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .emab-poll-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    border-radius: 10px;
    background: linear-gradient(90deg, rgba(55, 93, 251, 0.15), rgba(55, 93, 251, 0.04));
    width: var(--bar-w, 50%);
    min-width: 80px;
    transition: width 0.6s ease;
  }

  .emab-poll-bar i {
    font-style: normal;
    font-size: 12px;
    color: #14213b;
    font-weight: 600;
  }

  .emab-poll-bar b {
    font-size: 12px;
    color: #375dfb;
  }

  /* Dashboard art */
  .emab-dashboard {
    position: absolute;
    left: 24px;
    top: 24px;
    right: 24px;
    padding: 20px;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 22px 46px -36px rgba(17, 28, 56, 0.52);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .emab-dash-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 14px;
    border-radius: 14px;
    background: rgba(55, 93, 251, 0.06);
  }

  .emab-dash-stat strong {
    font-size: 22px;
    color: #183465;
    font-weight: 700;
  }

  .emab-dash-stat span {
    font-size: 12px;
    color: #607390;
  }

  .emab-dash-chart {
    grid-column: span 2;
    display: flex;
    align-items: flex-end;
