---
import { emabIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Attendee Experience",
    hero: {
      title: "Give every attendee a personalized event companion in their pocket",
      desc: "From live agenda and AI networking to interactive maps and push notifications — the app keeps attendees engaged and informed throughout the event.",
      visual: "agenda",
    },
    cards: [
      { title: "AI Smart Connect", desc: "Match attendees by shared interests, industry, and goals with one-tap meeting requests.", visual: "connect" },
      { title: "Interactive Maps", desc: "Indoor venue maps with booth locations, session rooms, and turn-by-turn wayfinding.", visual: "maps" },
      { title: "Push Notifications", desc: "Session reminders, networking match alerts, and organizer announcements delivered instantly.", visual: "push" },
      { title: "Attendee Profiles", desc: "Rich profiles with bio, interests, and social links — making every connection meaningful.", visual: "profiles" },
    ],
  },
  {
    label: "Engagement Tools",
    hero: {
      title: "Keep attendees actively participating with real-time interactive features",
      desc: "Live polls, Q&A, gamification, and activity feeds turn passive attendees into active participants who drive event energy.",
      visual: "polls",
    },
    cards: [
      { title: "Q&A Module", desc: "Attendees submit and upvote questions during sessions with speaker-side moderation controls.", visual: "qa" },
      { title: "Activity Feed", desc: "A live feed of photos, posts, and highlights shared by attendees during the event.", visual: "feed" },
      { title: "Gamification", desc: "Points, badges, and leaderboards that reward attendance, networking, and session participation.", visual: "gamify" },
      { title: "Session Feedback", desc: "Post-session rating prompts with quick feedback that helps organizers improve in real time.", visual: "feedback" },
    ],
  },
  {
    label: "Organizer Controls",
    hero: {
      title: "Monitor adoption, manage sponsors, and control content from one dashboard",
      desc: "Real-time analytics, sponsor placement configuration, content moderation, and QR check-in — all managed without leaving the organizer panel.",
      visual: "analytics",
    },
    cards: [
      { title: "Sponsor Placements", desc: "Banners, splash screens, sponsored sessions, and push notification sponsorships from one config.", visual: "sponsor" },
      { title: "Content Moderation", desc: "Review and approve activity feed posts, Q&A questions, and user-generated content before it goes live.", visual: "moderate" },
      { title: "QR Check-In", desc: "Contactless QR-based check-in with offline fallback and real-time attendance tracking.", visual: "qr" },
      { title: "Offline Mode", desc: "Core features cached locally — agenda, maps, and profiles work without internet connectivity.", visual: "offline" },
    ],
  },
];

const ICON = '<svg class="emab-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="emab-section" id="ema-bento">
  <div class="emab">
    <h2 class="emab-title">
      Attendee <b>Experience</b>, Engagement & <b>Organizer Control</b>
    </h2>
    <p class="emab-subtitle">
      Deliver a branded mobile experience with AI networking, live engagement tools, and full organizer
      control — all from one event app platform.
    </p>

    <nav class="emab-nav">
      {tabs.map((t, i) => (
        <button class={`emab-tab ${i === 0 ? "emab-tab--active" : ""}`} data-emab-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`emab-panel ${tabIdx === 0 ? "emab-panel--active" : ""}`} data-emab-panel={String(tabIdx)}>
        <div class="emab-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="emab-card emab-card--tall emab-pos-0" style="animation-delay:0s">
            <div class="emab-card__inner">
              <div class="emab-card__text">
                <Fragment set:html={ICON} />
                <h3 class="emab-card__title">{t.hero.title}</h3>
                <p class="emab-card__desc">{t.hero.desc}</p>
              </div>
              <div class="emab-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`emab-card emab-card--sm emab-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="emab-card__inner emab-card__inner--row">
                <div class="emab-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="emab-card__title">{c.title}</h3>
                  <p class="emab-card__desc">{c.desc}</p>
                </div>
                <div class="emab-card__img emab-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const emabTabs = Array.from(document.querySelectorAll('[data-emab-tab]'));
  const emabPanels = Array.from(document.querySelectorAll('[data-emab-panel]'));
  let emabActive = 0;
  let emabInterval: ReturnType<typeof setInterval>;

  function setEmabTab(index: number) {
    emabTabs.forEach((t) => t.classList.remove('emab-tab--active'));
    emabPanels.forEach((p) => p.classList.remove('emab-panel--active'));
    emabTabs[index]?.classList.add('emab-tab--active');
    emabPanels[index]?.classList.add('emab-panel--active');
    emabActive = index;
  }
  function startEmab() {
    emabInterval = setInterval(() => setEmabTab((emabActive + 1) % emabTabs.length), 5000);
  }
  emabTabs.forEach((tab, i) => tab.addEventListener('click', () => { setEmabTab(i); clearInterval(emabInterval); startEmab(); }));
  startEmab();
  const emabSection = document.querySelector('.emab-section');
  if (emabSection) {
    emabSection.addEventListener('mouseenter', () => clearInterval(emabInterval));
    emabSection.addEventListener('mouseleave', () => startEmab());
  }
</script>

<style>
  .emab-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .emab { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .emab-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .emab-title b { font-weight: 700; }
  .emab-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .emab-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .emab-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .emab-tab:hover { background: rgba(55,93,251,.08); }
  .emab-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .emab-panel { display: none; }
  .emab-panel--active { display: block; animation: emabFadeUp 0.4s ease; }
  @keyframes emabFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .emab-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .emab-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .emab-pos-1 { grid-column: 2; grid-row: 1; }
  .emab-pos-2 { grid-column: 3; grid-row: 1; }
  .emab-pos-3 { grid-column: 2; grid-row: 2; }
  .emab-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .emab-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .emab-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .emab-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .emab-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .emab-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .emab-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .emab-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .emab-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .emab-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .emab-pos-4 { grid-column: 3; grid-row: 2; }

  @property --emab-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .emab-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: emabCardIn 0.5s ease forwards;
  }
  .emab-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--emab-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .emab-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .emab-card:hover::after { opacity: 1; animation: emabBorder 2.4s linear infinite; }
  @keyframes emabBorder { to { --emab-angle: 360deg; } }
  @keyframes emabCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .emab-pos-1 { animation-delay: 0.06s; }
  .emab-pos-2 { animation-delay: 0.12s; }
  .emab-pos-3 { animation-delay: 0.18s; }
  .emab-pos-4 { animation-delay: 0.24s; }

  .emab-card__inner { display: flex; flex-direction: column; height: 100%; }
  .emab-card__inner--row { flex-direction: row; }
  .emab-card__text { display: flex; flex-direction: column; gap: 6px; }
  .emab-card--tall .emab-card__text { padding: 20px 20px 8px; }
  .emab-card--sm .emab-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .emab-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .emab-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .emab-card--sm .emab-card__title { font-size: 17px; }
  .emab-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .emab-card--sm .emab-card__desc { font-size: 13px; }

  .emab-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .emab-card--tall .emab-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .emab-card--sm .emab-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .emab-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .emab-card:hover .emab-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: emabFloat 2.2s ease-in-out infinite;
  }
  @keyframes emabFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .emab-section { padding: 60px 0 48px; }
    .emab-title { font-size: 36px; }
    .emab-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .emab-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .emab-pos-1, .emab-pos-2, .emab-pos-3, .emab-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .emab-pos-0, [data-layout="c"] .emab-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .emab-pos-1, [data-layout="b"] .emab-pos-2, [data-layout="b"] .emab-pos-3, [data-layout="b"] .emab-pos-4,
    [data-layout="c"] .emab-pos-1, [data-layout="c"] .emab-pos-2, [data-layout="c"] .emab-pos-3, [data-layout="c"] .emab-pos-4 { grid-column: auto; grid-row: auto; }
    .emab-card--tall .emab-card__inner { flex-direction: row; }
    .emab-card--tall .emab-card__text { flex: 1; }
    .emab-card--tall .emab-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .emab-title { font-size: 28px; }
    .emab-subtitle { font-size: 15px; }
    .emab-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .emab-tab { border-radius: 12px; }
    .emab-grid { grid-template-columns: 1fr; }
    .emab-pos-0, .emab-pos-1, .emab-pos-2, .emab-pos-3, .emab-pos-4,
    [data-layout="b"] .emab-pos-0, [data-layout="b"] .emab-pos-1, [data-layout="b"] .emab-pos-2, [data-layout="b"] .emab-pos-3, [data-layout="b"] .emab-pos-4,
    [data-layout="c"] .emab-pos-0, [data-layout="c"] .emab-pos-1, [data-layout="c"] .emab-pos-2, [data-layout="c"] .emab-pos-3, [data-layout="c"] .emab-pos-4 { grid-column: 1; grid-row: auto; }
    .emab-card--sm .emab-card__inner, .emab-card--tall .emab-card__inner { flex-direction: row; }
    .emab-card--sm .emab-card__text, .emab-card--tall .emab-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .emab-card--sm .emab-card__img, .emab-card--tall .emab-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .emab-card { animation: none !important; opacity: 1; transform: none; }
    .emab-card:hover::after { animation: none !important; }
    .emab-card:hover .emab-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
