---
const featureCards = [
  {
    eyebrow: "AI networking",
    title: "AI-powered networking that matches the right people",
    desc: "AI Smart Connect analyzes attendee profiles, interests, industry, and goals to suggest the most relevant connections — turning a crowded event into curated one-on-one opportunities.",
    items: [
      "Smart matching based on profile data and behavior",
      "One-tap meeting requests with calendar integration",
      "Direct messaging between matched attendees and speakers",
    ],
    visual: "networking",
  },
  {
    eyebrow: "Branded experience",
    title: "Your brand, your app, published under your name",
    desc: "The event app is fully white-labeled — your logo, colors, and fonts on every screen, published to iOS and Android app stores under your event or organization name.",
    items: [
      "Custom logo, colors, fonts, and splash screen",
      "Published to iOS and Android under your event name",
      "Configurable home layout with widgets and quick links",
    ],
    visual: "branding",
  },
  {
    eyebrow: "Live engagement",
    title: "Keep attendees engaged with real-time interactive tools",
    desc: "Live polls, Q&A, gamification, and an activity feed turn passive attendees into active participants who shape the event experience in real time.",
    items: [
      "Launch polls during sessions with instant visualization",
      "Points, badges, and leaderboards driving interactions",
      "Live activity feed with photos, posts, and highlights",
    ],
    visual: "engagement",
  },
  {
    eyebrow: "Operational control",
    title: "Real-time analytics and sponsor monetization built in",
    desc: "Monitor app adoption, track feature usage, manage sponsor placements, and run contactless QR check-in — all from one organizer dashboard.",
    items: [
      "Live dashboard showing app adoption and feature usage",
      "Sponsor banners, splash screens, and sponsored sessions",
      "Contactless QR check-in with offline fallback",
    ],
    visual: "control",
  },
];
---

<section class="emaf-shell">
  <div class="emaf-section">
    <div class="emaf-header">
      <span class="emaf-subtitle">Everything your event app needs — built in, not bolted on</span>
      <h2 class="emaf-title">
        AI Networking, <span class="emaf-highlight">White-Label Branding</span>,<br />
        and Live Engagement
      </h2>
    </div>

    <div class="emaf-cards" id="emaf-stacking-cards">
      {featureCards.map((card, index) => (
        <div class="emaf-card" data-card-index={index} style={`--card-index: ${index}; top: calc(20px + ${index * 20}px);`}>
          <div class="emaf-card-content">
            <span class="emaf-card-eyebrow">{card.eyebrow}</span>
            <h3 class="emaf-card-title">{card.title}</h3>
            <p class="emaf-card-desc">{card.desc}</p>
            <ul class="emaf-card-items">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href="/book-a-demo/" class="emaf-card-btn">Explore More</a>
          </div>

          <div class={`emaf-card-visual emaf-card-visual--${card.visual}`}>
            {card.visual === "networking" && (
              <Fragment>
                <div class="emaf-network-globe">
                  <div class="emaf-globe-ring emaf-globe-ring--1"></div>
                  <div class="emaf-globe-ring emaf-globe-ring--2"></div>
                  <div class="emaf-globe-ring emaf-globe-ring--3"></div>
                  <div class="emaf-globe-center"></div>
                  <div class="emaf-node emaf-node--1"></div>
                  <div class="emaf-node emaf-node--2"></div>
                  <div class="emaf-node emaf-node--3"></div>
                  <div class="emaf-node emaf-node--4"></div>
                </div>
                <div class="emaf-pill">92% match accuracy</div>
              </Fragment>
            )}

            {card.visual === "branding" && (
              <Fragment>
                <div class="emaf-phone-frame">
                  <div class="emaf-phone-inner">
                    <div class="emaf-brand-bar"></div>
                    <div class="emaf-brand-widgets">
                      <span></span><span></span>
                    </div>
                    <div class="emaf-brand-nav">
                      <span></span><span></span><span></span><span></span>
                    </div>
                  </div>
                </div>
                <div class="emaf-store-badges">
                  <span class="emaf-badge-ios">iOS</span>
                  <span class="emaf-badge-android">Android</span>
                </div>
              </Fragment>
            )}

            {card.visual === "engagement" && (
              <Fragment>
                <div class="emaf-engage-stack">
                  <div class="emaf-engage-poll">
                    <strong>Live Poll</strong>
                    <div class="emaf-engage-bars">
                      <i style="width:70%"></i>
                      <i style="width:30%"></i>
                    </div>
                  </div>
                  <div class="emaf-engage-badges">
                    <span>🏆</span><span>⭐</span><span>🎯</span>
                  </div>
                </div>
                <div class="emaf-pill">248 live votes</div>
              </Fragment>
            )}

            {card.visual === "control" && (
              <Fragment>
                <div class="emaf-control-dash">
                  <div class="emaf-ctrl-stat">
                    <strong>85%</strong>
                    <span>Adoption</span>
                  </div>
                  <div class="emaf-ctrl-stat">
                    <strong>4.2K</strong>
                    <span>Active</span>
                  </div>
                </div>
                <div class="emaf-qr-check">
                  <div class="emaf-qr-mini">
                    <span></span><span></span><span></span><span></span>
                  </div>
                  <strong>QR check-in live</strong>
                </div>
              </Fragment>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .emaf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .emaf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .emaf-header {
    width: 72%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .emaf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .emaf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .emaf-highlight {
    color: #AFA3FF;
  }

  .emaf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .emaf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.88));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .emaf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .emaf-card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(175, 163, 255, 0.12);
    border: 1px solid rgba(175, 163, 255, 0.2);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #afa3ff;
  }

  .emaf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .emaf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .emaf-card-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .emaf-card-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
  }

  .emaf-card-items li::before {
    content: "";
    flex: 0 0 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
  }

  .emaf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .emaf-card-btn:hover {
    transform: scale(1.05);
  }

  .emaf-card-visual {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
    background: radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 52%);
  }

  /* Networking globe */
  .emaf-network-globe {
    position: relative;
    width: 220px;
    height: 220px;
  }

  .emaf-globe-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(175, 163, 255, 0.2);
  }

  .emaf-globe-ring--1 { inset: 0; }
  .emaf-globe-ring--2 { inset: 25px; border-color: rgba(175, 163, 255, 0.3); }
  .emaf-globe-ring--3 { inset: 50px; border-color: rgba(175, 163, 255, 0.4); }

  .emaf-globe-center {
    position: absolute;
    inset: 75px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.5), rgba(175, 163, 255, 0.2));
  }

  .emaf-node {
    position: absolute;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: linear-gradient(135deg, #d9e4ff, #7fb4ff);
    border: 2px solid rgba(55, 93, 251, 0.3);
    box-shadow: 0 0 12px rgba(55, 93, 251, 0.3);
  }

  .emaf-node--1 { top: 10px; left: 50%; transform: translateX(-50%); }
  .emaf-node--2 { bottom: 10px; left: 50%; transform: translateX(-50%); }
  .emaf-node--3 { top: 50%; left: 10px; transform: translateY(-50%); }
  .emaf-node--4 { top: 50%; right: 10px; transform: translateY(-50%); }

  .emaf-pill {
    position: absolute;
    right: 32px;
    bottom: 36px;
    display: inline-flex;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: #183465;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
  }

  /* Brand phone */
  .emaf-phone-frame {
    width: 200px;
    padding: 10px;
    border-radius: 30px;
    background: linear-gradient(180deg, #1a2340 0%, #243873 100%);
    box-shadow: 0 28px 50px -32px rgba(12, 22, 52, 0.85);
  }

  .emaf-phone-inner {
    height: 320px;
    border-radius: 24px;
    background: linear-gradient(180deg, #eef4ff 0%, #dfe8ff 100%);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 20px 14px;
  }

  .emaf-brand-bar {
    height: 24px;
    border-radius: 8px;
    background: linear-gradient(90deg, rgba(55, 93, 251, 0.3), rgba(55, 93, 251, 0.1));
  }

  .emaf-brand-widgets {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    flex: 1;
  }

  .emaf-brand-widgets span {
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(55, 93, 251, 0.08);
  }

  .emaf-brand-nav {
    display: flex;
    gap: 8px;
    justify-content: center;
  }

  .emaf-brand-nav span {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(55, 93, 251, 0.1);
  }

  .emaf-store-badges {
    position: absolute;
    right: 32px;
    bottom: 42px;
    display: flex;
    gap: 8px;
  }

  .emaf-badge-ios,
  .emaf-badge-android {
    padding: 8px 14px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: 700;
  }

  .emaf-badge-ios {
    background: rgba(255, 255, 255, 0.9);
    color: #183465;
  }

  .emaf-badge-android {
    background: rgba(34, 197, 94, 0.15);
    color: #15803d;
  }

  /* Engagement stack */
  .emaf-engage-stack {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 240px;
  }

  .emaf-engage-poll {
    padding: 18px;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .emaf-engage-poll strong {
    color: #183465;
    font-size: 15px;
  }

  .emaf-engage-bars {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .emaf-engage-bars i {
    display: block;
    height: 10px;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #7fb4ff);
    opacity: 0.6;
  }

  .emaf-engage-badges {
    display: flex;
    gap: 10px;
    justify-content: center;
    font-size: 24px;
  }

  /* Control dashboard */
  .emaf-control-dash {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 220px;
  }

  .emaf-ctrl-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 16px;
    border-radius: 16px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
  }

  .emaf-ctrl-stat strong {
    font-size: 22px;
    color: #183465;
    font-weight: 700;
  }

  .emaf-ctrl-stat span {
    font-size: 12px;
    color: #607390;
  }

  .emaf-qr-check {
    position: absolute;
    right: 28px;
    bottom: 42px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 16px;
    background: rgba(24, 52, 101, 0.94);
    color: #f8fbff;
    box-shadow: 0 20px 40px -28px rgba(17, 28, 56, 0.75);
  }

  .emaf-qr-check strong {
    font-size: 13px;
  }

  .emaf-qr-mini {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    width: 24px;
    height: 24px;
  }

  .emaf-qr-mini span {
    background: #fff;
    border-radius: 2px;
    opacity: 0.7;
  }

  .emaf-qr-mini span:nth-child(even) { opacity: 0.3; }

  @media (max-width: 1024px) {
    .emaf-section { padding: 60px 20px 30px; }
    .emaf-header { width: 80%; }
    .emaf-subtitle { font-size: 16px; }
    .emaf-title { font-size: 40px; line-height: 1em; }
    .emaf-card { height: 450px; }
    .emaf-card-content { flex-basis: 50%; }
    .emaf-card-title { font-size: 28px; }
    .emaf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .emaf-section { padding: 50px 20px 30px; }
    .emaf-header { width: 100%; }
    .emaf-title { font-size: 30px; }
    .emaf-card { flex-direction: column; height: auto; min-height: 520px; }
    .emaf-card-content { flex: 0 0 auto; padding: 20px 20px 0; }
    .emaf-card-visual { min-height: 260px; padding: 12px; }
    .emaf-card-title { font-size: 24px; }
    .emaf-card-desc { font-size: 15px; }
    .emaf-cards { padding-bottom: 40px; }
    .emaf-card-items li { font-size: 14px; }
  }
</style>
