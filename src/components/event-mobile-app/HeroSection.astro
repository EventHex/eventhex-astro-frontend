---
const heroPoints = [
  "AI-powered networking",
  "White-label branding",
  "Offline support",
];

const trustItems = [
  "50K+ app downloads",
  "4.8★ App Store rating",
];

const metrics = [
  { value: "85%", label: "attendee adoption" },
  { value: "4.8★", label: "App Store rating" },
  { value: "300+", label: "events powered" },
];
---

<section class="emah-hero">
  <div class="emah-hero__shell">
    <div class="emah-hero__grid">
      <div class="emah-hero__content">
        <div class="emah-hero__badge animate-on-scroll" data-animation="fadeInDown">
          <span>Event Mobile App</span>
        </div>

        <h1 class="emah-hero__title animate-on-scroll" data-animation="fadeInUp">
          Your Event's Own Mobile
          <span>App Experience</span>
        </h1>

        <p class="emah-hero__desc animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 800ms">
          Launch a branded mobile app for your event — attendee networking, live agenda, push notifications, QR check-in, and interactive maps — all under your event brand.
        </p>

        <div class="emah-hero__points animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 950ms">
          {heroPoints.map((point) => <span class="emah-hero__point">{point}</span>)}
        </div>

        <div class="emah-hero__cta animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 1100ms">
          <a href="/book-a-demo/" class="emah-hero__btn emah-hero__btn--primary">Get a Free Demo</a>
          <a href="#ema-bento" class="emah-hero__btn emah-hero__btn--secondary">Explore Features</a>
        </div>

        <div class="emah-hero__trust animate-on-scroll" data-animation="fadeIn" style="--anim-duration: 1250ms">
          {trustItems.map((item) => <span class="emah-hero__trust-item">{item}</span>)}
        </div>
      </div>

      <div class="emah-hero__visual animate-on-scroll" data-animation="fadeInRight">
        <div class="emah-hero__visual-card">
          <div class="emah-hero__floating emah-hero__floating--top">
            <span class="emah-hero__floating-label">AI Smart Connect</span>
            <strong>Match attendees by interest and goals</strong>
          </div>

          <img
            src="https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png"
            alt="EventHex Event Mobile App dashboard"
            width="700"
            height="500"
            loading="eager"
          />

          <div class="emah-hero__floating emah-hero__floating--bottom">
            <span class="emah-hero__floating-label">White-Label</span>
            <strong>Your brand on iOS and Android stores</strong>
          </div>

          <div class="emah-hero__metric-row">
            {metrics.map((metric) => (
              <div class="emah-hero__metric">
                <strong>{metric.value}</strong>
                <span>{metric.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .emah-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    padding: 0 0 220px;
    background:
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }

  .emah-hero__shell {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 160px 0 0;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat;
  }

  .emah-hero__grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .emah-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .emah-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .emah-hero__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 600;
    line-height: 60px;
    letter-spacing: -1px;
    color: var(--heading-dark);
  }

  .emah-hero__title span {
    display: block;
    color: var(--brand-blue);
  }

  .emah-hero__desc {
    margin: 0;
    max-width: 580px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .emah-hero__points {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .emah-hero__point {
    display: inline-flex;
    align-items: center;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #e5ebff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #475467;
    box-shadow: 0 8px 24px rgba(34, 39, 47, 0.05);
  }

  .emah-hero__cta {
    display: flex;
    gap: 14px;
    padding-top: 6px;
  }

  .emah-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, border-color 0.3s;
  }

  .emah-hero__btn--primary {
    color: #fff;
    background: var(--brand-blue);
    box-shadow: 0 10px 24px rgba(55, 93, 251, 0.28);
  }

  .emah-hero__btn--primary:hover {
    transform: translateY(-2px);
    background: var(--brand-blue-hover);
    box-shadow: 0 14px 30px rgba(55, 93, 251, 0.34);
  }

  .emah-hero__btn--secondary {
    color: var(--heading-dark);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #dce4ff;
  }

  .emah-hero__btn--secondary:hover {
    transform: translateY(-2px);
    border-color: #c5d2ff;
    box-shadow: 0 10px 24px rgba(34, 39, 47, 0.06);
  }

  .emah-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .emah-hero__trust-item {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #667085;
  }

  .emah-hero__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
  }

  .emah-hero__visual {
    position: relative;
  }

  .emah-hero__visual-card {
    position: relative;
    padding: 20px 0 36px;
  }

  .emah-hero__visual-card img {
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 26px 48px rgba(34, 39, 47, 0.14));
  }

  .emah-hero__floating {
    position: absolute;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.94);
    color: var(--heading-dark);
    border: 1px solid rgba(229, 235, 255, 0.9);
    box-shadow: 0 18px 36px rgba(34, 39, 47, 0.12);
    backdrop-filter: blur(12px);
  }

  .emah-hero__floating--top {
    top: -18px;
    left: -18px;
    max-width: 260px;
  }

  .emah-hero__floating--bottom {
    right: -18px;
    bottom: 94px;
    max-width: 280px;
  }

  .emah-hero__floating-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    line-height: 16px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #667085;
  }

  .emah-hero__floating strong {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.45;
  }

  .emah-hero__metric-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 24px;
  }

  .emah-hero__metric {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 18px;
    border-radius: 18px;
    background: rgba(247, 248, 252, 0.96);
    border: 1px solid rgba(55, 93, 251, 0.08);
  }

  .emah-hero__metric strong {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.8px;
    color: var(--heading-dark);
  }

  .emah-hero__metric span {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: #667085;
  }

  @media (max-width: 1120px) {
    .emah-hero { padding: 0 20px 110px; }
    .emah-hero__shell { padding: 136px 0 0; }
    .emah-hero__grid { gap: 28px; padding: 0 0 40px; }
    .emah-hero__desc { max-width: 520px; }
    .emah-hero__title { font-size: 46px; line-height: 1.1em; }
  }

  @media (max-width: 960px) {
    .emah-hero { padding: 0 20px 96px; }
    .emah-hero__shell { padding: 130px 0 0; }
    .emah-hero__grid { grid-template-columns: 1fr; gap: 34px; padding: 0 0 40px; }
    .emah-hero__content { align-items: center; text-align: center; }
    .emah-hero__desc { max-width: 720px; }
    .emah-hero__trust,
    .emah-hero__points,
    .emah-hero__cta { justify-content: center; }
    .emah-hero__title { font-size: 42px; line-height: 1.1em; }
    .emah-hero__visual-card { padding: 26px 0 0; }
    .emah-hero__floating--top { left: 0; }
    .emah-hero__floating--bottom { right: 0; bottom: 34px; }
  }

  @media (max-width: 767px) {
    .emah-hero { margin-top: -80px; padding: 0 20px 90px; }
    .emah-hero__shell { padding: 120px 0 0; }
    .emah-hero__grid { padding: 0 0 30px; }
    .emah-hero__title { font-size: 30px; line-height: 1.2em; letter-spacing: 0; }
    .emah-hero__desc { font-size: 15px; line-height: 1.7; }
    .emah-hero__badge { font-size: 16px; line-height: 1.1em; }
    .emah-hero__point { font-size: 13px; padding: 8px 12px; }
    .emah-hero__cta { width: 100%; flex-direction: column; }
    .emah-hero__btn { width: 100%; }
    .emah-hero__trust { gap: 10px; justify-content: center; }
    .emah-hero__floating { position: static; margin-bottom: 12px; max-width: none; }
    .emah-hero__visual-card { padding: 18px 0 0; }
    .emah-hero__metric-row { grid-template-columns: 1fr; }
  }
</style>
