---
const faqs = [
  {
    q: "Is the event app published under our brand?",
    a: "Yes. The app is fully white-labeled and published to iOS and Android app stores under your event or organization name — attendees see your brand, not EventHex.",
  },
  {
    q: "Do attendees need to download the app?",
    a: "We offer both a native app (iOS/Android) and a mobile-responsive web app. Attendees who prefer not to download can access core features via the web version.",
  },
  {
    q: "How does AI networking work?",
    a: "Our AI analyzes attendee profiles, interests, industry, and stated goals to suggest relevant connections. Attendees receive smart match recommendations and can schedule meetings directly in the app.",
  },
  {
    q: "Can the app work offline?",
    a: "Yes. Core features like the agenda, venue maps, and attendee profiles are cached locally. When connectivity returns, data syncs automatically.",
  },
  {
    q: "How do sponsors get visibility in the app?",
    a: "Organizers can place sponsor banners, splash screen ads, sponsored sessions, and push notification sponsorships — creating multiple monetization touchpoints.",
  },
  {
    q: "What engagement features are included?",
    a: "Live polls, session Q&A with moderation, activity feed / social wall, gamification (points, badges, leaderboards), and session feedback — all built in.",
  },
  {
    q: "How fast can we launch the app?",
    a: "The app can be configured and published within days. Content updates sync in real time, so you can keep refining right up to the event.",
  },
  {
    q: "Is attendee data secure?",
    a: "Absolutely. All data is encrypted in transit and at rest. We follow industry best practices for data protection and comply with GDPR requirements.",
  },
];

const checklist = [
  "App branding and store publishing",
  "AI networking and engagement setup",
  "Sponsor placement configuration",
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="emafq">
  <div class="emafq__inner">
    <div class="emafq__support">
      <span class="emafq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need a custom app setup?</span>
      <h2 class="emafq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="emafq__desc animate-on-scroll" data-animation="fadeInUp">
        We help event teams shape branded mobile experiences, AI networking flows, and sponsor monetization around how their live event operations actually run.
      </p>

      <div class="emafq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="emafq__support-label">Included with every rollout</span>
        <ul class="emafq__support-list">
          {checklist.map((item) => (
            <li class="emafq__support-item">{item}</li>
          ))}
        </ul>

        <div class="emafq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your event app workflow before launch and keep your team aligned on branding, engagement, and sponsor settings.</span>
        </div>

        <a href="/book-a-demo/" class="emafq__cta">Plan my app launch</a>
      </div>
    </div>

    <div class="emafq__list">
      {faqs.map((faq, index) => (
        <details class="emafq__item animate-on-scroll" data-animation="fadeInUp" data-ema-faq open={index === 0}>
          <summary class="emafq__question">
            <span>{faq.q}</span>
            <span class="emafq__icon" aria-hidden="true">
              <span class="emafq__icon-line emafq__icon-line--horizontal"></span>
              <span class="emafq__icon-line emafq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="emafq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const emaFaqItems = Array.from(document.querySelectorAll('[data-ema-faq]'));

  emaFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      emaFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .emafq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .emafq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .emafq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .emafq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .emafq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .emafq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .emafq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .emafq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .emafq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .emafq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .emafq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .emafq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .emafq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .emafq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .emafq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .emafq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .emafq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .emafq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .emafq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
  }

  .emafq__question::-webkit-details-marker,
  .emafq__question::marker {
    display: none;
  }

  .emafq__icon {
    position: relative;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 4px;
  }

  .emafq__icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #375dfb;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .emafq__icon-line--vertical {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .emafq__item[open] .emafq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0);
  }

  .emafq__answer {
    padding: 0 24px 24px;
  }

  .emafq__answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #5b6477;
  }

  @media (max-width: 1100px) {
    .emafq { padding: 76px 0; }
    .emafq__inner { grid-template-columns: 1fr; gap: 28px; }
    .emafq__support { position: static; }
  }

  @media (max-width: 1024px) {
    .emafq__title { font-size: 40px; }
    .emafq__desc { font-size: 16px; }
    .emafq__question { padding: 24px 22px; font-size: 20px; }
    .emafq__answer { padding: 0 22px 22px; }
  }

  @media (max-width: 767px) {
    .emafq { padding: 56px 0; }
    .emafq__inner { padding: 0 16px; gap: 24px; }
    .emafq__title { font-size: 32px; line-height: 1.08; }
    .emafq__desc { font-size: 15px; line-height: 1.7; }
    .emafq__support-card { padding: 20px 18px; border-radius: 24px; }
    .emafq__support-item { font-size: 15px; }
    .emafq__support-note strong { font-size: 18px; }
    .emafq__cta { width: 100%; }
    .emafq__item { border-radius: 24px; }
    .emafq__question { padding: 20px 18px; font-size: 17px; line-height: 1.45; }
    .emafq__answer { padding: 0 18px 20px; }
    .emafq__answer p { font-size: 15px; line-height: 1.75; }
  }
</style>
