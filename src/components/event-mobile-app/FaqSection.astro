---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "Is the event app published under our brand?", a: "Yes. The app is fully white-labeled and published to iOS and Android app stores under your event or organization name — attendees see your brand, not EventHex." },
  { q: "Do attendees need to download the app?", a: "We offer both a native app (iOS/Android) and a mobile-responsive web app. Attendees who prefer not to download can access core features via the web version." },
  { q: "How does AI networking work?", a: "Our AI analyzes attendee profiles, interests, industry, and stated goals to suggest relevant connections. Attendees receive smart match recommendations and can schedule meetings directly in the app." },
  { q: "Can the app work offline?", a: "Yes. Core features like the agenda, venue maps, and attendee profiles are cached locally. When connectivity returns, data syncs automatically." },
  { q: "How do sponsors get visibility in the app?", a: "Organizers can place sponsor banners, splash screen ads, sponsored sessions, and push notification sponsorships — creating multiple monetization touchpoints." },
  { q: "What engagement features are included?", a: "Live polls, session Q&A with moderation, activity feed / social wall, gamification (points, badges, leaderboards), and session feedback — all built in." },
  { q: "How fast can we launch the app?", a: "The app can be configured and published within days. Content updates sync in real time, so you can keep refining right up to the event." },
  { q: "Is attendee data secure?", a: "Absolutely. All data is encrypted in transit and at rest. We follow industry best practices for data protection and comply with GDPR requirements." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need a custom app setup?"
  title="Frequently Asked Questions"
  description="We help event teams shape branded mobile experiences, AI networking flows, and sponsor monetization around how their live event operations actually run."
/>
