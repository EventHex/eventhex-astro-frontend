---
const steps = [
  {
    num: "01",
    title: "Configure Your App",
    desc: "Set up branding, upload logo, choose colors, and configure the home screen layout in the organizer dashboard.",
  },
  {
    num: "02",
    title: "Add Event Content",
    desc: "Import your agenda, speakers, sponsors, and venue maps. Everything syncs to the app in real time.",
  },
  {
    num: "03",
    title: "Publish to App Stores",
    desc: "We publish the white-label app to iOS and Android — listed under your event name.",
  },
  {
    num: "04",
    title: "Engage Attendees",
    desc: "Attendees download the app, build their schedule, network via AI, and engage with live sessions.",
  },
];
---

<section class="emahw-full">
  <div class="emahw-full__inner">
    <div class="emahw-full__header">
      <span class="emahw-full__tag animate-on-scroll" data-animation="fadeIn">How It Works</span>
      <h2 class="emahw-full__title animate-on-scroll" data-animation="fadeInUp">From Setup to <b>Attendee Engagement</b></h2>
      <p class="emahw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Configure your branded event app, add content, publish to app stores, and watch attendees engage — all in days, not months.
      </p>
    </div>

    <div class="emahw-full__cards">
      {steps.map((step) => (
        <article class="emahw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="emahw-full__card-icon">{step.num}</div>
          <h3 class="emahw-full__card-title">{step.title}</h3>
          <p class="emahw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .emahw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .emahw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .emahw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .emahw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .emahw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .emahw-full__title b { font-weight: 700; }

  .emahw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .emahw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .emahw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .emahw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .emahw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .emahw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .emahw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .emahw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .emahw-full { padding: 64px 0; }
    .emahw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .emahw-full { padding: 52px 0; }
    .emahw-full__title { font-size: 30px; line-height: 1.15; }
    .emahw-full__desc { font-size: 15px; }
    .emahw-full__cards { grid-template-columns: 1fr; }
  }
</style>
