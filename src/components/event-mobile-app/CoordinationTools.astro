---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3" stroke="#375DFB" stroke-width="2"/><path d="M5 20a7 7 0 0114 0" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M17 10l2 2 3-3" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "AI-powered networking",
    desc: "Match attendees by shared interests, industry, and goals with AI Smart Connect. Schedule meetings and message directly inside the app.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="3" stroke="#375DFB" stroke-width="2"/><path d="M10 18h4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="8" r="2" stroke="#375DFB" stroke-width="1.5"/></svg>`,
    title: "Complete white-label control",
    desc: "Your brand on every screen — from splash page to App Store listing. Configure home layout, widgets, and sponsor placements from the dashboard.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3z" stroke="#375DFB" stroke-width="2" stroke-linejoin="round"/><path d="M9.5 12.5l1.8 1.8 3.2-3.6" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Offline-ready engagement",
    desc: "Core features work without internet. Agenda, maps, and profiles are cached locally and sync automatically when connectivity returns.",
  },
];
---

<section class="emac-full">
  <div class="emac-full__inner">
    <div class="emac-full__header">
      <span class="emac-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Mobile App</span>
      <h2 class="emac-full__title animate-on-scroll" data-animation="fadeInUp">Seamless Mobile <b>Event Experience</b></h2>
      <p class="emac-full__desc animate-on-scroll" data-animation="fadeInUp">Keep attendee networking, live engagement, sponsor visibility, and offline access aligned without adding more tools to the event-day stack.</p>
    </div>

    <div class="emac-full__cards">
      {cards.map((card) => (
        <div class="emac-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="emac-full__card-icon" set:html={card.icon}></div>
          <h3 class="emac-full__card-title">{card.title}</h3>
          <p class="emac-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .emac-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://cms.eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .emac-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .emac-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .emac-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .emac-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .emac-full__title b { font-weight: 700; }

  .emac-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .emac-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .emac-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .emac-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .emac-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .emac-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .emac-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .emac-full { padding: 64px 0; }
    .emac-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .emac-full { padding: 52px 0; }
    .emac-full__title { font-size: 30px; line-height: 1.15; }
    .emac-full__desc { font-size: 15px; }
    .emac-full__cards { grid-template-columns: 1fr; }
  }
</style>
