---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Sub-second QR scanning",
    desc: "QR recognition and verification in under 1 second on any device.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16z" stroke="#375DFB" stroke-width="2"/><path d="M4.93 4.93l14.14 14.14" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M8 2h8M12 2v4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M2 8v8M2 12h4" stroke="#375DFB" stroke-width="2" stroke-linecap="round" opacity="0.4"/></svg>`,
    title: "Offline scanning mode",
    desc: "Continue scanning without internet — data auto-syncs when reconnected.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M3 10h18" stroke="#375DFB" stroke-width="2"/><path d="M9 4v16" stroke="#375DFB" stroke-width="2"/><circle cx="15" cy="14" r="1.5" fill="#22C55E"/><circle cx="15" cy="18" r="1.5" fill="#22C55E"/></svg>`,
    title: "Session attendance tracking",
    desc: "Track per-session attendance for speakers, sponsors, and post-event reports.",
  },
];
---

<section class="ecic-full">
  <div class="ecic-full__inner">
    <div class="ecic-full__header">
      <span class="ecic-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Check-In</span>
      <h2 class="ecic-full__title animate-on-scroll" data-animation="fadeInUp">Effortless Event Day <b>Operations</b></h2>
      <p class="ecic-full__desc animate-on-scroll" data-animation="fadeInUp">Scan, track, and manage event-day check-in with sub-second QR scanning and real-time operations dashboards.</p>
    </div>

    <div class="ecic-full__cards">
      {cards.map((card) => (
        <div class="ecic-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="ecic-full__card-icon" set:html={card.icon}></div>
          <h3 class="ecic-full__card-title">{card.title}</h3>
          <p class="ecic-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .ecic-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://cms.eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .ecic-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .ecic-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .ecic-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ecic-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .ecic-full__title b { font-weight: 700; }

  .ecic-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .ecic-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .ecic-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .ecic-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .ecic-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .ecic-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .ecic-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .ecic-full { padding: 64px 0; }
    .ecic-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .ecic-full { padding: 52px 0; }
    .ecic-full__title { font-size: 30px; line-height: 1.15; }
    .ecic-full__desc { font-size: 15px; }
    .ecic-full__cards { grid-template-columns: 1fr; }
  }
</style>
