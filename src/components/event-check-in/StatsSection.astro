---
const stats = [
  { value: "100K+", label: "Check-Ins Processed" },
  { value: "1 sec", label: "Per-Scan Time" },
  { value: "99.9%", label: "Scan Accuracy" },
  { value: "100+", label: "Simultaneous Scanners" },
];
---

<section class="ecis-dark">
  <div class="ecis-engagement">
    <div class="ecis-engagement-text">
      <h2 class="ecis-heading animate-on-scroll" data-animation="fadeInDown">
        <span class="ecis-white">Check in attendees with</span>
        <br />
        <span class="ecis-purple">sub-second QR scanning</span>
        <br />
        <span class="ecis-white">and </span>
        <span class="ecis-cyan">real-time tracking</span>
      </h2>
    </div>
  </div>

  <div class="ecis-stats">
    {stats.map((stat) => (
      <div class="ecis-stat-card">
        <span class="ecis-stat-value">{stat.value}</span>
        <span class="ecis-stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .ecis-dark {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 110px 0;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .ecis-engagement {
    width: 100%;
    padding: 0 0 60px;
    display: flex;
    justify-content: center;
  }

  .ecis-engagement-text {
    width: 65%;
  }

  .ecis-heading {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    text-align: center;
    margin: 0;
  }

  .ecis-white { color: #fff; }
  .ecis-purple { color: #AFA3FF; }
  .ecis-cyan { color: #ABFFFF; }

  .ecis-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    padding: 0 20px;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    flex-wrap: nowrap;
  }

  .ecis-stat-card {
    flex: 1 1 0;
    max-width: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 2.25rem 1.5rem;
    background: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .ecis-stat-card:hover {
    transform: translateY(-6px);
    border-color: rgba(159,129,255,0.35);
    box-shadow: 0 8px 32px rgba(159,129,255,0.12);
  }

  .ecis-stat-value {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -1.5px;
    color: #fff;
  }

  .ecis-stat-label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.55);
  }

  @media (max-width: 1024px) {
    .ecis-dark { padding: 80px 0; }
    .ecis-engagement { padding: 0 20px 40px; }
    .ecis-engagement-text { width: 85%; }
    .ecis-stats { gap: 1rem; }
    .ecis-stat-card { padding: 1.75rem 1.25rem; }
    .ecis-stat-value { font-size: 2.25rem; }
    .ecis-stat-label { font-size: 0.8125rem; }
  }

  @media (max-width: 767px) {
    .ecis-dark { padding: 64px 0; }
    .ecis-engagement { padding: 0 15px 30px; }
    .ecis-engagement-text { width: 100%; }
    .ecis-heading { font-size: 25px; line-height: 1.2em; letter-spacing: 0; }
    .ecis-stats {
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: center;
    }
    .ecis-stat-card {
      flex: 1 1 calc(50% - 0.5rem);
      max-width: none;
      padding: 1.5rem 1rem;
    }
    .ecis-stat-value { font-size: 1.75rem; }
    .ecis-stat-label { font-size: 0.8125rem; }
  }
</style>
