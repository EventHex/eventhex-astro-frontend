---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "How does QR code check-in work?", a: "Every registered attendee receives a unique QR code via email or the mobile app. At the event, staff scan the QR code with any smartphone or tablet camera. The system verifies the attendee and marks them as checked-in in under 1 second." },
  { q: "Can multiple staff scan simultaneously?", a: "Yes. You can have 100+ devices scanning simultaneously across multiple entrances. Each device runs independently, and all data syncs to the central dashboard in real time." },
  { q: "Does check-in work offline?", a: "Yes. Offline mode pre-caches the attendee database on each device. Scans continue normally without internet, and data syncs automatically when connectivity returns." },
  { q: "Can I track session-level attendance?", a: "Yes. Set up scanning points at session room entrances. Each scan records which attendee attended which session — providing valuable data for speakers, sponsors, and post-event reports." },
  { q: "What devices are supported for scanning?", a: "Any device with a camera works — iPhones, Android phones, iPads, Android tablets, and dedicated barcode/QR scanners. The web-based scanner runs in any modern browser." },
  { q: "How do I handle duplicate scans?", a: "The system automatically detects and blocks duplicate scans. If an attendee is already checked in, the scanner shows a clear alert — preventing double-counting." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need Help?"
  title="Frequently Asked Questions"
  description="Everything you need to know about event check-in and how it works with EventHex."
/>
