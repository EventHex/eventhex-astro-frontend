---
const faqs = [
  {
    q: "How does QR code check-in work?",
    a: "Every registered attendee receives a unique QR code via email or the mobile app. At the event, staff scan the QR code with any smartphone or tablet camera. The system verifies the attendee and marks them as checked-in in under 1 second.",
  },
  {
    q: "Can multiple staff scan simultaneously?",
    a: "Yes. You can have 100+ devices scanning simultaneously across multiple entrances. Each device runs independently, and all data syncs to the central dashboard in real time.",
  },
  {
    q: "Does check-in work offline?",
    a: "Yes. Offline mode pre-caches the attendee database on each device. Scans continue normally without internet, and data syncs automatically when connectivity returns.",
  },
  {
    q: "Can I track session-level attendance?",
    a: "Yes. Set up scanning points at session room entrances. Each scan records which attendee attended which session — providing valuable data for speakers, sponsors, and post-event reports.",
  },
  {
    q: "What devices are supported for scanning?",
    a: "Any device with a camera works — iPhones, Android phones, iPads, Android tablets, and dedicated barcode/QR scanners. The web-based scanner runs in any modern browser.",
  },
  {
    q: "How do I handle duplicate scans?",
    a: "The system automatically detects and blocks duplicate scans. If an attendee is already checked in, the scanner shows a clear alert — preventing double-counting.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="ecifq" data-eci-faq>
  <div class="ecifq__inner">
    <div class="ecifq__sidebar animate-on-scroll" data-animation="fadeInLeft">
      <span class="ecifq__eyebrow">Need Help?</span>
      <h2 class="ecifq__title">Frequently Asked Questions</h2>
      <p class="ecifq__desc">
        Everything you need to know about event check-in and how it works with EventHex.
      </p>
      <div class="ecifq__support-card">
        <h3 class="ecifq__support-title">Talk to Our Team</h3>
        <p class="ecifq__support-desc">Our experts can walk you through a personalized demo and answer any questions about check-in setup.</p>
      </div>
      <a href="/book-a-demo/" class="ecifq__cta">Book a Demo</a>
    </div>

    <div class="ecifq__list">
      {faqs.map((faq, index) => (
        <details class="ecifq__item animate-on-scroll" data-animation="fadeInUp" data-delay={String(index * 60)} data-eci-faq-item>
          <summary class="ecifq__question">
            {faq.q}
            <svg class="ecifq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="ecifq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const eciFaqItems = Array.from(document.querySelectorAll('[data-eci-faq-item]'));

  eciFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      eciFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .ecifq {
    background: var(--surface-light, #f8f9fc);
    padding: 5rem 1.5rem;
  }

  .ecifq__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .ecifq__sidebar {
    position: sticky;
    top: 6rem;
  }

  .ecifq__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-blue);
    margin-bottom: 0.5rem;
  }

  .ecifq__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .ecifq__desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0 0 1.25rem;
  }

  .ecifq__support-card {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf4);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .ecifq__support-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0 0 0.35rem;
  }

  .ecifq__support-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0;
  }

  .ecifq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 1.25rem;
    border-radius: 10px;
    background: var(--brand-blue);
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    transition: background 0.2s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .ecifq__cta:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(55, 93, 251, 0.25);
  }

  .ecifq__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ecifq__item {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf4);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .ecifq__item[open] {
    border-color: var(--brand-blue);
  }

  .ecifq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--heading-dark);
    cursor: pointer;
    list-style: none;
  }

  .ecifq__question::-webkit-details-marker,
  .ecifq__question::marker {
    display: none;
  }

  .ecifq__chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
    color: var(--subheading-gray);
  }

  .ecifq__item[open] .ecifq__chevron {
    transform: rotate(180deg);
    color: var(--brand-blue);
  }

  .ecifq__answer {
    padding: 0 1.5rem 1.25rem;
  }

  .ecifq__answer p {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .ecifq__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .ecifq__sidebar {
      position: static;
    }
  }

  @media (max-width: 767px) {
    .ecifq {
      padding: 3rem 1rem;
    }
    .ecifq__title {
      font-size: 1.5rem;
    }
    .ecifq__question {
      padding: 1rem 1.25rem;
      font-size: 0.875rem;
    }
    .ecifq__answer {
      padding: 0 1.25rem 1rem;
    }
    .ecifq__cta {
      width: 100%;
    }
  }
</style>
