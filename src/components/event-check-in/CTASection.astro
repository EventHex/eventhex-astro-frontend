---
import LottiePlayer from "../LottiePlayer.astro";
---

<section class="ecicta">
  <div class="ecicta__card">
    <div class="ecicta__glow ecicta__glow--1"></div>
    <div class="ecicta__glow ecicta__glow--2"></div>
    <div class="ecicta__inner">
      <div class="ecicta__content">
        <span class="ecicta__eyebrow animate-on-scroll" data-animation="fadeIn">Streamline Event Day</span>
        <h2 class="ecicta__title animate-on-scroll" data-animation="fadeInUp">Ready to Streamline Your Event Day Operations?</h2>
        <p class="ecicta__desc animate-on-scroll" data-animation="fadeInUp">See how EventHex check-in handles thousands of attendees with sub-second QR scanning and real-time dashboards.</p>
        <div class="ecicta__proof-row animate-on-scroll" data-animation="fadeInUp">
          <span class="ecicta__proof-pill">Sub-second scanning</span>
          <span class="ecicta__proof-pill">Offline mode</span>
          <span class="ecicta__proof-pill">Free onboarding support</span>
        </div>
        <div class="ecicta__buttons">
          <a href="/book-a-demo/" class="ecicta__btn ecicta__btn--primary">
            Book a Free Demo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/contact-en/" class="ecicta__btn ecicta__btn--secondary">Contact Sales</a>
        </div>
        <div class="ecicta__trust">
          <span class="ecicta__trust-item">No credit card required</span>
          <span class="ecicta__trust-item">Free onboarding support</span>
          <span class="ecicta__trust-item">Cancel anytime</span>
        </div>
      </div>
      <div class="ecicta__visual">
        <LottiePlayer src="/animations/event-check-in-cta.json" class="ecicta__lottie" />
      </div>
    </div>
  </div>
</section>


<style is:global>
  .ecicta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }

  .ecicta__card {
    position: relative;
    border-radius: 24px;
    padding: 60px 40px;
    overflow: hidden;
    background: #0F1629;
  }

  .ecicta__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .ecicta__content {
    flex: 1 1 55%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    text-align: left;
  }

  .ecicta__visual {
    flex: 1 1 40%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ecicta__lottie {
    width: 100%;
    max-width: 400px;
  }

  .ecicta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .ecicta__glow--1 {
    width: 400px;
    height: 400px;
    background: rgba(55, 93, 251, 0.2);
    top: -100px;
    left: -50px;
  }

  .ecicta__glow--2 {
    width: 300px;
    height: 300px;
    background: rgba(159, 129, 255, 0.15);
    bottom: -80px;
    right: -30px;
  }

  /* removed old .ecicta__content — now in card layout above */

  .ecicta__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .ecicta__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .ecicta__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.3px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .ecicta__proof-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ecicta__proof-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: rgba(255, 255, 255, 0.74);
  }

  .ecicta__buttons { display: flex; gap: 12px; }

  .ecicta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.3px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .ecicta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.35);
  }

  .ecicta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(55, 93, 251, 0.4);
  }

  .ecicta__btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .ecicta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .ecicta__trust {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-top: 8px;
  }

  .ecicta__trust-item {
    position: relative;
    padding-left: 14px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
  }

  .ecicta__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
  }

  @media (max-width: 1024px) {
    .ecicta__card { padding: 48px 24px; }
    .ecicta__inner { gap: 24px; }
    .ecicta__title { font-size: 36px; }
    .ecicta__desc { font-size: 16px; }
    .ecicta__lottie { max-width: 320px; }
  }

  @media (max-width: 767px) {
    .ecicta { padding: 40px 16px 60px; }
    .ecicta__card { padding: 40px 20px; border-radius: 20px; }
    .ecicta__inner { flex-direction: column; }
    .ecicta__content { align-items: center; text-align: center; }
    .ecicta__proof-row { justify-content: center; }
    .ecicta__buttons { justify-content: center; }
    .ecicta__title { font-size: 28px; line-height: 1.2em; }
    .ecicta__desc { font-size: 15px; }
    .ecicta__proof-row { gap: 8px; }
    .ecicta__buttons { flex-direction: column; width: 100%; }
    .ecicta__btn { width: 100%; justify-content: center; }
    .ecicta__trust { flex-direction: column; gap: 8px; align-items: center; }
    .ecicta__lottie { max-width: 280px; }
  }
</style>
