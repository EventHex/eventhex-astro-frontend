---
const featureCards = [
  {
    eyebrow: "scan engine",
    title: "Check in thousands of attendees in minutes with QR scanning",
    desc: "Multiple staff scan simultaneously across entrances. Each QR scan takes under 1 second with instant visual confirmation and optional auto-print badge trigger.",
    items: [
      "Works on any smartphone, tablet, or scanner",
      "Under 1 second scan and verification",
      "Auto-trigger badge printing on scan",
    ],
    visual: "scanengine",
  },
  {
    eyebrow: "session tracking",
    title: "Track attendance per session for speakers and sponsors",
    desc: "Set up scanning points at session rooms to track exactly who attended which sessions — giving speakers feedback and sponsors ROI data.",
    items: [
      "Dedicated session room scanners",
      "Post-event attendance reports",
      "Speaker session attendance insights",
    ],
    visual: "sessioneng",
  },
  {
    eyebrow: "offline mode",
    title: "Scan even without internet — zero risk of losing data",
    desc: "Venue WiFi unreliable? Offline mode caches attendee data locally and continues scanning. Data syncs automatically when connectivity returns.",
    items: [
      "Attendee data cached locally pre-event",
      "Auto-sync when device reconnects",
      "Every scan stored locally first",
    ],
    visual: "offlineeng",
  },
  {
    eyebrow: "operations",
    title: "Real-time operations dashboard for event-day command",
    desc: "Monitor check-in rates, queue lengths, staff activity, and attendance metrics from a single live dashboard. React to bottlenecks instantly.",
    items: [
      "Live check-in rate and queue monitoring",
      "Staff activity and gate status tracking",
      "Exportable real-time attendance lists",
    ],
    visual: "opseng",
  },
];
---

<section class="ecif-shell">
  <div class="ecif-section">
    <div class="ecif-header">
      <span class="ecif-subtitle">Everything you need to manage event-day check-in and operations</span>
      <h2 class="ecif-title">
        Everything You Need to <span class="ecif-highlight">Scan, Track, and Manage</span><br />
        Event Day Operations
      </h2>
    </div>

    <div class="ecif-cards" id="ecif-stacking-cards">
      {featureCards.map((card, index) => (
        <div class="ecif-card" data-card-index={index} style={`--card-index: ${index}; top: calc(20px + ${index * 20}px);`}>
          <div class="ecif-card-content">
            <span class="ecif-card-eyebrow">{card.eyebrow}</span>
            <h3 class="ecif-card-title">{card.title}</h3>
            <p class="ecif-card-desc">{card.desc}</p>
            <ul class="ecif-card-items">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href="/book-a-demo/" class="ecif-card-btn">Explore More</a>
          </div>

          <div class={`ecif-card-visual ecif-card-visual--${card.visual}`}>
            {card.visual === "scanengine" && (
              <Fragment>
                <img
                  src="/feature-images/event-check-in/scan-engine-visual.svg"
                  alt="QR scan check-in with attendee list and profile card"
                  class="ecif-scanengine-img"
                  loading="lazy"
                  width="578"
                  height="476"
                />
              </Fragment>
            )}

            {card.visual === "sessioneng" && (
              <Fragment>
                <img
                  src="/feature-images/event-check-in/session-tracking-visual.svg"
                  alt="Session tracking dashboard with attendance data"
                  class="ecif-sessioneng-img"
                  loading="lazy"
                  width="269"
                  height="181"
                />
              </Fragment>
            )}

            {card.visual === "offlineeng" && (
              <Fragment>
                <img
                  src="/feature-images/event-check-in/offline-mode-visual.svg"
                  alt="Offline mode with cached attendee data and auto-sync"
                  class="ecif-offlineeng-img"
                  loading="lazy"
                  width="267"
                  height="149"
                />
              </Fragment>
            )}

            {card.visual === "opseng" && (
              <Fragment>
                <img
                  src="/feature-images/event-check-in/operations-visual.svg"
                  alt="Real-time operations dashboard with check-in metrics"
                  class="ecif-opseng-img"
                  loading="lazy"
                  width="407"
                  height="248"
                />
              </Fragment>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .ecif-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .ecif-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .ecif-header {
    width: 72%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .ecif-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .ecif-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .ecif-highlight { color: #AFA3FF; }

  .ecif-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .ecif-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.88));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .ecif-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .ecif-card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(175, 163, 255, 0.12);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #afa3ff;
  }

  .ecif-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .ecif-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .ecif-card-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ecif-card-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .ecif-card-items li::before {
    content: "";
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
  }

  .ecif-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .ecif-card-btn:hover { transform: scale(1.05); }

  .ecif-card-visual {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
    background: radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 52%);
  }

  /* Scan engine visual */
  .ecif-scanengine-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    object-fit: contain;
    animation: ecif-float 4s ease-in-out infinite;
  }

  @keyframes ecif-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* Session tracking visual */
  .ecif-sessioneng-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    object-fit: contain;
    animation: ecif-float-session 4.5s ease-in-out infinite;
  }

  @keyframes ecif-float-session {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-10px) scale(1.02); }
  }

  /* Offline visual */
  .ecif-offlineeng-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    object-fit: contain;
    animation: ecif-float-offline 5s ease-in-out infinite;
  }

  @keyframes ecif-float-offline {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-10px) scale(1.01); }
  }

  /* Operations visual */
  .ecif-opseng-img {
    width: 100%;
    max-width: 520px;
    height: auto;
    object-fit: contain;
    animation: ecif-float-ops 4.8s ease-in-out infinite;
  }

  @keyframes ecif-float-ops {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-11px); }
  }

  @media (max-width: 1024px) {
    .ecif-section { padding: 60px 20px 30px; }
    .ecif-header { width: 80%; }
    .ecif-subtitle { font-size: 16px; }
    .ecif-title { font-size: 40px; line-height: 1em; }
    .ecif-card { height: 450px; }
    .ecif-card-content { flex-basis: 50%; }
    .ecif-card-title { font-size: 28px; }
    .ecif-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .ecif-section { padding: 50px 20px 30px; }
    .ecif-header { width: 100%; }
    .ecif-title { font-size: 30px; }
    .ecif-card { flex-direction: column; height: 620px; }
    .ecif-card-content { flex: 0 0 55%; padding: 20px 20px 0; }
    .ecif-card-visual { min-height: 260px; padding: 12px; }
    .ecif-card-title { font-size: 24px; }
    .ecif-card-desc { font-size: 15px; }
    .ecif-cards { padding-bottom: 40px; }
    .ecif-scanengine-img { max-width: 100%; }
    .ecif-sessioneng-img { max-width: 100%; }
    .ecif-offlineeng-img { max-width: 100%; }
    .ecif-opseng-img { max-width: 100%; }
  }
</style>
