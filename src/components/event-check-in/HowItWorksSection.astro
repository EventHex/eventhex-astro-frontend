---
const steps = [
  {
    num: "01",
    title: "Set Up Scanning Stations",
    desc: "Assign staff devices to entrance gates and session rooms. Download the attendee list for offline mode.",
  },
  {
    num: "02",
    title: "Attendees Arrive & Scan",
    desc: "Attendees show their QR code — staff scan with any smartphone or tablet. Check-in takes under 1 second.",
  },
  {
    num: "03",
    title: "Monitor Live Dashboard",
    desc: "Track check-in rates, queue lengths, and attendance in real time from the organizer dashboard.",
  },
  {
    num: "04",
    title: "Export Reports",
    desc: "After the event, export full attendance data — total check-ins, session attendance, and time analytics.",
  },
];
---

<section class="ecihw-full">
  <div class="ecihw-full__inner">
    <div class="ecihw-full__header">
      <span class="ecihw-full__tag animate-on-scroll" data-animation="fadeIn">How Event Check-In Works</span>
      <h2 class="ecihw-full__title animate-on-scroll" data-animation="fadeInUp">From Setup to <b>Smooth Event Day</b></h2>
      <p class="ecihw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Set up scanning stations, check in attendees, monitor live dashboards, and export complete reports.
      </p>
    </div>

    <div class="ecihw-full__cards">
      {steps.map((step) => (
        <article class="ecihw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="ecihw-full__card-icon">{step.num}</div>
          <h3 class="ecihw-full__card-title">{step.title}</h3>
          <p class="ecihw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .ecihw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .ecihw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .ecihw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .ecihw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ecihw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .ecihw-full__title b { font-weight: 700; }

  .ecihw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .ecihw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .ecihw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .ecihw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .ecihw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .ecihw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .ecihw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .ecihw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .ecihw-full { padding: 64px 0; }
    .ecihw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .ecihw-full { padding: 52px 0; }
    .ecihw-full__title { font-size: 30px; line-height: 1.15; }
    .ecihw-full__desc { font-size: 15px; }
    .ecihw-full__cards { grid-template-columns: 1fr; }
  }
</style>
