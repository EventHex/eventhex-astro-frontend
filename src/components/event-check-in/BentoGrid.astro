---
const tabs = [
  {
    label: "QR Scanning",
    hero: {
      eyebrow: "Scan Engine",
      title: "Camera-based QR scanning with barcode support and multi-device deployment",
      desc: "Scan attendee QR codes with any smartphone or tablet camera. Support 100+ simultaneous devices across the venue with offline capability.",
      points: ["Any device camera scanning", "100+ simultaneous scanners", "Offline mode available"],
      visual: "qrscan",
    },
    cards: [
      {
        eyebrow: "Barcode",
        title: "Barcode Support",
        desc: "Also supports barcode scanning for ticket and badge verification.",
        visual: "barcode",
      },
      {
        eyebrow: "Multi-Device",
        title: "Multi-Device",
        desc: "Run 100+ simultaneous scanning devices across the venue.",
        visual: "multidev",
      },
      {
        eyebrow: "Offline",
        title: "Offline Scanning",
        desc: "Continue scanning without internet — data syncs when reconnected.",
        visual: "offline",
      },
      {
        eyebrow: "Confirm",
        title: "Instant Confirmation",
        desc: "Visual and audio confirmation for each successful check-in.",
        visual: "confirm",
      },
    ],
  },
  {
    label: "Attendance Tracking",
    hero: {
      eyebrow: "Tracking Engine",
      title: "Real-time attendance tracking with session-level scanning and duplicate prevention",
      desc: "Live count of checked-in vs registered attendees with multi-entrance support and session-level attendance tracking.",
      points: ["Live attendance counts", "Session-level scanning", "Duplicate prevention"],
      visual: "tracking",
    },
    cards: [
      {
        eyebrow: "Sessions",
        title: "Session Attendance",
        desc: "Track who attended which sessions with session-level scanning.",
        visual: "sessiontrack",
      },
      {
        eyebrow: "Search",
        title: "Attendee Search",
        desc: "Instantly search attendees by name, email, or company.",
        visual: "search",
      },
      {
        eyebrow: "Security",
        title: "Duplicate Prevention",
        desc: "Automatic detection and blocking of duplicate scans.",
        visual: "dupeblock",
      },
      {
        eyebrow: "Entrances",
        title: "Multi-Entrance",
        desc: "Track check-in at multiple entrances simultaneously.",
        visual: "entrance",
      },
    ],
  },
  {
    label: "Event Day Dashboard",
    hero: {
      eyebrow: "Operations Hub",
      title: "Bird's-eye view of check-in flow, queues, staff activity, and live stats",
      desc: "Monitor everything from one dashboard — check-in rates, queue lengths, staff activity, and attendance metrics updating in real time.",
      points: ["Live operations view", "Staff login portal", "Real-time statistics"],
      visual: "opsdash",
    },
    cards: [
      {
        eyebrow: "Staff",
        title: "Staff Login Portal",
        desc: "Dedicated staff login for each screening gate and kiosk.",
        visual: "staffportal",
      },
      {
        eyebrow: "List",
        title: "Scanned Users List",
        desc: "Exportable real-time list of all checked-in attendees.",
        visual: "scanlist",
      },
      {
        eyebrow: "Print",
        title: "On-Site Badge Print",
        desc: "Print badges immediately upon check-in scan.",
        visual: "badgeprint",
      },
      {
        eyebrow: "Metrics",
        title: "Real-Time Stats",
        desc: "Live metrics — check-in rate, peak times, and wait estimates.",
        visual: "livestats",
      },
    ],
  },
];
---

<section class="ecib-section" id="eci-bento">
  <div class="ecib-shell">
    <h2 class="ecib-title">
      QR <b>Scanning</b>, Attendance <b>Tracking</b> &amp; <b>Operations</b>
    </h2>
    <p class="ecib-subtitle">
      Scan, track, and manage event-day operations from a single real-time dashboard.
    </p>

    <nav class="ecib-nav" aria-label="Event check-in workflows">
      {tabs.map((tab, index) => (
        <button
          class={`ecib-tab${index === 0 ? " ecib-tab--active" : ""}`}
          data-ecib-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`ecib-panel${tabIndex === 0 ? " ecib-panel--active" : ""}`}
        data-ecib-panel={tabIndex}
      >
        <div class="ecib-grid">
          <article class="ecib-card ecib-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="ecib-card__content">
              <span class="ecib-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="ecib-card__title">{tab.hero.title}</h3>
              <p class="ecib-card__desc">{tab.hero.desc}</p>

              <ul class="ecib-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`ecib-art ecib-art--hero ecib-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "qrscan" && (
                <Fragment>
                  <div class="ecib-qr-frame">
                    <div class="ecib-qr-corners">
                      <span class="ecib-qr-corner ecib-qr-corner--tl"></span>
                      <span class="ecib-qr-corner ecib-qr-corner--tr"></span>
                      <span class="ecib-qr-corner ecib-qr-corner--bl"></span>
                      <span class="ecib-qr-corner ecib-qr-corner--br"></span>
                    </div>
                    <div class="ecib-qr-grid">
                      <span></span><span></span><span></span><span></span>
                      <span></span><span></span><span></span><span></span>
                      <span></span>
                    </div>
                    <div class="ecib-scan-line"></div>
                  </div>
                  <div class="ecib-scan-badge">
                    <span class="ecib-scan-check">&#10003;</span>
                    <span class="ecib-scan-text">Verified</span>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "tracking" && (
                <Fragment>
                  <div class="ecib-counter-display">
                    <div class="ecib-counter-row">
                      <div class="ecib-counter-item">
                        <strong class="ecib-counter-num">1,847</strong>
                        <span class="ecib-counter-label">Checked In</span>
                      </div>
                      <div class="ecib-counter-divider"></div>
                      <div class="ecib-counter-item">
                        <strong class="ecib-counter-num">2,500</strong>
                        <span class="ecib-counter-label">Registered</span>
                      </div>
                    </div>
                    <div class="ecib-counter-bar">
                      <div class="ecib-counter-fill"></div>
                    </div>
                    <span class="ecib-counter-pct">73.9%</span>
                  </div>
                  <div class="ecib-entrance-chips">
                    <div class="ecib-entrance-chip"><span class="ecib-entrance-dot ecib-entrance-dot--green"></span> Gate A: 842</div>
                    <div class="ecib-entrance-chip"><span class="ecib-entrance-dot ecib-entrance-dot--blue"></span> Gate B: 621</div>
                    <div class="ecib-entrance-chip"><span class="ecib-entrance-dot ecib-entrance-dot--purple"></span> Gate C: 384</div>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "opsdash" && (
                <Fragment>
                  <div class="ecib-dash-frame">
                    <div class="ecib-dash-topbar">
                      <div class="ecib-dash-dots"><span></span><span></span><span></span></div>
                      <span class="ecib-dash-title-bar"></span>
                    </div>
                    <div class="ecib-dash-body">
                      <div class="ecib-dash-widget">
                        <span class="ecib-dash-widget-label"></span>
                        <strong class="ecib-dash-widget-val">1,847</strong>
                      </div>
                      <div class="ecib-dash-widget">
                        <span class="ecib-dash-widget-label"></span>
                        <strong class="ecib-dash-widget-val">42/min</strong>
                      </div>
                      <div class="ecib-dash-chart">
                        <span style="--h:40%"></span>
                        <span style="--h:65%"></span>
                        <span style="--h:50%"></span>
                        <span style="--h:85%"></span>
                        <span style="--h:70%"></span>
                      </div>
                    </div>
                  </div>
                  <div class="ecib-dash-live-dot">
                    <span class="ecib-live-pulse"></span>
                    LIVE
                  </div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="ecib-card ecib-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="ecib-card__content">
                <span class="ecib-card__eyebrow">{card.eyebrow}</span>
                <h3 class="ecib-card__title">{card.title}</h3>
                <p class="ecib-card__desc">{card.desc}</p>
              </div>

              <div class={`ecib-art ecib-art--mini ecib-art--${card.visual}`} aria-hidden="true">
                {card.visual === "barcode" && (
                  <Fragment>
                    <div class="ecib-barcode-strip">
                      <span></span><span></span><span></span><span></span><span></span>
                      <span></span><span></span><span></span><span></span><span></span>
                      <span></span><span></span>
                    </div>
                    <div class="ecib-barcode-highlight"></div>
                    <div class="ecib-mini-chip">Barcode scan</div>
                  </Fragment>
                )}

                {card.visual === "multidev" && (
                  <Fragment>
                    <div class="ecib-devices">
                      <div class="ecib-device ecib-device--phone">
                        <div class="ecib-device-screen"></div>
                      </div>
                      <div class="ecib-device ecib-device--tablet">
                        <div class="ecib-device-screen"></div>
                      </div>
                      <div class="ecib-device ecib-device--phone ecib-device--phone2">
                        <div class="ecib-device-screen"></div>
                      </div>
                    </div>
                    <div class="ecib-mini-chip">100+ devices</div>
                  </Fragment>
                )}

                {card.visual === "offline" && (
                  <Fragment>
                    <div class="ecib-offline-icon">
                      <svg viewBox="0 0 48 48" class="ecib-signal-svg">
                        <path d="M24 36a3 3 0 1 0 0 6 3 3 0 0 0 0-6z" fill="#375dfb"/>
                        <path d="M16 30c2.2-2.2 5.1-3.3 8-3.3s5.8 1.1 8 3.3" stroke="#375dfb" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.6"/>
                        <path d="M10 24c3.8-3.8 8.8-5.7 14-5.7s10.2 1.9 14 5.7" stroke="#375dfb" stroke-width="3" fill="none" stroke-linecap="round" opacity="0.3"/>
                      </svg>
                      <div class="ecib-offline-slash"></div>
                    </div>
                    <div class="ecib-offline-badge">Cached</div>
                    <div class="ecib-mini-chip">Offline ready</div>
                  </Fragment>
                )}

                {card.visual === "confirm" && (
                  <Fragment>
                    <div class="ecib-confirm-circle">
                      <svg viewBox="0 0 48 48" class="ecib-confirm-svg">
                        <circle cx="24" cy="24" r="20" fill="none" stroke="#22c55e" stroke-width="3" opacity="0.2"/>
                        <circle cx="24" cy="24" r="20" fill="none" stroke="#22c55e" stroke-width="3" stroke-dasharray="126" stroke-dashoffset="0" stroke-linecap="round" class="ecib-confirm-ring"/>
                        <path d="M16 24l5 5 11-11" stroke="#22c55e" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="ecib-mini-chip">Confirmed</div>
                  </Fragment>
                )}

                {card.visual === "sessiontrack" && (
                  <Fragment>
                    <div class="ecib-session-cards">
                      <div class="ecib-session-card">
                        <span class="ecib-session-name"></span>
                        <strong>124</strong>
                      </div>
                      <div class="ecib-session-card">
                        <span class="ecib-session-name"></span>
                        <strong>89</strong>
                      </div>
                      <div class="ecib-session-card">
                        <span class="ecib-session-name"></span>
                        <strong>67</strong>
                      </div>
                    </div>
                    <div class="ecib-mini-chip">Session data</div>
                  </Fragment>
                )}

                {card.visual === "search" && (
                  <Fragment>
                    <div class="ecib-search-bar">
                      <span class="ecib-search-icon">&#128269;</span>
                      <span class="ecib-search-placeholder"></span>
                    </div>
                    <div class="ecib-search-results">
                      <div class="ecib-search-row"><span class="ecib-search-avatar"></span><span class="ecib-search-name"></span></div>
                      <div class="ecib-search-row"><span class="ecib-search-avatar"></span><span class="ecib-search-name"></span></div>
                    </div>
                    <div class="ecib-mini-chip">Instant search</div>
                  </Fragment>
                )}

                {card.visual === "dupeblock" && (
                  <Fragment>
                    <div class="ecib-shield">
                      <svg viewBox="0 0 48 56" class="ecib-shield-svg">
                        <path d="M24 2L4 12v16c0 14 20 24 20 24s20-10 20-24V12L24 2z" fill="rgba(55,93,251,0.08)" stroke="#375dfb" stroke-width="2"/>
                        <path d="M17 28l-1-1M31 28l1-1M18 22l14 12M32 22l-14 12" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round"/>
                      </svg>
                    </div>
                    <div class="ecib-mini-chip">Blocked</div>
                  </Fragment>
                )}

                {card.visual === "entrance" && (
                  <Fragment>
                    <div class="ecib-gates">
                      <div class="ecib-gate">
                        <span class="ecib-gate-indicator ecib-gate-indicator--green"></span>
                        <span class="ecib-gate-label">A</span>
                      </div>
                      <div class="ecib-gate">
                        <span class="ecib-gate-indicator ecib-gate-indicator--green"></span>
                        <span class="ecib-gate-label">B</span>
                      </div>
                      <div class="ecib-gate">
                        <span class="ecib-gate-indicator ecib-gate-indicator--yellow"></span>
                        <span class="ecib-gate-label">C</span>
                      </div>
                    </div>
                    <div class="ecib-mini-chip">3 entrances</div>
                  </Fragment>
                )}

                {card.visual === "staffportal" && (
                  <Fragment>
                    <div class="ecib-login-form">
                      <div class="ecib-login-avatar">
                        <span></span>
                      </div>
                      <div class="ecib-login-field"></div>
                      <div class="ecib-login-field"></div>
                      <div class="ecib-login-btn"></div>
                    </div>
                    <div class="ecib-mini-chip">Staff login</div>
                  </Fragment>
                )}

                {card.visual === "scanlist" && (
                  <Fragment>
                    <div class="ecib-list-table">
                      <div class="ecib-list-header">
                        <span></span><span></span><span></span>
                      </div>
                      <div class="ecib-list-row"><span></span><span></span><span class="ecib-list-badge">&#10003;</span></div>
                      <div class="ecib-list-row"><span></span><span></span><span class="ecib-list-badge">&#10003;</span></div>
                      <div class="ecib-list-row"><span></span><span></span><span class="ecib-list-badge">&#10003;</span></div>
                    </div>
                    <div class="ecib-mini-chip">Live list</div>
                  </Fragment>
                )}

                {card.visual === "badgeprint" && (
                  <Fragment>
                    <div class="ecib-printer">
                      <div class="ecib-printer-body">
                        <div class="ecib-printer-slot"></div>
                      </div>
                      <div class="ecib-badge-output">
                        <div class="ecib-badge-card">
                          <span class="ecib-badge-avatar"></span>
                          <span class="ecib-badge-name"></span>
                          <span class="ecib-badge-qr"></span>
                        </div>
                      </div>
                    </div>
                    <div class="ecib-mini-chip">Auto-print</div>
                  </Fragment>
                )}

                {card.visual === "livestats" && (
                  <Fragment>
                    <div class="ecib-stat-cards">
                      <div class="ecib-stat-card">
                        <span class="ecib-stat-card-val">42/min</span>
                        <span class="ecib-stat-card-lbl">Rate</span>
                        <span class="ecib-stat-live-dot"></span>
                      </div>
                      <div class="ecib-stat-card">
                        <span class="ecib-stat-card-val">2.3m</span>
                        <span class="ecib-stat-card-lbl">Wait</span>
                        <span class="ecib-stat-live-dot"></span>
                      </div>
                    </div>
                    <div class="ecib-mini-chip">Live metrics</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".ecib-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".ecib-tab"));
      const panels = Array.from(root.querySelectorAll(".ecib-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("ecib-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("ecib-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .ecib-section {
    padding: 48px 0 40px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .ecib-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ecib-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 10px;
  }

  .ecib-title b { font-weight: 700; }

  .ecib-subtitle {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.5;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 20px;
  }

  .ecib-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 20px;
    max-width: 620px;
    gap: 4px;
  }

  .ecib-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .ecib-tab:hover,
  .ecib-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .ecib-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .ecib-panel { display: none; }
  .ecib-panel--active { display: block; }

  .ecib-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .ecib-panel--active .ecib-card {
    animation: ecib-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  .ecib-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 170px;
  }

  .ecib-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .ecib-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 360px;
  }

  .ecib-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .ecib-card--mini:nth-of-type(2) { grid-area: mini1; }
  .ecib-card--mini:nth-of-type(3) { grid-area: mini2; }
  .ecib-card--mini:nth-of-type(4) { grid-area: mini3; }
  .ecib-card--mini:nth-of-type(5) { grid-area: mini4; }

  .ecib-card__content { position: relative; z-index: 1; }

  .ecib-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ecib-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .ecib-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .ecib-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .ecib-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .ecib-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .ecib-art { position: relative; z-index: 1; min-height: 120px; }
  .ecib-art--hero { min-height: 180px; margin-top: 0.4rem; }
  .ecib-art--mini { align-self: end; }

  /* === Hero visual: qrscan === */
  .ecib-qr-frame {
    position: absolute;
    inset: 0.5rem 10% auto 10%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .ecib-qr-corners {
    position: absolute;
    inset: 0;
  }

  .ecib-qr-corner {
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: #375dfb;
    border-style: solid;
    border-width: 0;
  }

  .ecib-qr-corner--tl { top: 0; left: 0; border-top-width: 3px; border-left-width: 3px; border-radius: 6px 0 0 0; }
  .ecib-qr-corner--tr { top: 0; right: 0; border-top-width: 3px; border-right-width: 3px; border-radius: 0 6px 0 0; }
  .ecib-qr-corner--bl { bottom: 0; left: 0; border-bottom-width: 3px; border-left-width: 3px; border-radius: 0 0 0 6px; }
  .ecib-qr-corner--br { bottom: 0; right: 0; border-bottom-width: 3px; border-right-width: 3px; border-radius: 0 0 6px 0; }

  .ecib-qr-frame .ecib-qr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    width: 3.6rem;
    height: 3.6rem;
  }

  .ecib-qr-frame .ecib-qr-grid span {
    background: #14213b;
