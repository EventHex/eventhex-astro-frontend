---
import { ecibIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "QR Scanning",
    hero: {
      title: "Camera-based QR scanning with barcode support and multi-device deployment",
      desc: "Scan attendee QR codes with any smartphone or tablet camera. Support 100+ simultaneous devices across the venue with offline capability.",
      visual: "qrscan",
    },
    cards: [
      { title: "Barcode Support", desc: "Also supports barcode scanning for ticket and badge verification.", visual: "barcode" },
      { title: "Multi-Device", desc: "Run 100+ simultaneous scanning devices across the venue.", visual: "multidev" },
      { title: "Offline Scanning", desc: "Continue scanning without internet — data syncs when reconnected.", visual: "offline" },
      { title: "Instant Confirmation", desc: "Visual and audio confirmation for each successful check-in.", visual: "confirm" },
    ],
  },
  {
    label: "Attendance Tracking",
    hero: {
      title: "Real-time attendance tracking with session-level scanning and duplicate prevention",
      desc: "Live count of checked-in vs registered attendees with multi-entrance support and session-level attendance tracking.",
      visual: "tracking",
    },
    cards: [
      { title: "Session Attendance", desc: "Track who attended which sessions with session-level scanning.", visual: "sessiontrack" },
      { title: "Attendee Search", desc: "Instantly search attendees by name, email, or company.", visual: "search" },
      { title: "Duplicate Prevention", desc: "Automatic detection and blocking of duplicate scans.", visual: "dupeblock" },
      { title: "Multi-Entrance", desc: "Track check-in at multiple entrances simultaneously.", visual: "entrance" },
    ],
  },
  {
    label: "Event Day Dashboard",
    hero: {
      title: "Bird's-eye view of check-in flow, queues, staff activity, and live stats",
      desc: "Monitor everything from one dashboard — check-in rates, queue lengths, staff activity, and attendance metrics updating in real time.",
      visual: "opsdash",
    },
    cards: [
      { title: "Staff Login Portal", desc: "Dedicated staff login for each screening gate and kiosk.", visual: "staffportal" },
      { title: "Scanned Users List", desc: "Exportable real-time list of all checked-in attendees.", visual: "scanlist" },
      { title: "On-Site Badge Print", desc: "Print badges immediately upon check-in scan.", visual: "badgeprint" },
      { title: "Real-Time Stats", desc: "Live metrics — check-in rate, peak times, and wait estimates.", visual: "livestats" },
    ],
  },
  {
    label: "Face & Zone Access",
    hero: {
      title: "Face-match contactless check-in powered by AWS Rekognition",
      desc: "Attendees check in by simply looking at a kiosk camera — no QR needed. AWS Rekognition matches face to registration photo in under a second.",
      visual: "opsdash",
    },
    cards: [
      { title: "Face-Match Check-In", desc: "AWS Rekognition compares live face to registration photo for instant, touchless entry.", visual: "confirm" },
      { title: "Kiosk Self-Check-In", desc: "Attendees walk up to a self-service kiosk and check in without staff assistance.", visual: "staffportal" },
      { title: "Zone & AV Access Control", desc: "Restrict backstage, VIP areas, and AV rooms — QR or badge required for each zone.", visual: "entrance" },
      { title: "Restricted Area Logs", desc: "Full audit trail of who accessed each restricted zone and when.", visual: "scanlist" },
    ],
  },
];

const ICON = '<svg class="ecib-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="ecib-section" id="eci-bento">
  <div class="ecib">
    <h2 class="ecib-title">
      QR <b>Scanning</b>, Attendance <b>Tracking</b> &amp; <b>Operations</b>
    </h2>
    <p class="ecib-subtitle">
      Scan, track, and manage event-day operations from a single real-time dashboard.
    </p>

    <nav class="ecib-nav">
      {tabs.map((t, i) => (
        <button class={`ecib-tab ${i === 0 ? "ecib-tab--active" : ""}`} data-ecib-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`ecib-panel ${tabIdx === 0 ? "ecib-panel--active" : ""}`} data-ecib-panel={String(tabIdx)}>
        <div class="ecib-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="ecib-card ecib-card--tall ecib-pos-0" style="animation-delay:0s">
            <div class="ecib-card__inner">
              <div class="ecib-card__text">
                <Fragment set:html={ICON} />
                <h3 class="ecib-card__title">{t.hero.title}</h3>
                <p class="ecib-card__desc">{t.hero.desc}</p>
              </div>
              <div class="ecib-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`ecib-card ecib-card--sm ecib-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="ecib-card__inner ecib-card__inner--row">
                <div class="ecib-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="ecib-card__title">{c.title}</h3>
                  <p class="ecib-card__desc">{c.desc}</p>
                </div>
                <div class="ecib-card__img ecib-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const ecibTabs = Array.from(document.querySelectorAll('[data-ecib-tab]'));
  const ecibPanels = Array.from(document.querySelectorAll('[data-ecib-panel]'));
  let ecibActive = 0;
  let ecibInterval: ReturnType<typeof setInterval>;

  function setEcibTab(index: number) {
    ecibTabs.forEach((t) => t.classList.remove('ecib-tab--active'));
    ecibPanels.forEach((p) => p.classList.remove('ecib-panel--active'));
    ecibTabs[index]?.classList.add('ecib-tab--active');
    ecibPanels[index]?.classList.add('ecib-panel--active');
    ecibActive = index;
  }
  function startEcib() {
    ecibInterval = setInterval(() => setEcibTab((ecibActive + 1) % ecibTabs.length), 5000);
  }
  ecibTabs.forEach((tab, i) => tab.addEventListener('click', () => { setEcibTab(i); clearInterval(ecibInterval); startEcib(); }));
  startEcib();
  const ecibSection = document.querySelector('.ecib-section');
  if (ecibSection) {
    ecibSection.addEventListener('mouseenter', () => clearInterval(ecibInterval));
    ecibSection.addEventListener('mouseleave', () => startEcib());
  }
</script>

<style>
  .ecib-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .ecib { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .ecib-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .ecib-title b { font-weight: 700; }
  .ecib-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .ecib-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .ecib-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .ecib-tab:hover { background: rgba(55,93,251,.08); }
  .ecib-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .ecib-panel { display: none; }
  .ecib-panel--active { display: block; animation: ecibFadeUp 0.4s ease; }
  @keyframes ecibFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .ecib-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .ecib-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .ecib-pos-1 { grid-column: 2; grid-row: 1; }
  .ecib-pos-2 { grid-column: 3; grid-row: 1; }
  .ecib-pos-3 { grid-column: 2; grid-row: 2; }
  .ecib-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .ecib-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .ecib-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .ecib-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .ecib-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .ecib-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .ecib-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .ecib-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .ecib-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .ecib-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .ecib-pos-4 { grid-column: 3; grid-row: 2; }

  @property --ecib-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .ecib-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: ecibCardIn 0.5s ease forwards;
  }
  .ecib-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--ecib-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .ecib-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .ecib-card:hover::after { opacity: 1; animation: ecibBorder 2.4s linear infinite; }
  @keyframes ecibBorder { to { --ecib-angle: 360deg; } }
  @keyframes ecibCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .ecib-pos-1 { animation-delay: 0.06s; }
  .ecib-pos-2 { animation-delay: 0.12s; }
  .ecib-pos-3 { animation-delay: 0.18s; }
  .ecib-pos-4 { animation-delay: 0.24s; }

  .ecib-card__inner { display: flex; flex-direction: column; height: 100%; }
  .ecib-card__inner--row { flex-direction: row; }
  .ecib-card__text { display: flex; flex-direction: column; gap: 6px; }
  .ecib-card--tall .ecib-card__text { padding: 20px 20px 8px; }
  .ecib-card--sm .ecib-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .ecib-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .ecib-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .ecib-card--sm .ecib-card__title { font-size: 17px; }
  .ecib-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .ecib-card--sm .ecib-card__desc { font-size: 13px; }

  .ecib-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .ecib-card--tall .ecib-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .ecib-card--sm .ecib-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .ecib-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .ecib-card:hover .ecib-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: ecibFloat 2.2s ease-in-out infinite;
  }
  @keyframes ecibFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .ecib-section { padding: 60px 0 48px; }
    .ecib-title { font-size: 36px; }
    .ecib-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .ecib-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .ecib-pos-1, .ecib-pos-2, .ecib-pos-3, .ecib-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .ecib-pos-0, [data-layout="c"] .ecib-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .ecib-pos-1, [data-layout="b"] .ecib-pos-2, [data-layout="b"] .ecib-pos-3, [data-layout="b"] .ecib-pos-4,
    [data-layout="c"] .ecib-pos-1, [data-layout="c"] .ecib-pos-2, [data-layout="c"] .ecib-pos-3, [data-layout="c"] .ecib-pos-4 { grid-column: auto; grid-row: auto; }
    .ecib-card--tall .ecib-card__inner { flex-direction: row; }
    .ecib-card--tall .ecib-card__text { flex: 1; }
    .ecib-card--tall .ecib-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .ecib-title { font-size: 28px; }
    .ecib-subtitle { font-size: 15px; }
    .ecib-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .ecib-tab { border-radius: 12px; }
    .ecib-grid { grid-template-columns: 1fr; }
    .ecib-pos-0, .ecib-pos-1, .ecib-pos-2, .ecib-pos-3, .ecib-pos-4,
    [data-layout="b"] .ecib-pos-0, [data-layout="b"] .ecib-pos-1, [data-layout="b"] .ecib-pos-2, [data-layout="b"] .ecib-pos-3, [data-layout="b"] .ecib-pos-4,
    [data-layout="c"] .ecib-pos-0, [data-layout="c"] .ecib-pos-1, [data-layout="c"] .ecib-pos-2, [data-layout="c"] .ecib-pos-3, [data-layout="c"] .ecib-pos-4 { grid-column: 1; grid-row: auto; }
    .ecib-card--sm .ecib-card__inner, .ecib-card--tall .ecib-card__inner { flex-direction: row; }
    .ecib-card--sm .ecib-card__text, .ecib-card--tall .ecib-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .ecib-card--sm .ecib-card__img, .ecib-card--tall .ecib-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ecib-card { animation: none !important; opacity: 1; transform: none; }
    .ecib-card:hover::after { animation: none !important; }
    .ecib-card:hover .ecib-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
