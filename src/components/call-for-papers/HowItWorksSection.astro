---
const steps = [
  {
    num: "01",
    title: "Publish Submission Portal",
    desc: "Create your CFP form with custom fields, file upload types, and submission deadline. Publish the link on your conference website.",
  },
  {
    num: "02",
    title: "Assign to Reviewers",
    desc: "Import your reviewer panel, set expertise tags, and let EventHex suggest assignments. Configure single or double-blind review mode.",
  },
  {
    num: "03",
    title: "Collect Reviews & Score",
    desc: "Reviewers complete rubric-based reviews through their portal. Scores aggregate automatically — programme chairs see ranked submissions.",
  },
  {
    num: "04",
    title: "Decide & Publish",
    desc: "Accept, reject, or request revisions. Authors receive automated emails. Assign accepted papers to sessions and export proceedings.",
  },
];
---

<section class="cfphw-full">
  <div class="cfphw-full__inner">
    <div class="cfphw-full__header">
      <span class="cfphw-full__tag animate-on-scroll" data-animation="fadeIn">How Call for Papers Works</span>
      <h2 class="cfphw-full__title animate-on-scroll" data-animation="fadeInUp">From Submission to <b>Conference Proceedings</b></h2>
      <p class="cfphw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Publish your CFP portal, assign reviewers, collect scores, make decisions, and export proceedings.
      </p>
    </div>

    <div class="cfphw-full__cards">
      {steps.map((step) => (
        <article class="cfphw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="cfphw-full__card-icon">{step.num}</div>
          <h3 class="cfphw-full__card-title">{step.title}</h3>
          <p class="cfphw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .cfphw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .cfphw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .cfphw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .cfphw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cfphw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .cfphw-full__title b { font-weight: 700; }

  .cfphw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .cfphw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .cfphw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .cfphw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .cfphw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .cfphw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .cfphw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .cfphw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .cfphw-full { padding: 64px 0; }
    .cfphw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .cfphw-full { padding: 52px 0; }
    .cfphw-full__title { font-size: 30px; line-height: 1.15; }
    .cfphw-full__desc { font-size: 15px; }
    .cfphw-full__cards { grid-template-columns: 1fr; }
  }
</style>
