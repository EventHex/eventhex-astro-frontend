---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><rect x="9" y="3" width="6" height="4" rx="1" stroke="#375DFB" stroke-width="2"/><path d="M9 12h6M9 16h4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Clean submission portal",
    desc: "Authors submit and track papers in a self-service portal with file uploads and status tracking.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Blind peer review",
    desc: "Single and double-blind review with custom rubrics, automated reminders, and conflict management.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="16" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M3 10h18" stroke="#375DFB" stroke-width="2"/><path d="M9 4v16" stroke="#375DFB" stroke-width="2"/><circle cx="15" cy="14" r="1.5" fill="#22C55E"/><circle cx="15" cy="18" r="1.5" fill="#22C55E"/></svg>`,
    title: "Schedule integration",
    desc: "Accepted papers slot directly into the conference agenda with one-click session assignment.",
  },
];
---

<section class="cfpc-full">
  <div class="cfpc-full__inner">
    <div class="cfpc-full__header">
      <span class="cfpc-full__tag animate-on-scroll" data-animation="fadeIn">Why Academic Organizers Choose EventHex CFP</span>
      <h2 class="cfpc-full__title animate-on-scroll" data-animation="fadeInUp">End-to-End <b>Call for Papers</b></h2>
      <p class="cfpc-full__desc animate-on-scroll" data-animation="fadeInUp">Manage submissions, peer review, and proceedings export without spreadsheets or email threads.</p>
    </div>

    <div class="cfpc-full__cards">
      {cards.map((card) => (
        <div class="cfpc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="cfpc-full__card-icon" set:html={card.icon}></div>
          <h3 class="cfpc-full__card-title">{card.title}</h3>
          <p class="cfpc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .cfpc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .cfpc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .cfpc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .cfpc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cfpc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .cfpc-full__title b { font-weight: 700; }

  .cfpc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .cfpc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .cfpc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .cfpc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .cfpc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .cfpc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .cfpc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .cfpc-full { padding: 64px 0; }
    .cfpc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .cfpc-full { padding: 52px 0; }
    .cfpc-full__title { font-size: 30px; line-height: 1.15; }
    .cfpc-full__desc { font-size: 15px; }
    .cfpc-full__cards { grid-template-columns: 1fr; }
  }
</style>
