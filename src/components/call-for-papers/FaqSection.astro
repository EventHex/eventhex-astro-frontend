---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "Does EventHex support double-blind review?", a: "Yes. You can configure single-blind (reviewers anonymous to authors) or double-blind (both authors and reviewers anonymous to each other) review modes. Author identities are masked from reviewers in double-blind mode." },
  { q: "Can I create custom scoring rubrics?", a: "Yes. Define up to 10 scoring criteria per review form with custom labels, weighting, and scoring scales (1-5, 1-10, or custom). Aggregate scores are calculated automatically." },
  { q: "How many reviewers can be assigned per paper?", a: "You can assign between 1 and 10 reviewers per submission. The system supports reviewer bidding and conflict of interest declarations." },
  { q: "Can authors revise and resubmit after review?", a: "Yes. The programme chair can request major or minor revisions. Authors receive reviewer comments via email and submit a revised version through the author portal." },
  { q: "Can I export accepted papers as a proceedings document?", a: "Yes. EventHex can generate a formatted proceedings PDF with all accepted abstract titles, authors, institutions, and abstracts sorted by session and track." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with call for papers?"
  title="Frequently Asked Questions"
  description="We help academic and research conference teams set up submission portals, peer review workflows, and proceedings export."
/>
