---
const faqs = [
  {
    q: "Does EventHex support double-blind review?",
    a: "Yes. You can configure single-blind (reviewers anonymous to authors) or double-blind (both authors and reviewers anonymous to each other) review modes. Author identities are masked from reviewers in double-blind mode.",
  },
  {
    q: "Can I create custom scoring rubrics?",
    a: "Yes. Define up to 10 scoring criteria per review form with custom labels, weighting, and scoring scales (1-5, 1-10, or custom). Aggregate scores are calculated automatically.",
  },
  {
    q: "How many reviewers can be assigned per paper?",
    a: "You can assign between 1 and 10 reviewers per submission. The system supports reviewer bidding and conflict of interest declarations.",
  },
  {
    q: "Can authors revise and resubmit after review?",
    a: "Yes. The programme chair can request major or minor revisions. Authors receive reviewer comments via email and submit a revised version through the author portal.",
  },
  {
    q: "Can I export accepted papers as a proceedings document?",
    a: "Yes. EventHex can generate a formatted proceedings PDF with all accepted abstract titles, authors, institutions, and abstracts sorted by session and track.",
  },
];

const checklist = [
  "Submission portal setup",
  "Peer review configuration",
  "Proceedings generation",
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="cfpfq" data-cfp-faq>
  <div class="cfpfq__inner">
    <div class="cfpfq__support">
      <span class="cfpfq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need help with call for papers?</span>
      <h2 class="cfpfq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="cfpfq__desc animate-on-scroll" data-animation="fadeInUp">
        We help academic and research conference teams set up submission portals, peer review workflows, and proceedings export.
      </p>

      <div class="cfpfq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="cfpfq__support-label">Included with every rollout</span>
        <ul class="cfpfq__support-list">
          {checklist.map((item) => (
            <li class="cfpfq__support-item">{item}</li>
          ))}
        </ul>

        <div class="cfpfq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your CFP workflow before launch and keep your team aligned on submission forms, reviewer assignments, and decision timelines.</span>
        </div>

        <a href="/book-a-demo/" class="cfpfq__cta">Plan my CFP workflow</a>
      </div>
    </div>

    <div class="cfpfq__list">
      {faqs.map((faq, index) => (
        <details class="cfpfq__item animate-on-scroll" data-animation="fadeInUp" data-cfp-faq-item open={index === 0}>
          <summary class="cfpfq__question">
            <span>{faq.q}</span>
            <span class="cfpfq__icon" aria-hidden="true">
              <span class="cfpfq__icon-line cfpfq__icon-line--horizontal"></span>
              <span class="cfpfq__icon-line cfpfq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="cfpfq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const cfpFaqItems = Array.from(document.querySelectorAll('[data-cfp-faq-item]'));

  cfpFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      cfpFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .cfpfq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .cfpfq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .cfpfq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .cfpfq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .cfpfq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .cfpfq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .cfpfq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .cfpfq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .cfpfq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .cfpfq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .cfpfq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .cfpfq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .cfpfq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .cfpfq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .cfpfq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .cfpfq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .cfpfq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cfpfq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .cfpfq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
  }

  .cfpfq__question::-webkit-details-marker,
  .cfpfq__question::marker {
    display: none;
  }

  .cfpfq__icon {
    position: relative;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 4px;
  }

  .cfpfq__icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #375dfb;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .cfpfq__icon-line--vertical {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .cfpfq__item[open] .cfpfq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0);
  }

  .cfpfq__answer {
    padding: 0 24px 24px;
  }

  .cfpfq__answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #5b6477;
  }

  @media (max-width: 1100px) {
    .cfpfq { padding: 76px 0; }
    .cfpfq__inner { grid-template-columns: 1fr; gap: 28px; }
    .cfpfq__support { position: static; }
  }

  @media (max-width: 1024px) {
    .cfpfq__title { font-size: 40px; }
    .cfpfq__desc { font-size: 16px; }
    .cfpfq__question { padding: 24px 22px; font-size: 20px; }
    .cfpfq__answer { padding: 0 22px 22px; }
  }

  @media (max-width: 767px) {
    .cfpfq { padding: 56px 0; }
    .cfpfq__inner { padding: 0 16px; gap: 24px; }
    .cfpfq__title { font-size: 32px; line-height: 1.08; }
    .cfpfq__desc { font-size: 15px; line-height: 1.7; }
    .cfpfq__support-card { padding: 20px 18px; border-radius: 24px; }
    .cfpfq__support-item { font-size: 15px; }
    .cfpfq__support-note strong { font-size: 18px; }
    .cfpfq__cta { width: 100%; }
    .cfpfq__item { border-radius: 24px; }
    .cfpfq__question { padding: 20px 18px; font-size: 17px; line-height: 1.45; }
    .cfpfq__answer { padding: 0 18px 20px; }
    .cfpfq__answer p { font-size: 15px; line-height: 1.75; }
  }
</style>
