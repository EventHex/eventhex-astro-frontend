---
const featureCards = [
  {
    eyebrow: "peer review",
    title: "Organise reviewers and never chase them again",
    desc: "Assign papers to reviewers, track progress, send automated reminders, and aggregate scores — all in the EventHex CFP dashboard. No email threads.",
    items: [
      "Reviewer pool management with expertise tags",
      "Rubric-based scoring with structured feedback",
      "Automated deadline reminders — zero manual follow-up",
    ],
    visual: "reviewmgmt",
  },
  {
    eyebrow: "submission portal",
    title: "A submission portal authors actually like using",
    desc: "Authors submit, revise, and track their submissions through a clean self-service portal — no confused emails about formats or status.",
    items: [
      "Configurable fields for abstract and keywords",
      "PDF, DOCX, and LaTeX file uploads accepted",
      "Real-time status: under review, revisions, accepted",
    ],
    visual: "authorportal",
  },
  {
    eyebrow: "decisions",
    title: "From accepted paper to conference schedule in one click",
    desc: "Accept a paper and assign it directly to a session slot. Authors are notified, the programme is updated, and proceedings can be exported.",
    items: [
      "One-click acceptance with auto notification",
      "Drag papers into session slots in schedule builder",
      "Generate formatted proceedings PDF automatically",
    ],
    visual: "decisionflow",
  },
  {
    eyebrow: "compliance",
    title: "Blind review and conflict management built in",
    desc: "Configure single or double-blind review modes. Reviewers declare conflicts of interest, and the system automatically reassigns conflicted submissions.",
    items: [
      "Single and double-blind review modes",
      "Conflict of interest declaration and reassignment",
      "Multi-round review with revision tracking",
    ],
    visual: "compliance",
  },
];
---

<section class="cfpf-shell">
  <div class="cfpf-section">
    <div class="cfpf-header">
      <span class="cfpf-subtitle">Everything you need to manage the full call-for-papers lifecycle</span>
      <h2 class="cfpf-title">
        Everything You Need to <span class="cfpf-highlight">Submit, Review, and Publish</span><br />
        Conference Papers
      </h2>
    </div>

    <div class="cfpf-cards" id="cfpf-stacking-cards">
      {featureCards.map((card, index) => (
        <div class="cfpf-card" data-card-index={index} style={`--card-index: ${index}; top: calc(20px + ${index * 20}px);`}>
          <div class="cfpf-card-content">
            <span class="cfpf-card-eyebrow">{card.eyebrow}</span>
            <h3 class="cfpf-card-title">{card.title}</h3>
            <p class="cfpf-card-desc">{card.desc}</p>
            <ul class="cfpf-card-items">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href="/book-a-demo/" class="cfpf-card-btn">Explore More</a>
          </div>

          <div class={`cfpf-card-visual cfpf-card-visual--${card.visual}`}>
            {card.visual === "reviewmgmt" && (
              <Fragment>
                <img
                  src="/feature-images/call-for-papers/peer-review-card.svg"
                  alt="Peer review dashboard"
                  loading="lazy"
                  class="cfpf-card-svg"
                />
              </Fragment>
            )}

            {card.visual === "authorportal" && (
              <Fragment>
                <img
                  src="/feature-images/call-for-papers/submission-portal-card.svg"
                  alt="Submission portal"
                  loading="lazy"
                  class="cfpf-card-svg"
                />
              </Fragment>
            )}

            {card.visual === "decisionflow" && (
              <Fragment>
                <img
                  src="/feature-images/call-for-papers/decision-flow-card.svg"
                  alt="Decision flow"
                  loading="lazy"
                  class="cfpf-card-svg"
                />
              </Fragment>
            )}

            {card.visual === "compliance" && (
              <Fragment>
                <img
                  src="/feature-images/call-for-papers/compliance-card.svg"
                  alt="Compliance"
                  loading="lazy"
                  class="cfpf-card-svg"
                />
              </Fragment>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .cfpf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .cfpf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .cfpf-header {
    width: 72%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .cfpf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .cfpf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .cfpf-highlight { color: #AFA3FF; }

  .cfpf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .cfpf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.88));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .cfpf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .cfpf-card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(175, 163, 255, 0.12);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #afa3ff;
  }

  .cfpf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .cfpf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .cfpf-card-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cfpf-card-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .cfpf-card-items li::before {
    content: "";
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
  }

  .cfpf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .cfpf-card-btn:hover { transform: scale(1.05); }

  .cfpf-card-visual {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
    background: radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 52%);
  }

  /* card SVG visual */
  .cfpf-card-svg {
    width: 75%;
    height: auto;
    max-height: 85%;
    object-fit: contain;
    animation: cfpf-card-float 6s ease-in-out infinite;
  }

  @keyframes cfpf-card-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 1024px) {
    .cfpf-section { padding: 60px 20px 30px; }
    .cfpf-header { width: 80%; }
    .cfpf-subtitle { font-size: 16px; }
    .cfpf-title { font-size: 40px; line-height: 1em; }
    .cfpf-card { height: 450px; }
    .cfpf-card-content { flex-basis: 50%; }
    .cfpf-card-title { font-size: 28px; }
    .cfpf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .cfpf-section { padding: 50px 20px 30px; }
    .cfpf-header { width: 100%; }
    .cfpf-title { font-size: 30px; }
    .cfpf-card { flex-direction: column; height: 620px; }
    .cfpf-card-content { flex: 0 0 55%; padding: 20px 20px 0; }
    .cfpf-card-visual { min-height: 260px; padding: 12px; }
    .cfpf-card-title { font-size: 24px; }
    .cfpf-card-desc { font-size: 15px; }
    .cfpf-cards { padding-bottom: 40px; }
  }
</style>
