---
---

<section class="cfpcta">
  <div class="cfpcta__card">
    <div class="cfpcta__glow cfpcta__glow--1"></div>
    <div class="cfpcta__glow cfpcta__glow--2"></div>
    <div class="cfpcta__grid">
      <div class="cfpcta__content">
        <span class="cfpcta__eyebrow animate-on-scroll" data-animation="fadeIn">Manage Your CFP End-to-End</span>
        <h2 class="cfpcta__title animate-on-scroll" data-animation="fadeInUp">Ready to Run Your Call for Papers in One Platform?</h2>
        <p class="cfpcta__desc animate-on-scroll" data-animation="fadeInUp">See how EventHex handles submission, peer review, scoring, acceptance, and proceedings export.</p>
        <div class="cfpcta__proof-row animate-on-scroll" data-animation="fadeInUp">
          <span class="cfpcta__proof-pill">Peer review workflows</span>
          <span class="cfpcta__proof-pill">Custom rubrics</span>
          <span class="cfpcta__proof-pill">Free onboarding support</span>
        </div>
        <div class="cfpcta__buttons">
          <a href="/book-a-demo/" class="cfpcta__btn cfpcta__btn--primary">
            Book a Free Demo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/contact-en/" class="cfpcta__btn cfpcta__btn--secondary">Contact Sales</a>
        </div>
      </div>
      <div class="cfpcta__visual animate-on-scroll" data-animation="fadeInRight">
        <img
          src="/feature-images/call-for-papers/cta-visual.svg"
          alt="Call for papers management dashboard"
          loading="lazy"
          class="cfpcta__visual-img"
        />
      </div>
    </div>
  </div>
</section>

<style is:global>
  .cfpcta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }

  .cfpcta__card {
    position: relative;
    border-radius: 24px;
    padding: 60px 40px;
    overflow: hidden;
    background: #0F1629;
  }

  .cfpcta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .cfpcta__glow--1 {
    width: 400px;
    height: 400px;
    background: rgba(55, 93, 251, 0.2);
    top: -100px;
    left: -50px;
  }

  .cfpcta__glow--2 {
    width: 300px;
    height: 300px;
    background: rgba(159, 129, 255, 0.15);
    bottom: -80px;
    right: -30px;
  }

  .cfpcta__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .cfpcta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .cfpcta__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .cfpcta__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .cfpcta__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.3px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .cfpcta__proof-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .cfpcta__proof-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: rgba(255, 255, 255, 0.74);
  }

  .cfpcta__buttons { display: flex; gap: 12px; }

  .cfpcta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.3px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .cfpcta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.35);
  }

  .cfpcta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(55, 93, 251, 0.4);
  }

  .cfpcta__btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .cfpcta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .cfpcta__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cfpcta__visual-img {
    width: 100%;
    height: auto;
    animation: cfpcta-float 6s ease-in-out infinite;
  }

  @keyframes cfpcta-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 1024px) {
    .cfpcta__card { padding: 48px 24px; }
    .cfpcta__title { font-size: 36px; }
    .cfpcta__desc { font-size: 16px; }
  }

  @media (max-width: 960px) {
    .cfpcta__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .cfpcta__content {
      align-items: center;
      text-align: center;
    }

    .cfpcta__proof-row {
      justify-content: center;
    }

    .cfpcta__buttons {
      justify-content: center;
    }

    .cfpcta__visual-img {
      max-width: 500px;
    }
  }

  @media (max-width: 767px) {
    .cfpcta { padding: 40px 16px 60px; }
    .cfpcta__card { padding: 40px 20px; border-radius: 20px; }
    .cfpcta__title { font-size: 28px; line-height: 1.2em; }
    .cfpcta__desc { font-size: 15px; }
    .cfpcta__proof-row { gap: 8px; }
    .cfpcta__buttons { flex-direction: column; width: 100%; }
    .cfpcta__btn { width: 100%; justify-content: center; }
    .cfpcta__visual-img { max-width: 100%; }
  }
</style>
