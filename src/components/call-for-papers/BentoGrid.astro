---
const tabs = [
  {
    label: "Submission Portal",
    hero: {
      eyebrow: "Submission Engine",
      title: "Customizable submission form with author portal, file uploads, and deadline management",
      desc: "Authors submit abstracts with keywords, co-authors, and file uploads through a clean self-service portal with real-time status tracking.",
      points: ["Custom submission forms", "Author self-service portal", "Deadline management"],
      visual: "submit",
    },
    cards: [
      { eyebrow: "Authors", title: "Author Portal", desc: "Authors log in to view submission status, reviewer comments, and revision requests.", visual: "authorport" },
      { eyebrow: "Files", title: "File Upload Support", desc: "Accept PDF, DOCX, or LaTeX submissions with format validation.", visual: "fileup" },
      { eyebrow: "Deadlines", title: "Submission Deadlines", desc: "Set submission windows, late rules, and auto-close with timezone support.", visual: "deadline" },
      { eyebrow: "Co-Authors", title: "Multi-Author Support", desc: "List co-authors with ORCID integration and institutional affiliations.", visual: "coauthor" },
    ],
  },
  {
    label: "Peer Review",
    hero: {
      eyebrow: "Review Engine",
      title: "Reviewer assignment with blind review, custom rubrics, and conflict management",
      desc: "Assign reviewers manually or with AI matching. Configure single or double-blind review with custom scoring rubrics and automated reminders.",
      points: ["AI-assisted reviewer matching", "Custom scoring rubrics", "Automated reminders"],
      visual: "review",
    },
    cards: [
      { eyebrow: "Blind", title: "Blind & Double-Blind", desc: "Configure single-blind or double-blind review modes.", visual: "blindrev" },
      { eyebrow: "Rubrics", title: "Custom Review Rubrics", desc: "Define scoring criteria — originality, methodology, clarity — with weighted scales.", visual: "rubric" },
      { eyebrow: "Conflicts", title: "Conflict of Interest", desc: "Reviewers declare conflicts; system automatically reassigns submissions.", visual: "conflict" },
      { eyebrow: "Reminders", title: "Review Reminders", desc: "Automated email reminders sent to reviewers approaching their deadline.", visual: "reminder" },
    ],
  },
  {
    label: "Decision & Publishing",
    hero: {
      eyebrow: "Decision Engine",
      title: "Acceptance workflows, automated decision emails, and proceedings export",
      desc: "Programme chairs review scores and make accept/reject/revise decisions. Authors receive automated emails. Accepted papers slot into the conference schedule.",
      points: ["One-click accept/reject", "Automated decision emails", "Proceedings PDF export"],
      visual: "decision",
    },
    cards: [
      { eyebrow: "Emails", title: "Automated Decision Emails", desc: "Send acceptance, rejection, and revision emails with reviewer comments attached.", visual: "decemail" },
      { eyebrow: "Schedule", title: "Session Assignment", desc: "Accepted papers are assigned to sessions directly from the CFP dashboard.", visual: "sessassign" },
      { eyebrow: "Export", title: "Proceedings Export", desc: "Export accepted abstracts as a formatted proceedings PDF with one click.", visual: "proceedings" },
      { eyebrow: "Camera-Ready", title: "Camera-Ready Submission", desc: "Authors submit final camera-ready versions via the portal after acceptance.", visual: "cameraready" },
    ],
  },
];
---

<section class="cfpb-section" id="cfp-bento">
  <div class="cfpb-shell">
    <h2 class="cfpb-title">
      Submission <b>Portal</b>, Peer <b>Review</b> &amp; <b>Publishing</b>
    </h2>
    <p class="cfpb-subtitle">
      Manage the full CFP lifecycle from submission to proceedings export.
    </p>

    <nav class="cfpb-nav" aria-label="Call for papers workflows">
      {tabs.map((tab, index) => (
        <button
          class={`cfpb-tab${index === 0 ? " cfpb-tab--active" : ""}`}
          data-cfpb-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`cfpb-panel${tabIndex === 0 ? " cfpb-panel--active" : ""}`}
        data-cfpb-panel={tabIndex}
      >
        <div class="cfpb-grid">
          <article class="cfpb-card cfpb-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="cfpb-card__content">
              <span class="cfpb-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="cfpb-card__title">{tab.hero.title}</h3>
              <p class="cfpb-card__desc">{tab.hero.desc}</p>
              <ul class="cfpb-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`cfpb-art cfpb-art--hero cfpb-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "submit" && (
                <Fragment>
                  <div class="cfpb-form-frame">
                    <div class="cfpb-form-header"></div>
                    <div class="cfpb-form-field"><span class="cfpb-form-label"></span><span class="cfpb-form-input"></span></div>
                    <div class="cfpb-form-field"><span class="cfpb-form-label"></span><span class="cfpb-form-input cfpb-form-input--wide"></span></div>
                    <div class="cfpb-form-field"><span class="cfpb-form-label"></span><span class="cfpb-form-textarea"></span></div>
                    <div class="cfpb-form-submit"></div>
                  </div>
                  <div class="cfpb-submit-badge">
                    <span class="cfpb-submit-check">&#10003;</span>
                    <span class="cfpb-submit-text">Submitted</span>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "review" && (
                <Fragment>
                  <div class="cfpb-review-grid">
                    <div class="cfpb-reviewer-card">
                      <span class="cfpb-reviewer-avatar"></span>
                      <span class="cfpb-reviewer-bar"></span>
                      <div class="cfpb-reviewer-stars">
                        <span></span><span></span><span></span><span></span><span class="cfpb-star--empty"></span>
                      </div>
                    </div>
                    <div class="cfpb-reviewer-card">
                      <span class="cfpb-reviewer-avatar cfpb-reviewer-avatar--alt"></span>
                      <span class="cfpb-reviewer-bar"></span>
                      <div class="cfpb-reviewer-stars">
                        <span></span><span></span><span></span><span></span><span></span>
                      </div>
                    </div>
                    <div class="cfpb-reviewer-card">
                      <span class="cfpb-reviewer-avatar cfpb-reviewer-avatar--alt2"></span>
                      <span class="cfpb-reviewer-bar"></span>
                      <div class="cfpb-reviewer-stars">
                        <span></span><span></span><span></span><span class="cfpb-star--empty"></span><span class="cfpb-star--empty"></span>
                      </div>
                    </div>
                  </div>
                  <div class="cfpb-review-badge">
                    <span class="cfpb-review-badge-dot"></span>
                    <span>3 Reviewers Assigned</span>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "decision" && (
                <Fragment>
                  <div class="cfpb-decision-panel">
                    <div class="cfpb-decision-row">
                      <span class="cfpb-decision-paper-bar"></span>
                      <span class="cfpb-decision-score">4.2</span>
                      <span class="cfpb-decision-btn cfpb-decision-btn--accept">Accept</span>
                    </div>
                    <div class="cfpb-decision-row">
                      <span class="cfpb-decision-paper-bar"></span>
                      <span class="cfpb-decision-score">3.1</span>
                      <span class="cfpb-decision-btn cfpb-decision-btn--revise">Revise</span>
                    </div>
                    <div class="cfpb-decision-row">
                      <span class="cfpb-decision-paper-bar"></span>
                      <span class="cfpb-decision-score">2.0</span>
                      <span class="cfpb-decision-btn cfpb-decision-btn--reject">Reject</span>
                    </div>
                  </div>
                  <div class="cfpb-decision-badge">
                    <span class="cfpb-decision-badge-icon">&#9993;</span>
                    <span>Emails Sent</span>
                  </div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="cfpb-card cfpb-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="cfpb-card__content">
                <span class="cfpb-card__eyebrow">{card.eyebrow}</span>
                <h3 class="cfpb-card__title">{card.title}</h3>
                <p class="cfpb-card__desc">{card.desc}</p>
              </div>

              <div class={`cfpb-art cfpb-art--mini cfpb-art--${card.visual}`} aria-hidden="true">
                {card.visual === "authorport" && (
                  <Fragment>
                    <div class="cfpb-portal-cards">
                      <div class="cfpb-portal-card">
                        <span class="cfpb-portal-status cfpb-portal-status--review"></span>
                        <span class="cfpb-portal-bar"></span>
                      </div>
                      <div class="cfpb-portal-card">
                        <span class="cfpb-portal-status cfpb-portal-status--accepted"></span>
                        <span class="cfpb-portal-bar"></span>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">Author portal</div>
                  </Fragment>
                )}

                {card.visual === "fileup" && (
                  <Fragment>
                    <div class="cfpb-upload-zone">
                      <div class="cfpb-upload-icon">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12" stroke="#375dfb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                      <div class="cfpb-file-icons">
                        <span class="cfpb-file-icon cfpb-file-icon--pdf">PDF</span>
                        <span class="cfpb-file-icon cfpb-file-icon--doc">DOC</span>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">File upload</div>
                  </Fragment>
                )}

                {card.visual === "deadline" && (
                  <Fragment>
                    <div class="cfpb-calendar">
                      <div class="cfpb-calendar-header"></div>
                      <div class="cfpb-calendar-grid">
                        <span></span><span></span><span></span><span></span><span></span>
                        <span></span><span></span><span></span><span></span><span class="cfpb-calendar-today"></span>
                        <span></span><span class="cfpb-calendar-deadline"></span>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">Deadline set</div>
                  </Fragment>
                )}

                {card.visual === "coauthor" && (
                  <Fragment>
                    <div class="cfpb-authors-linked">
                      <div class="cfpb-author-node"><span class="cfpb-author-avatar"></span></div>
                      <div class="cfpb-author-link-line"></div>
                      <div class="cfpb-author-node"><span class="cfpb-author-avatar cfpb-author-avatar--alt"></span></div>
                      <div class="cfpb-author-link-line"></div>
                      <div class="cfpb-author-node"><span class="cfpb-author-avatar cfpb-author-avatar--alt2"></span></div>
                    </div>
                    <div class="cfpb-mini-chip">3 co-authors</div>
                  </Fragment>
                )}

                {card.visual === "blindrev" && (
                  <Fragment>
                    <div class="cfpb-blind-cards">
                      <div class="cfpb-blind-card">
                        <span class="cfpb-blind-avatar"></span>
                        <span class="cfpb-blind-mask">?</span>
                      </div>
                      <div class="cfpb-blind-card">
                        <span class="cfpb-blind-avatar cfpb-blind-avatar--alt"></span>
                        <span class="cfpb-blind-mask">?</span>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">Anonymous</div>
                  </Fragment>
                )}

                {card.visual === "rubric" && (
                  <Fragment>
                    <div class="cfpb-rubric-table">
                      <div class="cfpb-rubric-row">
                        <span class="cfpb-rubric-label"></span>
                        <div class="cfpb-rubric-dots"><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--empty"></span></div>
                      </div>
                      <div class="cfpb-rubric-row">
                        <span class="cfpb-rubric-label"></span>
                        <div class="cfpb-rubric-dots"><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--empty"></span><span class="cfpb-rubric-dot--empty"></span></div>
                      </div>
                      <div class="cfpb-rubric-row">
                        <span class="cfpb-rubric-label"></span>
                        <div class="cfpb-rubric-dots"><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span><span class="cfpb-rubric-dot--filled"></span></div>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">Scored</div>
                  </Fragment>
                )}

                {card.visual === "conflict" && (
                  <Fragment>
                    <div class="cfpb-conflict-display">
                      <div class="cfpb-conflict-badge-icon">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none"><path d="M12 9v4M12 17h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                      <div class="cfpb-conflict-arrow">&#8594;</div>
                      <div class="cfpb-conflict-reassign">
                        <span class="cfpb-conflict-new-avatar"></span>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">Reassigned</div>
                  </Fragment>
                )}

                {card.visual === "reminder" && (
                  <Fragment>
                    <div class="cfpb-reminder-display">
                      <div class="cfpb-reminder-envelope">
                        <svg viewBox="0 0 24 24" width="28" height="28" fill="none"><rect x="2" y="4" width="20" height="16" rx="2" stroke="#375dfb" stroke-width="2"/><path d="M22 7l-10 7L2 7" stroke="#375dfb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </div>
                      <div class="cfpb-reminder-clock">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none"><circle cx="12" cy="12" r="10" stroke="#f59e0b" stroke-width="2"/><path d="M12 6v6l4 2" stroke="#f59e0b" stroke-width="2" stroke-linecap="round"/></svg>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">Reminder sent</div>
                  </Fragment>
                )}

                {card.visual === "decemail" && (
                  <Fragment>
                    <div class="cfpb-email-template">
                      <div class="cfpb-email-header">
                        <span class="cfpb-email-header-bar"></span>
                      </div>
                      <div class="cfpb-email-body">
                        <span class="cfpb-email-line"></span>
                        <span class="cfpb-email-line cfpb-email-line--short"></span>
                      </div>
                      <div class="cfpb-email-decision-badge cfpb-email-decision-badge--accept">Accepted</div>
                    </div>
                    <div class="cfpb-mini-chip">Email sent</div>
                  </Fragment>
                )}

                {card.visual === "sessassign" && (
                  <Fragment>
                    <div class="cfpb-session-slots">
                      <div class="cfpb-session-slot">
                        <span class="cfpb-session-slot-time"></span>
                        <div class="cfpb-session-paper-card">
                          <span class="cfpb-session-paper-bar"></span>
                        </div>
                      </div>
                      <div class="cfpb-session-slot cfpb-session-slot--empty">
                        <span class="cfpb-session-slot-time"></span>
                        <div class="cfpb-session-slot-placeholder"></div>
                      </div>
                    </div>
                    <div class="cfpb-mini-chip">Assigned</div>
                  </Fragment>
                )}

                {card.visual === "proceedings" && (
                  <Fragment>
                    <div class="cfpb-pdf-doc">
                      <div class="cfpb-pdf-corner"></div>
                      <div class="cfpb-pdf-title-bar"></div>
                      <div class="cfpb-pdf-line"></div>
                      <div class="cfpb-pdf-line cfpb-pdf-line--short"></div>
                      <div class="cfpb-pdf-line"></div>
                      <div class="cfpb-pdf-line cfpb-pdf-line--med"></div>
                    </div>
                    <div class="cfpb-mini-chip">PDF ready</div>
                  </Fragment>
                )}

                {card.visual === "cameraready" && (
                  <Fragment>
                    <div class="cfpb-camera-ready">
                      <div class="cfpb-camera-circle">
                        <svg viewBox="0 0 48 48" class="cfpb-camera-svg">
                          <circle cx="24" cy="24" r="20" fill="none" stroke="#22c55e" stroke-width="3" opacity="0.2"/>
                          <circle cx="24" cy="24" r="20" fill="none" stroke="#22c55e" stroke-width="3" stroke-dasharray="126" stroke-dashoffset="0" stroke-linecap="round" class="cfpb-camera-ring"/>
                          <path d="M16 24l5 5 11-11" stroke="#22c55e" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                      <span class="cfpb-camera-label">Upload Complete</span>
                    </div>
                    <div class="cfpb-mini-chip">Final version</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".cfpb-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".cfpb-tab"));
      const panels = Array.from(root.querySelectorAll(".cfpb-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("cfpb-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("cfpb-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .cfpb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .cfpb-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .cfpb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .cfpb-title b { font-weight: 700; }

  .cfpb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .cfpb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .cfpb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .cfpb-tab:hover,
  .cfpb-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .cfpb-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .cfpb-panel { display: none; }
  .cfpb-panel--active { display: block; }

  .cfpb-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .cfpb-panel--active .cfpb-card {
    animation: cfpb-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  @keyframes cfpb-fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .cfpb-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .cfpb-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .cfpb-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .cfpb-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .cfpb-card--mini:nth-of-type(2) { grid-area: mini1; }
  .cfpb-card--mini:nth-of-type(3) { grid-area: mini2; }
  .cfpb-card--mini:nth-of-type(4) { grid-area: mini3; }
  .cfpb-card--mini:nth-of-type(5) { grid-area: mini4; }

  .cfpb-card__content { position: relative; z-index: 1; }

  .cfpb-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .cfpb-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .cfpb-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .cfpb-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .cfpb-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .cfpb-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .cfpb-art { position: relative; z-index: 1; min-height: 146px; }
  .cfpb-art--hero { min-height: 228px; margin-top: 0.6rem; }
  .cfpb-art--mini { align-self: end; }

  .cfpb-mini-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: #183465;
    font-size: 0.72rem;
    font-weight: 700;
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
    position: absolute;
    left: 0;
    bottom: 0;
  }

  /* === Hero visual: submit === */
  .cfpb-form-frame {
    position: absolute;
    inset: 0.5rem 8% auto 8%;
    padding: 1rem;
    border-radius: 1.2rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    display: flex;
    flex-direction: column;
