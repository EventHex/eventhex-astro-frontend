---
import { cfpbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Submission Portal",
    hero: {
      title: "Customizable submission form with author portal, file uploads, and deadline management",
      desc: "Authors submit abstracts with keywords, co-authors, and file uploads through a clean self-service portal with real-time status tracking.",
      visual: "submit",
    },
    cards: [
      { title: "Author Portal", desc: "Authors log in to view submission status, reviewer comments, and revision requests.", visual: "authorport" },
      { title: "File Upload Support", desc: "Accept PDF, DOCX, or LaTeX submissions with format validation.", visual: "fileup" },
      { title: "Submission Deadlines", desc: "Set submission windows, late rules, and auto-close with timezone support.", visual: "deadline" },
      { title: "Multi-Author Support", desc: "List co-authors with ORCID integration and institutional affiliations.", visual: "coauthor" },
    ],
  },
  {
    label: "Peer Review",
    hero: {
      title: "Reviewer assignment with blind review, custom rubrics, and conflict management",
      desc: "Assign reviewers manually or with AI matching. Configure single or double-blind review with custom scoring rubrics and automated reminders.",
      visual: "review",
    },
    cards: [
      { title: "Blind & Double-Blind", desc: "Configure single-blind or double-blind review modes.", visual: "blindrev" },
      { title: "Custom Review Rubrics", desc: "Define scoring criteria — originality, methodology, clarity — with weighted scales.", visual: "rubric" },
      { title: "Conflict of Interest", desc: "Reviewers declare conflicts; system automatically reassigns submissions.", visual: "conflict" },
      { title: "Review Reminders", desc: "Automated email reminders sent to reviewers approaching their deadline.", visual: "reminder" },
    ],
  },
  {
    label: "Decision & Publishing",
    hero: {
      title: "Acceptance workflows, automated decision emails, and proceedings export",
      desc: "Programme chairs review scores and make accept/reject/revise decisions. Authors receive automated emails. Accepted papers slot into the conference schedule.",
      visual: "decision",
    },
    cards: [
      { title: "Automated Decision Emails", desc: "Send acceptance, rejection, and revision emails with reviewer comments attached.", visual: "decemail" },
      { title: "Session Assignment", desc: "Accepted papers are assigned to sessions directly from the CFP dashboard.", visual: "sessassign" },
      { title: "Proceedings Export", desc: "Export accepted abstracts as a formatted proceedings PDF with one click.", visual: "proceedings" },
      { title: "Camera-Ready Submission", desc: "Authors submit final camera-ready versions via the portal after acceptance.", visual: "cameraready" },
    ],
  },
];

const ICON = '<svg class="cfpb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="cfpb-section" id="cfp-bento">
  <div class="cfpb">
    <h2 class="cfpb-title">
      Submission <b>Portal</b>, Peer <b>Review</b> &amp; <b>Publishing</b>
    </h2>
    <p class="cfpb-subtitle">
      Manage the full CFP lifecycle from submission to proceedings export.
    </p>

    <nav class="cfpb-nav" aria-label="Call for papers workflows">
      {tabs.map((t, i) => (
        <button class={`cfpb-tab ${i === 0 ? "cfpb-tab--active" : ""}`} data-cfpb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`cfpb-panel ${tabIdx === 0 ? "cfpb-panel--active" : ""}`} data-cfpb-panel={String(tabIdx)}>
        <div class="cfpb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="cfpb-card cfpb-card--tall cfpb-pos-0" style="animation-delay:0s">
            <div class="cfpb-card__inner">
              <div class="cfpb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="cfpb-card__title">{t.hero.title}</h3>
                <p class="cfpb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="cfpb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`cfpb-card cfpb-card--sm cfpb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="cfpb-card__inner cfpb-card__inner--row">
                <div class="cfpb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="cfpb-card__title">{c.title}</h3>
                  <p class="cfpb-card__desc">{c.desc}</p>
                </div>
                <div class="cfpb-card__img cfpb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const cfpbTabs = Array.from(document.querySelectorAll('[data-cfpb-tab]'));
  const cfpbPanels = Array.from(document.querySelectorAll('[data-cfpb-panel]'));
  let cfpbActive = 0;
  let cfpbInterval: ReturnType<typeof setInterval>;

  function setCfpbTab(index: number) {
    cfpbTabs.forEach((t) => t.classList.remove('cfpb-tab--active'));
    cfpbPanels.forEach((p) => p.classList.remove('cfpb-panel--active'));
    cfpbTabs[index]?.classList.add('cfpb-tab--active');
    cfpbPanels[index]?.classList.add('cfpb-panel--active');
    cfpbActive = index;
  }
  function startCfpb() {
    cfpbInterval = setInterval(() => setCfpbTab((cfpbActive + 1) % cfpbTabs.length), 5000);
  }
  cfpbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setCfpbTab(i); clearInterval(cfpbInterval); startCfpb(); }));
  startCfpb();
  const cfpbSection = document.querySelector('.cfpb-section');
  if (cfpbSection) {
    cfpbSection.addEventListener('mouseenter', () => clearInterval(cfpbInterval));
    cfpbSection.addEventListener('mouseleave', () => startCfpb());
  }
</script>

<style>
  .cfpb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .cfpb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .cfpb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .cfpb-title b { font-weight: 700; }
  .cfpb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .cfpb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .cfpb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .cfpb-tab:hover { background: rgba(55,93,251,.08); }
  .cfpb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .cfpb-panel { display: none; }
  .cfpb-panel--active { display: block; animation: cfpbFadeUp 0.4s ease; }
  @keyframes cfpbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .cfpb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .cfpb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .cfpb-pos-1 { grid-column: 2; grid-row: 1; }
  .cfpb-pos-2 { grid-column: 3; grid-row: 1; }
  .cfpb-pos-3 { grid-column: 2; grid-row: 2; }
  .cfpb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .cfpb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .cfpb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .cfpb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .cfpb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .cfpb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .cfpb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .cfpb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .cfpb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .cfpb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .cfpb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --cfpb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .cfpb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: cfpbCardIn 0.5s ease forwards;
  }
  .cfpb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--cfpb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .cfpb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .cfpb-card:hover::after { opacity: 1; animation: cfpbBorder 2.4s linear infinite; }
  @keyframes cfpbBorder { to { --cfpb-angle: 360deg; } }
  @keyframes cfpbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .cfpb-pos-1 { animation-delay: 0.06s; }
  .cfpb-pos-2 { animation-delay: 0.12s; }
  .cfpb-pos-3 { animation-delay: 0.18s; }
  .cfpb-pos-4 { animation-delay: 0.24s; }

  .cfpb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .cfpb-card__inner--row { flex-direction: row; }
  .cfpb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .cfpb-card--tall .cfpb-card__text { padding: 20px 20px 8px; }
  .cfpb-card--sm .cfpb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .cfpb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .cfpb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .cfpb-card--sm .cfpb-card__title { font-size: 17px; }
  .cfpb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .cfpb-card--sm .cfpb-card__desc { font-size: 13px; }

  .cfpb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .cfpb-card--tall .cfpb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .cfpb-card--sm .cfpb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .cfpb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .cfpb-card:hover .cfpb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: cfpbFloat 2.2s ease-in-out infinite;
  }
  @keyframes cfpbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .cfpb-section { padding: 60px 0 48px; }
    .cfpb-title { font-size: 36px; }
    .cfpb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .cfpb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .cfpb-pos-1, .cfpb-pos-2, .cfpb-pos-3, .cfpb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .cfpb-pos-0, [data-layout="c"] .cfpb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .cfpb-pos-1, [data-layout="b"] .cfpb-pos-2, [data-layout="b"] .cfpb-pos-3, [data-layout="b"] .cfpb-pos-4,
    [data-layout="c"] .cfpb-pos-1, [data-layout="c"] .cfpb-pos-2, [data-layout="c"] .cfpb-pos-3, [data-layout="c"] .cfpb-pos-4 { grid-column: auto; grid-row: auto; }
    .cfpb-card--tall .cfpb-card__inner { flex-direction: row; }
    .cfpb-card--tall .cfpb-card__text { flex: 1; }
    .cfpb-card--tall .cfpb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .cfpb-title { font-size: 28px; }
    .cfpb-subtitle { font-size: 15px; }
    .cfpb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .cfpb-tab { border-radius: 12px; }
    .cfpb-grid { grid-template-columns: 1fr; }
    .cfpb-pos-0, .cfpb-pos-1, .cfpb-pos-2, .cfpb-pos-3, .cfpb-pos-4,
    [data-layout="b"] .cfpb-pos-0, [data-layout="b"] .cfpb-pos-1, [data-layout="b"] .cfpb-pos-2, [data-layout="b"] .cfpb-pos-3, [data-layout="b"] .cfpb-pos-4,
    [data-layout="c"] .cfpb-pos-0, [data-layout="c"] .cfpb-pos-1, [data-layout="c"] .cfpb-pos-2, [data-layout="c"] .cfpb-pos-3, [data-layout="c"] .cfpb-pos-4 { grid-column: 1; grid-row: auto; }
    .cfpb-card--sm .cfpb-card__inner, .cfpb-card--tall .cfpb-card__inner { flex-direction: row; }
    .cfpb-card--sm .cfpb-card__text, .cfpb-card--tall .cfpb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .cfpb-card--sm .cfpb-card__img, .cfpb-card--tall .cfpb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cfpb-card { animation: none !important; opacity: 1; transform: none; }
    .cfpb-card:hover::after { animation: none !important; }
    .cfpb-card:hover .cfpb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
