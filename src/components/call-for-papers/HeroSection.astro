---
import LottiePlayer from "../LottiePlayer.astro";

const heroPoints = [
  "Abstract Submission Portal",
  "Peer Review Workflows",
  "Rubric-Based Scoring",
];

const trustItems = [
  "Multi-round review support",
  "Trusted by 400+ events",
];

---

<section class="cfph-hero">
  <div class="cfph-hero__shell">
    <div class="cfph-hero__grid">
      <div class="cfph-hero__content">
        <div class="cfph-hero__badge animate-on-scroll" data-animation="fadeInDown">
          <span>Call for Papers</span>
        </div>

        <h1 class="cfph-hero__title animate-on-scroll" data-animation="fadeInUp">
          Manage Abstract <b>Submissions &amp;</b>
          <span><b>Peer Review Seamlessly</b></span>
        </h1>

        <p class="cfph-hero__desc animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 800ms">
          EventHex handles the full call-for-papers lifecycle — from submission portal and reviewer assignment to rubric scoring, approval workflows, and automated acceptance emails.
        </p>

        <div class="cfph-hero__points animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 950ms">
          {heroPoints.map((point) => <span class="cfph-hero__point">{point}</span>)}
        </div>

        <div class="cfph-hero__cta animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 1100ms">
          <a href="/book-a-demo/" class="cfph-hero__btn cfph-hero__btn--primary">Book a Demo</a>
          <a href="#cfp-bento" class="cfph-hero__btn cfph-hero__btn--secondary">Explore Features</a>
        </div>

        <div class="cfph-hero__trust animate-on-scroll" data-animation="fadeIn" style="--anim-duration: 1250ms">
          {trustItems.map((item) => <span class="cfph-hero__trust-item">{item}</span>)}
        </div>
      </div>

      <div class="cfph-hero__visual animate-on-scroll" data-animation="fadeInRight">
        <LottiePlayer src="/animations/call-for-papers-hero.json" class="cfph-hero__lottie" eager />
      </div>
    </div>
  </div>
</section>

<style is:global>
  .cfph-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    padding: 0 0 220px;
    background:
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }

  .cfph-hero__shell {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 160px 0 0;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat;
  }

  .cfph-hero__grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .cfph-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .cfph-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .cfph-hero__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 600;
    line-height: 60px;
    letter-spacing: -1px;
    color: var(--heading-dark);
  }

  .cfph-hero__title span {
    display: block;
    color: var(--brand-blue);
  }

  .cfph-hero__desc {
    margin: 0;
    max-width: 580px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .cfph-hero__points {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .cfph-hero__point {
    display: inline-flex;
    align-items: center;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #e5ebff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #475467;
    box-shadow: 0 8px 24px rgba(34, 39, 47, 0.05);
  }

  .cfph-hero__cta {
    display: flex;
    gap: 14px;
    padding-top: 6px;
  }

  .cfph-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, border-color 0.3s;
  }

  .cfph-hero__btn--primary {
    color: #fff;
    background: var(--brand-blue);
    box-shadow: 0 10px 24px rgba(55, 93, 251, 0.28);
  }

  .cfph-hero__btn--primary:hover {
    transform: translateY(-2px);
    background: var(--brand-blue-hover);
    box-shadow: 0 14px 30px rgba(55, 93, 251, 0.34);
  }

  .cfph-hero__btn--secondary {
    color: var(--heading-dark);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #dce4ff;
  }

  .cfph-hero__btn--secondary:hover {
    transform: translateY(-2px);
    border-color: #c5d2ff;
    box-shadow: 0 10px 24px rgba(34, 39, 47, 0.06);
  }

  .cfph-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }

  .cfph-hero__trust-item {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #667085;
  }

  .cfph-hero__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
  }

  .cfph-hero__visual {
    position: relative;
  }

  .cfph-hero__lottie {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 1120px) {
    .cfph-hero { padding: 0 20px 110px; }
    .cfph-hero__shell { padding: 136px 0 0; }
    .cfph-hero__grid { gap: 28px; padding: 0 0 40px; }
    .cfph-hero__desc { max-width: 520px; }
    .cfph-hero__title { font-size: 46px; line-height: 1.1em; }
  }

  @media (max-width: 960px) {
    .cfph-hero { padding: 0 20px 96px; }
    .cfph-hero__shell { padding: 130px 0 0; }
    .cfph-hero__grid { grid-template-columns: 1fr; gap: 34px; padding: 0 0 40px; }
    .cfph-hero__content { align-items: center; text-align: center; }
    .cfph-hero__desc { max-width: 720px; }
    .cfph-hero__trust,
    .cfph-hero__points,
    .cfph-hero__cta { justify-content: center; }
    .cfph-hero__title { font-size: 42px; line-height: 1.1em; }
  }

  @media (max-width: 767px) {
    .cfph-hero { margin-top: -80px; padding: 0 20px 90px; }
    .cfph-hero__shell { padding: 120px 0 0; }
    .cfph-hero__grid { padding: 0 0 30px; }
    .cfph-hero__title { font-size: 30px; line-height: 1.2em; letter-spacing: 0; }
    .cfph-hero__desc { font-size: 15px; line-height: 1.7; }
    .cfph-hero__badge { font-size: 16px; line-height: 1.1em; }
    .cfph-hero__point { font-size: 13px; padding: 8px 12px; }
    .cfph-hero__cta { width: 100%; flex-direction: column; }
    .cfph-hero__btn { width: 100%; }
    .cfph-hero__trust { gap: 10px; justify-content: center; }
  }
</style>
