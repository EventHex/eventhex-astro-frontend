---
const stats = [
  { value: "3x", label: "Engagement Increase" },
  { value: "78%", label: "Challenge Completion Rate" },
  { value: "500+", label: "Events Gamified" },
  { value: "92%", label: "Attendee Satisfaction" },
];
---

<section class="egs-dark">
  <div class="egs-engagement">
    <div class="egs-engagement-text">
      <h2 class="egs-heading animate-on-scroll" data-animation="fadeInDown">
        <span class="egs-white">Gamify events with </span>
        <span class="egs-purple">challenges </span>
        <span class="egs-white">and </span>
        <span class="egs-cyan">real-time leaderboards</span>
      </h2>
    </div>
  </div>

  <div class="egs-stats">
    {stats.map((stat) => (
      <div class="egs-stat">
        <span class="egs-stat-value">{stat.value}</span>
        <span class="egs-stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .egs-dark {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 110px 0;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .egs-engagement {
    width: 100%;
    padding: 0 0 60px;
    display: flex;
    justify-content: center;
  }

  .egs-engagement-text {
    width: 65%;
  }

  .egs-heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 52px;
    letter-spacing: -1px;
    color: #fff;
    text-align: center;
    margin: 0;
  }

  .egs-white { color: #fff; }
  .egs-purple { color: #AFA3FF; }
  .egs-cyan { color: #ABFFFF; }

  .egs-stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    padding: 0 20px;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .egs-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .egs-stat-value {
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 700;
    line-height: 48px;
    letter-spacing: -1px;
    color: #fff;
  }

  .egs-stat-label {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 20px;
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 1024px) {
    .egs-dark { padding: 80px 0; }
    .egs-engagement { padding: 0 20px 40px; }
    .egs-engagement-text { width: 85%; }
    .egs-heading { font-size: 40px; line-height: 1.1em; }
    .egs-stats { gap: 40px; }
    .egs-stat-value { font-size: 32px; }
    .egs-stat-label { font-size: 14px; }
  }

  @media (max-width: 767px) {
    .egs-dark { padding: 64px 0; }
    .egs-engagement { padding: 0 15px 30px; }
    .egs-engagement-text { width: 100%; }
    .egs-heading { font-size: 25px; line-height: 1.2em; letter-spacing: 0; }
    .egs-stats {
      flex-wrap: wrap;
      gap: 24px;
      justify-content: center;
    }
    .egs-stat { width: 40%; }
    .egs-stat-value { font-size: 28px; }
    .egs-stat-label { font-size: 13px; }
  }
</style>
