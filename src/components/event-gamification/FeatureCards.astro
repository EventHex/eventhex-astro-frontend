---
const featureCards = [
  {
    eyebrow: "challenge engine",
    title: "Challenges that drive real engagement across your event",
    desc: "Design custom challenges — visit 5 sponsor booths, attend 3 sessions, network with 10 attendees — and reward completion with points, badges, and prizes.",
    items: [
      "Custom task definitions with point values",
      "QR code verification for booth visits",
      "Flash challenges for peak engagement",
    ],
    visual: "challenge",
  },
  {
    eyebrow: "rewards system",
    title: "Reward engagement, not just attendance",
    desc: "Run lucky draws weighted by engagement points, unlock milestone rewards, and showcase a live Wall of Fame — making every interaction count.",
    items: [
      "Weighted lucky draws by engagement",
      "Auto-triggered milestone rewards",
      "Live Wall of Fame display",
    ],
    visual: "rewards",
  },
  {
    eyebrow: "sponsor value",
    title: "Prove sponsor ROI with verified engagement data",
    desc: "Gamification drives booth traffic — and proves it. Show sponsors exactly how many attendees visited, engaged, and completed challenges.",
    items: [
      "QR-verified booth visit tracking",
      "Auto-generated sponsor ROI reports",
      "Visual engagement heatmaps",
    ],
    visual: "sponsor",
  },
  {
    eyebrow: "analytics",
    title: "Real-time analytics for every gamification touchpoint",
    desc: "Track participation rates, challenge completion, top players, and engagement heatmaps — all from a live analytics dashboard.",
    items: [
      "Real-time participation dashboards",
      "Challenge completion tracking",
      "Top player identification and rewards",
    ],
    visual: "analyticsg",
  },
];
---

<section class="egf-shell">
  <div class="egf-section">
    <div class="egf-header">
      <span class="egf-subtitle">Key features that turn events into interactive engagement experiences</span>
      <h2 class="egf-title">
        Everything You Need to <span class="egf-highlight">Gamify, Reward, and Measure</span><br />
        Event Engagement
      </h2>
    </div>

    <div class="egf-cards" id="egf-stacking-cards">
      {featureCards.map((card, index) => (
        <div class="egf-card" data-card-index={index} style={`--card-index: ${index}; top: calc(20px + ${index * 20}px);`}>
          <div class="egf-card-content">
            <span class="egf-card-eyebrow">{card.eyebrow}</span>
            <h3 class="egf-card-title">{card.title}</h3>
            <p class="egf-card-desc">{card.desc}</p>
            <ul class="egf-card-items">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href="/book-a-demo/" class="egf-card-btn">Explore More</a>
          </div>

          <div class={`egf-card-visual egf-card-visual--${card.visual}`}>
            {card.visual === "challenge" && (
              <Fragment>
                <div class="egf-checklist">
                  <div class="egf-checklist-item egf-checklist-item--done">
                    <span class="egf-checklist-check">&#10003;</span>
                    <div class="egf-checklist-label"><span></span></div>
                    <span class="egf-checklist-badge">+50</span>
                  </div>
                  <div class="egf-checklist-item egf-checklist-item--done">
                    <span class="egf-checklist-check">&#10003;</span>
                    <div class="egf-checklist-label"><span></span></div>
                    <span class="egf-checklist-badge">+30</span>
                  </div>
                  <div class="egf-checklist-item">
                    <span class="egf-checklist-circle"></span>
                    <div class="egf-checklist-label"><span></span></div>
                    <span class="egf-checklist-badge">+40</span>
                  </div>
                </div>
                <div class="egf-qr-scan">
                  <div class="egf-qr-box">
                    <span></span><span></span><span></span><span></span>
                    <span></span><span></span><span></span><span></span><span></span>
                  </div>
                  <span class="egf-qr-text">QR Verified</span>
                </div>
                <div class="egf-visual-pill">Challenge engine</div>
              </Fragment>
            )}

            {card.visual === "rewards" && (
              <Fragment>
                <div class="egf-draw-wheel">
                  <div class="egf-draw-inner">
                    <span></span><span></span><span></span><span></span>
                  </div>
                  <div class="egf-draw-pointer"></div>
                </div>
                <div class="egf-prize-cards">
                  <div class="egf-prize-card">
                    <span class="egf-prize-icon">&#127942;</span>
                    <div class="egf-prize-text"><span></span></div>
                  </div>
                  <div class="egf-prize-card">
                    <span class="egf-prize-icon">&#127775;</span>
                    <div class="egf-prize-text"><span></span></div>
                  </div>
                </div>
                <div class="egf-visual-pill">Rewards system</div>
              </Fragment>
            )}

            {card.visual === "sponsor" && (
              <Fragment>
                <div class="egf-booth-dash">
                  <div class="egf-booth-header"></div>
                  <div class="egf-booth-metrics">
                    <div class="egf-booth-metric">
                      <strong>342</strong>
                      <span>Visits</span>
                    </div>
                    <div class="egf-booth-metric">
                      <strong>89%</strong>
                      <span>Engaged</span>
                    </div>
                    <div class="egf-booth-metric">
                      <strong>3.2x</strong>
                      <span>ROI</span>
                    </div>
                  </div>
                  <div class="egf-booth-bars">
                    <span style="--w:85%"></span>
                    <span style="--w:62%"></span>
                    <span style="--w:78%"></span>
                  </div>
                </div>
                <div class="egf-visual-pill">Sponsor metrics</div>
              </Fragment>
            )}

            {card.visual === "analyticsg" && (
              <Fragment>
                <div class="egf-analytics-dash">
                  <div class="egf-analytics-chart">
                    <div class="egf-analytics-bars">
                      <span style="--h:50%"></span>
                      <span style="--h:75%"></span>
                      <span style="--h:40%"></span>
                      <span style="--h:90%"></span>
                      <span style="--h:60%"></span>
                    </div>
                  </div>
                  <div class="egf-analytics-leader">
                    <div class="egf-analytics-row">
                      <span class="egf-analytics-avatar"></span>
                      <div class="egf-analytics-bar-wrap"><span style="--w:92%"></span></div>
                    </div>
                    <div class="egf-analytics-row">
                      <span class="egf-analytics-avatar"></span>
                      <div class="egf-analytics-bar-wrap"><span style="--w:78%"></span></div>
                    </div>
                    <div class="egf-analytics-row">
                      <span class="egf-analytics-avatar"></span>
                      <div class="egf-analytics-bar-wrap"><span style="--w:65%"></span></div>
                    </div>
                  </div>
                </div>
                <div class="egf-visual-pill">Live analytics</div>
              </Fragment>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .egf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .egf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .egf-header {
    width: 72%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .egf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .egf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .egf-highlight { color: #AFA3FF; }

  .egf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .egf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.88));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .egf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .egf-card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(175, 163, 255, 0.12);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #afa3ff;
  }

  .egf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .egf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .egf-card-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .egf-card-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .egf-card-items li::before {
    content: "";
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
  }

  .egf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .egf-card-btn:hover { transform: scale(1.05); }

  .egf-card-visual {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
    background: radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 52%);
  }

  /* Challenge visual */
  .egf-checklist {
    position: absolute;
    left: 34px;
    top: 60px;
    right: 120px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .egf-checklist-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-radius: 16px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 18px 36px -28px rgba(17, 28, 56, 0.4);
  }

  .egf-checklist-item--done {
    border-left: 3px solid #22c55e;
  }

  .egf-checklist-check {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #22c55e;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .egf-checklist-circle {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid rgba(55, 93, 251, 0.25);
    flex-shrink: 0;
  }

  .egf-checklist-label { flex: 1; }

  .egf-checklist-label span {
    display: block;
    height: 6px;
    width: 80%;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.08);
  }

  .egf-checklist-badge {
    font-size: 12px;
    font-weight: 700;
    color: #375dfb;
    flex-shrink: 0;
    padding: 4px 8px;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.08);
  }

  .egf-qr-scan {
    position: absolute;
    right: 34px;
    top: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px;
    border-radius: 20px;
    background: rgba(20, 33, 59, 0.95);
    box-shadow: 0 20px 40px -26px rgba(17, 28, 56, 0.7);
  }

  .egf-qr-box {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
    width: 48px;
    height: 48px;
  }

  .egf-qr-box span {
    background: #fff;
    border-radius: 2px;
  }

  .egf-qr-box span:nth-child(5) { background: transparent; }
  .egf-qr-box span:nth-child(8) { background: rgba(55, 93, 251, 0.6); }

  .egf-qr-text {
    font-size: 11px;
    font-weight: 700;
    color: #22c55e;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .egf-visual-pill {
    position: absolute;
    right: 32px;
    bottom: 36px;
    display: inline-flex;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: #183465;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
  }

  /* Rewards visual */
  .egf-draw-wheel {
    position: absolute;
    left: 50px;
    top: 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .egf-draw-inner {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: conic-gradient(
      #375dfb 0deg 90deg,
      #22c55e 90deg 180deg,
      #f59e0b 180deg 270deg,
      #AFA3FF 270deg 360deg
    );
    position: relative;
    animation: egf-spin 8s linear infinite;
  }

  .egf-draw-inner span {
    position: absolute;
    width: 2px;
    height: 50%;
    background: rgba(255, 255, 255, 0.6);
    left: 50%;
    transform: translateX(-50%);
    transform-origin: bottom center;
  }

  .egf-draw-inner span:nth-child(1) { transform: translateX(-50%) rotate(0deg); }
  .egf-draw-inner span:nth-child(2) { transform: translateX(-50%) rotate(90deg); }
  .egf-draw-inner span:nth-child(3) { transform: translateX(-50%) rotate(180deg); }
  .egf-draw-inner span:nth-child(4) { transform: translateX(-50%) rotate(270deg); }

  .egf-draw-pointer {
    width: 0;
    height: 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 14px solid #dc2626;
    margin-top: -4px;
  }

  .egf-prize-cards {
    position: absolute;
    right: 34px;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .egf-prize-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-radius: 16px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 18px 36px -28px rgba(17, 28, 56, 0.4);
  }

  .egf-prize-icon { font-size: 20px; }

  .egf-prize-text span {
    display: block;
    height: 6px;
    width: 60px;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.08);
  }

  /* Sponsor visual */
  .egf-booth-dash {
    position: absolute;
    left: 34px;
    top: 60px;
    right: 80px;
    padding: 20px;
    border-radius: 20px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    box-shadow: 0 20px 40px -28px rgba(17, 28, 56, 0.5);
  }

  .egf-booth-header {
    height: 10px;
    width: 55%;
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
    margin-bottom: 16px;
  }

  .egf-booth-metrics {
    display: flex;
    gap: 20px;
    margin-bottom: 14px;
  }

  .egf-booth-metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .egf-booth-metric strong { color: #183465; font-size: 20px; }
  .egf-booth-metric span { color: #607390; font-size: 12px; }

  .egf-booth-bars {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .egf-booth-bars span {
    display: block;
    height: 8px;
    width: var(--w, 50%);
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
    opacity: 0.7;
  }

  /* Analytics visual */
  .egf-analytics-dash {
    position: absolute;
    inset: 50px 30px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .egf-analytics-chart {
    padding: 14px;
    border-radius: 18px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    display: flex;
    align-items: flex-end;
  }

  .egf-analytics-bars {
    width: 100%;
    display: flex;
    align-items: flex-end;
    gap: 6px;
    height: 100%;
  }

  .egf-analytics-bars span {
    flex: 1;
    height: var(--h, 50%);
    border-radius: 4px 4px 0 0;
    background: linear-gradient(180deg, #375dfb, #38bdf8);
    opacity: 0.7;
  }

  .egf-analytics-leader {
    display: flex;
    flex-direction: column;
    gap: 10px;
    justify-content: center;
  }

  .egf-analytics-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-radius: 14px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
  }

  .egf-analytics-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(55, 93, 251, 0.34), rgba(34, 197, 94, 0.24));
    flex-shrink: 0;
  }

  .egf-analytics-bar-wrap {
    flex: 1;
    height: 6px;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.08);
  }

  .egf-analytics-bar-wrap span {
    display: block;
    height: 100%;
    width: var(--w, 50%);
    border-radius: 999px;
    background: linear-gradient(90deg, #375dfb, #22c55e);
  }

  @keyframes egf-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (max-width: 1024px) {
    .egf-section { padding: 60px 20px 30px; }
    .egf-header { width: 80%; }
    .egf-subtitle { font-size: 16px; }
    .egf-title { font-size: 40px; line-height: 1em; }
    .egf-card { height: 450px; }
    .egf-card-content { flex-basis: 50%; }
    .egf-card-title { font-size: 28px; }
    .egf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .egf-section { padding: 50px 20px 30px; }
    .egf-header { width: 100%; }
    .egf-title { font-size: 30px; }
    .egf-card { flex-direction: column; height: 620px; }
    .egf-card-content { flex: 0 0 55%; padding: 20px 20px 0; }
    .egf-card-visual { min-height: 260px; padding: 12px; }
    .egf-card-title { font-size: 24px; }
    .egf-card-desc { font-size: 15px; }
    .egf-cards { padding-bottom: 40px; }
    .egf-checklist { left: 20px; right: 80px; }
    .egf-qr-scan { right: 18px; }
    .egf-draw-wheel { left: 20px; top: 30px; }
    .egf-prize-cards { right: 18px; top: 50px; }
    .egf-booth-dash { left: 20px; right: 40px; }
    .egf-analytics-dash { inset: 30px 16px 60px; }
  }
</style>
