---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "How does event gamification increase engagement?", a: "Gamification gives attendees a reason to explore — visit booths, attend sessions, and network — by rewarding those activities with points, badges, and prizes. Our clients see 3x more interactions at gamified events." },
  { q: "What types of challenges can I create?", a: "Any trackable activity can be a challenge — visit 5 sponsor booths, attend 3 sessions, network with 10 people, post on social media, answer quiz questions, or scan QR codes at specific locations." },
  { q: "Can I run a lucky draw at my event?", a: "Yes. Lucky draws can be weighted by engagement points — so more active attendees have better odds. You can run multiple draws throughout the event with configurable prize pools." },
  { q: "How does the leaderboard work?", a: "The leaderboard updates in real-time as attendees complete challenges. It can be displayed on venue screens, in the mobile app, and on the event website. Position-based rewards can auto-trigger at milestones." },
  { q: "Can sponsors sponsor challenges?", a: "Absolutely. Sponsors can have branded challenges tied to their booth — driving verified foot traffic. They receive detailed engagement reports showing exactly how many attendees interacted with their brand." },
  { q: "Do attendees need an app to participate?", a: "Attendees can participate via the EventHex mobile app or the web-based event page. QR scanning works with any smartphone camera — no special app required." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with event gamification?"
  title="Frequently Asked Questions"
  description="We help event teams design gamification strategies that drive engagement, prove sponsor ROI, and create memorable event experiences."
/>
