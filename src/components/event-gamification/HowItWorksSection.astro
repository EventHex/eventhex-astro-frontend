---
const steps = [
  {
    num: "01",
    title: "Choose a Game Template",
    desc: "Pick a pre-built gamification template or create a custom game from scratch with your own challenges.",
  },
  {
    num: "02",
    title: "Define Challenges & Points",
    desc: "Set up activities — booth visits, session attendance, networking — with point values and rewards.",
  },
  {
    num: "03",
    title: "Attendees Play & Engage",
    desc: "Attendees scan QR codes, complete challenges, and climb the real-time leaderboard during the event.",
  },
  {
    num: "04",
    title: "Reward & Report",
    desc: "Run lucky draws, distribute prizes, and generate sponsor ROI reports with verified engagement data.",
  },
];
---

<section class="eghw-full">
  <div class="eghw-full__inner">
    <div class="eghw-full__header">
      <span class="eghw-full__tag animate-on-scroll" data-animation="fadeIn">How Gamification Works</span>
      <h2 class="eghw-full__title animate-on-scroll" data-animation="fadeInUp">From Template to <b>Live Event Game</b></h2>
      <p class="eghw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Choose a game template, define challenges and points, and let attendees compete for rewards during your event.
      </p>
    </div>

    <div class="eghw-full__cards">
      {steps.map((step) => (
        <article class="eghw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="eghw-full__card-icon">{step.num}</div>
          <h3 class="eghw-full__card-title">{step.title}</h3>
          <p class="eghw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .eghw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .eghw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .eghw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .eghw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eghw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .eghw-full__title b { font-weight: 700; }

  .eghw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .eghw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .eghw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .eghw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .eghw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .eghw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .eghw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .eghw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .eghw-full { padding: 64px 0; }
    .eghw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .eghw-full { padding: 52px 0; }
    .eghw-full__title { font-size: 30px; line-height: 1.15; }
    .eghw-full__desc { font-size: 15px; }
    .eghw-full__cards { grid-template-columns: 1fr; }
  }
</style>
