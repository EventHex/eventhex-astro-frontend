---
import { egbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Games & Challenges",
    hero: {
      title: "Pre-built game templates and custom challenges for every event type",
      desc: "Design custom challenge lists — visit booths, attend sessions, network — and verify completion with QR codes for accurate tracking.",
      visual: "games",
    },
    cards: [
      { title: "Game Templates", desc: "Pre-built gamification templates for conferences, expos, and workshops.", visual: "templateg" },
      { title: "Custom Challenges", desc: "Create tasks — visit booths, attend sessions, network, scan QR codes.", visual: "custom" },
      { title: "Point Scoring", desc: "Configurable point values for different activities and interactions.", visual: "points" },
      { title: "Flash Challenges", desc: "Create urgency with time-limited activities and flash competitions.", visual: "timed" },
    ],
  },
  {
    label: "Leaderboards & Rewards",
    hero: {
      title: "Real-time leaderboards, milestone rewards, and weighted lucky draws",
      desc: "Live rankings on screens and in the attendee app — with auto-triggered rewards at milestones and engagement-weighted lucky draws.",
      visual: "leader",
    },
    cards: [
      { title: "Position Rewards", desc: "Auto-assign prizes for top performers at each milestone.", visual: "position" },
      { title: "Milestone Rewards", desc: "Unlock rewards when attendees reach specific point thresholds.", visual: "milestone" },
      { title: "Lucky Draw System", desc: "Run lucky draws with weighted entries based on engagement points.", visual: "draw" },
      { title: "Wall of Fame", desc: "Showcase top participants with photos and achievement badges.", visual: "fame" },
    ],
  },
  {
    label: "Analytics & Sponsor ROI",
    hero: {
      title: "Participation analytics, engagement heatmaps, and sponsor ROI metrics",
      desc: "Track challenge completion rates, identify top players, and prove sponsor booth traffic with QR-verified engagement data.",
      visual: "roi",
    },
    cards: [
      { title: "Challenge Completion", desc: "Monitor completion rates and identify popular activities.", visual: "completion" },
      { title: "Top Players", desc: "Identify your most engaged attendees and reward them.", visual: "topplay" },
      { title: "Engagement Heatmaps", desc: "Visualize which booths and sessions drive the most activity.", visual: "heatmapg" },
      { title: "Sponsor ROI Metrics", desc: "Show sponsors how gamification drove traffic to their booths.", visual: "sponsorroi" },
    ],
  },
];

const ICON = '<svg class="egb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="egb-section" id="eg-bento">
  <div class="egb">
    <h2 class="egb-title">
      Games & <b>Challenges</b>, Leaderboards & <b>Rewards</b>
    </h2>
    <p class="egb-subtitle">
      Create challenges, track leaderboards, run lucky draws, and reward engagement from a single gamification dashboard.
    </p>

    <nav class="egb-nav">
      {tabs.map((t, i) => (
        <button class={`egb-tab ${i === 0 ? "egb-tab--active" : ""}`} data-egb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`egb-panel ${tabIdx === 0 ? "egb-panel--active" : ""}`} data-egb-panel={String(tabIdx)}>
        <div class="egb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="egb-card egb-card--tall egb-pos-0" style="animation-delay:0s">
            <div class="egb-card__inner">
              <div class="egb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="egb-card__title">{t.hero.title}</h3>
                <p class="egb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="egb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`egb-card egb-card--sm egb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="egb-card__inner egb-card__inner--row">
                <div class="egb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="egb-card__title">{c.title}</h3>
                  <p class="egb-card__desc">{c.desc}</p>
                </div>
                <div class="egb-card__img egb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const egbTabs = Array.from(document.querySelectorAll('[data-egb-tab]'));
  const egbPanels = Array.from(document.querySelectorAll('[data-egb-panel]'));
  let egbActive = 0;
  let egbInterval: ReturnType<typeof setInterval>;

  function setEgbTab(index: number) {
    egbTabs.forEach((t) => t.classList.remove('egb-tab--active'));
    egbPanels.forEach((p) => p.classList.remove('egb-panel--active'));
    egbTabs[index]?.classList.add('egb-tab--active');
    egbPanels[index]?.classList.add('egb-panel--active');
    egbActive = index;
  }
  function startEgb() {
    egbInterval = setInterval(() => setEgbTab((egbActive + 1) % egbTabs.length), 5000);
  }
  egbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setEgbTab(i); clearInterval(egbInterval); startEgb(); }));
  startEgb();
  const egbSection = document.querySelector('.egb-section');
  if (egbSection) {
    egbSection.addEventListener('mouseenter', () => clearInterval(egbInterval));
    egbSection.addEventListener('mouseleave', () => startEgb());
  }
</script>

<style>
  .egb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .egb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .egb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .egb-title b { font-weight: 700; }
  .egb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .egb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .egb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .egb-tab:hover { background: rgba(55,93,251,.08); }
  .egb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .egb-panel { display: none; }
  .egb-panel--active { display: block; animation: egbFadeUp 0.4s ease; }
  @keyframes egbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .egb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .egb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .egb-pos-1 { grid-column: 2; grid-row: 1; }
  .egb-pos-2 { grid-column: 3; grid-row: 1; }
  .egb-pos-3 { grid-column: 2; grid-row: 2; }
  .egb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .egb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .egb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .egb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .egb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .egb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .egb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .egb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .egb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .egb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .egb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --egb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .egb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: egbCardIn 0.5s ease forwards;
  }
  .egb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--egb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .egb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .egb-card:hover::after { opacity: 1; animation: egbBorder 2.4s linear infinite; }
  @keyframes egbBorder { to { --egb-angle: 360deg; } }
  @keyframes egbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .egb-pos-1 { animation-delay: 0.06s; }
  .egb-pos-2 { animation-delay: 0.12s; }
  .egb-pos-3 { animation-delay: 0.18s; }
  .egb-pos-4 { animation-delay: 0.24s; }

  .egb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .egb-card__inner--row { flex-direction: row; }
  .egb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .egb-card--tall .egb-card__text { padding: 20px 20px 8px; }
  .egb-card--sm .egb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .egb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .egb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .egb-card--sm .egb-card__title { font-size: 17px; }
  .egb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .egb-card--sm .egb-card__desc { font-size: 13px; }

  .egb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .egb-card--tall .egb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .egb-card--sm .egb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .egb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .egb-card:hover .egb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: egbFloat 2.2s ease-in-out infinite;
  }
  @keyframes egbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .egb-section { padding: 60px 0 48px; }
    .egb-title { font-size: 36px; }
    .egb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .egb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .egb-pos-1, .egb-pos-2, .egb-pos-3, .egb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .egb-pos-0, [data-layout="c"] .egb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .egb-pos-1, [data-layout="b"] .egb-pos-2, [data-layout="b"] .egb-pos-3, [data-layout="b"] .egb-pos-4,
    [data-layout="c"] .egb-pos-1, [data-layout="c"] .egb-pos-2, [data-layout="c"] .egb-pos-3, [data-layout="c"] .egb-pos-4 { grid-column: auto; grid-row: auto; }
    .egb-card--tall .egb-card__inner { flex-direction: row; }
    .egb-card--tall .egb-card__text { flex: 1; }
    .egb-card--tall .egb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .egb-title { font-size: 28px; }
    .egb-subtitle { font-size: 15px; }
    .egb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .egb-tab { border-radius: 12px; }
    .egb-grid { grid-template-columns: 1fr; }
    .egb-pos-0, .egb-pos-1, .egb-pos-2, .egb-pos-3, .egb-pos-4,
    [data-layout="b"] .egb-pos-0, [data-layout="b"] .egb-pos-1, [data-layout="b"] .egb-pos-2, [data-layout="b"] .egb-pos-3, [data-layout="b"] .egb-pos-4,
    [data-layout="c"] .egb-pos-0, [data-layout="c"] .egb-pos-1, [data-layout="c"] .egb-pos-2, [data-layout="c"] .egb-pos-3, [data-layout="c"] .egb-pos-4 { grid-column: 1; grid-row: auto; }
    .egb-card--sm .egb-card__inner, .egb-card--tall .egb-card__inner { flex-direction: row; }
    .egb-card--sm .egb-card__text, .egb-card--tall .egb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .egb-card--sm .egb-card__img, .egb-card--tall .egb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .egb-card { animation: none !important; opacity: 1; transform: none; }
    .egb-card:hover::after { animation: none !important; }
    .egb-card:hover .egb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
