---
const tabs = [
  {
    label: "Games & Challenges",
    hero: {
      eyebrow: "Challenge Engine",
      title: "Pre-built game templates and custom challenges for every event type",
      desc: "Design custom challenge lists — visit booths, attend sessions, network — and verify completion with QR codes for accurate tracking.",
      points: ["Master game templates", "QR-verified activities", "Configurable point values"],
      visual: "games",
    },
    cards: [
      {
        eyebrow: "Templates",
        title: "Game Templates",
        desc: "Pre-built gamification templates for conferences, expos, and workshops.",
        visual: "templateg",
      },
      {
        eyebrow: "Custom",
        title: "Custom Challenges",
        desc: "Create tasks — visit booths, attend sessions, network, scan QR codes.",
        visual: "custom",
      },
      {
        eyebrow: "Points",
        title: "Point Scoring",
        desc: "Configurable point values for different activities and interactions.",
        visual: "points",
      },
      {
        eyebrow: "Timed",
        title: "Flash Challenges",
        desc: "Create urgency with time-limited activities and flash competitions.",
        visual: "timed",
      },
    ],
  },
  {
    label: "Leaderboards & Rewards",
    hero: {
      eyebrow: "Rewards Engine",
      title: "Real-time leaderboards, milestone rewards, and weighted lucky draws",
      desc: "Live rankings on screens and in the attendee app — with auto-triggered rewards at milestones and engagement-weighted lucky draws.",
      points: ["Live leaderboard displays", "Position-based rewards", "Weighted lucky draws"],
      visual: "leader",
    },
    cards: [
      {
        eyebrow: "Ranking",
        title: "Position Rewards",
        desc: "Auto-assign prizes for top performers at each milestone.",
        visual: "position",
      },
      {
        eyebrow: "Milestones",
        title: "Milestone Rewards",
        desc: "Unlock rewards when attendees reach specific point thresholds.",
        visual: "milestone",
      },
      {
        eyebrow: "Draws",
        title: "Lucky Draw System",
        desc: "Run lucky draws with weighted entries based on engagement points.",
        visual: "draw",
      },
      {
        eyebrow: "Fame",
        title: "Wall of Fame",
        desc: "Showcase top participants with photos and achievement badges.",
        visual: "fame",
      },
    ],
  },
  {
    label: "Analytics & Sponsor ROI",
    hero: {
      eyebrow: "Event Intelligence",
      title: "Participation analytics, engagement heatmaps, and sponsor ROI metrics",
      desc: "Track challenge completion rates, identify top players, and prove sponsor booth traffic with QR-verified engagement data.",
      points: ["Participation rate tracking", "Engagement heatmaps", "Sponsor ROI reports"],
      visual: "roi",
    },
    cards: [
      {
        eyebrow: "Completion",
        title: "Challenge Completion",
        desc: "Monitor completion rates and identify popular activities.",
        visual: "completion",
      },
      {
        eyebrow: "Players",
        title: "Top Players",
        desc: "Identify your most engaged attendees and reward them.",
        visual: "topplay",
      },
      {
        eyebrow: "Heatmaps",
        title: "Engagement Heatmaps",
        desc: "Visualize which booths and sessions drive the most activity.",
        visual: "heatmapg",
      },
      {
        eyebrow: "Sponsors",
        title: "Sponsor ROI Metrics",
        desc: "Show sponsors how gamification drove traffic to their booths.",
        visual: "sponsorroi",
      },
    ],
  },
];
---

<section class="egb-section" id="eg-bento">
  <div class="egb-shell">
    <h2 class="egb-title">
      Games & <b>Challenges</b>, Leaderboards & <b>Rewards</b>
    </h2>
    <p class="egb-subtitle">
      Create challenges, track leaderboards, run lucky draws, and reward engagement from a single gamification dashboard.
    </p>

    <nav class="egb-nav" aria-label="Event gamification workflows">
      {tabs.map((tab, index) => (
        <button
          class={`egb-tab${index === 0 ? " egb-tab--active" : ""}`}
          data-egb-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`egb-panel${tabIndex === 0 ? " egb-panel--active" : ""}`}
        data-egb-panel={tabIndex}
      >
        <div class="egb-grid">
          <article class="egb-card egb-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="egb-card__content">
              <span class="egb-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="egb-card__title">{tab.hero.title}</h3>
              <p class="egb-card__desc">{tab.hero.desc}</p>

              <ul class="egb-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`egb-art egb-art--hero egb-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "games" && (
                <Fragment>
                  <div class="egb-challenge-list">
                    <div class="egb-challenge-item egb-challenge-item--done">
                      <span class="egb-challenge-check">&#10003;</span>
                      <div class="egb-challenge-text"><span></span></div>
                      <span class="egb-challenge-pts">+50</span>
                    </div>
                    <div class="egb-challenge-item egb-challenge-item--done">
                      <span class="egb-challenge-check">&#10003;</span>
                      <div class="egb-challenge-text"><span></span></div>
                      <span class="egb-challenge-pts">+30</span>
                    </div>
                    <div class="egb-challenge-item">
                      <span class="egb-challenge-circle"></span>
                      <div class="egb-challenge-text"><span></span></div>
                      <span class="egb-challenge-pts">+40</span>
                    </div>
                    <div class="egb-challenge-item">
                      <span class="egb-challenge-circle"></span>
                      <div class="egb-challenge-text"><span></span></div>
                      <span class="egb-challenge-pts">+25</span>
                    </div>
                  </div>
                  <div class="egb-qr-badge">
                    <div class="egb-qr-grid">
                      <span></span><span></span><span></span><span></span>
                      <span></span><span></span><span></span><span></span>
                      <span></span>
                    </div>
                    <span class="egb-qr-label">Scan to verify</span>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "leader" && (
                <Fragment>
                  <div class="egb-podium">
                    <div class="egb-podium-bar egb-podium-bar--2nd">
                      <span class="egb-podium-avatar"></span>
                      <strong>2nd</strong>
                      <span class="egb-podium-score">820</span>
                    </div>
                    <div class="egb-podium-bar egb-podium-bar--1st">
                      <span class="egb-podium-crown">&#9733;</span>
                      <span class="egb-podium-avatar"></span>
                      <strong>1st</strong>
                      <span class="egb-podium-score">1,240</span>
                    </div>
                    <div class="egb-podium-bar egb-podium-bar--3rd">
                      <span class="egb-podium-avatar"></span>
                      <strong>3rd</strong>
                      <span class="egb-podium-score">690</span>
                    </div>
                  </div>
                  <div class="egb-reward-chip">&#127942; Rewards unlocked</div>
                </Fragment>
              )}

              {tab.hero.visual === "roi" && (
                <Fragment>
                  <div class="egb-roi-chart">
                    <div class="egb-roi-bars">
                      <div class="egb-roi-bar-group">
                        <span style="--h:55%"></span>
                        <span class="egb-roi-dollar">$</span>
                      </div>
                      <div class="egb-roi-bar-group">
                        <span style="--h:80%"></span>
                        <span class="egb-roi-dollar">$</span>
                      </div>
                      <div class="egb-roi-bar-group">
                        <span style="--h:45%"></span>
                        <span class="egb-roi-dollar">$</span>
                      </div>
                      <div class="egb-roi-bar-group">
                        <span style="--h:92%"></span>
                        <span class="egb-roi-dollar">$</span>
                      </div>
                      <div class="egb-roi-bar-group">
                        <span style="--h:68%"></span>
                        <span class="egb-roi-dollar">$</span>
                      </div>
                    </div>
                    <div class="egb-roi-label">Sponsor engagement</div>
                  </div>
                  <div class="egb-roi-pill">
                    <strong>3x</strong>
                    <span>ROI verified</span>
                  </div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="egb-card egb-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="egb-card__content">
                <span class="egb-card__eyebrow">{card.eyebrow}</span>
                <h3 class="egb-card__title">{card.title}</h3>
                <p class="egb-card__desc">{card.desc}</p>
              </div>

              <div class={`egb-art egb-art--mini egb-art--${card.visual}`} aria-hidden="true">
                {card.visual === "templateg" && (
                  <Fragment>
                    <div class="egb-template-grid">
                      <div class="egb-template-card"><span></span><span></span></div>
                      <div class="egb-template-card"><span></span><span></span></div>
                      <div class="egb-template-card"><span></span><span></span></div>
                      <div class="egb-template-card"><span></span><span></span></div>
                    </div>
                    <div class="egb-mini-chip">4 templates</div>
                  </Fragment>
                )}

                {card.visual === "custom" && (
                  <Fragment>
                    <div class="egb-task-card">
                      <div class="egb-task-head"></div>
                      <div class="egb-task-checks">
                        <span class="egb-task-row egb-task-row--done"></span>
                        <span class="egb-task-row egb-task-row--done"></span>
                        <span class="egb-task-row"></span>
                      </div>
                    </div>
                    <div class="egb-mini-chip">Custom tasks</div>
                  </Fragment>
                )}

                {card.visual === "points" && (
                  <Fragment>
                    <div class="egb-score-counter">
                      <strong class="egb-score-num">850</strong>
                      <div class="egb-score-plus">+50</div>
                    </div>
                    <div class="egb-mini-chip">Points earned</div>
                  </Fragment>
                )}

                {card.visual === "timed" && (
                  <Fragment>
                    <div class="egb-clock">
                      <div class="egb-clock-face">
                        <div class="egb-clock-hand"></div>
                      </div>
                      <div class="egb-countdown">05:00</div>
                    </div>
                    <div class="egb-mini-chip">Flash active</div>
                  </Fragment>
                )}

                {card.visual === "position" && (
                  <Fragment>
                    <div class="egb-trophy">
                      <div class="egb-trophy-cup"></div>
                      <div class="egb-trophy-num">#1</div>
                    </div>
                    <div class="egb-mini-chip">Top prize</div>
                  </Fragment>
                )}

                {card.visual === "milestone" && (
                  <Fragment>
                    <div class="egb-progress-track">
                      <div class="egb-progress-fill"></div>
                      <span class="egb-milestone-dot egb-milestone-dot--1"></span>
                      <span class="egb-milestone-dot egb-milestone-dot--2"></span>
                      <span class="egb-milestone-dot egb-milestone-dot--3"></span>
                    </div>
                    <div class="egb-mini-chip">75% complete</div>
                  </Fragment>
                )}

                {card.visual === "draw" && (
                  <Fragment>
                    <div class="egb-wheel">
                      <div class="egb-wheel-inner">
                        <span></span><span></span><span></span><span></span>
                      </div>
                      <div class="egb-wheel-pointer"></div>
                    </div>
                    <div class="egb-mini-chip">Lucky draw</div>
                  </Fragment>
                )}

                {card.visual === "fame" && (
                  <Fragment>
                    <div class="egb-fame-cards">
                      <div class="egb-fame-card">
                        <span class="egb-fame-avatar"></span>
                        <span class="egb-fame-star">&#9733;</span>
                      </div>
                      <div class="egb-fame-card">
                        <span class="egb-fame-avatar"></span>
                        <span class="egb-fame-star">&#9733;</span>
                      </div>
                      <div class="egb-fame-card">
                        <span class="egb-fame-avatar"></span>
                        <span class="egb-fame-star">&#9733;</span>
                      </div>
                    </div>
                    <div class="egb-mini-chip">Wall of Fame</div>
                  </Fragment>
                )}

                {card.visual === "completion" && (
                  <Fragment>
                    <div class="egb-ring">
                      <svg viewBox="0 0 80 80" class="egb-ring-svg">
                        <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(55,93,251,0.1)" stroke-width="8"/>
                        <circle cx="40" cy="40" r="34" fill="none" stroke="#375dfb" stroke-width="8" stroke-dasharray="163" stroke-dashoffset="41" stroke-linecap="round" transform="rotate(-90 40 40)"/>
                      </svg>
                      <span class="egb-ring-pct">78%</span>
                    </div>
                    <div class="egb-mini-chip">Completion rate</div>
                  </Fragment>
                )}

                {card.visual === "topplay" && (
                  <Fragment>
                    <div class="egb-player-card">
                      <span class="egb-player-avatar"></span>
                      <div class="egb-player-info">
                        <span class="egb-player-bar"></span>
                        <strong>1,240 pts</strong>
                      </div>
                    </div>
                    <div class="egb-mini-chip">#1 Player</div>
                  </Fragment>
                )}

                {card.visual === "heatmapg" && (
                  <Fragment>
                    <div class="egb-heatmap-grid">
                      <span style="--o:0.2"></span><span style="--o:0.5"></span><span style="--o:0.9"></span>
                      <span style="--o:0.7"></span><span style="--o:1"></span><span style="--o:0.3"></span>
                      <span style="--o:0.4"></span><span style="--o:0.8"></span><span style="--o:0.6"></span>
                    </div>
                    <div class="egb-mini-chip">Activity map</div>
                  </Fragment>
                )}

                {card.visual === "sponsorroi" && (
                  <Fragment>
                    <div class="egb-report-card">
                      <div class="egb-report-head"></div>
                      <div class="egb-report-metrics">
                        <div><strong>342</strong><span>Visits</span></div>
                        <div><strong>89%</strong><span>Engaged</span></div>
                      </div>
                    </div>
                    <div class="egb-mini-chip">Sponsor report</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".egb-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".egb-tab"));
      const panels = Array.from(root.querySelectorAll(".egb-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("egb-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("egb-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .egb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .egb-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .egb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .egb-title b { font-weight: 700; }

  .egb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .egb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .egb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .egb-tab:hover,
  .egb-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .egb-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .egb-panel { display: none; }
  .egb-panel--active { display: block; }

  .egb-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .egb-panel--active .egb-card {
    animation: egb-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  .egb-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .egb-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .egb-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .egb-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .egb-card--mini:nth-of-type(2) { grid-area: mini1; }
  .egb-card--mini:nth-of-type(3) { grid-area: mini2; }
  .egb-card--mini:nth-of-type(4) { grid-area: mini3; }
  .egb-card--mini:nth-of-type(5) { grid-area: mini4; }

  .egb-card__content { position: relative; z-index: 1; }

  .egb-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .egb-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .egb-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .egb-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .egb-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .egb-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .egb-art { position: relative; z-index: 1; min-height: 146px; }
  .egb-art--hero { min-height: 228px; margin-top: 0.6rem; }
  .egb-art--mini { align-self: end; }

  /* === Hero visual: games === */
  .egb-challenge-list {
    position: absolute;
    inset: 0 10% auto 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .egb-challenge-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 0.8rem;
    border-radius: 1rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    animation: egb-float 5.2s ease-in-out infinite;
  }

  .egb-challenge-item:nth-child(2) { animation-delay: -0.6s; }
  .egb-challenge-item:nth-child(3) { animation-delay: -1.2s; }
  .egb-challenge-item:nth-child(4) { animation-delay: -1.8s; }

  .egb-challenge-item--done {
    border-left: 3px solid #22c55e;
  }

  .egb-challenge-check {
    width: 1.2rem;
    height: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #22c55e;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .egb-challenge-circle {
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 50%;
    border: 2px solid rgba(55, 93, 251, 0.25);
    flex-shrink: 0;
  }

  .egb-challenge-text {
    flex: 1;
  }

  .egb-challenge-text span {
    display: block;
    height: 0.4rem;
    width: 80%;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.08);
  }

  .egb-challenge-pts {
    font-size: 0.75rem;
    font-weight: 700;
    color: #375dfb;
    flex-shrink: 0;
  }

  .egb-qr-badge {
    position: absolute;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 0.8rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
  }

  .egb-qr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    width: 2.4rem;
    height: 2.4rem;
  }

  .egb-qr-grid span {
    background: #14213b;
    border-radius: 1px;
  }

  .egb-qr-grid span:nth-child(5) { background: transparent; }
  .egb-qr-grid span:nth-child(8) { background: rgba(55, 93, 251, 0.4); }

  .egb-qr-label {
    font-size: 0.65rem;
    font-weight: 700;
    color: #45608e;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* === Hero visual: leader (podium) === */
  .egb-podium {
    position: absolute;
    inset: 0.5rem 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 0.5rem;
