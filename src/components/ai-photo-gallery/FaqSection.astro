---
const faqs = [
  {
    q: "How does InstaSnap face recognition work?",
    a: "InstaSnap uses AWS Rekognition to cluster faces automatically when photos are uploaded. Attendees take a selfie on the event app or web gallery, and the AI matches their face against all event photos to deliver results in seconds.",
  },
  {
    q: "Do attendees need to install an app?",
    a: "No. InstaSnap works via the event's web-based gallery or the EventHex attendee app. Attendees simply visit the gallery link, take a selfie, and get their matched photos without any extra installation step.",
  },
  {
    q: "Is InstaSnap GDPR compliant?",
    a: "Yes. InstaSnap follows a privacy-first design. Photo permissions can be configured by the organizer, attendees can opt out of face recognition, and facial data is encrypted and deleted according to the event's retention rules.",
  },
  {
    q: "How many photos can InstaSnap process?",
    a: "InstaSnap handles thousands of photos per event. The AI pipeline is designed for bulk uploads from professional photographers and can cluster and index the gallery while the event is still active.",
  },
  {
    q: "Can sponsors advertise in the photo gallery?",
    a: "Yes. Organizers can place sponsor banners, branded frames, and promotional content inside the gallery, creating a new monetization channel directly tied to attendee engagement.",
  },
  {
    q: "What happens if face matching fails?",
    a: "If the AI cannot confidently find a match, attendees can still browse the full gallery manually. Match accuracy improves with high-quality photos and strong lighting, and the system keeps learning as more images are processed.",
  },
  {
    q: "Can attendees opt out of face recognition?",
    a: "Absolutely. Organizers can enable opt-out controls so attendees choose whether to participate in face recognition while their photos remain available in the broader event gallery.",
  },
  {
    q: "Does InstaSnap work with professional photographers?",
    a: "Yes. Photographers can bulk upload photos via the organizer dashboard. InstaSnap processes, clusters, and indexes the files automatically, saving hours of manual sorting.",
  },
];

const checklist = [
  "Photographer upload and album setup",
  "Sponsor placement and branded gallery configuration",
  "Privacy rules, opt-out flows, and attendee delivery readiness",
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="apgfq">
  <div class="apgfq__inner">
    <div class="apgfq__support">
      <span class="apgfq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need a custom gallery setup?</span>
      <h2 class="apgfq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="apgfq__desc animate-on-scroll" data-animation="fadeInUp">
        We help event teams shape AI photo delivery, sponsor-ready gallery flows, and privacy controls around how their live event operations actually run.
      </p>

      <div class="apgfq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="apgfq__support-label">Included with every rollout</span>
        <ul class="apgfq__support-list">
          {checklist.map((item) => (
            <li class="apgfq__support-item">{item}</li>
          ))}
        </ul>

        <div class="apgfq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your gallery workflow before launch and keep your event team aligned on privacy, sponsor, and delivery settings.</span>
        </div>

        <a href="/book-a-demo/" class="apgfq__cta">Plan my gallery flow</a>
      </div>
    </div>

    <div class="apgfq__list">
      {faqs.map((faq, index) => (
        <details class="apgfq__item animate-on-scroll" data-animation="fadeInUp" data-photo-faq open={index === 0}>
          <summary class="apgfq__question">
            <span>{faq.q}</span>
            <span class="apgfq__icon" aria-hidden="true">
              <span class="apgfq__icon-line apgfq__icon-line--horizontal"></span>
              <span class="apgfq__icon-line apgfq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="apgfq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const photoFaqItems = Array.from(document.querySelectorAll('[data-photo-faq]'));

  photoFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      photoFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .apgfq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .apgfq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .apgfq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .apgfq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .apgfq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .apgfq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .apgfq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .apgfq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .apgfq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .apgfq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .apgfq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .apgfq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .apgfq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .apgfq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .apgfq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .apgfq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .apgfq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .apgfq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .apgfq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
  }

  .apgfq__question::-webkit-details-marker,
  .apgfq__question::marker {
    display: none;
  }

  .apgfq__icon {
    position: relative;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 4px;
  }

  .apgfq__icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #375dfb;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .apgfq__icon-line--vertical {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .apgfq__item[open] .apgfq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0);
  }

  .apgfq__answer {
    padding: 0 24px 24px;
  }

  .apgfq__answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #5b6477;
  }

  @media (max-width: 1100px) {
    .apgfq { padding: 76px 0; }
    .apgfq__inner { grid-template-columns: 1fr; gap: 28px; }
    .apgfq__support { position: static; }
  }

  @media (max-width: 1024px) {
    .apgfq__title { font-size: 40px; }
    .apgfq__desc { font-size: 16px; }
    .apgfq__question { padding: 24px 22px; font-size: 20px; }
    .apgfq__answer { padding: 0 22px 22px; }
  }

  @media (max-width: 767px) {
    .apgfq { padding: 56px 0; }
    .apgfq__inner { padding: 0 16px; gap: 24px; }
    .apgfq__title { font-size: 32px; line-height: 1.08; }
    .apgfq__desc { font-size: 15px; line-height: 1.7; }
    .apgfq__support-card { padding: 20px 18px; border-radius: 24px; }
    .apgfq__support-item { font-size: 15px; }
    .apgfq__support-note strong { font-size: 18px; }
    .apgfq__cta { width: 100%; }
    .apgfq__item { border-radius: 24px; }
    .apgfq__question { padding: 20px 18px; font-size: 17px; line-height: 1.45; }
    .apgfq__answer { padding: 0 18px 20px; }
    .apgfq__answer p { font-size: 15px; line-height: 1.75; }
  }
</style>