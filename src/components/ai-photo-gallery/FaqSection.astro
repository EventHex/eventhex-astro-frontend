---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "How does InstaSnap face recognition work?", a: "InstaSnap uses AWS Rekognition to cluster faces automatically when photos are uploaded. Attendees take a selfie on the event app or web gallery, and the AI matches their face against all event photos to deliver results in seconds." },
  { q: "Do attendees need to install an app?", a: "No. InstaSnap works via the event's web-based gallery or the EventHex attendee app. Attendees simply visit the gallery link, take a selfie, and get their matched photos without any extra installation step." },
  { q: "Is InstaSnap GDPR compliant?", a: "Yes. InstaSnap follows a privacy-first design. Photo permissions can be configured by the organizer, attendees can opt out of face recognition, and facial data is encrypted and deleted according to the event's retention rules." },
  { q: "How many photos can InstaSnap process?", a: "InstaSnap handles thousands of photos per event. The AI pipeline is designed for bulk uploads from professional photographers and can cluster and index the gallery while the event is still active." },
  { q: "Can sponsors advertise in the photo gallery?", a: "Yes. Organizers can place sponsor banners, branded frames, and promotional content inside the gallery, creating a new monetization channel directly tied to attendee engagement." },
  { q: "What happens if face matching fails?", a: "If the AI cannot confidently find a match, attendees can still browse the full gallery manually. Match accuracy improves with high-quality photos and strong lighting, and the system keeps learning as more images are processed." },
  { q: "Can attendees opt out of face recognition?", a: "Absolutely. Organizers can enable opt-out controls so attendees choose whether to participate in face recognition while their photos remain available in the broader event gallery." },
  { q: "Does InstaSnap work with professional photographers?", a: "Yes. Photographers can bulk upload photos via the organizer dashboard. InstaSnap processes, clusters, and indexes the files automatically, saving hours of manual sorting." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need a custom gallery setup?"
  title="Frequently Asked Questions"
  description="We help event teams shape AI photo delivery, sponsor-ready gallery flows, and privacy controls around how their live event operations actually run."
/>
