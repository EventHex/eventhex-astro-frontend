---
const stats = [
  { value: "50K+", label: "Photos Processed" },
  { value: "95%+", label: "Face Match Accuracy" },
  { value: "3s", label: "Average Match Time" },
  { value: "400+", label: "Events Powered" },
];
---

<section class="apgs-dark">
  <div class="apgs-engagement">
    <div class="apgs-engagement-text">
      <h2 class="apgs-heading animate-on-scroll" data-animation="fadeInDown">
        <span class="apgs-white">Centralize photo delivery with </span>
        <span class="apgs-purple">AI-powered face matching </span>
        <span class="apgs-white">and </span>
        <span class="apgs-cyan">sponsor-ready gallery sharing</span>
      </h2>
    </div>
  </div>

  <div class="apgs-stats">
    {stats.map((stat) => (
      <div class="apgs-stat">
        <span class="apgs-stat-value">{stat.value}</span>
        <span class="apgs-stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .apgs-dark {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 110px 0;
    background-color: #000;
    background-image:
      radial-gradient(at 57% 33%, hsl(219 0% 0%) 0px, transparent 50%),
      radial-gradient(at 46% 60%, hsl(219 100% 15%) 0px, transparent 50%),
      radial-gradient(at 60% 56%, hsl(327 100% 11%) 0px, transparent 50%),
      radial-gradient(at 49% 0%, hsl(307 100% 11%) 0px, transparent 50%),
      radial-gradient(at 96% 0%, hsl(195 97% 13%) 0px, transparent 50%),
      radial-gradient(at 96% 97%, hsl(206 100% 24%) 0px, transparent 50%),
      radial-gradient(at 8% 82%, hsl(293 96% 10%) 0px, transparent 50%),
      radial-gradient(at 0% 0%, hsl(196 100% 21%) 0px, transparent 50%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-1.webp');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .apgs-engagement {
    width: 100%;
    padding: 0 0 60px;
    display: flex;
    justify-content: center;
  }

  .apgs-engagement-text {
    width: 65%;
  }

  .apgs-heading {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 52px;
    letter-spacing: -1px;
    color: #fff;
    text-align: center;
    margin: 0;
  }

  .apgs-white { color: #fff; }
  .apgs-purple { color: #AFA3FF; }
  .apgs-cyan { color: #ABFFFF; }

  .apgs-stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    padding: 0 20px;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  .apgs-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 6px;
    padding: 28px 32px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    flex: 1;
    min-width: 0;
  }

  .apgs-stat-value {
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 700;
    line-height: 48px;
    letter-spacing: -1px;
    color: #fff;
  }

  .apgs-stat-label {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 20px;
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 1024px) {
    .apgs-dark { padding: 80px 0; }
    .apgs-engagement { padding: 0 20px 40px; }
    .apgs-engagement-text { width: 85%; }
    .apgs-heading { font-size: 40px; line-height: 1.1em; }
    .apgs-stats { gap: 40px; }
    .apgs-stat-value { font-size: 32px; }
    .apgs-stat-label { font-size: 14px; }
  }

  @media (max-width: 767px) {
    .apgs-dark { padding: 64px 0; }
    .apgs-engagement { padding: 0 15px 30px; }
    .apgs-engagement-text { width: 100%; }
    .apgs-heading { font-size: 25px; line-height: 1.2em; letter-spacing: 0; }
    .apgs-stats {
      flex-wrap: wrap;
      gap: 24px;
      justify-content: center;
    }
    .apgs-stat { width: 40%; }
    .apgs-stat-value { font-size: 28px; }
    .apgs-stat-label { font-size: 13px; }
  }
</style>