---
import { apgbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "AI Face Matching",
    hero: {
      title: "Let attendees take one selfie and find every relevant photo in seconds",
      desc: "Upload event galleries once and let the AI photo gallery handle clustering, personal matching, and delivery across solo portraits and crowded group shots.",
      visual: "scan",
    },
    cards: [
      { title: "AWS Rekognition Powered", desc: "Enterprise-grade face clustering with 95%+ accuracy for real event photo volumes.", visual: "engine" },
      { title: "Instant Notification", desc: "Trigger web or app alerts when newly matched photos are ready for an attendee.", visual: "notify" },
      { title: "Group Photo Detection", desc: "Make sure group shots and multi-person moments still land in every attendee gallery.", visual: "group" },
      { title: "Privacy-First Approach", desc: "Encrypted facial data, organizer controls, and attendee opt-out settings keep operations compliant.", visual: "shield" },
    ],
  },
  {
    label: "Photo Management",
    hero: {
      title: "Keep photographers, uploads, and album structure organized from one workflow",
      desc: "EventHex gives event teams a single place to bulk ingest, tag, watermark, and structure thousands of files without losing photographer context.",
      visual: "albums",
    },
    cards: [
      { title: "Bulk Upload", desc: "Move thousands of images into the gallery quickly while AI starts indexing in the background.", visual: "upload" },
      { title: "Watermarking", desc: "Auto-apply event branding and sponsor overlays before attendees start downloading.", visual: "watermark" },
      { title: "Contributed Photos (UGC)", desc: "Let attendees add their own images so the gallery reflects the full event energy.", visual: "ugc" },
      { title: "Upload History", desc: "Track who uploaded what, when it processed, and how much content is now live.", visual: "history" },
    ],
  },
  {
    label: "Monetization & Sharing",
    hero: {
      title: "Turn event photos into a branded distribution and monetization channel",
      desc: "Blend sponsor placements, branded frames, and premium download rules into the same gallery attendees already want to browse.",
      visual: "sponsor",
    },
    cards: [
      { title: "Social Sharing Links", desc: "Make it easy for attendees to post matched photos to LinkedIn, Instagram, and X.", visual: "share" },
      { title: "Person-Specific Pages", desc: "Give every attendee a unique page containing the photos the AI found for them.", visual: "person" },
      { title: "Branded Gallery", desc: "Customize gallery colors, framing, and sponsor surfaces to match the event identity.", visual: "brand" },
      { title: "Download Controls", desc: "Set permissions, watermark rules, and resolution access for every gallery experience.", visual: "download" },
    ],
  },
];

const ICON = '<svg class="apgb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="apgb-section" id="gallery-bento">
  <div class="apgb">
    <h2 class="apgb-title">
      AI Face <b>Matching</b>, Photo Management & <b>Sharing</b>
    </h2>
    <p class="apgb-subtitle">
      Match attendees to their photos, keep uploads structured, and turn the gallery into a branded
      distribution channel without leaving the EventHex workflow.
    </p>

    <nav class="apgb-nav">
      {tabs.map((t, i) => (
        <button class={`apgb-tab ${i === 0 ? "apgb-tab--active" : ""}`} data-apgb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`apgb-panel ${tabIdx === 0 ? "apgb-panel--active" : ""}`} data-apgb-panel={String(tabIdx)}>
        <div class="apgb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="apgb-card apgb-card--tall apgb-pos-0" style="animation-delay:0s">
            <div class="apgb-card__inner">
              <div class="apgb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="apgb-card__title">{t.hero.title}</h3>
                <p class="apgb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="apgb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`apgb-card apgb-card--sm apgb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="apgb-card__inner apgb-card__inner--row">
                <div class="apgb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="apgb-card__title">{c.title}</h3>
                  <p class="apgb-card__desc">{c.desc}</p>
                </div>
                <div class="apgb-card__img apgb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const apgbTabs = Array.from(document.querySelectorAll('[data-apgb-tab]'));
  const apgbPanels = Array.from(document.querySelectorAll('[data-apgb-panel]'));
  let apgbActive = 0;
  let apgbInterval: ReturnType<typeof setInterval>;

  function setApgbTab(index: number) {
    apgbTabs.forEach((t) => t.classList.remove('apgb-tab--active'));
    apgbPanels.forEach((p) => p.classList.remove('apgb-panel--active'));
    apgbTabs[index]?.classList.add('apgb-tab--active');
    apgbPanels[index]?.classList.add('apgb-panel--active');
    apgbActive = index;
  }
  function startApgb() {
    apgbInterval = setInterval(() => setApgbTab((apgbActive + 1) % apgbTabs.length), 5000);
  }
  apgbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setApgbTab(i); clearInterval(apgbInterval); startApgb(); }));
  startApgb();
  const apgbSection = document.querySelector('.apgb-section');
  if (apgbSection) {
    apgbSection.addEventListener('mouseenter', () => clearInterval(apgbInterval));
    apgbSection.addEventListener('mouseleave', () => startApgb());
  }
</script>

<style>
  .apgb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .apgb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .apgb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .apgb-title b { font-weight: 700; }
  .apgb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .apgb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .apgb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .apgb-tab:hover { background: rgba(55,93,251,.08); }
  .apgb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .apgb-panel { display: none; }
  .apgb-panel--active { display: block; animation: apgbFadeUp 0.4s ease; }
  @keyframes apgbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .apgb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .apgb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .apgb-pos-1 { grid-column: 2; grid-row: 1; }
  .apgb-pos-2 { grid-column: 3; grid-row: 1; }
  .apgb-pos-3 { grid-column: 2; grid-row: 2; }
  .apgb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .apgb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .apgb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .apgb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .apgb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .apgb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .apgb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .apgb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .apgb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .apgb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .apgb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --apgb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .apgb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: apgbCardIn 0.5s ease forwards;
  }
  .apgb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--apgb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .apgb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .apgb-card:hover::after { opacity: 1; animation: apgbBorder 2.4s linear infinite; }
  @keyframes apgbBorder { to { --apgb-angle: 360deg; } }
  @keyframes apgbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .apgb-pos-1 { animation-delay: 0.06s; }
  .apgb-pos-2 { animation-delay: 0.12s; }
  .apgb-pos-3 { animation-delay: 0.18s; }
  .apgb-pos-4 { animation-delay: 0.24s; }

  .apgb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .apgb-card__inner--row { flex-direction: row; }
  .apgb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .apgb-card--tall .apgb-card__text { padding: 20px 20px 8px; }
  .apgb-card--sm .apgb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .apgb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .apgb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .apgb-card--sm .apgb-card__title { font-size: 17px; }
  .apgb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .apgb-card--sm .apgb-card__desc { font-size: 13px; }

  .apgb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .apgb-card--tall .apgb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .apgb-card--sm .apgb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .apgb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .apgb-card:hover .apgb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: apgbFloat 2.2s ease-in-out infinite;
  }
  @keyframes apgbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .apgb-section { padding: 60px 0 48px; }
    .apgb-title { font-size: 36px; }
    .apgb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .apgb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .apgb-pos-1, .apgb-pos-2, .apgb-pos-3, .apgb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .apgb-pos-0, [data-layout="c"] .apgb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .apgb-pos-1, [data-layout="b"] .apgb-pos-2, [data-layout="b"] .apgb-pos-3, [data-layout="b"] .apgb-pos-4,
    [data-layout="c"] .apgb-pos-1, [data-layout="c"] .apgb-pos-2, [data-layout="c"] .apgb-pos-3, [data-layout="c"] .apgb-pos-4 { grid-column: auto; grid-row: auto; }
    .apgb-card--tall .apgb-card__inner { flex-direction: row; }
    .apgb-card--tall .apgb-card__text { flex: 1; }
    .apgb-card--tall .apgb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .apgb-title { font-size: 28px; }
    .apgb-subtitle { font-size: 15px; }
    .apgb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .apgb-tab { border-radius: 12px; }
    .apgb-grid { grid-template-columns: 1fr; }
    .apgb-pos-0, .apgb-pos-1, .apgb-pos-2, .apgb-pos-3, .apgb-pos-4,
    [data-layout="b"] .apgb-pos-0, [data-layout="b"] .apgb-pos-1, [data-layout="b"] .apgb-pos-2, [data-layout="b"] .apgb-pos-3, [data-layout="b"] .apgb-pos-4,
    [data-layout="c"] .apgb-pos-0, [data-layout="c"] .apgb-pos-1, [data-layout="c"] .apgb-pos-2, [data-layout="c"] .apgb-pos-3, [data-layout="c"] .apgb-pos-4 { grid-column: 1; grid-row: auto; }
    .apgb-card--sm .apgb-card__inner, .apgb-card--tall .apgb-card__inner { flex-direction: row; }
    .apgb-card--sm .apgb-card__text, .apgb-card--tall .apgb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .apgb-card--sm .apgb-card__img, .apgb-card--tall .apgb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .apgb-card { animation: none !important; opacity: 1; transform: none; }
    .apgb-card:hover::after { animation: none !important; }
    .apgb-card:hover .apgb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
