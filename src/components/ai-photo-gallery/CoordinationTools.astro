---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 7a3 3 0 013-3h10a3 3 0 013 3v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7z" stroke="#375DFB" stroke-width="2"/><path d="M8 10h8M8 14h5" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Photographer-ready uploads",
    desc: "Keep pro photographer drops, bulk uploads, and album organization visible from one dashboard while AI handles background indexing.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3" stroke="#375DFB" stroke-width="2"/><path d="M5 20a7 7 0 0114 0" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><path d="M17 10l2 2 3-3" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Attendee delivery that feels instant",
    desc: "Let attendees search with one selfie, receive personal gallery results quickly, and share branded downloads while the event momentum is still high.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v5c0 5-3.5 8.5-7 10-3.5-1.5-7-5-7-10V6l7-3z" stroke="#375DFB" stroke-width="2" stroke-linejoin="round"/><path d="M9.5 12.5l1.8 1.8 3.2-3.6" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Revenue and privacy in one layer",
    desc: "Add sponsor surfaces, branded frames, opt-out controls, and download permissions without splitting monetization from compliance.",
  },
];
---

<section class="apgc-full">
  <div class="apgc-full__inner">
    <div class="apgc-full__header">
      <span class="apgc-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose InstaSnap</span>
      <h2 class="apgc-full__title animate-on-scroll" data-animation="fadeInUp">Effortless Photo <b>Coordination</b></h2>
      <p class="apgc-full__desc animate-on-scroll" data-animation="fadeInUp">Keep gallery operations, attendee delivery, sponsor branding, and privacy controls aligned without adding more tools to the event-day stack.</p>
    </div>

    <div class="apgc-full__cards">
      {cards.map((card) => (
        <div class="apgc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="apgc-full__card-icon" set:html={card.icon}></div>
          <h3 class="apgc-full__card-title">{card.title}</h3>
          <p class="apgc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .apgc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .apgc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .apgc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .apgc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .apgc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .apgc-full__title b { font-weight: 700; }

  .apgc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .apgc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .apgc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .apgc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .apgc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .apgc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .apgc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .apgc-full { padding: 64px 0; }
    .apgc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .apgc-full { padding: 52px 0; }
    .apgc-full__title { font-size: 30px; line-height: 1.15; }
    .apgc-full__desc { font-size: 15px; }
    .apgc-full__cards { grid-template-columns: 1fr; }
  }
</style>