---
const steps = [
  {
    num: "01",
    title: "Upload Photos",
    desc: "Photographers bulk upload event photos. AI automatically clusters faces and indexes every image.",
  },
  {
    num: "02",
    title: "Take a Selfie",
    desc: "Attendees open the gallery on their phone, snap a quick selfie, and start the search instantly.",
  },
  {
    num: "03",
    title: "AI Matches Instantly",
    desc: "AWS Rekognition compares the selfie against the full gallery and returns likely matches in seconds.",
  },
  {
    num: "04",
    title: "Share and Download",
    desc: "Attendees view, save, and share their matched photos through the branded event gallery experience.",
  },
];
---

<section class="apghw-full">
  <div class="apghw-full__inner">
    <div class="apghw-full__header">
      <span class="apghw-full__tag animate-on-scroll" data-animation="fadeIn">How InstaSnap Works</span>
      <h2 class="apghw-full__title animate-on-scroll" data-animation="fadeInUp">From Upload to <b>Face-Matched Delivery</b></h2>
      <p class="apghw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Keep photographers, attendees, and sponsor-ready sharing connected in one flow that feels fast for attendees and controlled for event teams.
      </p>
    </div>

    <div class="apghw-full__cards">
      {steps.map((step) => (
        <article class="apghw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="apghw-full__card-icon">{step.num}</div>
          <h3 class="apghw-full__card-title">{step.title}</h3>
          <p class="apghw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .apghw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .apghw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .apghw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .apghw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .apghw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .apghw-full__title b { font-weight: 700; }

  .apghw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .apghw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .apghw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .apghw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .apghw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .apghw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .apghw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .apghw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .apghw-full { padding: 64px 0; }
    .apghw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .apghw-full { padding: 52px 0; }
    .apghw-full__title { font-size: 30px; line-height: 1.15; }
    .apghw-full__desc { font-size: 15px; }
    .apghw-full__cards { grid-template-columns: 1fr; }
  }
</style>