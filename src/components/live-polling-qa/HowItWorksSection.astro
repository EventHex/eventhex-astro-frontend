---
const steps = [
  {
    num: "01",
    title: "Create Polls & Q&A Sessions",
    desc: "Set up multiple-choice polls, word clouds, and Q&A sessions for each segment of your event program.",
  },
  {
    num: "02",
    title: "Share Access Link",
    desc: "Attendees join via a simple URL, QR code, or the event app — no download or signup required.",
  },
  {
    num: "03",
    title: "Engage Live",
    desc: "Launch polls during sessions, collect Q&A questions with upvoting, and display results on venue screens in real time.",
  },
  {
    num: "04",
    title: "Analyze & Report",
    desc: "Export all responses, generate speaker feedback reports, and track engagement metrics across your event.",
  },
];
---

<section class="lpqhw-full">
  <div class="lpqhw-full__inner">
    <div class="lpqhw-full__header">
      <span class="lpqhw-full__tag animate-on-scroll" data-animation="fadeIn">How Live Polling & Q&A Works</span>
      <h2 class="lpqhw-full__title animate-on-scroll" data-animation="fadeInUp">From Setup to <b>Live Engagement</b></h2>
      <p class="lpqhw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Create polls and Q&A sessions, share the access link, engage during sessions, and export all data for reports.
      </p>
    </div>

    <div class="lpqhw-full__cards">
      {steps.map((step) => (
        <article class="lpqhw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="lpqhw-full__card-icon">{step.num}</div>
          <h3 class="lpqhw-full__card-title">{step.title}</h3>
          <p class="lpqhw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .lpqhw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .lpqhw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .lpqhw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .lpqhw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .lpqhw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .lpqhw-full__title b { font-weight: 700; }

  .lpqhw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .lpqhw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .lpqhw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .lpqhw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .lpqhw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .lpqhw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .lpqhw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .lpqhw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .lpqhw-full { padding: 64px 0; }
    .lpqhw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .lpqhw-full { padding: 52px 0; }
    .lpqhw-full__title { font-size: 30px; line-height: 1.15; }
    .lpqhw-full__desc { font-size: 15px; }
    .lpqhw-full__cards { grid-template-columns: 1fr; }
  }
</style>
