---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "How do attendees participate in live polls?", a: "Attendees participate via any web browser on their phone, tablet, or laptop. They access polls through a URL, QR code, or the event app — no download required. Responses appear on venue screens in under 2 seconds." },
  { q: "Can I moderate Q&A questions?", a: "Yes. All questions go through a moderation queue before appearing publicly. Moderators can approve, reject, or star questions. Attendees can also upvote questions, surfacing the most popular ones." },
  { q: "Can results be displayed on venue screens?", a: "Yes. The stage display mode is designed for projectors and LED screens. Poll results animate in real-time — bar charts race, word clouds grow — creating energy and engagement in the room." },
  { q: "Can I collect feedback per session?", a: "Yes. Feedback forms can auto-trigger at the end of each session. Collect star ratings, NPS scores, and open-text comments. Speaker feedback reports are generated automatically." },
  { q: "What poll types are supported?", a: "Multiple-choice, rating scales (1-5/1-10), word clouds, open text, and ranked-choice polls. Pre-built templates are available for common use cases like icebreakers and session feedback." },
  { q: "Can Q&A be anonymous?", a: "Yes. You can enable anonymous mode for any Q&A session — encouraging honest questions and feedback. Moderators still see all submissions in the admin panel." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with live polling?"
  title="Frequently Asked Questions"
  description="We help event teams set up live polls, Q&A moderation, and feedback collection for engaging sessions."
/>
