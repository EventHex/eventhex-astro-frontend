---
---

<section class="lpqcta">
  <div class="lpqcta__card">
    <div class="lpqcta__glow lpqcta__glow--1"></div>
    <div class="lpqcta__glow lpqcta__glow--2"></div>
    <div class="lpqcta__content">
      <span class="lpqcta__eyebrow animate-on-scroll" data-animation="fadeIn">Engage Your Audience</span>
      <h2 class="lpqcta__title animate-on-scroll" data-animation="fadeInUp">Ready to Transform Passive Attendees Into Active Participants?</h2>
      <p class="lpqcta__desc animate-on-scroll" data-animation="fadeInUp">See how live polls and moderated Q&A create real-time engagement at every session.</p>
      <div class="lpqcta__proof-row animate-on-scroll" data-animation="fadeInUp">
        <span class="lpqcta__proof-pill">Live venue display</span>
        <span class="lpqcta__proof-pill">Moderated Q&A</span>
        <span class="lpqcta__proof-pill">Free onboarding support</span>
      </div>
      <div class="lpqcta__buttons">
        <a href="/book-a-demo/" class="lpqcta__btn lpqcta__btn--primary">
          Book a Free Demo
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/contact-en/" class="lpqcta__btn lpqcta__btn--secondary">Contact Sales</a>
      </div>
      <div class="lpqcta__trust">
        <span class="lpqcta__trust-item">No credit card required</span>
        <span class="lpqcta__trust-item">Free onboarding support</span>
        <span class="lpqcta__trust-item">Cancel anytime</span>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .lpqcta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }

  .lpqcta__card {
    position: relative;
    border-radius: 24px;
    padding: 80px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow: hidden;
    background: #0F1629;
  }

  .lpqcta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .lpqcta__glow--1 {
    width: 400px;
    height: 400px;
    background: rgba(55, 93, 251, 0.2);
    top: -100px;
    left: -50px;
  }

  .lpqcta__glow--2 {
    width: 300px;
    height: 300px;
    background: rgba(159, 129, 255, 0.15);
    bottom: -80px;
    right: -30px;
  }

  .lpqcta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 600px;
  }

  .lpqcta__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .lpqcta__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .lpqcta__desc {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.3px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .lpqcta__proof-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .lpqcta__proof-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: rgba(255, 255, 255, 0.74);
  }

  .lpqcta__buttons { display: flex; gap: 12px; justify-content: center; }

  .lpqcta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.3px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .lpqcta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.35);
  }

  .lpqcta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(55, 93, 251, 0.4);
  }

  .lpqcta__btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .lpqcta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .lpqcta__trust {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-top: 8px;
  }

  .lpqcta__trust-item {
    position: relative;
    padding-left: 14px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
  }

  .lpqcta__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
  }

  @media (max-width: 1024px) {
    .lpqcta__card { padding: 60px 24px; }
    .lpqcta__title { font-size: 36px; }
    .lpqcta__desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .lpqcta { padding: 40px 16px 60px; }
    .lpqcta__card { padding: 48px 20px; border-radius: 20px; }
    .lpqcta__title { font-size: 28px; line-height: 1.2em; }
    .lpqcta__desc { font-size: 15px; }
    .lpqcta__proof-row { gap: 8px; }
    .lpqcta__buttons { flex-direction: column; width: 100%; }
    .lpqcta__btn { width: 100%; justify-content: center; }
    .lpqcta__trust { flex-direction: column; gap: 8px; }
  }
</style>
