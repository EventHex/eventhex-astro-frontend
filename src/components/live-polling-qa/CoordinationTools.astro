---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M7 17v-4M11 17v-7M15 17v-5M19 17v-9" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Live polls and word clouds",
    desc: "Multiple-choice, rating, and word cloud polls with real-time venue display.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="#375DFB" stroke-width="2"/><path d="M9 12l2 2 4-4" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Moderated Q&A with upvoting",
    desc: "Upvoted questions with moderator approval and dedicated speaker view.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.5 5.5H20l-4.5 3.5L17 17l-5-3.5L7 17l1.5-6L4 7.5h5.5L12 2z" stroke="#375DFB" stroke-width="2" stroke-linejoin="round"/><path d="M8 20h8M10 22h4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/></svg>`,
    title: "Session feedback and NPS",
    desc: "Instant ratings, NPS surveys, and auto-generated speaker reports.",
  },
];
---

<section class="lpqc-full">
  <div class="lpqc-full__inner">
    <div class="lpqc-full__header">
      <span class="lpqc-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Polling & Q&A</span>
      <h2 class="lpqc-full__title animate-on-scroll" data-animation="fadeInUp">Real-Time Audience <b>Engagement</b></h2>
      <p class="lpqc-full__desc animate-on-scroll" data-animation="fadeInUp">Run live polls, moderate Q&A, collect feedback, and display results on venue screens from one platform.</p>
    </div>

    <div class="lpqc-full__cards">
      {cards.map((card) => (
        <div class="lpqc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="lpqc-full__card-icon" set:html={card.icon}></div>
          <h3 class="lpqc-full__card-title">{card.title}</h3>
          <p class="lpqc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .lpqc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://cms.eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .lpqc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .lpqc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .lpqc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .lpqc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .lpqc-full__title b { font-weight: 700; }

  .lpqc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .lpqc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .lpqc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .lpqc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .lpqc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .lpqc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .lpqc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .lpqc-full { padding: 64px 0; }
    .lpqc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .lpqc-full { padding: 52px 0; }
    .lpqc-full__title { font-size: 30px; line-height: 1.15; }
    .lpqc-full__desc { font-size: 15px; }
    .lpqc-full__cards { grid-template-columns: 1fr; }
  }
</style>
