---
const tabs = [
  {
    label: "Live Polls",
    hero: {
      eyebrow: "Poll Engine",
      title: "Multiple-choice polls, word clouds, and timed questions with live venue display",
      desc: "Create polls in seconds and display results on venue screens as votes pour in. Bar charts race, word clouds grow — creating energy in the room.",
      points: ["Multiple-choice and rating polls", "Real-time word clouds", "Live venue screen display"],
      visual: "polls",
    },
    cards: [
      {
        eyebrow: "Words",
        title: "Word Clouds",
        desc: "Generate real-time word clouds from attendee responses.",
        visual: "wordcloud",
      },
      {
        eyebrow: "Timer",
        title: "Timed Polls",
        desc: "Set countdown timers for urgency and focused engagement.",
        visual: "timedpoll",
      },
      {
        eyebrow: "Charts",
        title: "Live Bar Charts",
        desc: "Results animate in real-time on venue screens as votes come in.",
        visual: "livechart",
      },
      {
        eyebrow: "Templates",
        title: "Pre-Built Templates",
        desc: "Poll templates for icebreakers, feedback, and session topics.",
        visual: "polltpl",
      },
    ],
  },
  {
    label: "Q&A System",
    hero: {
      eyebrow: "Q&A Engine",
      title: "Attendee questions with upvoting, moderation queue, and speaker view",
      desc: "Attendees submit questions from any device, others upvote the best ones. Moderators filter and approve before they go live.",
      points: ["Upvoted question ranking", "Moderator approval queue", "Dedicated speaker view"],
      visual: "qa",
    },
    cards: [
      {
        eyebrow: "Voting",
        title: "Upvoting",
        desc: "Attendees upvote the best questions — popular ones rise to the top.",
        visual: "upvote",
      },
      {
        eyebrow: "Moderate",
        title: "Moderation Queue",
        desc: "Moderators review and approve questions before they go live.",
        visual: "modqueue",
      },
      {
        eyebrow: "Speaker",
        title: "Speaker View",
        desc: "Dedicated speaker view showing approved questions in order.",
        visual: "speakerview",
      },
      {
        eyebrow: "Anon",
        title: "Anonymous Mode",
        desc: "Allow anonymous questions to encourage honest participation.",
        visual: "anonmode",
      },
    ],
  },
  {
    label: "Feedback & Analytics",
    hero: {
      eyebrow: "Feedback Engine",
      title: "Session ratings, NPS surveys, and response analytics with export",
      desc: "Collect real-time feedback at session end — star ratings, NPS scores, and comments. Export all data and auto-generate speaker reports.",
      points: ["Session-end feedback forms", "NPS survey support", "Auto speaker reports"],
      visual: "feedback",
    },
    cards: [
      {
        eyebrow: "NPS",
        title: "NPS Surveys",
        desc: "Run Net Promoter Score surveys during or after the event.",
        visual: "nps",
      },
      {
        eyebrow: "Charts",
        title: "Response Analytics",
        desc: "Detailed charts and insights for every poll and Q&A session.",
        visual: "analytics",
      },
      {
        eyebrow: "Export",
        title: "Export Data",
        desc: "Export all poll results, Q&A logs, and feedback data as CSV or PDF.",
        visual: "export",
      },
      {
        eyebrow: "Reports",
        title: "Speaker Reports",
        desc: "Auto-generated speaker feedback reports with audience ratings.",
        visual: "speakerreport",
      },
    ],
  },
];
---

<section class="lpqb-section" id="lpq-bento">
  <div class="lpqb-shell">
    <h2 class="lpqb-title">
      Live <b>Polls</b>, Moderated <b>Q&A</b> & <b>Feedback</b>
    </h2>
    <p class="lpqb-subtitle">
      Create polls, moderate questions, collect feedback, and display results in real time.
    </p>

    <nav class="lpqb-nav" aria-label="Live polling and Q&A workflows">
      {tabs.map((tab, index) => (
        <button
          class={`lpqb-tab${index === 0 ? " lpqb-tab--active" : ""}`}
          data-lpqb-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`lpqb-panel${tabIndex === 0 ? " lpqb-panel--active" : ""}`}
        data-lpqb-panel={tabIndex}
      >
        <div class="lpqb-grid">
          <article class="lpqb-card lpqb-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="lpqb-card__content">
              <span class="lpqb-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="lpqb-card__title">{tab.hero.title}</h3>
              <p class="lpqb-card__desc">{tab.hero.desc}</p>

              <ul class="lpqb-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`lpqb-art lpqb-art--hero lpqb-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "polls" && (
                <Fragment>
                  <div class="lpqb-poll-bars">
                    <div class="lpqb-poll-option">
                      <span class="lpqb-poll-label"></span>
                      <div class="lpqb-poll-track"><span class="lpqb-poll-fill" style="--w:78%"></span></div>
                      <span class="lpqb-poll-pct">78%</span>
                    </div>
                    <div class="lpqb-poll-option">
                      <span class="lpqb-poll-label"></span>
                      <div class="lpqb-poll-track"><span class="lpqb-poll-fill" style="--w:55%"></span></div>
                      <span class="lpqb-poll-pct">55%</span>
                    </div>
                    <div class="lpqb-poll-option">
                      <span class="lpqb-poll-label"></span>
                      <div class="lpqb-poll-track"><span class="lpqb-poll-fill" style="--w:34%"></span></div>
                      <span class="lpqb-poll-pct">34%</span>
                    </div>
                    <div class="lpqb-poll-option">
                      <span class="lpqb-poll-label"></span>
                      <div class="lpqb-poll-track"><span class="lpqb-poll-fill" style="--w:12%"></span></div>
                      <span class="lpqb-poll-pct">12%</span>
                    </div>
                  </div>
                  <div class="lpqb-vote-counter">
                    <strong>1,247</strong>
                    <span>votes</span>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "qa" && (
                <Fragment>
                  <div class="lpqb-qa-phone">
                    <div class="lpqb-qa-notch"></div>
                    <div class="lpqb-qa-screen">
                      <div class="lpqb-qa-bubble lpqb-qa-bubble--top">
                        <span class="lpqb-qa-bubble-text"></span>
                        <span class="lpqb-qa-upvote">&#9650; 24</span>
                      </div>
                      <div class="lpqb-qa-bubble">
                        <span class="lpqb-qa-bubble-text"></span>
                        <span class="lpqb-qa-upvote">&#9650; 18</span>
                      </div>
                      <div class="lpqb-qa-bubble">
                        <span class="lpqb-qa-bubble-text"></span>
                        <span class="lpqb-qa-upvote">&#9650; 9</span>
                      </div>
                    </div>
                    <div class="lpqb-qa-input"></div>
                  </div>
                  <div class="lpqb-qa-badge">Live Q&A</div>
                </Fragment>
              )}

              {tab.hero.visual === "feedback" && (
                <Fragment>
                  <div class="lpqb-fb-card">
                    <div class="lpqb-fb-stars">
                      <span class="lpqb-fb-star lpqb-fb-star--filled">&#9733;</span>
                      <span class="lpqb-fb-star lpqb-fb-star--filled">&#9733;</span>
                      <span class="lpqb-fb-star lpqb-fb-star--filled">&#9733;</span>
                      <span class="lpqb-fb-star lpqb-fb-star--filled">&#9733;</span>
                      <span class="lpqb-fb-star">&#9733;</span>
                    </div>
                    <div class="lpqb-fb-comment">
                      <span></span>
                      <span></span>
                    </div>
                    <div class="lpqb-fb-submit"></div>
                  </div>
                  <div class="lpqb-fb-nps">
                    <div class="lpqb-fb-nps-bar">
                      <span class="lpqb-fb-nps-zone lpqb-fb-nps-zone--red"></span>
                      <span class="lpqb-fb-nps-zone lpqb-fb-nps-zone--yellow"></span>
                      <span class="lpqb-fb-nps-zone lpqb-fb-nps-zone--green"></span>
                    </div>
                    <span class="lpqb-fb-nps-label">NPS: 72</span>
                  </div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="lpqb-card lpqb-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="lpqb-card__content">
                <span class="lpqb-card__eyebrow">{card.eyebrow}</span>
                <h3 class="lpqb-card__title">{card.title}</h3>
                <p class="lpqb-card__desc">{card.desc}</p>
              </div>

              <div class={`lpqb-art lpqb-art--mini lpqb-art--${card.visual}`} aria-hidden="true">
                {card.visual === "wordcloud" && (
                  <Fragment>
                    <div class="lpqb-wc-words">
                      <span class="lpqb-wc-word" style="--s:1.6;--x:-20%;--y:-10%">Innovation</span>
                      <span class="lpqb-wc-word" style="--s:1.1;--x:15%;--y:20%">AI</span>
                      <span class="lpqb-wc-word" style="--s:0.8;--x:-30%;--y:30%">Future</span>
                      <span class="lpqb-wc-word" style="--s:1.3;--x:25%;--y:-20%">Growth</span>
                      <span class="lpqb-wc-word" style="--s:0.9;--x:0%;--y:10%">Data</span>
                    </div>
                    <div class="lpqb-mini-chip">Word cloud</div>
                  </Fragment>
                )}

                {card.visual === "timedpoll" && (
                  <Fragment>
                    <div class="lpqb-timer">
                      <svg viewBox="0 0 60 60" class="lpqb-timer-svg">
                        <circle cx="30" cy="30" r="26" fill="none" stroke="rgba(55,93,251,0.1)" stroke-width="5"/>
                        <circle cx="30" cy="30" r="26" fill="none" stroke="#375dfb" stroke-width="5" stroke-dasharray="163" stroke-dashoffset="41" stroke-linecap="round" transform="rotate(-90 30 30)" class="lpqb-timer-arc"/>
                      </svg>
                      <span class="lpqb-timer-num">0:15</span>
                    </div>
                    <div class="lpqb-timer-opts">
                      <span class="lpqb-timer-opt"></span>
                      <span class="lpqb-timer-opt"></span>
                    </div>
                    <div class="lpqb-mini-chip">Timed poll</div>
                  </Fragment>
                )}

                {card.visual === "livechart" && (
                  <Fragment>
                    <div class="lpqb-hbars">
                      <div class="lpqb-hbar"><span style="--w:85%"></span></div>
                      <div class="lpqb-hbar"><span style="--w:62%"></span></div>
                      <div class="lpqb-hbar"><span style="--w:45%"></span></div>
                      <div class="lpqb-hbar"><span style="--w:28%"></span></div>
                    </div>
                    <div class="lpqb-mini-chip">Live results</div>
                  </Fragment>
                )}

                {card.visual === "polltpl" && (
                  <Fragment>
                    <div class="lpqb-tpl-grid">
                      <div class="lpqb-tpl-card"><span></span><span></span></div>
                      <div class="lpqb-tpl-card"><span></span><span></span></div>
                      <div class="lpqb-tpl-card"><span></span><span></span></div>
                      <div class="lpqb-tpl-card"><span></span><span></span></div>
                    </div>
                    <div class="lpqb-mini-chip">4 templates</div>
                  </Fragment>
                )}

                {card.visual === "upvote" && (
                  <Fragment>
                    <div class="lpqb-uv-cards">
                      <div class="lpqb-uv-card">
                        <span class="lpqb-uv-text"></span>
                        <span class="lpqb-uv-badge">&#9650; 24</span>
                      </div>
                      <div class="lpqb-uv-card">
                        <span class="lpqb-uv-text"></span>
                        <span class="lpqb-uv-badge">&#9650; 18</span>
                      </div>
                    </div>
                    <div class="lpqb-mini-chip">Top voted</div>
                  </Fragment>
                )}

                {card.visual === "modqueue" && (
                  <Fragment>
                    <div class="lpqb-mod-panel">
                      <div class="lpqb-mod-row">
                        <span class="lpqb-mod-text"></span>
                        <span class="lpqb-mod-btn lpqb-mod-btn--approve">&#10003;</span>
                        <span class="lpqb-mod-btn lpqb-mod-btn--reject">&#10005;</span>
                      </div>
                      <div class="lpqb-mod-row">
                        <span class="lpqb-mod-text"></span>
                        <span class="lpqb-mod-btn lpqb-mod-btn--approve">&#10003;</span>
                        <span class="lpqb-mod-btn lpqb-mod-btn--reject">&#10005;</span>
                      </div>
                    </div>
                    <div class="lpqb-mini-chip">Moderation</div>
                  </Fragment>
                )}

                {card.visual === "speakerview" && (
                  <Fragment>
                    <div class="lpqb-sv-panel">
                      <div class="lpqb-sv-head"></div>
                      <div class="lpqb-sv-q lpqb-sv-q--active">
                        <span class="lpqb-sv-dot"></span>
                        <span class="lpqb-sv-text"></span>
                      </div>
                      <div class="lpqb-sv-q">
                        <span class="lpqb-sv-dot"></span>
                        <span class="lpqb-sv-text"></span>
                      </div>
                    </div>
                    <div class="lpqb-mini-chip">Speaker view</div>
                  </Fragment>
                )}

                {card.visual === "anonmode" && (
                  <Fragment>
                    <div class="lpqb-anon">
                      <div class="lpqb-anon-avatar">
                        <span class="lpqb-anon-icon">?</span>
                      </div>
                      <div class="lpqb-anon-lock">&#128274;</div>
                    </div>
                    <div class="lpqb-mini-chip">Anonymous</div>
                  </Fragment>
                )}

                {card.visual === "nps" && (
                  <Fragment>
                    <div class="lpqb-nps-scale">
                      <div class="lpqb-nps-bar">
                        <span class="lpqb-nps-zone lpqb-nps-zone--red"></span>
                        <span class="lpqb-nps-zone lpqb-nps-zone--yellow"></span>
                        <span class="lpqb-nps-zone lpqb-nps-zone--green"></span>
                      </div>
                      <div class="lpqb-nps-pointer"></div>
                      <span class="lpqb-nps-score">72</span>
                    </div>
                    <div class="lpqb-mini-chip">NPS score</div>
                  </Fragment>
                )}

                {card.visual === "analytics" && (
                  <Fragment>
                    <div class="lpqb-an-bars">
                      <span style="--h:50%"></span>
                      <span style="--h:75%"></span>
                      <span style="--h:40%"></span>
                      <span style="--h:90%"></span>
                      <span style="--h:60%"></span>
                    </div>
                    <div class="lpqb-mini-chip">Analytics</div>
                  </Fragment>
                )}

                {card.visual === "export" && (
                  <Fragment>
                    <div class="lpqb-exp-dialog">
                      <div class="lpqb-exp-head"></div>
                      <div class="lpqb-exp-btns">
                        <span class="lpqb-exp-btn">CSV</span>
                        <span class="lpqb-exp-btn">PDF</span>
                      </div>
                    </div>
                    <div class="lpqb-mini-chip">Export</div>
                  </Fragment>
                )}

                {card.visual === "speakerreport" && (
                  <Fragment>
                    <div class="lpqb-sr-card">
                      <div class="lpqb-sr-avatar"></div>
                      <div class="lpqb-sr-info">
                        <span class="lpqb-sr-name"></span>
                        <div class="lpqb-sr-stars">
                          <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span class="lpqb-sr-star-dim">&#9733;</span>
                        </div>
                        <span class="lpqb-sr-score">4.2 / 5</span>
                      </div>
                    </div>
                    <div class="lpqb-mini-chip">Speaker report</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".lpqb-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".lpqb-tab"));
      const panels = Array.from(root.querySelectorAll(".lpqb-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("lpqb-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("lpqb-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .lpqb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .lpqb-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .lpqb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .lpqb-title b { font-weight: 700; }

  .lpqb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .lpqb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .lpqb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .lpqb-tab:hover,
  .lpqb-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .lpqb-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .lpqb-panel { display: none; }
  .lpqb-panel--active { display: block; }

  .lpqb-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .lpqb-panel--active .lpqb-card {
    animation: lpqb-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  .lpqb-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .lpqb-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .lpqb-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .lpqb-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .lpqb-card--mini:nth-of-type(2) { grid-area: mini1; }
  .lpqb-card--mini:nth-of-type(3) { grid-area: mini2; }
  .lpqb-card--mini:nth-of-type(4) { grid-area: mini3; }
  .lpqb-card--mini:nth-of-type(5) { grid-area: mini4; }

  .lpqb-card__content { position: relative; z-index: 1; }

  .lpqb-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lpqb-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .lpqb-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .lpqb-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .lpqb-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .lpqb-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .lpqb-art { position: relative; z-index: 1; min-height: 146px; }
  .lpqb-art--hero { min-height: 228px; margin-top: 0.6rem; }
  .lpqb-art--mini { align-self: end; }

  /* === Hero visual: polls === */
  .lpqb-poll-bars {
    position: absolute;
    inset: 0 0 2.4rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0.8rem;
    border-radius: 1.3rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
  }

  .lpqb-poll-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .lpqb-poll-label {
    width: 2rem;
    height: 0.4rem;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.08);
    flex-shrink: 0;
  }

  .lpqb-poll-track {
    flex: 1;
    height: 1.2rem;
    border-radius: 0.6rem;
    background: rgba(55, 93, 251, 0.06);
    overflow: hidden;
  }

  .lpqb-poll-fill {
    display: block;
    height: 100%;
    width: var(--w, 50%);
    border-radius: 0.6rem;
    background: linear-gradient(90deg, #375dfb, #38bdf8);
    animation: lpqb-bar-race 3s ease-in-out infinite alternate;
  }

