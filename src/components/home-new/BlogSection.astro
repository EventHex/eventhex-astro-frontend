---
// Source: Elementor Container ddefb0d (depth 0)
// Background: Untitled-design-11.webp, boxed 1140px, padding 60px 0
// Children:
//   a557308: button "Explore More" — hidden on all breakpoints
//   dfd01e5: heading "Your Countless Events Begin Here" — Manrope 48px/500, 50% width
//   9ca0129: loop-carousel — template 1267, 15px gap, dots #375DFB

// Fetch blog posts from WP API
interface WPPost {
  id: number;
  title: { rendered: string };
  excerpt: { rendered: string };
  link: string;
  date: string;
  _embedded?: {
    'wp:featuredmedia'?: Array<{ source_url: string; alt_text: string }>;
  };
}

const WP_URL = import.meta.env.WP_URL || 'https://eventhex.ai';
let posts: WPPost[] = [];
try {
  const res = await fetch(`${WP_URL}/wp-json/wp/v2/posts?per_page=6&_embed`);
  if (res.ok) posts = await res.json();
} catch {}
---

<section class="blog-section">
  <h3 class="blog-title">Your Countless Events Begin Here</h3>

  <div class="blog-carousel">
    {posts.map((post) => {
      const img = post._embedded?.['wp:featuredmedia']?.[0];
      const excerpt = post.excerpt.rendered.replace(/<[^>]+>/g, '').slice(0, 120);
      return (
        <a href={post.link} class="blog-card" target="_blank" rel="noopener">
          {img && (
            <div class="blog-card__img">
              <img src={img.source_url} alt={img.alt_text || post.title.rendered} loading="lazy" />
            </div>
          )}
          <div class="blog-card__body">
            <h4 class="blog-card__title" set:html={post.title.rendered} />
            <p class="blog-card__excerpt">{excerpt}...</p>
          </div>
        </a>
      );
    })}
  </div>
</section>

<style>
  .blog-section {
    max-width: 1140px;
    margin: 0 auto;
    padding: 60px 0;
    background: url('https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11.webp') center center / cover no-repeat;
  }
  .blog-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 50px;
    letter-spacing: -1px;
    color: #000;
    margin: 0 0 40px;
    max-width: 50%;
  }
  .blog-carousel {
    display: flex;
    gap: 15px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 10px;
  }
  .blog-carousel::-webkit-scrollbar { display: none; }
  .blog-card {
    flex: 0 0 calc(33.333% - 10px);
    scroll-snap-align: start;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s, box-shadow 0.3s;
    border: 1px solid #E8ECF2;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,.08);
  }
  .blog-card__img {
    height: 180px;
    overflow: hidden;
  }
  .blog-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-card__body {
    padding: 16px 20px;
  }
  .blog-card__title {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    color: var(--heading-dark);
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .blog-card__excerpt {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: var(--body-gray);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .blog-section { padding: 50px 20px; }
    .blog-title { font-size: 40px; line-height: 1.1em; }
    .blog-card { flex: 0 0 calc(50% - 8px); }
  }
  @media (max-width: 767px) {
    .blog-section { padding: 40px 16px; }
    .blog-title { font-size: 30px; line-height: 1.2em; max-width: 100%; letter-spacing: 0; }
    .blog-card { flex: 0 0 85%; }
  }
</style>
