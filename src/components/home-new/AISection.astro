  },
  {
    title: "InstaSnap AI",
    desc: "EventHex's photo-distributing system that helps attendees find, edit, and share their photos by just uploading a selfie",
    image: "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png",
  },
  {
    title: "AI Bot",
    desc: "Customizable AI bot designed to help attendees navigate through the event details and interactively respond to their queries",
