<section class="ai-section-shell">
  <div class="ai-section">
    <!-- Header area (b4813e6) -->
    <div class="ai-header">
      <h3 class="ai-subtitle">Harness the power of AI to revolutionize your events</h3>
      <h2 class="ai-title">
        Simply The Best <span class="ai-title-highlight">AI-Powered</span><br/>Event Management Software
      </h2>
    </div>

    <!-- Stacking Cards (bb3f883) — GSAP ScrollTrigger sticky cards -->
    <div class="stacking-cards" id="ai-stacking-cards">
      {aiCards.map((card, i) => (
        <div
          class="stacking-card"
          data-card-index={i}
          style={`--card-index: ${i}; top: calc(20px + ${i * 20}px);`}
        >
          <div class="card-content">
            <h3 class="card-title">{card.title}</h3>
            <p class="card-desc">{card.desc}</p>
            <a href="/book-a-demo/" class="card-btn">Explore More</a>
          </div>
          <div class="card-image">
            <img src={card.image} alt={card.title} loading="lazy" />
          </div>
        </div>
      ))}
    </div>

    <!-- Rifath testimonial (fde1553) -->
    <div class="testimonial-rifath">
      <p class="rifath-quote rifath-quote--desktop animate-on-scroll" data-animation="fadeInLeft">
