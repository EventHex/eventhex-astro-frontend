            </svg>
          </a>
        </div>
        <div class="footer-columns">
          {footerColumns.map((col) => (
            <nav class="footer-col" aria-label="Footer navigation">
              {col.links.map((link) => (
                <a href={link.url} class="footer-link">{link.title}</a>
              ))}
            </nav>
          ))}
        </div>
      </div>

      <!-- Divider -->
      <hr class="footer-divider" />

      <!-- Bottom: Copyright + Social -->
      <div class="footer-row-bottom">
        <div class="footer-copyright">
          <p>EventHex&copy; {currentYear} All rights reserved</p>
        </div>
        <div class="footer-social">
          <a href="https://x.com/EventhexAi" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Twitter/X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a href="https://linkedin.com/company/eventhex" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zM.02 24h4.97V8H.02v16zM7.99 8H12.7v2.2h.07C13.4 8.84 15.32 7.5 18.23 7.5 23.02 7.5 24 10.64 24 14.72V24h-5V15.55c0-2.01-.04-4.59-2.8-4.59-2.8 0-3.23 2.18-3.23 4.44V24H8V8z" />
            </svg>
          </a>
          <a href="https://www.instagram.com/eventhex.ai/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
  }

  /* CTA Banner: f44f575 → 3218551 */
  .footer-cta-wrapper {
    max-width: 1140px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .footer-cta-banner {
    display: flex;
    flex-direction: row;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2025/01/Mask-group-43.png') center center / cover no-repeat;
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 30px;
    overflow: hidden;
    position: relative;
  }
  .footer-cta-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/01/Vector-20.png') center center / cover no-repeat;
    pointer-events: none;
  }
  .footer-cta-content {
    flex: 1;
    min-height: 400px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 50px 40px 50px 50px;
    position: relative;
    z-index: 1;
  }
  .footer-cta-spacer {
    flex: 0 0 40%;
  }
  .footer-cta-title {
    font-family: 'Manrope', var(--font-heading);
    font-size: 42px;
    font-weight: 500;
    line-height: 50px;
    letter-spacing: -1px;
    color: #fff;
    margin: 0 0 30px 0;
    max-width: 82%;
    white-space: pre-line;
  }
  .footer-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', var(--font-body);
    font-size: 16px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    background: linear-gradient(90deg, #0011C7 32%, #8399FF 100%);
    padding: 10px 30px;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.3s;
    width: fit-content;
  }
  .footer-cta-button:hover {
    transform: scale(1.05);
  }

  /* Main Footer */
  .footer-main {
    background: #000;
  }
  .footer-main--with-cta {
    margin-top: -200px;
    padding: 260px 0 60px 0;
  }
  .footer-main--plain {
    margin-top: 0;
    padding: 80px 0 60px;
  }
  .footer-main-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 60px;
  }

  /* Top: Logo left + 3 link columns right */
  .footer-row-top {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 60px;
    padding-bottom: 80px;
  }
  .footer-brand {
    flex: 0 0 auto;
    padding-top: 4px;
  }
  .footer-logo {
    height: auto;
    max-width: 200px;
  }
  .footer-columns {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    gap: 80px;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .footer-link {
    font-family: 'Inter', var(--font-body);
    font-size: 15px;
    font-weight: 400;
    color: #9CA3AF;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .footer-link:hover {
    color: #fff;
  }

  /* Divider */
  .footer-divider {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    margin: 0 0 30px 0;
  }

  /* Bottom: Copyright + Social */
  .footer-row-bottom {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
  .footer-copyright {
    flex: 1;
  }
  .footer-copyright p {
    font-family: 'Inter', var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: #6B7280;
    margin: 0;
  }
  .footer-social {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .social-icon {
    color: #6B7280;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid #374151;
    border-radius: 50%;
    transition: color 0.2s, border-color 0.2s;
  }
  .social-icon:hover {
    color: #fff;
    border-color: #6B7280;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .footer-cta-wrapper { padding: 0 20px; }
    .footer-main--with-cta { padding: 220px 20px 60px 20px; margin-top: -160px; }
    .footer-main--plain { padding: 60px 20px; }
    .footer-main-inner { padding: 0 30px; }
    .footer-cta-content { padding: 30px; }
    .footer-cta-title { font-size: 32px; line-height: 1.2; }
    .footer-cta-spacer { flex: 0 0 30%; }
    .footer-columns { gap: 40px; }
    .footer-row-top { gap: 40px; }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .footer-main--with-cta { margin-top: -90px; padding: 150px 20px 60px 20px; }
    .footer-main--plain { padding: 50px 20px 60px; }
    .footer-main-inner { padding: 0 20px; }
    .footer-cta-content { min-height: 250px; padding: 30px 20px; }
    .footer-cta-spacer { display: none; }
    .footer-cta-title { font-size: 22px; line-height: 1.2; max-width: 100%; }
    .footer-cta-button { font-size: 14px; padding: 6px 15px; }
    .footer-row-top { flex-direction: column; align-items: flex-start; gap: 40px; padding-bottom: 40px; }
    .footer-brand { text-align: left; }
    .footer-columns { width: 100%; justify-content: space-between; gap: 24px; }
    .footer-link { font-size: 14px; }
    .footer-row-bottom { flex-direction: column; gap: 24px; align-items: center; }
    .footer-copyright { text-align: center; }
    .footer-copyright p { font-size: 13px; }
    .footer-social { justify-content: center; }
  }
</style>
