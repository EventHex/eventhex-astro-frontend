---
// Source: Elementor footer template #2208
// Container f44f575 (depth 0): CTA banner wrapper, boxed 1140px
//   Container 3218551: bg #000, image Mask-group-43.png, overlay Vector-20.png, border 1px #ACA1F182, radius 30px
//     Container 09bb1d9: left side, min-height 400px, padding 50 40 50 50
//       Widget 899f096: heading "Begin Your Journey With EventHex Now!" Manrope 42px/50px/500 white
//       Widget 68c4a7d: button "Get a demo" gradient #0011C7→#8399FF 90deg, radius 8px
//     Container 40b8d2c: right side (empty spacer)
// Container c34fa2e (depth 0): main footer, bg #000, boxed 1140px, padding 260 0 80 0, margin-top -200px
//   Container 476c850: logo 40% + nav 60%
//   Widget a311842: divider #404040, padding 20 0
//   Container 46cb45f: copyright 70% + social 30%

interface Props {
  ctaTitle?: string;
  ctaButtonText?: string;
  ctaHref?: string;
  showCta?: boolean;
}

const {
  ctaTitle = "Begin Your Journey With EventHex Now!",
  ctaButtonText = "Get a demo",
  ctaHref = "/book-a-demo/",
  showCta = true,
} = Astro.props;

const footerColumns = [
  {
    links: [
      { title: "Home", url: "/" },
      { title: "About Us", url: "/about-us/" },
      { title: "Partner With Us", url: "/partnership/" },
      { title: "Get Demo", url: "/book-a-demo/" },
    ],
  },
  {
    links: [
      { title: "Get Demo", url: "/book-a-demo/" },
      { title: "Blog", url: "/blog/" },
      { title: "Contact", url: "/contact-en/" },
      { title: "Refunds", url: "/cancellation-refund-policy/" },
    ],
  },
  {
    links: [
      { title: "Cancellation", url: "/cancellation-refund-policy/" },
      { title: "Privacy Policy", url: "/privacy-policy/" },
      { title: "Terms & Conditions", url: "/terms-of-service/" },
      { title: "Cookie Policy", url: "/cookie-policy/" },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <!-- CTA Banner: f44f575 → 3218551 -->
  {showCta && (
    <section class="footer-cta-wrapper">
      <div class="footer-cta-banner">
        <div class="footer-cta-content">
          <h3 class="footer-cta-title">{ctaTitle}</h3>
          <a href={ctaHref} class="footer-cta-button">{ctaButtonText}</a>
        </div>
        <div class="footer-cta-spacer"></div>
      </div>
    </section>
  )}

  <!-- Main Footer -->
  <div class:list={["footer-main", showCta ? "footer-main--with-cta" : "footer-main--plain"]}>
    <div class="footer-main-inner">
      <!-- Top: Logo + Link Columns -->
      <div class="footer-row-top">
        <div class="footer-brand">
          <a href="/">
            <svg width="200" height="39" viewBox="0 0 296 58" fill="none" xmlns="http://www.w3.org/2000/svg" class="footer-logo">
              <path d="M98.2876 40.4727V46.5238H72.0625V11.0173H97.8088V17.0684H79.4035V25.6199H95.2556V31.221H79.4035V40.4727H98.2876Z" fill="white"/>
