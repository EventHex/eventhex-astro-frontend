---
// Source: Elementor footer template #2208
// Container f44f575 (depth 0): CTA banner wrapper, boxed 1140px
//   Container 3218551: bg #000, image Mask-group-43.png, overlay Vector-20.png, border 1px #ACA1F182, radius 30px
//     Container 09bb1d9: left side, min-height 400px, padding 50 40 50 50
//       Widget 899f096: heading "Begin Your Journey With EventHex Now!" Manrope 42px/50px/500 white
//       Widget 68c4a7d: button "Get a demo" gradient #0011C7→#8399FF 90deg, radius 8px
//     Container 40b8d2c: right side (empty spacer)
// Container c34fa2e (depth 0): main footer, bg #000, boxed 1140px, padding 260 0 80 0, margin-top -200px
//   Container 476c850: logo 40% + nav 60%
//   Widget a311842: divider #404040, padding 20 0
//   Container 46cb45f: copyright 70% + social 30%

interface Props {
  ctaTitle?: string;
  ctaButtonText?: string;
  ctaHref?: string;
  showCta?: boolean;
}

const {
  ctaTitle = "Begin Your Journey With EventHex Now!",
  ctaButtonText = "Get a demo",
  ctaHref = "/book-a-demo/",
  showCta = true,
} = Astro.props;

const footerLinks = [
  { title: "Home", url: "/" },
  { title: "About", url: "/about-us/" },
  { title: "Partner with us", url: "/partnership/" },
  { title: "Blog", url: "/blog/" },
  { title: "Contact", url: "/contact-en/" },
];

const socialLinks = [
  { name: "LinkedIn", url: "https://linkedin.com/company/eventhex", icon: "M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zM.02 24h4.97V8H.02v16zM7.99 8H12.7v2.2h.07C13.4 8.84 15.32 7.5 18.23 7.5 23.02 7.5 24 10.64 24 14.72V24h-5V15.55c0-2.01-.04-4.59-2.8-4.59-2.8 0-3.23 2.18-3.23 4.44V24H8V8z" },
  { name: "Twitter", url: "https://x.com/EventhexAi", icon: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" },
  { name: "Instagram", url: "https://www.instagram.com/eventhex.ai/", icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <!-- CTA Banner: f44f575 → 3218551 -->
  {showCta && (
    <section class="footer-cta-wrapper">
      <div class="footer-cta-banner">
        <div class="footer-cta-content">
          <h3 class="footer-cta-title">{ctaTitle}</h3>
          <a href={ctaHref} class="footer-cta-button">{ctaButtonText}</a>
        </div>
        <div class="footer-cta-spacer"></div>
      </div>
    </section>
  )}

  <!-- Main Footer: c34fa2e — bg #000, margin-top -200px, padding 260 0 80 0 -->
  <div class:list={["footer-main", showCta ? "footer-main--with-cta" : "footer-main--plain"]}>
    <div class="footer-main-inner">
      <!-- Row 1: Logo + Nav — 476c850 -->
      <div class="footer-row-top">
        <div class="footer-brand">
          <a href="/">
            <img
              src="https://cms.eventhex.ai/wp-content/uploads/2024/09/Layer-1-1.png"
              alt="EventHex"
              class="footer-logo"
              loading="lazy"
            />
          </a>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          {footerLinks.map((link) => (
            <a href={link.url} class="footer-link">{link.title}</a>
          ))}
        </nav>
      </div>

      <!-- Divider: a311842 — #404040 -->
      <hr class="footer-divider" />

      <!-- Row 2: Copyright + Social — 46cb45f -->
      <div class="footer-row-bottom">
        <div class="footer-copyright">
          <p>
            &copy; {currentYear} EventHex. All rights reserved
            <a href="/privacy-policy/">Privacy Policy</a> |
            <a href="/cancellation-refund-policy/">Cancellation &amp; Refund Policy</a> |
            <a href="/terms-of-service/">Terms &amp; Conditions</a> |
            <a href="/cookie-policy/">Cookie Policy</a>
          </p>
        </div>
        <div class="footer-social">
          {socialLinks.map((social) => (
            <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label={social.name}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
  }

  /* CTA Banner: f44f575 → 3218551 */
  .footer-cta-wrapper {
    max-width: 1140px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .footer-cta-banner {
    display: flex;
    flex-direction: row;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2025/01/Mask-group-43.png') center center / cover no-repeat;
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 30px;
    overflow: hidden;
    position: relative;
  }
  .footer-cta-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/01/Vector-20.png') center center / cover no-repeat;
    pointer-events: none;
  }
  .footer-cta-content {
    flex: 1;
    min-height: 400px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 50px 40px 50px 50px;
    position: relative;
    z-index: 1;
  }
  .footer-cta-spacer {
    flex: 0 0 40%;
  }
  .footer-cta-title {
    font-family: 'Manrope', var(--font-heading);
    font-size: 42px;
    font-weight: 500;
    line-height: 50px;
    letter-spacing: -1px;
    color: #fff;
    margin: 0 0 30px 0;
    max-width: 82%;
    white-space: pre-line;
  }
  .footer-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', var(--font-body);
    font-size: 16px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    background: linear-gradient(90deg, #0011C7 32%, #8399FF 100%);
    padding: 10px 30px;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.3s;
    width: fit-content;
  }
  .footer-cta-button:hover {
    transform: scale(1.05);
  }

  /* Main Footer: c34fa2e */
  .footer-main {
    background: #000;
  }
  .footer-main--with-cta {
    margin-top: -200px;
    padding: 260px 0 80px 0;
  }
  .footer-main--plain {
    margin-top: 0;
    padding: 80px 0;
  }
  .footer-main-inner {
    max-width: 1140px;
    margin: 0 auto;
  }

  /* Row 1: Logo 40% + Nav 60% — 476c850 */
  .footer-row-top {
    display: flex;
    flex-direction: row;
    align-items: center;
  }
  .footer-brand {
    flex: 0 0 40%;
  }
  .footer-logo {
    height: auto;
    max-width: 180px;
  }
  .footer-nav {
    flex: 0 0 60%;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0;
  }
  .footer-link {
    font-family: 'Inter', var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: #CDD0D5;
    text-decoration: none;
    padding: 0 16px;
    transition: color 0.2s;
  }
  .footer-link:hover {
    color: #fff;
  }

  /* Divider: a311842 */
  .footer-divider {
    border: none;
    border-top: 1px solid #404040;
    margin: 20px 0;
  }

  /* Row 2: Copyright 70% + Social 30% — 46cb45f */
  .footer-row-bottom {
    display: flex;
    flex-direction: row;
    align-items: center;
  }
  .footer-copyright {
    flex: 0 0 70%;
    padding-top: 10px;
  }
  .footer-copyright p {
    font-family: 'Inter', var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.6;
  }
  .footer-copyright a {
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .footer-copyright a:hover {
    opacity: 0.8;
  }
  .footer-social {
    flex: 0 0 30%;
    display: flex;
    justify-content: flex-end;
    gap: 16px;
  }
  .social-icon {
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }
  .social-icon:hover {
    opacity: 0.7;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .footer-cta-wrapper { padding: 0 20px; }
    .footer-main--with-cta { padding: 220px 20px 60px 20px; margin-top: -160px; }
    .footer-main--plain { padding: 60px 20px; }
    .footer-cta-content { padding: 30px; }
    .footer-cta-title { font-size: 32px; line-height: 1.2; }
    .footer-cta-spacer { flex: 0 0 30%; }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .footer-main--with-cta { margin-top: -90px; padding: 150px 20px 60px 20px; }
    .footer-main--plain { padding: 50px 20px 60px; }
    .footer-cta-content { min-height: 250px; padding: 30px 20px; }
    .footer-cta-spacer { display: none; }
    .footer-cta-title { font-size: 22px; line-height: 1.2; max-width: 100%; }
    .footer-cta-button { font-size: 14px; padding: 6px 15px; }
    .footer-row-top { flex-direction: column; align-items: center; gap: 20px; }
    .footer-brand { flex: auto; text-align: center; }
    .footer-nav { flex: auto; flex-wrap: wrap; justify-content: center; }
    .footer-link { font-size: 15px; padding: 0 15px; }
    .footer-row-bottom { flex-direction: column; gap: 16px; align-items: center; }
    .footer-copyright { flex: auto; text-align: center; }
    .footer-copyright p { font-size: 14px; }
    .footer-social { flex: auto; justify-content: center; }
  }
</style>
