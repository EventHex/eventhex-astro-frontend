---
interface Props {
  title?: string;
  subtitle?: string;
  href?: string;
  avatarSrc?: string;
  avatarAlt?: string;
  /** Reveal once the user scrolls past this many px of the page. */
  revealAfterPx?: number;
}

const {
  title = "Book a demo with Hamim Akif",
  subtitle = "See EventHex live in 20 minutes",
  href = "/book-a-demo/",
  avatarSrc = "https://cms.eventhex.ai/wp-content/uploads/2026/06/hamim-akif.jpg",
  avatarAlt = "Hamim Akif",
  revealAfterPx = 600,
} = Astro.props;
---

<div class="eh-demobar" data-demobar data-reveal={String(revealAfterPx)} hidden>
  <a href={href} class="eh-demobar__pill" aria-label={`${title} — ${subtitle}`}>
    <span class="eh-demobar__avatar" aria-hidden={avatarSrc ? "true" : "false"}>
      {avatarSrc ? <img src={avatarSrc} alt={avatarAlt} loading="lazy" /> : <span class="eh-demobar__wave">👋</span>}
    </span>
    <span class="eh-demobar__text">
      <span class="eh-demobar__title">{title}</span>
      <span class="eh-demobar__subtitle">{subtitle}</span>
    </span>
    <svg class="eh-demobar__arrow" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </a>

  <button type="button" class="eh-demobar__close" data-demobar-close aria-label="Dismiss demo invitation">
    <span aria-hidden="true">&times;</span>
  </button>
</div>

<script>
  const storageKey = "eventhex-demobar-dismissed";

  const isDismissed = () => {
    try {
      return window.sessionStorage.getItem(storageKey) === "true";
    } catch {
      return false;
    }
  };

  const setDismissed = () => {
    try {
      window.sessionStorage.setItem(storageKey, "true");
    } catch {
      // Ignore storage failures and keep the widget usable.
    }
  };

  const initDemoBars = () => {
    document.querySelectorAll("[data-demobar]").forEach((bar) => {
      if (bar.dataset.bound === "true") return;
      bar.dataset.bound = "true";

      const closeButton = bar.querySelector("[data-demobar-close]");
      const revealAfter = Number(bar.dataset.reveal || "600");

      if (isDismissed()) return;

      let shown = false;
      const reveal = () => {
        if (shown || isDismissed()) return;
        if (window.scrollY < revealAfter) return;
        shown = true;
        bar.hidden = false;
        // Next frame so the transition runs from the hidden state.
        requestAnimationFrame(() => bar.classList.add("is-visible"));
        window.removeEventListener("scroll", reveal);
      };

      window.addEventListener("scroll", reveal, { passive: true });
      reveal();

      closeButton?.addEventListener("click", () => {
        bar.classList.remove("is-visible");
        setDismissed();
        window.setTimeout(() => {
          bar.hidden = true;
        }, 250);
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDemoBars, { once: true });
  } else {
    initDemoBars();
  }

  document.addEventListener("astro:page-load", initDemoBars);
</script>

<style>
  .eh-demobar {
    position: fixed;
    left: 50%;
    bottom: clamp(14px, 2.4vw, 24px);
    z-index: 65;
    display: flex;
    align-items: center;
    gap: 8px;
    transform: translate(-50%, 16px);
    opacity: 0;
    transition:
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 260ms ease;
  }

  .eh-demobar.is-visible {
    transform: translate(-50%, 0);
    opacity: 1;
  }

  .eh-demobar__pill {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 5px 16px 5px 5px;
    background: #ffffff;
    border: 1.5px solid var(--surface-card-border);
    border-radius: 999px;
    box-shadow: 0 18px 40px rgba(34, 39, 47, 0.16);
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .eh-demobar__pill:hover {
    transform: translateY(-2px);
    border-color: var(--surface-blue-tint);
    box-shadow: 0 22px 48px rgba(55, 93, 251, 0.22);
  }

  .eh-demobar__avatar {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--brand-blue), var(--accent-purple));
    font-size: 18px;
  }

  .eh-demobar__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .eh-demobar__text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .eh-demobar__title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    color: var(--heading-dark);
  }

  .eh-demobar__subtitle {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--body-light);
  }

  .eh-demobar__arrow {
    flex-shrink: 0;
    color: var(--brand-blue);
    transition: transform 180ms ease;
  }

  .eh-demobar__pill:hover .eh-demobar__arrow {
    transform: translateX(3px);
  }

  .eh-demobar__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 999px;
    background: rgba(34, 39, 47, 0.06);
    color: var(--body-gray);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    transition: background 160ms ease;
  }

  .eh-demobar__close:hover {
    background: rgba(34, 39, 47, 0.12);
  }

  /* Phones: anchor left, stay content-sized, and never reach the WhatsApp FAB. */
  @media (max-width: 640px) {
    .eh-demobar {
      left: 14px;
      right: auto;
      /* Cap so the pill + close button can't overlap the bottom-right FAB. */
      max-width: calc(100vw - 96px);
      transform: translateY(16px);
    }

    .eh-demobar.is-visible {
      transform: translateY(0);
    }

    .eh-demobar__pill {
      min-width: 0;
      padding: 4px 13px 4px 4px;
      gap: 9px;
    }

    /* Let the text column shrink and the subtitle truncate instead of forcing width. */
    .eh-demobar__text {
      min-width: 0;
    }

    .eh-demobar__title,
    .eh-demobar__subtitle {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .eh-demobar__avatar {
      width: 32px;
      height: 32px;
    }

    .eh-demobar__title {
      font-size: 13px;
    }

    .eh-demobar__subtitle {
      font-size: 11px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eh-demobar {
      transition: opacity 200ms ease;
      transform: translate(-50%, 0);
    }
    .eh-demobar__pill,
    .eh-demobar__arrow {
      transition: none;
    }
  }
</style>
