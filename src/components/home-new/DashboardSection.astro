<script>
  const dashboardImage = document.querySelector('[data-dashboard-motion]') as HTMLElement | null;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

  if (dashboardImage && !prefersReducedMotion.matches) {
    let frameId = 0;

    const updateDashboardMotion = () => {
      const rect = dashboardImage.getBoundingClientRect();
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      const scaleStart = viewportHeight * 0.4;
      const scaleEnd = viewportHeight * 0.05;
      const scaleProgress = clamp((scaleStart - rect.top) / (scaleStart - scaleEnd), 0, 1);
      const scaleBoost = scaleProgress * 0.1;

      dashboardImage.style.setProperty('--dashboard-scale', `${(1 + scaleBoost).toFixed(3)}`);
    };

    const requestDashboardMotionUpdate = () => {
      if (frameId) return;
      frameId = window.requestAnimationFrame(() => {
        frameId = 0;
        updateDashboardMotion();
      });
    };

    updateDashboardMotion();
    window.addEventListener('scroll', requestDashboardMotionUpdate, { passive: true });
    window.addEventListener('resize', requestDashboardMotionUpdate);
  }
</script>

