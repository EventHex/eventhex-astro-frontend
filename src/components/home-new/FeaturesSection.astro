    .ehf-grid[data-layout] .ehf-pos-0,.ehf-grid[data-layout] .ehf-pos-1,.ehf-grid[data-layout] .ehf-pos-2,.ehf-grid[data-layout] .ehf-pos-3,.ehf-grid[data-layout] .ehf-pos-4{grid-column:auto;grid-row:auto}
