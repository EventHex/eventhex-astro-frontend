<script>
(function(){
  var s=document.getElementById('ehf-section');
  if(!s)return;
  var tabs=s.querySelectorAll('.ehf-tab'),panels=s.querySelectorAll('.ehf-panel'),ai=0,timer,paused=false;
  function sw(i){
    ai=i;
    tabs.forEach(function(t,j){t.classList.toggle('ehf-tab--active',j===i)});
    panels.forEach(function(p,j){
      var active=j===i;
      if(active&&!p.classList.contains('ehf-panel--active')){
        p.classList.add('ehf-panel--active');
        var g=p.querySelector('.ehf-grid');if(g){g.style.animation='none';g.offsetHeight;g.style.animation='';g.scrollTo({left:0,behavior:'instant'})}
        ud(p,0);
      }else if(!active){
        p.classList.remove('ehf-panel--active');
      }
    })
  }
  function startAuto(){if(paused)return;clearInterval(timer);timer=setInterval(function(){if(!paused)sw((ai+1)%tabs.length)},5000)}
  function stopAuto(){clearInterval(timer)}
  s.addEventListener('click',function(e){var b=e.target.closest('.ehf-tab');if(!b)return;stopAuto();sw(parseInt(b.getAttribute('data-tab'),10));setTimeout(startAuto,10000)});
  s.addEventListener('mouseenter',function(){paused=true;stopAuto()});
  s.addEventListener('mouseleave',function(){paused=false;startAuto()});
  s.addEventListener('touchstart',function(){paused=true;stopAuto()},{passive:true});
  s.addEventListener('touchend',function(){setTimeout(function(){paused=false;startAuto()},8000)},{passive:true});
  function ud(p,c){var d=p.querySelector('.ehf-dots');if(!d)return;d.querySelectorAll('.ehf-dot').forEach(function(x,i){x.classList.toggle('ehf-dot--active',i===c)})}
  panels.forEach(function(p){var dc=p.querySelector('.ehf-dots'),cs=p.querySelectorAll('.ehf-card');if(dc&&cs.length)for(var i=0;i<cs.length;i++){var d=document.createElement('div');d.className='ehf-dot'+(i===0?' ehf-dot--active':'');dc.appendChild(d)}});
  panels.forEach(function(p,pi){
    var g=p.querySelector('.ehf-grid');if(!g)return;var to;
    g.addEventListener('scroll',function(){clearTimeout(to);
      var cs=g.querySelectorAll('.ehf-card');if(cs.length&&g.scrollWidth>g.clientWidth){var cw=cs[0].offsetWidth+12;ud(p,Math.round(g.scrollLeft/cw))}
      to=setTimeout(function(){if(g.scrollLeft+g.clientWidth>=g.scrollWidth-10){sw((pi+1)%tabs.length)}},200)},{passive:true})
  });
  startAuto();
})();
</script>
