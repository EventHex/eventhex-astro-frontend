    .ehf-grid{display:flex;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;gap:12px;padding-bottom:8px;scrollbar-width:none;height:auto}
    .ehf-grid::-webkit-scrollbar{display:none}
    .ehf-grid[data-layout] .ehf-pos-0,.ehf-grid[data-layout] .ehf-pos-1,.ehf-grid[data-layout] .ehf-pos-2,.ehf-grid[data-layout] .ehf-pos-3,.ehf-grid[data-layout] .ehf-pos-4{flex:0 0 78%;max-width:78%;scroll-snap-align:start}
    .ehf-card--sm .ehf-card__inner,.ehf-card--tall .ehf-card__inner{flex-direction:column}
    .ehf-card--sm .ehf-card__text,.ehf-card--tall .ehf-card__text{padding:20px 20px 8px;flex:none}
    .ehf-card--sm .ehf-card__img,.ehf-card--tall .ehf-card__img{flex:none;height:160px;padding:0 16px 12px;display:flex;align-items:flex-end;justify-content:center;overflow:hidden}
    .ehf-card--sm .ehf-card__img img,.ehf-card--tall .ehf-card__img img{max-height:148px;width:auto;max-width:100%;object-fit:contain}
    .ehf-card{animation-delay:0s!important}
    .ehf-card__title{font-size:18px}
    .ehf-dots{display:flex;justify-content:center;gap:6px;margin-top:12px}
