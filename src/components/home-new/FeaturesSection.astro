  .ehf-panel--active .ehf-grid{animation:ehfFadeUp .35s ease both}
  @keyframes ehfFadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .ehf-grid[data-layout="a"] .ehf-pos-0{grid-column:1;grid-row:1/3}
  .ehf-grid[data-layout="a"] .ehf-pos-1{grid-column:2;grid-row:1}
  .ehf-grid[data-layout="a"] .ehf-pos-2{grid-column:3;grid-row:1}
  .ehf-grid[data-layout="a"] .ehf-pos-3{grid-column:2;grid-row:2}
  .ehf-grid[data-layout="a"] .ehf-pos-4{grid-column:3;grid-row:2}
  .ehf-grid[data-layout="b"] .ehf-pos-0{grid-column:1;grid-row:1}
  .ehf-grid[data-layout="b"] .ehf-pos-1{grid-column:1;grid-row:2}
  .ehf-grid[data-layout="b"] .ehf-pos-2{grid-column:2;grid-row:1/3}
  .ehf-grid[data-layout="b"] .ehf-pos-3{grid-column:3;grid-row:1}
  .ehf-grid[data-layout="b"] .ehf-pos-4{grid-column:3;grid-row:2}
  .ehf-grid[data-layout="c"] .ehf-pos-0{grid-column:1;grid-row:1}
  .ehf-grid[data-layout="c"] .ehf-pos-1{grid-column:2;grid-row:1}
  .ehf-grid[data-layout="c"] .ehf-pos-2{grid-column:1;grid-row:2}
  .ehf-grid[data-layout="c"] .ehf-pos-3{grid-column:2;grid-row:2}
  .ehf-grid[data-layout="c"] .ehf-pos-4{grid-column:3;grid-row:1/3}
  .ehf-card{background:#F5F8FF;border:1px solid #E8ECF2;border-radius:20px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.03);transition:transform .3s ease,box-shadow .3s ease,border-color .3s ease;opacity:0;animation:ehfCardIn .5s ease forwards}
