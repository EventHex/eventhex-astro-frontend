---
// Source: Elementor template #1951 (Header)
// Container 6b78e6d: row, boxed 1140px, padding 20px 0, box-shadow, hidden on mobile
// Logo: 25% width, theme-site-logo
// Nav: 50% width, ucaddon_mega_menu with Poppins 16px/400
// CTA: 25% width, button #375DFB, Inter 15px/600, border-radius 10px, hover grow

const navItems = [
  { title: "Home", url: "/" },
  { title: "About", url: "/about-us/" },
  {
    title: "Features",
    url: "#",
    children: [
      { title: "Speaker Management Software", url: "/speaker-management/" },
      { title: "Event Ticketing", url: "/event-ticketing/" },
      { title: "AI Event Smart-Connect", url: "/enhance-networking-ai-smart-connect/" },
      { title: "Event Marketing", url: "/event-marketing/" },
      { title: "Event Registration", url: "/event-registration/" },
      { title: "Sponsor Management", url: "/sponsor-management/" },
      { title: "Exhibitor Management", url: "/exhibitor-management/" },
      { title: "Centralized Dashboard", url: "/centralized-dashboard/" },
      { title: "AI Form Builder", url: "/ai-form-builder/" },
    ],
  },
  { title: "Blog", url: "/blog/" },
  { title: "News", url: "/news/" },
  { title: "Contact", url: "/contact-en/" },
];
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo (25%) -->
    <a href="/" class="header-logo">
      <img
        src="https://eventhex.ai/wp-content/uploads/2024/09/EventHex-Logo.svg"
        alt="EventHex"
        width="180"
        height="36"
      />
    </a>

    <!-- Desktop Nav (50%) -->
    <nav class="header-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class="nav-item">
          <a href={item.url} class:list={["nav-link", item.children && "has-dropdown"]}>
            {item.title}
            {item.children && (
              <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
          {item.children && (
            <div class="dropdown">
              <div class="dropdown-inner">
                {item.children.map((child) => (
                  <a href={child.url} class="dropdown-link">{child.title}</a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- CTA (25%) -->
    <div class="header-cta">
      <a href="/book-a-demo/" class="cta-button">Get a demo</a>
    </div>

    <!-- Mobile Toggle -->
    <button class="mobile-toggle" id="mobile-menu-btn" aria-label="Open menu">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav class="mobile-nav">
      {navItems.map((item) => (
        <>
          <a href={item.url} class="mobile-link">{item.title}</a>
          {item.children?.map((child) => (
            <a href={child.url} class="mobile-link mobile-link--sub">{child.title}</a>
          ))}
        </>
      ))}
      <a href="/book-a-demo/" class="cta-button cta-button--mobile">Get a demo</a>
    </nav>
  </div>
</header>

<style>
  /* Header: Elementor 6b78e6d */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #fff;
  }

  .header-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    padding: 20px 0;
    gap: 0;
  }

  /* Logo: 25% — Elementor ed18255 */
  .header-logo {
    flex: 0 0 25%;
    display: flex;
    align-items: center;
  }
  .header-logo img {
    height: 36px;
    width: auto;
  }

  /* Nav: 50% — Elementor 9270f11 mega menu, Poppins 16px/400, gap 30px */
  .header-nav {
    flex: 0 0 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
  }
  .nav-item { position: relative; }
  .nav-link {
    font-family: 'Poppins', var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--nav-text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s;
  }
  .nav-link:hover, .nav-link:focus-visible {
    color: var(--brand-blue);
  }
  .dropdown-arrow {
    transition: transform 0.2s;
  }
  .nav-item:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  /* Dropdown: box-shadow 0 0 10px -3px rgba(0,0,0,0.5), padding 20px 30px */
  .dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 12px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
    z-index: 10;
  }
  .nav-item:hover .dropdown {
    opacity: 1;
    visibility: visible;
  }
  .dropdown-inner {
    background: #fff;
    border-radius: 12px;
    padding: 20px 30px;
    min-width: 260px;
    box-shadow: 0 0 10px -3px rgba(0, 0, 0, 0.5);
  }
  .dropdown-link {
    display: block;
    padding: 8px 0;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    color: var(--heading-dark);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    border-radius: 6px;
  }
  .dropdown-link:hover {
    color: var(--brand-blue);
    background: rgba(55, 93, 251, 0.04);
  }

  /* CTA: 25% — Elementor 40bfb5b, button #375DFB, Inter 15px/600, radius 10px */
  .header-cta {
    flex: 0 0 25%;
    display: flex;
    justify-content: flex-end;
  }
  .cta-button {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    background: var(--brand-blue);
    padding: 10px 24px;
    border-radius: 10px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s, background 0.3s;
    cursor: pointer;
    border: none;
  }
  .cta-button:hover {
    background: var(--brand-blue-hover);
    transform: scale(1.05);
  }

  /* Mobile toggle — hidden on desktop */
  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--heading-dark);
  }

  /* Mobile menu */
  .mobile-menu {
    background: #fff;
    border-top: 1px solid #f0f0f0;
    padding: 16px 20px;
  }
  .mobile-nav { display: flex; flex-direction: column; gap: 4px; }
  .mobile-link {
    display: block;
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--heading-dark);
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .mobile-link:hover { background: #f5f5f5; }
  .mobile-link--sub {
    padding-left: 28px;
    font-weight: 400;
    font-size: 14px;
    color: var(--body-gray);
  }
  .cta-button--mobile {
    margin-top: 12px;
    width: 100%;
    justify-content: center;
  }

  /* Box shadow matches Elementor: 0 0 10px -3px #B6C4FF */
  @media (min-width: 768px) {
    .site-header {
      box-shadow: 0 0 10px -3px #B6C4FF;
    }
  }

  /* Tablet: 1024px */
  @media (max-width: 1024px) {
    .header-inner { padding: 20px 20px; }
    .header-nav { gap: 20px; }
    .nav-link { font-size: 15px; }
  }

  /* Mobile: 767px */
  @media (max-width: 767px) {
    .header-nav { display: none; }
    .header-cta { display: none; }
    .mobile-toggle { display: block; }
    .header-inner {
      padding: 12px 16px;
    }
    .header-logo { flex: 1; }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.hasAttribute('hidden');
    if (isHidden) menu?.removeAttribute('hidden');
    else menu?.setAttribute('hidden', '');
  });
</script>
