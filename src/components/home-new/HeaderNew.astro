<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.hasAttribute('hidden');
    if (isHidden) menu?.removeAttribute('hidden');
    else menu?.setAttribute('hidden', '');
    btn?.setAttribute('aria-expanded', String(isHidden));
  });

  // Mobile accordion toggles
  document.querySelectorAll('.mobile-accordion-btn').forEach((accordionBtn) => {
    accordionBtn.addEventListener('click', () => {
      const body = (accordionBtn as HTMLElement).nextElementSibling as HTMLElement | null;
      if (!body) return;
      const isOpen = !body.hasAttribute('hidden');
      if (isOpen) {
        body.setAttribute('hidden', '');
        accordionBtn.setAttribute('aria-expanded', 'false');
      } else {
        body.removeAttribute('hidden');
        accordionBtn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Handle multiple mega-dropdowns
  const dropdownItems = document.querySelectorAll('.nav-item--dropdown');
  const allDropdowns = document.querySelectorAll('.mega-dropdown');
  const timeouts = new Map<string, ReturnType<typeof setTimeout>>();

  function closeAll(except?: string) {
    allDropdowns.forEach((dd) => {
      if (dd.id !== except) dd.classList.remove('is-open');
    });
    dropdownItems.forEach((item) => {
      const ddId = (item as HTMLElement).dataset.dropdown;
      if (ddId !== except) item.classList.remove('mega-active');
    });
  }

  dropdownItems.forEach((navItem) => {
    const link = navItem.querySelector('.nav-link') as HTMLAnchorElement | null;
    const ddId = (navItem as HTMLElement).dataset.dropdown;
    if (!ddId) return;
    const dropdown = document.getElementById(ddId);
    if (!dropdown) return;

    const show = () => {
      const t = timeouts.get(ddId);
      if (t) clearTimeout(t);
      closeAll(ddId);
      dropdown.classList.add('is-open');
      navItem.classList.add('mega-active');
    };
    const hide = () => {
      timeouts.set(ddId, setTimeout(() => {
        dropdown.classList.remove('is-open');
        navItem.classList.remove('mega-active');
      }, 200));
    };

    navItem.addEventListener('mouseenter', show);
    navItem.addEventListener('mouseleave', hide);
    dropdown.addEventListener('mouseenter', show);
    dropdown.addEventListener('mouseleave', hide);
    link?.addEventListener('click', (e) => {
      if (link.getAttribute('href') === '#') e.preventDefault();
      dropdown.classList.toggle('is-open');
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });

  // Feature category tab switching
  const featTabs = document.querySelectorAll('.feat-tab');
  const featPanels = document.querySelectorAll('.feat-items');
  featTabs.forEach((tab) => {
    tab.addEventListener('mouseenter', () => {
      const idx = (tab as HTMLElement).dataset.cat;
      featTabs.forEach((t) => t.classList.remove('feat-tab--active'));
      featPanels.forEach((p) => p.classList.remove('feat-items--active'));
      tab.classList.add('feat-tab--active');
      document.querySelector(`.feat-items[data-panel="${idx}"]`)?.classList.add('feat-items--active');
    });
  });
</script>
