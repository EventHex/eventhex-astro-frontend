---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo 25% -->
    <a href="/" class="header-logo">
      <img
        src="https://cms.eventhex.ai/wp-content/uploads/2024/09/EventHex-Logo.svg"
        alt="EventHex"
        width="180"
        height="36"
      />
    </a>

    <!-- Desktop Nav 45% -->
    <nav class="header-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class:list={["nav-item", item.hasDropdown && "nav-item--dropdown"]} data-dropdown={item.dropdownId}>
          <a
            href={item.url}
            class:list={["nav-link", item.hasDropdown && "has-dropdown"]}
            aria-haspopup={item.hasDropdown ? "true" : undefined}
          >
            {item.title}
            {item.hasDropdown && (
              <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
        </div>
      ))}
    </nav>

    <!-- CTA 30% -->
    <div class="header-cta">
      <a href="/book-a-demo/" class="cta-button">Get a demo</a>
    </div>

    <!-- Mobile Toggle -->
    <button class="mobile-toggle" id="mobile-menu-btn" aria-label="Open menu">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
