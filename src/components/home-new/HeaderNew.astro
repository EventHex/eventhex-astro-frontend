---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo 25% -->
    <a href="/" class="header-logo">
      <img
        src="https://eventhex.ai/wp-content/uploads/2024/09/EventHex-Logo.svg"
        alt="EventHex"
        width="180"
        height="36"
      />
    </a>

    <!-- Desktop Nav 45% -->
    <nav class="header-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class:list={["nav-item", item.hasDropdown && "nav-item--dropdown"]} data-dropdown={item.dropdownId}>
          <a
            href={item.url}
            class:list={["nav-link", item.hasDropdown && "has-dropdown"]}
            aria-haspopup={item.hasDropdown ? "true" : undefined}
          >
            {item.title}
            {item.hasDropdown && (
              <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
        </div>
      ))}
    </nav>

    <!-- CTA 30% -->
    <div class="header-cta">
      <a href="/book-a-demo/" class="cta-button">Get a demo</a>
    </div>

    <!-- Mobile Toggle -->
    <button class="mobile-toggle" id="mobile-menu-btn" aria-label="Open menu">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Features Mega Menu — Categorized layout -->
  <div class="mega-dropdown" id="mega-dropdown" role="menu">
    <div class="mega-inner">
      <div class="mega-header">
        <h6 class="mega-label">PLATFORM FEATURES</h6>
      </div>
      <div class="mega-categories">
        {featureCategories.map((cat) => (
          <div class="mega-category">
            <div class="mega-category-header">
              <span class="mega-category-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={iconPaths[cat.icon]} />
                </svg>
              </span>
              <span class="mega-category-label">{cat.label}</span>
            </div>
            <div class="mega-category-items">
              {cat.items.map((item) => (
                <a href={item.url} class="mega-item-link">{item.title}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="mega-footer">
        <span class="mega-footer-text">Explore 23+ features built for modern event teams</span>
        <a href="/book-a-demo/" class="mega-footer-link">
          See it in action
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Integrations Mega Menu Dropdown -->
  <div class="mega-dropdown" id="integrations-dropdown" role="menu">
    <div class="mega-inner">
      <div class="mega-header">
        <h6 class="mega-label">INTEGRATIONS</h6>
      </div>
      <div class="mega-grid">
        {integrationItems.map((item) => (
          <a href={item.url} class="mega-card">
            <span class="mega-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths[item.icon]} />
              </svg>
            </span>
            <span class="mega-text">
              <span class="mega-title">{item.title}</span>
              <span class="mega-desc">{item.desc}</span>
            </span>
          </a>
        ))}
      </div>
      <div class="mega-footer">
        <span class="mega-footer-text">Explore all integrations</span>
        <a href="/integrations/" class="mega-footer-link">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Industries Mega Menu Dropdown -->
  <div class="mega-dropdown" id="industries-dropdown" role="menu">
    <div class="mega-inner">
      <div class="mega-header">
        <h6 class="mega-label">INDUSTRIES</h6>
      </div>
      <div class="mega-grid mega-grid--5col">
        {industryItems.map((item) => (
          <a href={item.url} class="mega-card mega-card--compact">
            <span class="mega-icon mega-icon--sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconPaths[item.icon]} />
              </svg>
            </span>
            <span class="mega-text">
              <span class="mega-title">{item.title}</span>
            </span>
          </a>
        ))}
      </div>
      <div class="mega-footer">
        <span class="mega-footer-text">Solutions for every industry</span>
        <a href="/industries/" class="mega-footer-link">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav class="mobile-nav">
      <a href="/" class="mobile-link">Home</a>
      <a href="/about-us/" class="mobile-link">About</a>

      <!-- Features accordion -->
      <div class="mobile-accordion">
        <button class="mobile-link mobile-accordion-btn" type="button">
          Features
          <svg class="mobile-accordion-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-body" hidden>
          {featureCategories.map((cat) => (
            <div class="mobile-category">
              <span class="mobile-category-label">{cat.label}</span>
              {cat.items.map((item) => (
                <a href={item.url} class="mobile-link mobile-link--sub">{item.title}</a>
              ))}
            </div>
          ))}
        </div>
      </div>

      <!-- Integrations accordion -->
      <div class="mobile-accordion">
        <button class="mobile-link mobile-accordion-btn" type="button">
          Integrations
          <svg class="mobile-accordion-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-body" hidden>
          {integrationItems.map((child) => (
            <a href={child.url} class="mobile-link mobile-link--sub">{child.title}</a>
          ))}
          <a href="/integrations/" class="mobile-link mobile-link--sub mobile-link--view-all">View all integrations →</a>
        </div>
      </div>

      <!-- Industries accordion -->
      <div class="mobile-accordion">
        <button class="mobile-link mobile-accordion-btn" type="button">
          Industries
          <svg class="mobile-accordion-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-body" hidden>
          {industryItems.map((child) => (
            <a href={child.url} class="mobile-link mobile-link--sub">{child.title}</a>
          ))}
          <a href="/industries/" class="mobile-link mobile-link--sub mobile-link--view-all">View all industries →</a>
        </div>
      </div>

      <a href="/blog/" class="mobile-link">Blog</a>
      <a href="/contact-en/" class="mobile-link">Contact</a>
      <a href="/book-a-demo/" class="cta-button cta-button--mobile">Get a demo</a>
    </nav>
  </div>
</header>

<style>
  /* Header: 3536b26 — NO background, relative position, z-index 1 */
  .site-header {
    position: relative;
    z-index: 100;
  }

  .header-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    padding: 20px 0;
    gap: 0;
  }

  /* Logo: 25% */
  .header-logo {
    flex: 0 0 25%;
    display: flex;
    align-items: center;
  }
  .header-logo img {
    height: 36px;
    width: auto;
  }

  /* Nav: 45% — Inter 16px/400, gap 30px */
  .header-nav {
    flex: 0 0 45%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
  }
  .nav-item { position: relative; }
  .nav-link {
    font-family: 'Inter', var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: #000;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--brand-blue, #375DFB);
  }
  .dropdown-arrow {
    transition: transform 0.2s;
  }
  .nav-item--dropdown:hover .dropdown-arrow {
    transform: rotate(180deg);
  }

  /* CTA: 30% — button Inter 15px/600, #375DFB, radius 10px */
  .header-cta {
    flex: 0 0 30%;
    display: flex;
    justify-content: flex-end;
  }
  .cta-button {
    font-family: 'Inter', var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    background: var(--brand-blue, #375DFB);
    padding: 10px 24px;
    border-radius: 10px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
