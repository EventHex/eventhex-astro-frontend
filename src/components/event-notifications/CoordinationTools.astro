---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="#375DFB" stroke-width="2"/><path d="M22 6l-10 7L2 6" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "4 delivery channels",
    desc: "Email, WhatsApp, push notifications, and SMS from one communication dashboard.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Automated trigger workflows",
    desc: "Messages fire on registration, payment, check-in, and session start automatically.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M18 20V10M12 20V4M6 20v-6" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: "Delivery analytics",
    desc: "Track every message across every channel with per-recipient delivery status.",
  },
];
---

<section class="enc-full">
  <div class="enc-full__inner">
    <div class="enc-full__header">
      <span class="enc-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Notifications</span>
      <h2 class="enc-full__title animate-on-scroll" data-animation="fadeInUp">Multi-Channel <b>Event Communication</b></h2>
      <p class="enc-full__desc animate-on-scroll" data-animation="fadeInUp">Deliver transactional and marketing messages across email, WhatsApp, push, and SMS from one hub.</p>
    </div>

    <div class="enc-full__cards">
      {cards.map((card) => (
        <div class="enc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="enc-full__card-icon" set:html={card.icon}></div>
          <h3 class="enc-full__card-title">{card.title}</h3>
          <p class="enc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .enc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .enc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .enc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .enc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .enc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .enc-full__title b { font-weight: 700; }

  .enc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .enc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .enc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .enc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .enc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .enc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .enc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .enc-full { padding: 64px 0; }
    .enc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .enc-full { padding: 52px 0; }
    .enc-full__title { font-size: 30px; line-height: 1.15; }
    .enc-full__desc { font-size: 15px; }
    .enc-full__cards { grid-template-columns: 1fr; }
  }
</style>
