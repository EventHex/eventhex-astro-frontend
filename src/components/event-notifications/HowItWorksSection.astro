---
const steps = [
  {
    num: "01",
    title: "Configure Channels",
    desc: "Connect your email domain (SES/SendGrid), WhatsApp Business account, and Twilio SMS in Communication Settings.",
  },
  {
    num: "02",
    title: "Build Templates",
    desc: "Design email and WhatsApp templates with dynamic fields — attendee name, ticket type, event date, venue, session links.",
  },
  {
    num: "03",
    title: "Set Triggers",
    desc: "Define which actions trigger which messages: registration via email + WhatsApp, check-in via push, session start via push.",
  },
  {
    num: "04",
    title: "Monitor Delivery",
    desc: "Track all message delivery in real time. EventHex queues high-volume sends and retries failed deliveries automatically.",
  },
];
---

<section class="enhw-full">
  <div class="enhw-full__inner">
    <div class="enhw-full__header">
      <span class="enhw-full__tag animate-on-scroll" data-animation="fadeIn">How Event Notifications Work</span>
      <h2 class="enhw-full__title animate-on-scroll" data-animation="fadeInUp">From Channel Setup to <b>Automated Delivery</b></h2>
      <p class="enhw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Configure channels, build templates, set triggers, and monitor delivery across all channels.
      </p>
    </div>

    <div class="enhw-full__cards">
      {steps.map((step) => (
        <article class="enhw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="enhw-full__card-icon">{step.num}</div>
          <h3 class="enhw-full__card-title">{step.title}</h3>
          <p class="enhw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .enhw-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000 url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp') center / cover no-repeat;
  }

  .enhw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .enhw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .enhw-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .enhw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .enhw-full__title b { font-weight: 700; }

  .enhw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .enhw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .enhw-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .enhw-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .enhw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: #7fb4ff;
  }

  .enhw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .enhw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .enhw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .enhw-full { padding: 64px 0; }
    .enhw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .enhw-full { padding: 52px 0; }
    .enhw-full__title { font-size: 30px; line-height: 1.15; }
    .enhw-full__desc { font-size: 15px; }
    .enhw-full__cards { grid-template-columns: 1fr; }
  }
</style>
