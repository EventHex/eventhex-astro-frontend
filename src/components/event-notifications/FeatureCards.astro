---
const featureCards = [
  {
    eyebrow: "automated workflows",
    title: "Set it once and reach everyone automatically",
    desc: "Define notification triggers — registration, payment, check-in, session start — and EventHex delivers the right message via the right channel at the right time.",
    items: [
      "Trigger-based automation for all events",
      "Smart channel routing per message type",
      "Fallback delivery if primary channel fails",
    ],
    visual: "workflows",
  },
  {
    eyebrow: "whatsapp marketing",
    title: "98% open rates — reach attendees where they read",
    desc: "WhatsApp Business API integration for broadcast campaigns, reminders, and real-time alerts to opted-in attendees — dramatically outperforming email.",
    items: [
      "WhatsApp broadcasts to segmented lists",
      "Auto-response bot for common queries",
      "GDPR-compliant opt-in and opt-out",
    ],
    visual: "wamarketing",
  },
  {
    eyebrow: "delivery analytics",
    title: "Know exactly who got your message on every channel",
    desc: "Track every sent, delivered, opened, and clicked message across email, WhatsApp, push, and SMS from the unified dashboard.",
    items: [
      "Channel-level delivery and open rates",
      "Per-attendee delivery status lookup",
      "Bounce and complaint tracking",
    ],
    visual: "deliveryana",
  },
  {
    eyebrow: "compliance",
    title: "GDPR and CAN-SPAM compliance built in from day one",
    desc: "Unsubscribe management, consent tracking, suppression lists, and opt-in collection at registration — all automated.",
    items: [
      "Auto unsubscribe link in all marketing emails",
      "WhatsApp opt-in/opt-out via STOP reply",
      "Suppression across all future sends",
    ],
    visual: "compliancecard",
  },
];
---

<section class="enf-shell">
  <div class="enf-section">
    <div class="enf-header">
      <span class="enf-subtitle">Everything you need to reach every attendee on every channel</span>
      <h2 class="enf-title">
        Everything You Need to <span class="enf-highlight">Notify, Remind, and Engage</span><br />
        Event Attendees
      </h2>
    </div>

    <div class="enf-cards" id="enf-stacking-cards">
      {featureCards.map((card, index) => (
        <div class="enf-card" data-card-index={index} style={`--card-index: ${index}; top: calc(20px + ${index * 20}px);`}>
          <div class="enf-card-content">
            <span class="enf-card-eyebrow">{card.eyebrow}</span>
            <h3 class="enf-card-title">{card.title}</h3>
            <p class="enf-card-desc">{card.desc}</p>
            <ul class="enf-card-items">
              {card.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href="/book-a-demo/" class="enf-card-btn">Explore More</a>
          </div>

          <div class={`enf-card-visual enf-card-visual--${card.visual}`}>
            {card.visual === "workflows" && (
              <Fragment>
                <div class="enf-workflow-diagram">
                  <div class="enf-wf-trigger">
                    <span class="enf-wf-trigger-icon">&#9889;</span>
                    <span class="enf-wf-trigger-label">Trigger</span>
                  </div>
                  <div class="enf-wf-arrow">&rarr;</div>
                  <div class="enf-wf-channels">
                    <div class="enf-wf-channel"><span class="enf-wf-ch-icon enf-wf-ch-icon--email">&#9993;</span></div>
                    <div class="enf-wf-channel"><span class="enf-wf-ch-icon enf-wf-ch-icon--wa">W</span></div>
                    <div class="enf-wf-channel"><span class="enf-wf-ch-icon enf-wf-ch-icon--push">&#128276;</span></div>
                  </div>
                  <div class="enf-wf-arrow">&rarr;</div>
                  <div class="enf-wf-delivery">
                    <span class="enf-wf-delivery-check">&#10003;</span>
                    <span class="enf-wf-delivery-label">Delivered</span>
                  </div>
                </div>
                <div class="enf-wf-events">
                  <span class="enf-wf-event">Registration</span>
                  <span class="enf-wf-event">Payment</span>
                  <span class="enf-wf-event">Check-in</span>
                </div>
                <div class="enf-visual-pill">Workflows</div>
              </Fragment>
            )}

            {card.visual === "wamarketing" && (
              <Fragment>
                <div class="enf-wa-conv">
                  <div class="enf-wa-conv-header">
                    <span class="enf-wa-conv-avatar"></span>
                    <span class="enf-wa-conv-name"></span>
                    <span class="enf-wa-conv-badge">Business</span>
                  </div>
                  <div class="enf-wa-conv-msgs">
                    <div class="enf-wa-conv-msg">
                      <span class="enf-wa-conv-line"></span>
                      <span class="enf-wa-conv-line enf-wa-conv-line--short"></span>
                    </div>
                    <div class="enf-wa-conv-msg enf-wa-conv-msg--reply">
                      <span class="enf-wa-conv-line"></span>
                    </div>
                  </div>
                </div>
                <div class="enf-wa-metric-card">
                  <strong>98%</strong>
                  <span>open rate</span>
                  <div class="enf-wa-metric-bar">
                    <div class="enf-wa-metric-fill"></div>
                  </div>
                </div>
                <div class="enf-visual-pill">WhatsApp</div>
              </Fragment>
            )}

            {card.visual === "deliveryana" && (
              <Fragment>
                <div class="enf-analytics-dash">
                  <div class="enf-ana-top">
                    <div class="enf-ana-widget">
                      <span class="enf-ana-label">Email</span>
                      <strong>94.2%</strong>
                      <span class="enf-ana-sublabel">delivered</span>
                    </div>
                    <div class="enf-ana-widget">
                      <span class="enf-ana-label">WhatsApp</span>
                      <strong>98.1%</strong>
                      <span class="enf-ana-sublabel">opened</span>
                    </div>
                  </div>
                  <div class="enf-ana-chart">
                    <span style="--h:80%"></span>
                    <span style="--h:65%"></span>
                    <span style="--h:90%"></span>
                    <span style="--h:45%"></span>
                    <span style="--h:72%"></span>
                    <span style="--h:85%"></span>
                  </div>
                  <div class="enf-ana-channels">
                    <span class="enf-ana-ch"><span class="enf-ana-ch-dot enf-ana-ch-dot--email"></span>Email</span>
                    <span class="enf-ana-ch"><span class="enf-ana-ch-dot enf-ana-ch-dot--wa"></span>WhatsApp</span>
                    <span class="enf-ana-ch"><span class="enf-ana-ch-dot enf-ana-ch-dot--push"></span>Push</span>
                    <span class="enf-ana-ch"><span class="enf-ana-ch-dot enf-ana-ch-dot--sms"></span>SMS</span>
                  </div>
                </div>
                <div class="enf-visual-pill">Analytics</div>
              </Fragment>
            )}

            {card.visual === "compliancecard" && (
              <Fragment>
                <div class="enf-gdpr-shield">
                  <svg viewBox="0 0 48 56" class="enf-gdpr-svg">
                    <path d="M24 2L4 12v16c0 14 20 24 20 24s20-10 20-24V12L24 2z" fill="rgba(34,197,94,0.08)" stroke="#22c55e" stroke-width="2"/>
                    <path d="M16 28l5 5 11-11" stroke="#22c55e" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="enf-gdpr-label">GDPR</span>
                </div>
                <div class="enf-compliance-flow">
                  <div class="enf-compliance-step"><span class="enf-compliance-icon">&#128274;</span><span>Consent</span></div>
                  <div class="enf-compliance-arrow">&rarr;</div>
                  <div class="enf-compliance-step"><span class="enf-compliance-icon">&#9993;</span><span>Send</span></div>
                  <div class="enf-compliance-arrow">&rarr;</div>
                  <div class="enf-compliance-step"><span class="enf-compliance-icon">&times;</span><span>Unsub</span></div>
                </div>
                <div class="enf-visual-pill">Compliance</div>
              </Fragment>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .enf-shell {
    width: 100%;
    background-color: #000;
    background-image: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/bg-2.webp');
    background-position: center left;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .enf-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 0 30px;
  }

  .enf-header {
    width: 72%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    text-align: center;
  }

  .enf-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: #fff;
    margin: 0;
  }

  .enf-title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  .enf-highlight { color: #AFA3FF; }

  .enf-cards {
    width: 100%;
    padding: 30px 0 0;
    position: relative;
    padding-bottom: 50px;
  }

  .enf-card {
    position: sticky;
    display: flex;
    align-items: stretch;
    background: var(--dark-card-bg, rgba(18, 15, 40, 0.88));
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 20px;
    overflow: hidden;
    height: 500px;
    margin-bottom: 60px;
    transition: transform 0.3s ease;
  }

  .enf-card-content {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    gap: 16px;
  }

  .enf-card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(175, 163, 255, 0.12);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #afa3ff;
  }

  .enf-card-title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 500;
    color: var(--accent-purple, #AFA3FF);
    margin: 0;
    line-height: 1.2;
  }

  .enf-card-desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: #fff;
    margin: 0;
    line-height: 1.65;
  }

  .enf-card-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .enf-card-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .enf-card-items li::before {
    content: "";
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
  }

  .enf-card-btn {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #0A0D14;
    background: var(--accent-btn-purple, #D4CAFE);
    border-radius: 10px;
    padding: 10px 24px;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    margin-top: 8px;
  }

  .enf-card-btn:hover { transform: scale(1.05); }

  .enf-card-visual {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    overflow: hidden;
    background: radial-gradient(circle at top, rgba(255, 255, 255, 0.08), transparent 52%);
  }

  /* Workflows visual */
  .enf-workflow-diagram {
    position: absolute;
    inset: 50px 30px auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .enf-wf-trigger {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 18px;
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(175, 163, 255, 0.15), rgba(175, 163, 255, 0.05));
    border: 1px solid rgba(175, 163, 255, 0.3);
  }

  .enf-wf-trigger-icon {
    font-size: 20px;
  }

  .enf-wf-trigger-label {
    font-size: 11px;
    font-weight: 700;
    color: #AFA3FF;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .enf-wf-arrow {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 700;
  }

  .enf-wf-channels {
    display: flex;
    gap: 8px;
  }

  .enf-wf-channel {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .enf-wf-ch-icon {
    font-size: 16px;
  }

  .enf-wf-ch-icon--email { color: #375dfb; }
  .enf-wf-ch-icon--wa { color: #25d366; font-weight: 800; font-size: 14px; }
  .enf-wf-ch-icon--push { color: #f59e0b; }

  .enf-wf-delivery {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 14px 18px;
    border-radius: 14px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.25);
  }

  .enf-wf-delivery-check {
    font-size: 18px;
    color: #22c55e;
    font-weight: 700;
  }

  .enf-wf-delivery-label {
    font-size: 11px;
    font-weight: 700;
    color: #22c55e;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .enf-wf-events {
    position: absolute;
    bottom: 70px;
    left: 30px;
    right: 30px;
    display: flex;
    gap: 8px;
    justify-content: center;
  }

  .enf-wf-event {
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
  }

  .enf-visual-pill {
    position: absolute;
    right: 32px;
    bottom: 36px;
    display: inline-flex;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    color: #183465;
    font-size: 13px;
    font-weight: 700;
    box-shadow: 0 18px 36px -24px rgba(18, 34, 74, 0.45);
  }

  /* WhatsApp marketing visual */
  .enf-wa-conv {
    position: absolute;
    left: 34px;
    top: 50px;
    right: 100px;
    border-radius: 16px;
    background: linear-gradient(180deg, #075e54, #128c7e);
    overflow: hidden;
    box-shadow: 0 20px 40px -28px rgba(0, 0, 0, 0.5);
  }

  .enf-wa-conv-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: rgba(0, 0, 0, 0.2);
  }

  .enf-wa-conv-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
  }

  .enf-wa-conv-name {
    height: 8px;
    width: 40%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.4);
  }

  .enf-wa-conv-badge {
    margin-left: auto;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(37, 211, 102, 0.3);
    font-size: 10px;
    font-weight: 700;
    color: #dcf8c6;
  }

  .enf-wa-conv-msgs {
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .enf-wa-conv-msg {
    max-width: 80%;
    padding: 8px 10px;
    border-radius: 8px;
    background: #dcf8c6;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .enf-wa-conv-msg--reply {
    align-self: flex-end;
    background: #fff;
  }

  .enf-wa-conv-line {
    display: block;
    height: 5px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.1);
  }

  .enf-wa-conv-line--short { width: 55%; }

  .enf-wa-metric-card {
    position: absolute;
    right: 34px;
    top: 70px;
    padding: 16px 20px;
    border-radius: 16px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(34, 197, 94, 0.2);
    box-shadow: 0 20px 40px -28px rgba(17, 28, 56, 0.5);
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: center;
  }

  .enf-wa-metric-card strong {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: #22c55e;
  }

  .enf-wa-metric-card > span {
    font-size: 11px;
    font-weight: 600;
    color: #607390;
  }

  .enf-wa-metric-bar {
    width: 80px;
    height: 6px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.12);
    margin-top: 4px;
  }

  .enf-wa-metric-fill {
    width: 98%;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #22c55e, #4ade80);
  }

  /* Delivery analytics visual */
  .enf-analytics-dash {
    position: absolute;
    inset: 40px 30px 70px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .enf-ana-top {
    display: flex;
    gap: 10px;
  }

  .enf-ana-widget {
    flex: 1;
    padding: 12px 14px;
    border-radius: 14px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .enf-ana-label {
    font-size: 11px;
    font-weight: 600;
    color: #607390;
  }

  .enf-ana-widget strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    color: #14213b;
  }

  .enf-ana-sublabel {
    font-size: 10px;
    font-weight: 500;
    color: #94a3b8;
  }

  .enf-ana-chart {
    flex: 1;
    display: flex;
    align-items: flex-end;
    gap: 6px;
    padding: 10px 14px;
    border-radius: 14px;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 1px solid rgba(55, 93, 251, 0.12);
  }

  .enf-ana-chart span {
    flex: 1;
    height: var(--h, 50%);
    border-radius: 4px 4px 0 0;
    background: linear-gradient(180deg, #375dfb, #38bdf8);
    opacity: 0.7;
  }

  .enf-ana-channels {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  .enf-ana-ch {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
  }

  .enf-ana-ch-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .enf-ana-ch-dot--email { background: #375dfb; }
  .enf-ana-ch-dot--wa { background: #25d366; }
  .enf-ana-ch-dot--push { background: #f59e0b; }
  .enf-ana-ch-dot--sms { background: #AFA3FF; }

  /* Compliance visual */
  .enf-gdpr-shield {
    position: absolute;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .enf-gdpr-svg { width: 60px; height: 70px; }

  .enf-gdpr-label {
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.12);
    font-size: 12px;
    font-weight: 800;
    color: #22c55e;
    letter-spacing: 0.1em;
  }

  .enf-compliance-flow {
    position: absolute;
    bottom: 80px;
    left: 30px;
    right: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .enf-compliance-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 12px 16px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .enf-compliance-icon {
    font-size: 16px;
  }

  .enf-compliance-step span:last-child {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
  }

  .enf-compliance-arrow {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.2);
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .enf-section { padding: 60px 20px 30px; }
    .enf-header { width: 80%; }
    .enf-subtitle { font-size: 16px; }
    .enf-title { font-size: 40px; line-height: 1em; }
    .enf-card { height: 450px; }
    .enf-card-content { flex-basis: 50%; }
    .enf-card-title { font-size: 28px; }
    .enf-card-desc { font-size: 16px; }
  }

  @media (max-width: 767px) {
    .enf-section { padding: 50px 20px 30px; }
    .enf-header { width: 100%; }
    .enf-title { font-size: 30px; }
    .enf-card { flex-direction: column; height: 620px; }
    .enf-card-content { flex: 0 0 55%; padding: 20px 20px 0; }
    .enf-card-visual { min-height: 260px; padding: 12px; }
    .enf-card-title { font-size: 24px; }
    .enf-card-desc { font-size: 15px; }
    .enf-cards { padding-bottom: 40px; }
    .enf-workflow-diagram { inset: 30px 16px auto; gap: 8px; }
    .enf-wf-events { bottom: 50px; left: 16px; right: 16px; }
    .enf-wa-conv { left: 20px; right: 60px; }
