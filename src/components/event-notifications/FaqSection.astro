---
const faqs = [
  {
    q: "Which email provider does EventHex use?",
    a: "EventHex uses Amazon SES for transactional emails, providing high deliverability and scalability. You can also connect your own SendGrid or Mailgun account.",
  },
  {
    q: "How does the WhatsApp integration work?",
    a: "EventHex connects to the WhatsApp Business API via Meta. You need a verified WhatsApp Business account. EventHex handles message templates, opt-in management, and delivery tracking.",
  },
  {
    q: "Can I send to only certain attendees?",
    a: "Yes. Segment your audience by ticket type, registration date, check-in status, session attendance, or any custom field. Send targeted messages to specific segments.",
  },
  {
    q: "Are there limits on how many emails I can send?",
    a: "Sending limits depend on your EventHex plan. Enterprise plans have unlimited sends. EventHex queues large sends to ensure reliable delivery without overloading providers.",
  },
  {
    q: "Can attendees unsubscribe from marketing emails?",
    a: "Yes. Every marketing email includes an unsubscribe link. Unsubscribed contacts are excluded from all future marketing sends while still receiving transactional messages.",
  },
  {
    q: "Does EventHex support email A/B testing?",
    a: "Yes. You can A/B test subject lines, sender names, and email content on a sample of your audience before sending to the full list.",
  },
];

const checklist = [
  "Email and WhatsApp setup",
  "Automated trigger configuration",
  "Delivery analytics dashboard",
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="enfq" data-en-faq>
  <div class="enfq__inner">
    <div class="enfq__support">
      <span class="enfq__eyebrow animate-on-scroll" data-animation="fadeInDown">Need help with event notifications?</span>
      <h2 class="enfq__title animate-on-scroll" data-animation="fadeInUp">Frequently asked questions</h2>
      <p class="enfq__desc animate-on-scroll" data-animation="fadeInUp">
        We help event teams configure multi-channel notifications with automated triggers and delivery tracking.
      </p>

      <div class="enfq__support-card animate-on-scroll" data-animation="fadeInUp">
        <span class="enfq__support-label">Included with every rollout</span>
        <ul class="enfq__support-list">
          {checklist.map((item) => (
            <li class="enfq__support-item">{item}</li>
          ))}
        </ul>

        <div class="enfq__support-note">
          <strong>Free onboarding support</strong>
          <span>Map your notification workflow before launch and keep your team aligned on channels, triggers, and compliance.</span>
        </div>

        <a href="/book-a-demo/" class="enfq__cta">Plan my notifications</a>
      </div>
    </div>

    <div class="enfq__list">
      {faqs.map((faq, index) => (
        <details class="enfq__item animate-on-scroll" data-animation="fadeInUp" data-en-faq-item open={index === 0}>
          <summary class="enfq__question">
            <span>{faq.q}</span>
            <span class="enfq__icon" aria-hidden="true">
              <span class="enfq__icon-line enfq__icon-line--horizontal"></span>
              <span class="enfq__icon-line enfq__icon-line--vertical"></span>
            </span>
          </summary>
          <div class="enfq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const enFaqItems = Array.from(document.querySelectorAll('[data-en-faq-item]'));

  enFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      enFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .enfq {
    width: 100%;
    margin: 0;
    padding: 96px 0;
    background: #f5f6fa;
  }

  .enfq__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: minmax(300px, 0.9fr) minmax(0, 1.1fr);
    gap: 32px;
    align-items: start;
  }

  .enfq__support {
    position: sticky;
    top: 108px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .enfq__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(99, 77, 255, 0.08);
    border: 1px solid rgba(99, 77, 255, 0.14);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5a3fd4;
  }

  .enfq__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #0f1117;
  }

  .enfq__desc {
    margin: 0;
    max-width: 540px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.65;
    color: #5b6477;
  }

  .enfq__support-card {
    width: 100%;
    padding: 24px 22px;
    border-radius: 28px;
    background: #fff;
    border: 1px solid rgba(99, 77, 255, 0.12);
    box-shadow: 0 2px 16px rgba(15, 17, 23, 0.06);
  }

  .enfq__support-label {
    display: inline-flex;
    margin-bottom: 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #375dfb;
  }

  .enfq__support-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .enfq__support-item {
    position: relative;
    padding-left: 22px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.55;
    color: #2d3340;
  }

  .enfq__support-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ec8ff 0%, #4d74ff 100%);
  }

  .enfq__support-note {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 20px;
    padding: 18px;
    border-radius: 22px;
    background: #f5f6fa;
    border: 1px solid rgba(15, 17, 23, 0.07);
  }

  .enfq__support-note strong {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 500;
    line-height: 1.3;
    color: #0f1117;
  }

  .enfq__support-note span {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: #5b6477;
  }

  .enfq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 18px;
    padding: 0 20px;
    border-radius: 16px;
    background: #375dfb;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.2s ease;
  }

  .enfq__cta:hover {
    background: #2248e8;
    transform: translateY(-1px);
    box-shadow: 0 10px 28px rgba(55, 93, 251, 0.28);
  }

  .enfq__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .enfq__item {
    overflow: hidden;
    border-radius: 24px;
    background: #fff;
    border: 1px solid rgba(15, 17, 23, 0.08);
    box-shadow: 0 1px 6px rgba(15, 17, 23, 0.04);
  }

  .enfq__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 26px 24px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    color: #0f1117;
  }

  .enfq__question::-webkit-details-marker,
  .enfq__question::marker {
    display: none;
  }

  .enfq__icon {
    position: relative;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 4px;
  }

  .enfq__icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: #375dfb;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .enfq__icon-line--vertical {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .enfq__item[open] .enfq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scaleX(0);
  }

  .enfq__answer {
    padding: 0 24px 24px;
  }

  .enfq__answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.7;
    color: #5b6477;
  }

  @media (max-width: 1100px) {
    .enfq { padding: 76px 0; }
    .enfq__inner { grid-template-columns: 1fr; gap: 28px; }
    .enfq__support { position: static; }
  }

  @media (max-width: 1024px) {
    .enfq__title { font-size: 40px; }
    .enfq__desc { font-size: 16px; }
    .enfq__question { padding: 24px 22px; font-size: 20px; }
    .enfq__answer { padding: 0 22px 22px; }
  }

  @media (max-width: 767px) {
    .enfq { padding: 56px 0; }
    .enfq__inner { padding: 0 16px; gap: 24px; }
    .enfq__title { font-size: 32px; line-height: 1.08; }
    .enfq__desc { font-size: 15px; line-height: 1.7; }
    .enfq__support-card { padding: 20px 18px; border-radius: 24px; }
    .enfq__support-item { font-size: 15px; }
    .enfq__support-note strong { font-size: 18px; }
    .enfq__cta { width: 100%; }
    .enfq__item { border-radius: 24px; }
    .enfq__question { padding: 20px 18px; font-size: 17px; line-height: 1.45; }
    .enfq__answer { padding: 0 18px 20px; }
    .enfq__answer p { font-size: 15px; line-height: 1.75; }
  }
</style>
