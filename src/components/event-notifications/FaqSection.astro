---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "Which email provider does EventHex use?", a: "EventHex uses Amazon SES for transactional emails, providing high deliverability and scalability. You can also connect your own SendGrid or Mailgun account." },
  { q: "How does the WhatsApp integration work?", a: "EventHex connects to the WhatsApp Business API via Meta. You need a verified WhatsApp Business account. EventHex handles message templates, opt-in management, and delivery tracking." },
  { q: "Can I send to only certain attendees?", a: "Yes. Segment your audience by ticket type, registration date, check-in status, session attendance, or any custom field. Send targeted messages to specific segments." },
  { q: "Are there limits on how many emails I can send?", a: "Sending limits depend on your EventHex plan. Enterprise plans have unlimited sends. EventHex queues large sends to ensure reliable delivery without overloading providers." },
  { q: "Can attendees unsubscribe from marketing emails?", a: "Yes. Every marketing email includes an unsubscribe link. Unsubscribed contacts are excluded from all future marketing sends while still receiving transactional messages." },
  { q: "Does EventHex support email A/B testing?", a: "Yes. You can A/B test subject lines, sender names, and email content on a sample of your audience before sending to the full list." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need help with event notifications?"
  title="Frequently Asked Questions"
  description="We help event teams configure multi-channel notifications with automated triggers and delivery tracking."
/>
