---
const tabs = [
  {
    label: "Email Notifications",
    hero: {
      eyebrow: "Email Engine",
      title: "Transactional emails, reminder sequences, and marketing broadcasts with templates",
      desc: "Instant registration confirmations, pre-event reminders, and marketing broadcasts with drag-and-drop templates and GDPR-compliant unsubscribe.",
      points: ["Transactional and marketing emails", "Automated reminder sequences", "GDPR-compliant unsubscribe"],
      visual: "email",
    },
    cards: [
      { eyebrow: "Reminders", title: "Pre-Event Reminders", desc: "Automated sequences: 7 days, 3 days, 1 day before, and day-of reminders.", visual: "reminders" },
      { eyebrow: "Broadcast", title: "Marketing Broadcasts", desc: "Speaker announcements, schedule updates, and sponsor messages to segments.", visual: "broadcast" },
      { eyebrow: "Templates", title: "Custom Email Templates", desc: "Drag-and-drop template builder with dynamic fields and responsive layouts.", visual: "emailtpl" },
      { eyebrow: "Compliance", title: "Unsubscribe Management", desc: "CAN-SPAM and GDPR compliant unsubscribe with auto list suppression.", visual: "unsub" },
    ],
  },
  {
    label: "WhatsApp & Push",
    hero: {
      eyebrow: "WhatsApp Engine",
      title: "WhatsApp confirmations, broadcasts, push notifications, and bot responses",
      desc: "Send ticket QR codes via WhatsApp on registration — 98% open rate. Push notifications for session alerts and in-app announcements.",
      points: ["98% WhatsApp open rate", "Push notifications via app", "WhatsApp bot responses"],
      visual: "whatsapp",
    },
    cards: [
      { eyebrow: "Campaigns", title: "WhatsApp Broadcasts", desc: "Send announcements to opted-in segments via WhatsApp Business API.", visual: "wabroadcast" },
      { eyebrow: "Push", title: "Push Notifications", desc: "Session start alerts and networking suggestions via the attendee app.", visual: "push" },
      { eyebrow: "In-App", title: "In-App Notifications", desc: "Real-time notification bell for schedule changes and session reminders.", visual: "inapp" },
      { eyebrow: "Bot", title: "WhatsApp Bot", desc: "Automated bot answers common queries — venue, status, ticket delivery.", visual: "wabot" },
    ],
  },
  {
    label: "SMS & Delivery",
    hero: {
      eyebrow: "Delivery Engine",
      title: "SMS via Twilio, queue-based delivery, tracking, and A/B testing",
      desc: "SMS for last-minute updates and emergency notifications. Queue-based delivery, per-recipient tracking, and A/B testing for optimization.",
      points: ["SMS via Twilio integration", "Per-recipient delivery tracking", "A/B testing support"],
      visual: "sms",
    },
    cards: [
      { eyebrow: "Queue", title: "Queue-Based Delivery", desc: "High-volume sends queued and delivered reliably — no messages lost.", visual: "queue" },
      { eyebrow: "Tracking", title: "Delivery Tracking", desc: "Sent, delivered, bounced, and opened status per recipient per channel.", visual: "tracking" },
      { eyebrow: "Testing", title: "A/B Testing", desc: "Test subject lines and message variants before sending to full audience.", visual: "abtest" },
      { eyebrow: "Suppression", title: "Suppression Lists", desc: "Hard bounces and unsubscribes automatically suppressed across all sends.", visual: "suppress" },
    ],
  },
];
---

<section class="enb-section" id="en-bento">
  <div class="enb-shell">
    <h2 class="enb-title">
      Email <b>Notifications</b>, WhatsApp &amp; <b>Push</b>
    </h2>
    <p class="enb-subtitle">
      Send transactional and marketing messages across all channels from one communication hub.
    </p>

    <nav class="enb-nav" aria-label="Event notification workflows">
      {tabs.map((tab, index) => (
        <button
          class={`enb-tab${index === 0 ? " enb-tab--active" : ""}`}
          data-enb-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`enb-panel${tabIndex === 0 ? " enb-panel--active" : ""}`}
        data-enb-panel={tabIndex}
      >
        <div class="enb-grid">
          <article class="enb-card enb-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="enb-card__content">
              <span class="enb-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="enb-card__title">{tab.hero.title}</h3>
              <p class="enb-card__desc">{tab.hero.desc}</p>
              <ul class="enb-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`enb-art enb-art--hero enb-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "email" && (
                <Fragment>
                  <div class="enb-envelope">
                    <div class="enb-envelope-body">
                      <div class="enb-envelope-flap"></div>
                      <div class="enb-envelope-content">
                        <span class="enb-envelope-line"></span>
                        <span class="enb-envelope-line enb-envelope-line--short"></span>
                      </div>
                    </div>
                    <div class="enb-notif-badge">3</div>
                  </div>
                  <div class="enb-email-stack">
                    <div class="enb-email-item"><span class="enb-email-dot enb-email-dot--green"></span><span class="enb-email-subject"></span></div>
                    <div class="enb-email-item"><span class="enb-email-dot enb-email-dot--blue"></span><span class="enb-email-subject"></span></div>
                  </div>
                </Fragment>
              )}
              {tab.hero.visual === "whatsapp" && (
                <Fragment>
                  <div class="enb-wa-phone">
                    <div class="enb-wa-header">
                      <span class="enb-wa-avatar"></span>
                      <span class="enb-wa-name"></span>
                    </div>
                    <div class="enb-wa-messages">
                      <div class="enb-wa-msg enb-wa-msg--received">
                        <span class="enb-wa-msg-text"></span>
                        <div class="enb-wa-qr">
                          <span></span><span></span><span></span><span></span>
                        </div>
                      </div>
                      <div class="enb-wa-msg enb-wa-msg--sent">
                        <span class="enb-wa-msg-text enb-wa-msg-text--short"></span>
                      </div>
                    </div>
                  </div>
                  <div class="enb-wa-rate-badge">
                    <strong>98%</strong>
                    <span>open rate</span>
                  </div>
                </Fragment>
              )}
              {tab.hero.visual === "sms" && (
                <Fragment>
                  <div class="enb-sms-bubbles">
                    <div class="enb-sms-bubble enb-sms-bubble--out">
                      <span class="enb-sms-line"></span>
                      <span class="enb-sms-line enb-sms-line--short"></span>
                    </div>
                    <div class="enb-sms-bubble enb-sms-bubble--in">
                      <span class="enb-sms-line"></span>
                    </div>
                    <div class="enb-sms-bubble enb-sms-bubble--out">
                      <span class="enb-sms-line enb-sms-line--med"></span>
                    </div>
                  </div>
                  <div class="enb-sms-provider">
                    <span class="enb-sms-provider-icon">T</span>
                    <span>Twilio</span>
                  </div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="enb-card enb-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="enb-card__content">
                <span class="enb-card__eyebrow">{card.eyebrow}</span>
                <h3 class="enb-card__title">{card.title}</h3>
                <p class="enb-card__desc">{card.desc}</p>
              </div>

              <div class={`enb-art enb-art--mini enb-art--${card.visual}`} aria-hidden="true">
                {card.visual === "reminders" && (
                  <Fragment>
                    <div class="enb-reminder-stack">
                      <div class="enb-reminder-card"><span class="enb-reminder-day">7d</span><span class="enb-reminder-bar"></span></div>
                      <div class="enb-reminder-card"><span class="enb-reminder-day">3d</span><span class="enb-reminder-bar"></span></div>
                      <div class="enb-reminder-card enb-reminder-card--active"><span class="enb-reminder-day">1d</span><span class="enb-reminder-bar"></span></div>
                    </div>
                    <div class="enb-mini-chip">Reminders</div>
                  </Fragment>
                )}
                {card.visual === "broadcast" && (
                  <Fragment>
                    <div class="enb-megaphone">
                      <div class="enb-megaphone-body">
                        <div class="enb-megaphone-cone"></div>
                        <div class="enb-megaphone-handle"></div>
                      </div>
                      <div class="enb-audience-dots">
                        <span></span><span></span><span></span><span></span><span></span>
                      </div>
                    </div>
                    <div class="enb-mini-chip">Broadcast</div>
                  </Fragment>
                )}
                {card.visual === "emailtpl" && (
                  <Fragment>
                    <div class="enb-tpl-canvas">
                      <div class="enb-tpl-header"></div>
                      <div class="enb-tpl-body">
                        <div class="enb-tpl-block enb-tpl-block--img"></div>
                        <div class="enb-tpl-block enb-tpl-block--text">
                          <span></span><span></span>
                        </div>
                      </div>
                      <div class="enb-tpl-btn"></div>
                    </div>
                    <div class="enb-mini-chip">Templates</div>
                  </Fragment>
                )}
                {card.visual === "unsub" && (
                  <Fragment>
                    <div class="enb-unsub-link">
                      <span class="enb-unsub-text">Unsubscribe</span>
                      <div class="enb-unsub-indicator">
                        <span class="enb-unsub-x">&times;</span>
                        <span class="enb-unsub-label">Suppressed</span>
                      </div>
                    </div>
                    <div class="enb-mini-chip">Compliance</div>
                  </Fragment>
                )}
                {card.visual === "wabroadcast" && (
                  <Fragment>
                    <div class="enb-wa-list">
                      <div class="enb-wa-list-row"><span class="enb-wa-list-icon">&#9679;</span><span class="enb-wa-list-name"></span><span class="enb-wa-list-count">1.2k</span></div>
                      <div class="enb-wa-list-row"><span class="enb-wa-list-icon" style="color:#22c55e">&#9679;</span><span class="enb-wa-list-name"></span><span class="enb-wa-list-count">840</span></div>
                      <div class="enb-wa-list-row"><span class="enb-wa-list-icon" style="color:#AFA3FF">&#9679;</span><span class="enb-wa-list-name"></span><span class="enb-wa-list-count">520</span></div>
                    </div>
                    <div class="enb-mini-chip">Segments</div>
                  </Fragment>
                )}
                {card.visual === "push" && (
                  <Fragment>
                    <div class="enb-push-phone">
                      <div class="enb-push-screen">
                        <div class="enb-push-banner">
                          <span class="enb-push-app-icon"></span>
                          <div class="enb-push-banner-text">
                            <span class="enb-push-banner-title"></span>
                            <span class="enb-push-banner-desc"></span>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div class="enb-mini-chip">Push</div>
                  </Fragment>
                )}
                {card.visual === "inapp" && (
                  <Fragment>
                    <div class="enb-bell-wrap">
                      <svg viewBox="0 0 48 48" class="enb-bell-svg">
                        <path d="M24 4c-5.5 0-10 4.5-10 10v8l-4 4v2h28v-2l-4-4v-8c0-5.5-4.5-10-10-10z" fill="rgba(55,93,251,0.12)" stroke="#375dfb" stroke-width="2"/>
                        <path d="M20 38c0 2.2 1.8 4 4 4s4-1.8 4-4" stroke="#375dfb" stroke-width="2" fill="none"/>
                      </svg>
                      <span class="enb-bell-dot"></span>
                    </div>
                    <div class="enb-mini-chip">In-App</div>
                  </Fragment>
                )}
                {card.visual === "wabot" && (
                  <Fragment>
                    <div class="enb-bot-chat">
                      <div class="enb-bot-avatar">
                        <svg viewBox="0 0 24 24" class="enb-bot-icon"><circle cx="12" cy="8" r="4" fill="rgba(55,93,251,0.3)"/><path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8" fill="rgba(55,93,251,0.15)"/></svg>
                      </div>
                      <div class="enb-bot-msgs">
                        <div class="enb-bot-msg"><span></span></div>
                        <div class="enb-bot-msg enb-bot-msg--reply"><span></span></div>
                      </div>
                    </div>
                    <div class="enb-mini-chip">Bot</div>
                  </Fragment>
                )}
                {card.visual === "queue" && (
                  <Fragment>
                    <div class="enb-queue-pipeline">
                      <div class="enb-queue-item enb-queue-item--1"></div>
                      <div class="enb-queue-item enb-queue-item--2"></div>
                      <div class="enb-queue-item enb-queue-item--3"></div>
                      <div class="enb-queue-arrow">&rarr;</div>
                      <div class="enb-queue-item enb-queue-item--sent">&#10003;</div>
                    </div>
                    <div class="enb-mini-chip">Queue</div>
                  </Fragment>
                )}
                {card.visual === "tracking" && (
                  <Fragment>
                    <div class="enb-tracking-timeline">
                      <div class="enb-tracking-step enb-tracking-step--done"><span class="enb-tracking-dot"></span><span class="enb-tracking-label">Sent</span></div>
                      <div class="enb-tracking-line enb-tracking-line--done"></div>
                      <div class="enb-tracking-step enb-tracking-step--done"><span class="enb-tracking-dot"></span><span class="enb-tracking-label">Delivered</span></div>
                      <div class="enb-tracking-line"></div>
                      <div class="enb-tracking-step"><span class="enb-tracking-dot"></span><span class="enb-tracking-label">Opened</span></div>
                    </div>
                    <div class="enb-mini-chip">Tracking</div>
                  </Fragment>
                )}
                {card.visual === "abtest" && (
                  <Fragment>
                    <div class="enb-ab-compare">
                      <div class="enb-ab-variant">
                        <span class="enb-ab-letter">A</span>
                        <div class="enb-ab-bar"><div class="enb-ab-fill" style="width:65%"></div></div>
                        <span class="enb-ab-pct">65%</span>
                      </div>
                      <div class="enb-ab-variant">
                        <span class="enb-ab-letter enb-ab-letter--b">B</span>
                        <div class="enb-ab-bar"><div class="enb-ab-fill enb-ab-fill--b" style="width:42%"></div></div>
                        <span class="enb-ab-pct">42%</span>
                      </div>
                    </div>
                    <div class="enb-mini-chip">A/B Test</div>
                  </Fragment>
                )}
                {card.visual === "suppress" && (
                  <Fragment>
                    <div class="enb-suppress-indicator">
                      <div class="enb-suppress-icon">
                        <svg viewBox="0 0 24 24" class="enb-suppress-svg">
                          <circle cx="12" cy="12" r="10" fill="rgba(220,38,38,0.08)" stroke="#dc2626" stroke-width="2"/>
                          <path d="M8 8l8 8M16 8l-8 8" stroke="#dc2626" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                      </div>
                      <div class="enb-suppress-labels">
                        <span class="enb-suppress-tag enb-suppress-tag--bounce">Bounced</span>
                        <span class="enb-suppress-tag enb-suppress-tag--unsub">Unsubscribed</span>
                      </div>
                    </div>
                    <div class="enb-mini-chip">Suppressed</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".enb-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".enb-tab"));
      const panels = Array.from(root.querySelectorAll(".enb-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("enb-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });
        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("enb-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .enb-section {
    padding: 80px 0 60px;
    background: url('https://eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .enb-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .enb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .enb-title b { font-weight: 700; }

  .enb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .enb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .enb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .enb-tab:hover,
  .enb-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .enb-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .enb-panel { display: none; }
  .enb-panel--active { display: block; }

  .enb-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .enb-panel--active .enb-card {
    animation: enb-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  .enb-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .enb-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .enb-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .enb-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .enb-card--mini:nth-of-type(2) { grid-area: mini1; }
  .enb-card--mini:nth-of-type(3) { grid-area: mini2; }
  .enb-card--mini:nth-of-type(4) { grid-area: mini3; }
  .enb-card--mini:nth-of-type(5) { grid-area: mini4; }

  .enb-card__content { position: relative; z-index: 1; }

  .enb-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .enb-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .enb-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .enb-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .enb-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .enb-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .enb-art { position: relative; z-index: 1; min-height: 146px; }
  .enb-art--hero { min-height: 228px; margin-top: 0.6rem; }
  .enb-art--mini { align-self: end; }

  /* === Hero visual: email === */
  .enb-envelope {
    position: absolute;
    inset: 0.5rem 10% auto 10%;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: enb-float 5s ease-in-out infinite;
  }

  .enb-envelope-body {
    position: relative;
    width: 6rem;
    height: 4rem;
    border-radius: 0.8rem;
    background: linear-gradient(180deg, #ffffff, #edf3ff);
    border: 2px solid rgba(55, 93, 251, 0.18);
    overflow: hidden;
  }

  .enb-envelope-flap {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(135deg, transparent 48%, rgba(55, 93, 251, 0.08) 50%, rgba(55, 93, 251, 0.04));
    border-bottom: 1px solid rgba(55, 93, 251, 0.1);
  }

  .enb-envelope-content {
    position: absolute;
    bottom: 0.5rem;
    left: 0.6rem;
    right: 0.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .enb-envelope-line {
    height: 0.25rem;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.1);
  }

  .enb-envelope-line--short { width: 60%; }

  .enb-notif-badge {
    position: absolute;
    top: -0.4rem;
    right: -0.4rem;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    background: #dc2626;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(220, 38, 38, 0.4);
  }

  .enb-email-stack {
    position: absolute;
    bottom: 0;
    left: 5%;
    right: 5%;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .enb-email-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.6rem;
