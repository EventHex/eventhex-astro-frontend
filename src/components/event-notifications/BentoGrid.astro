---
import { enbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Email Notifications",
    hero: {
      title: "Transactional emails, reminder sequences, and marketing broadcasts with templates",
      desc: "Instant registration confirmations, pre-event reminders, and marketing broadcasts with drag-and-drop templates and GDPR-compliant unsubscribe.",
      visual: "email",
    },
    cards: [
      { title: "Pre-Event Reminders", desc: "Automated sequences: 7 days, 3 days, 1 day before, and day-of reminders.", visual: "reminders" },
      { title: "Marketing Broadcasts", desc: "Speaker announcements, schedule updates, and sponsor messages to segments.", visual: "broadcast" },
      { title: "Custom Email Templates", desc: "Drag-and-drop template builder with dynamic fields and responsive layouts.", visual: "emailtpl" },
      { title: "Unsubscribe Management", desc: "CAN-SPAM and GDPR compliant unsubscribe with auto list suppression.", visual: "unsub" },
    ],
  },
  {
    label: "WhatsApp & Push",
    hero: {
      title: "WhatsApp confirmations, broadcasts, push notifications, and bot responses",
      desc: "Send ticket QR codes via WhatsApp on registration — 98% open rate. Push notifications for session alerts and in-app announcements.",
      visual: "whatsapp",
    },
    cards: [
      { title: "WhatsApp Broadcasts", desc: "Send announcements to opted-in segments via WhatsApp Business API.", visual: "wabroadcast" },
      { title: "Push Notifications", desc: "Session start alerts and networking suggestions via the attendee app.", visual: "push" },
      { title: "In-App Notifications", desc: "Real-time notification bell for schedule changes and session reminders.", visual: "inapp" },
      { title: "WhatsApp Bot", desc: "Automated bot answers common queries — venue, status, ticket delivery.", visual: "wabot" },
    ],
  },
  {
    label: "SMS & Delivery",
    hero: {
      title: "SMS via Twilio, queue-based delivery, tracking, and A/B testing",
      desc: "SMS for last-minute updates and emergency notifications. Queue-based delivery, per-recipient tracking, and A/B testing for optimization.",
      visual: "sms",
    },
    cards: [
      { title: "Queue-Based Delivery", desc: "High-volume sends queued and delivered reliably — no messages lost.", visual: "queue" },
      { title: "Delivery Tracking", desc: "Sent, delivered, bounced, and opened status per recipient per channel.", visual: "tracking" },
      { title: "A/B Testing", desc: "Test subject lines and message variants before sending to full audience.", visual: "abtest" },
      { title: "Suppression Lists", desc: "Hard bounces and unsubscribes automatically suppressed across all sends.", visual: "suppress" },
    ],
  },
];

const ICON = '<svg class="enb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="enb-section" id="en-bento">
  <div class="enb">
    <h2 class="enb-title">
      Email <b>Notifications</b>, WhatsApp &amp; <b>Push</b>
    </h2>
    <p class="enb-subtitle">
      Send transactional and marketing messages across all channels from one communication hub.
    </p>

    <nav class="enb-nav">
      {tabs.map((t, i) => (
        <button class={`enb-tab ${i === 0 ? "enb-tab--active" : ""}`} data-enb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`enb-panel ${tabIdx === 0 ? "enb-panel--active" : ""}`} data-enb-panel={String(tabIdx)}>
        <div class="enb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="enb-card enb-card--tall enb-pos-0" style="animation-delay:0s">
            <div class="enb-card__inner">
              <div class="enb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="enb-card__title">{t.hero.title}</h3>
                <p class="enb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="enb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`enb-card enb-card--sm enb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="enb-card__inner enb-card__inner--row">
                <div class="enb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="enb-card__title">{c.title}</h3>
                  <p class="enb-card__desc">{c.desc}</p>
                </div>
                <div class="enb-card__img enb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const enbTabs = Array.from(document.querySelectorAll('[data-enb-tab]'));
  const enbPanels = Array.from(document.querySelectorAll('[data-enb-panel]'));
  let enbActive = 0;
  let enbInterval: ReturnType<typeof setInterval>;

  function setEnbTab(index: number) {
    enbTabs.forEach((t) => t.classList.remove('enb-tab--active'));
    enbPanels.forEach((p) => p.classList.remove('enb-panel--active'));
    enbTabs[index]?.classList.add('enb-tab--active');
    enbPanels[index]?.classList.add('enb-panel--active');
    enbActive = index;
  }
  function startEnb() {
    enbInterval = setInterval(() => setEnbTab((enbActive + 1) % enbTabs.length), 5000);
  }
  enbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setEnbTab(i); clearInterval(enbInterval); startEnb(); }));
  startEnb();
  const enbSection = document.querySelector('.enb-section');
  if (enbSection) {
    enbSection.addEventListener('mouseenter', () => clearInterval(enbInterval));
    enbSection.addEventListener('mouseleave', () => startEnb());
  }
</script>

<style>
  .enb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .enb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .enb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .enb-title b { font-weight: 700; }
  .enb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .enb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .enb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .enb-tab:hover { background: rgba(55,93,251,.08); }
  .enb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .enb-panel { display: none; }
  .enb-panel--active { display: block; animation: enbFadeUp 0.4s ease; }
  @keyframes enbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .enb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .enb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .enb-pos-1 { grid-column: 2; grid-row: 1; }
  .enb-pos-2 { grid-column: 3; grid-row: 1; }
  .enb-pos-3 { grid-column: 2; grid-row: 2; }
  .enb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .enb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .enb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .enb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .enb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .enb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .enb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .enb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .enb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .enb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .enb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --enb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .enb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: enbCardIn 0.5s ease forwards;
  }
  .enb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--enb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .enb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .enb-card:hover::after { opacity: 1; animation: enbBorder 2.4s linear infinite; }
  @keyframes enbBorder { to { --enb-angle: 360deg; } }
  @keyframes enbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .enb-pos-1 { animation-delay: 0.06s; }
  .enb-pos-2 { animation-delay: 0.12s; }
  .enb-pos-3 { animation-delay: 0.18s; }
  .enb-pos-4 { animation-delay: 0.24s; }

  .enb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .enb-card__inner--row { flex-direction: row; }
  .enb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .enb-card--tall .enb-card__text { padding: 20px 20px 8px; }
  .enb-card--sm .enb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .enb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .enb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .enb-card--sm .enb-card__title { font-size: 17px; }
  .enb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .enb-card--sm .enb-card__desc { font-size: 13px; }

  .enb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .enb-card--tall .enb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .enb-card--sm .enb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .enb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .enb-card:hover .enb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: enbFloat 2.2s ease-in-out infinite;
  }
  @keyframes enbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .enb-section { padding: 60px 0 48px; }
    .enb-title { font-size: 36px; }
    .enb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .enb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .enb-pos-1, .enb-pos-2, .enb-pos-3, .enb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .enb-pos-0, [data-layout="c"] .enb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .enb-pos-1, [data-layout="b"] .enb-pos-2, [data-layout="b"] .enb-pos-3, [data-layout="b"] .enb-pos-4,
    [data-layout="c"] .enb-pos-1, [data-layout="c"] .enb-pos-2, [data-layout="c"] .enb-pos-3, [data-layout="c"] .enb-pos-4 { grid-column: auto; grid-row: auto; }
    .enb-card--tall .enb-card__inner { flex-direction: row; }
    .enb-card--tall .enb-card__text { flex: 1; }
    .enb-card--tall .enb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .enb-title { font-size: 28px; }
    .enb-subtitle { font-size: 15px; }
    .enb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .enb-tab { border-radius: 12px; }
    .enb-grid { grid-template-columns: 1fr; }
    .enb-pos-0, .enb-pos-1, .enb-pos-2, .enb-pos-3, .enb-pos-4,
    [data-layout="b"] .enb-pos-0, [data-layout="b"] .enb-pos-1, [data-layout="b"] .enb-pos-2, [data-layout="b"] .enb-pos-3, [data-layout="b"] .enb-pos-4,
    [data-layout="c"] .enb-pos-0, [data-layout="c"] .enb-pos-1, [data-layout="c"] .enb-pos-2, [data-layout="c"] .enb-pos-3, [data-layout="c"] .enb-pos-4 { grid-column: 1; grid-row: auto; }
    .enb-card--sm .enb-card__inner, .enb-card--tall .enb-card__inner { flex-direction: row; }
    .enb-card--sm .enb-card__text, .enb-card--tall .enb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .enb-card--sm .enb-card__img, .enb-card--tall .enb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .enb-card { animation: none !important; opacity: 1; transform: none; }
    .enb-card:hover::after { animation: none !important; }
    .enb-card:hover .enb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
