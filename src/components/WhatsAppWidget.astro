---
interface Props {
  phone?: string;
  message?: string;
  badgeCount?: number;
}

const {
  phone = "917356733317",
  message = "Hi",
  badgeCount = 1,
} = Astro.props;

const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<div class="eh-wa">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class="eh-wa__button"
    aria-label="Chat with EventHex on WhatsApp"
  >
    {badgeCount > 0 && (
      <span class="eh-wa__badge" aria-hidden="true">{badgeCount}</span>
    )}

    <span class="eh-wa__pulse" aria-hidden="true"></span>

    <svg width="30" height="30" viewBox="0 0 32 32" aria-hidden="true">
      <path
        d="M16 3C9.373 3 4 8.373 4 15c0 2.534.811 5.022 2.342 7.138L4 29l7.138-2.342A11.937 11.937 0 0 0 16 27c6.627 0 12-5.373 12-12S22.627 3 16 3zm0 22a9.933 9.933 0 0 1-5.15-1.44l-.367-.217-4.23 1.388 1.38-4.124-.24-.378A9.942 9.942 0 1 1 16 25zm5.07-7.61c-.28-.14-1.64-.81-1.9-.91-.25-.09-.43-.14-.62.14-.18.28-.71.91-.88 1.09-.16.18-.32.21-.6.07-.28-.14-1.17-.43-2.24-1.37-.83-.74-1.38-1.65-1.55-1.93-.16-.28-.02-.43.13-.57.13-.13.28-.34.43-.51.14-.18.18-.3.27-.49.09-.17.04-.37-.02-.52-.07-.14-.62-1.5-.85-2.04-.22-.52-.44-.45-.62-.46h-.53c-.18 0-.47.07-.72.34-.25.28-.97.95-.97 2.3s.99 2.67 1.13 2.85c.14.18 1.96 3.02 4.76 4.13.67.29 1.19.46 1.6.59.67.21 1.29.18 1.77.11.54-.08 1.64-.67 1.87-1.32.23-.66.23-1.22.17-1.34-.07-.12-.25-.19-.53-.33z"
        fill="currentColor"
      ></path>
    </svg>
  </a>
</div>

<style>
  .eh-wa {
    position: fixed;
    right: clamp(14px, 2.4vw, 24px);
    bottom: clamp(14px, 2.4vw, 24px);
    z-index: 70;
  }

  .eh-wa__button {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: linear-gradient(145deg, #2ee06f 0%, #25d366 55%, #1aa54f 100%);
    color: #ffffff;
    box-shadow: 0 18px 36px rgba(18, 122, 60, 0.32);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
    animation: eh-wa-bob 2.6s ease-in-out infinite;
  }

  .eh-wa__button:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 24px 48px rgba(18, 122, 60, 0.38);
    animation-play-state: paused;
  }

  /* Expanding ring behind the button to draw attention */
  .eh-wa__pulse {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: #25d366;
    z-index: -1;
    animation: eh-wa-pulse 2s ease-out infinite;
  }

  @keyframes eh-wa-pulse {
    0% {
      transform: scale(1);
      opacity: 0.55;
    }
    70% {
      transform: scale(1.5);
      opacity: 0;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  @keyframes eh-wa-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  .eh-wa__button:focus-visible {
    outline: 3px solid rgba(37, 211, 102, 0.35);
    outline-offset: 4px;
  }

  .eh-wa__button svg {
    display: block;
    width: 26px;
    height: 26px;
  }

  .eh-wa__badge {
    position: absolute;
    top: -5px;
    right: -5px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: #ff4b4b;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    border: 2px solid #ffffff;
    box-shadow: 0 8px 18px rgba(183, 28, 28, 0.28);
  }

  @media (max-width: 767px) {
    .eh-wa__button {
      width: 48px;
      height: 48px;
    }

    .eh-wa__button svg {
      width: 24px;
      height: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eh-wa__button {
      transition: none;
      animation: none;
    }

    .eh-wa__pulse {
      animation: none;
      display: none;
    }
  }
</style>