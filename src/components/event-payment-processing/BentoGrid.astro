---
const tabs = [
  {
    label: "Supported Gateways",
    hero: {
      eyebrow: "Gateway Engine",
      title: "Stripe, Razorpay, and Tap Payments with one-click OAuth connection",
      desc: "Connect your existing gateway account with one OAuth click. Revenue settles directly to your bank on your gateway's normal schedule — EventHex is never in the payment flow.",
      points: ["One-click OAuth connection", "Direct revenue settlement", "PCI DSS compliant"],
      visual: "gateways",
    },
    cards: [
      {
        eyebrow: "India",
        title: "Razorpay",
        desc: "Accept UPI, net banking, cards, and wallets in India with 0% EventHex fees.",
        visual: "razorpay",
      },
      {
        eyebrow: "MENA",
        title: "Tap Payments",
        desc: "Accept KNET, mada, Visa, and Mastercard in the GCC and MENA region.",
        visual: "tap",
      },
      {
        eyebrow: "Offline",
        title: "Offline Payments",
        desc: "Record cash, cheque, and bank transfer payments manually in EventHex.",
        visual: "offline",
      },
      {
        eyebrow: "Free",
        title: "Complimentary Tickets",
        desc: "Issue 100% discount codes or mark registrations as complimentary.",
        visual: "comp",
      },
    ],
  },
  {
    label: "Checkout & Pricing",
    hero: {
      eyebrow: "Pricing Engine",
      title: "Multi-tier tickets, promo codes, group purchases, and tax configuration",
      desc: "Create unlimited ticket types with early-bird windows, group discounts, and promo codes. Configure currency display, tax lines, and automatic tier switching.",
      points: ["Unlimited ticket tiers", "Promo and discount codes", "Tax and VAT configuration"],
      visual: "checkout",
    },
    cards: [
      {
        eyebrow: "Promos",
        title: "Promo & Discount Codes",
        desc: "Percentage or fixed-amount coupons with usage limits and expiry dates.",
        visual: "promo",
      },
      {
        eyebrow: "Groups",
        title: "Group Purchases",
        desc: "Buy tickets for multiple people in one checkout with separate registrations.",
        visual: "group",
      },
      {
        eyebrow: "Currency",
        title: "Currency Display",
        desc: "Set your event currency — attendees see prices in your chosen currency.",
        visual: "currency",
      },
      {
        eyebrow: "Tax",
        title: "Tax & VAT",
        desc: "Add configurable tax lines displayed at checkout and on receipts.",
        visual: "tax",
      },
    ],
  },
  {
    label: "Refunds & Reporting",
    hero: {
      eyebrow: "Revenue Engine",
      title: "Automated refunds, revenue dashboards, transaction export, and reconciliation",
      desc: "Process refunds from the dashboard, track real-time revenue, export transactions for accounting, and reconcile with your gateway.",
      points: ["Automated refund processing", "Real-time revenue dashboard", "CSV and Excel export"],
      visual: "reporting",
    },
    cards: [
      {
        eyebrow: "Export",
        title: "Transaction Export",
        desc: "Export all transactions as CSV or Excel with payment date, amount, and fees.",
        visual: "txexport",
      },
      {
        eyebrow: "Reconcile",
        title: "Reconciliation View",
        desc: "Match EventHex transactions against your gateway with side-by-side view.",
        visual: "reconcile",
      },
      {
        eyebrow: "Multi-Event",
        title: "Revenue Roll-Up",
        desc: "Aggregate revenue across all events in the centralized dashboard.",
        visual: "rollup",
      },
      {
        eyebrow: "Revenue",
        title: "Revenue Reports",
        desc: "Gross sales, net revenue, gateway fees, and revenue by ticket type.",
        visual: "revreport",
      },
    ],
  },
];
---

<section class="eppb-section" id="epp-bento">
  <div class="eppb-shell">
    <h2 class="eppb-title">
      Payment <b>Gateways</b>, Checkout &amp; <b>Reporting</b>
    </h2>
    <p class="eppb-subtitle">
      Connect your gateway, configure pricing, and track every transaction in real time.
    </p>

    <nav class="eppb-nav" aria-label="Event payment processing workflows">
      {tabs.map((tab, index) => (
        <button
          class={`eppb-tab${index === 0 ? " eppb-tab--active" : ""}`}
          data-eppb-tab={index}
          aria-selected={index === 0 ? "true" : "false"}
          type="button"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    {tabs.map((tab, tabIndex) => (
      <div
        class={`eppb-panel${tabIndex === 0 ? " eppb-panel--active" : ""}`}
        data-eppb-panel={tabIndex}
      >
        <div class="eppb-grid">
          <article class="eppb-card eppb-card--hero" style={`--card-delay:${0.04}s;`}>
            <div class="eppb-card__content">
              <span class="eppb-card__eyebrow">{tab.hero.eyebrow}</span>
              <h3 class="eppb-card__title">{tab.hero.title}</h3>
              <p class="eppb-card__desc">{tab.hero.desc}</p>

              <ul class="eppb-point-list">
                {tab.hero.points.map((point) => <li>{point}</li>)}
              </ul>
            </div>

            <div class={`eppb-art eppb-art--hero eppb-art--${tab.hero.visual}`} aria-hidden="true">
              {tab.hero.visual === "gateways" && (
                <Fragment>
                  <div class="eppb-gw-stack">
                    <div class="eppb-gw-card eppb-gw-card--stripe">
                      <div class="eppb-gw-logo">
                        <span class="eppb-gw-dot" style="background:#635bff"></span>
                        <span class="eppb-gw-name">Stripe</span>
                      </div>
                      <span class="eppb-gw-status">Connected</span>
                    </div>
                    <div class="eppb-gw-card eppb-gw-card--razorpay">
                      <div class="eppb-gw-logo">
                        <span class="eppb-gw-dot" style="background:#072654"></span>
                        <span class="eppb-gw-name">Razorpay</span>
                      </div>
                      <span class="eppb-gw-status">Connected</span>
                    </div>
                    <div class="eppb-gw-card eppb-gw-card--tap">
                      <div class="eppb-gw-logo">
                        <span class="eppb-gw-dot" style="background:#2ac3a2"></span>
                        <span class="eppb-gw-name">Tap</span>
                      </div>
                      <span class="eppb-gw-status">Connected</span>
                    </div>
                  </div>
                  <div class="eppb-gw-line"></div>
                  <div class="eppb-gw-badge">
                    <span class="eppb-gw-check">&#10003;</span>
                    <span>OAuth</span>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "checkout" && (
                <Fragment>
                  <div class="eppb-checkout-form">
                    <div class="eppb-checkout-tier">
                      <span class="eppb-checkout-tier-name">Early Bird</span>
                      <strong class="eppb-checkout-tier-price">$49</strong>
                    </div>
                    <div class="eppb-checkout-tier eppb-checkout-tier--active">
                      <span class="eppb-checkout-tier-name">Regular</span>
                      <strong class="eppb-checkout-tier-price">$99</strong>
                    </div>
                    <div class="eppb-checkout-tier">
                      <span class="eppb-checkout-tier-name">VIP</span>
                      <strong class="eppb-checkout-tier-price">$199</strong>
                    </div>
                    <div class="eppb-checkout-promo">
                      <span class="eppb-checkout-promo-input"></span>
                      <span class="eppb-checkout-promo-btn">Apply</span>
                    </div>
                    <div class="eppb-checkout-total">
                      <span>Total</span>
                      <strong>$99.00</strong>
                    </div>
                  </div>
                </Fragment>
              )}

              {tab.hero.visual === "reporting" && (
                <Fragment>
                  <div class="eppb-rev-dash">
                    <div class="eppb-rev-topbar">
                      <div class="eppb-rev-dots"><span></span><span></span><span></span></div>
                      <span class="eppb-rev-title-bar"></span>
                    </div>
                    <div class="eppb-rev-body">
                      <div class="eppb-rev-widget">
                        <span class="eppb-rev-widget-label">Revenue</span>
                        <strong class="eppb-rev-widget-val">$24,850</strong>
                      </div>
                      <div class="eppb-rev-widget">
                        <span class="eppb-rev-widget-label">Refunds</span>
                        <strong class="eppb-rev-widget-val">$320</strong>
                      </div>
                      <div class="eppb-rev-chart">
                        <span style="--h:35%"></span>
                        <span style="--h:55%"></span>
                        <span style="--h:45%"></span>
                        <span style="--h:80%"></span>
                        <span style="--h:65%"></span>
                        <span style="--h:90%"></span>
                      </div>
                    </div>
                  </div>
                  <div class="eppb-rev-live-dot">
                    <span class="eppb-live-pulse"></span>
                    LIVE
                  </div>
                </Fragment>
              )}
            </div>
          </article>

          {tab.cards.map((card, cardIndex) => (
            <article class="eppb-card eppb-card--mini" style={`--card-delay:${(cardIndex + 1) * 0.08}s;`}>
              <div class="eppb-card__content">
                <span class="eppb-card__eyebrow">{card.eyebrow}</span>
                <h3 class="eppb-card__title">{card.title}</h3>
                <p class="eppb-card__desc">{card.desc}</p>
              </div>

              <div class={`eppb-art eppb-art--mini eppb-art--${card.visual}`} aria-hidden="true">
                {card.visual === "razorpay" && (
                  <Fragment>
                    <div class="eppb-pay-methods">
                      <div class="eppb-pay-chip">UPI</div>
                      <div class="eppb-pay-chip">Cards</div>
                      <div class="eppb-pay-chip">Wallets</div>
                    </div>
                    <div class="eppb-pay-badge" style="background:rgba(7,38,84,0.1);color:#072654">Razorpay</div>
                    <div class="eppb-mini-chip">India</div>
                  </Fragment>
                )}

                {card.visual === "tap" && (
                  <Fragment>
                    <div class="eppb-pay-methods">
                      <div class="eppb-pay-chip">KNET</div>
                      <div class="eppb-pay-chip">mada</div>
                      <div class="eppb-pay-chip">Visa</div>
                    </div>
                    <div class="eppb-pay-badge" style="background:rgba(42,195,162,0.1);color:#2ac3a2">Tap</div>
                    <div class="eppb-mini-chip">MENA</div>
                  </Fragment>
                )}

                {card.visual === "offline" && (
                  <Fragment>
                    <div class="eppb-offline-icon">
                      <svg viewBox="0 0 48 48" class="eppb-offline-svg" width="48" height="48">
                        <rect x="8" y="6" width="32" height="36" rx="3" fill="none" stroke="#375dfb" stroke-width="2.5"/>
                        <path d="M16 16h16M16 22h12M16 28h8" stroke="#375dfb" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
                        <circle cx="36" cy="36" r="8" fill="#22c55e" opacity="0.2"/>
                        <path d="M32 36l3 3 5-5" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <div class="eppb-mini-chip">Manual entry</div>
                  </Fragment>
                )}

                {card.visual === "comp" && (
                  <Fragment>
                    <div class="eppb-comp-ticket">
                      <div class="eppb-comp-ticket-body">
                        <span class="eppb-comp-ticket-line"></span>
                        <span class="eppb-comp-ticket-line eppb-comp-ticket-line--short"></span>
                      </div>
                      <div class="eppb-comp-discount-badge">100% OFF</div>
                    </div>
                    <div class="eppb-mini-chip">Complimentary</div>
                  </Fragment>
                )}

                {card.visual === "promo" && (
                  <Fragment>
                    <div class="eppb-promo-input">
                      <span class="eppb-promo-code">EARLY20</span>
                      <span class="eppb-promo-apply">&#10003;</span>
                    </div>
                    <div class="eppb-promo-result">
                      <span class="eppb-promo-original">$99</span>
                      <span class="eppb-promo-final">$79.20</span>
                    </div>
                    <div class="eppb-mini-chip">-20% applied</div>
                  </Fragment>
                )}

                {card.visual === "group" && (
                  <Fragment>
                    <div class="eppb-group-stack">
                      <div class="eppb-group-ticket"></div>
                      <div class="eppb-group-ticket"></div>
                      <div class="eppb-group-ticket"></div>
                    </div>
                    <div class="eppb-group-badge">x3 Group</div>
                    <div class="eppb-mini-chip">Group buy</div>
                  </Fragment>
                )}

                {card.visual === "currency" && (
                  <Fragment>
                    <div class="eppb-currency-selector">
                      <span class="eppb-currency-sym eppb-currency-sym--active">$</span>
                      <span class="eppb-currency-sym">&#8377;</span>
                      <span class="eppb-currency-sym">AED</span>
                    </div>
                    <div class="eppb-mini-chip">Multi-currency</div>
                  </Fragment>
                )}

                {card.visual === "tax" && (
                  <Fragment>
                    <div class="eppb-tax-receipt">
                      <div class="eppb-tax-row">
                        <span>Subtotal</span>
                        <span>$99.00</span>
                      </div>
                      <div class="eppb-tax-row eppb-tax-row--tax">
                        <span>VAT (5%)</span>
                        <span>$4.95</span>
                      </div>
                      <div class="eppb-tax-row eppb-tax-row--total">
                        <span>Total</span>
                        <strong>$103.95</strong>
                      </div>
                    </div>
                    <div class="eppb-mini-chip">Tax config</div>
                  </Fragment>
                )}

                {card.visual === "txexport" && (
                  <Fragment>
                    <div class="eppb-csv-file">
                      <div class="eppb-csv-header">
                        <span></span><span></span><span></span>
                      </div>
                      <div class="eppb-csv-row"><span></span><span></span><span class="eppb-csv-amount">$99</span></div>
                      <div class="eppb-csv-row"><span></span><span></span><span class="eppb-csv-amount">$49</span></div>
                      <div class="eppb-csv-row"><span></span><span></span><span class="eppb-csv-amount">$199</span></div>
                    </div>
                    <div class="eppb-mini-chip">CSV export</div>
                  </Fragment>
                )}

                {card.visual === "reconcile" && (
                  <Fragment>
                    <div class="eppb-reconcile-panels">
                      <div class="eppb-reconcile-panel">
                        <span class="eppb-reconcile-label">EventHex</span>
                        <div class="eppb-reconcile-row"></div>
                        <div class="eppb-reconcile-row"></div>
                      </div>
                      <div class="eppb-reconcile-divider">
                        <span>&#10003;</span>
                      </div>
                      <div class="eppb-reconcile-panel">
                        <span class="eppb-reconcile-label">Gateway</span>
                        <div class="eppb-reconcile-row"></div>
                        <div class="eppb-reconcile-row"></div>
                      </div>
                    </div>
                    <div class="eppb-mini-chip">Matched</div>
                  </Fragment>
                )}

                {card.visual === "rollup" && (
                  <Fragment>
                    <div class="eppb-rollup-chart">
                      <div class="eppb-rollup-bar">
                        <span class="eppb-rollup-seg" style="--h:40%;background:#375dfb"></span>
                        <span class="eppb-rollup-seg" style="--h:25%;background:#22c55e"></span>
                        <span class="eppb-rollup-seg" style="--h:15%;background:#f59e0b"></span>
                      </div>
                      <div class="eppb-rollup-bar">
                        <span class="eppb-rollup-seg" style="--h:50%;background:#375dfb"></span>
                        <span class="eppb-rollup-seg" style="--h:30%;background:#22c55e"></span>
                      </div>
                      <div class="eppb-rollup-bar">
                        <span class="eppb-rollup-seg" style="--h:35%;background:#375dfb"></span>
                        <span class="eppb-rollup-seg" style="--h:20%;background:#22c55e"></span>
                        <span class="eppb-rollup-seg" style="--h:25%;background:#f59e0b"></span>
                      </div>
                    </div>
                    <div class="eppb-mini-chip">Multi-event</div>
                  </Fragment>
                )}

                {card.visual === "revreport" && (
                  <Fragment>
                    <div class="eppb-pie">
                      <svg viewBox="0 0 64 64" class="eppb-pie-svg">
                        <circle cx="32" cy="32" r="24" fill="none" stroke="#375dfb" stroke-width="12" stroke-dasharray="75.4 150.8" stroke-dashoffset="0"/>
                        <circle cx="32" cy="32" r="24" fill="none" stroke="#22c55e" stroke-width="12" stroke-dasharray="37.7 150.8" stroke-dashoffset="-75.4"/>
                        <circle cx="32" cy="32" r="24" fill="none" stroke="#f59e0b" stroke-width="12" stroke-dasharray="25.1 150.8" stroke-dashoffset="-113.1"/>
                        <circle cx="32" cy="32" r="24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="12" stroke-dasharray="12.6 150.8" stroke-dashoffset="-138.2"/>
                      </svg>
                    </div>
                    <div class="eppb-mini-chip">Revenue split</div>
                  </Fragment>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".eppb-shell").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll(".eppb-tab"));
      const panels = Array.from(root.querySelectorAll(".eppb-panel"));

      const activate = (index) => {
        tabs.forEach((tab, tabIndex) => {
          const selected = tabIndex === index;
          tab.classList.toggle("eppb-tab--active", selected);
          tab.setAttribute("aria-selected", selected ? "true" : "false");
        });

        panels.forEach((panel, panelIndex) => {
          panel.classList.toggle("eppb-panel--active", panelIndex === index);
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => activate(index));
      });
    });
  });
</script>

<style>
  .eppb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }

  .eppb-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .eppb-title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -1px;
    text-align: center;
    color: var(--heading-dark);
    margin: 0 0 12px;
  }

  .eppb-title b { font-weight: 700; }

  .eppb-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--subheading-gray);
    text-align: center;
    max-width: 620px;
    margin: 0 auto 32px;
  }

  .eppb-nav {
    display: flex;
    justify-content: center;
    background: #F0F2F5;
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto 32px;
    max-width: 560px;
    gap: 4px;
  }

  .eppb-tab {
    flex: 1;
    padding: 10px 20px;
    border: none;
    border-radius: 50px;
    background: transparent;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #475467;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .eppb-tab:hover,
  .eppb-tab:focus-visible {
    color: #16327b;
    outline: none;
  }

  .eppb-tab--active {
    background: var(--brand-blue);
    color: #ffffff;
    box-shadow: 0 2px 8px rgba(55, 93, 251, 0.3);
  }

  .eppb-panel { display: none; }
  .eppb-panel--active { display: block; }

  .eppb-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    grid-template-areas:
      "hero mini1 mini2"
      "hero mini3 mini4";
    gap: 1rem;
  }

  .eppb-panel--active .eppb-card {
    animation: eppb-fade-up 0.6s ease both;
    animation-delay: var(--card-delay, 0s);
  }

  @keyframes eppb-fade-up {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .eppb-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(166, 186, 255, 0.62);
    box-shadow: 0 30px 70px -48px rgba(27, 55, 142, 0.45);
    min-height: 205px;
  }

  .eppb-card::after {
    content: "";
    position: absolute;
    inset: auto -20% -45% 35%;
    height: 70%;
    background: radial-gradient(circle, rgba(55, 93, 251, 0.14), transparent 70%);
    pointer-events: none;
  }

  .eppb-card--hero {
    grid-area: hero;
    align-content: space-between;
    padding: 1.5rem;
    min-height: 430px;
  }

  .eppb-card--mini {
    padding: 1.2rem;
    grid-template-rows: auto 1fr;
  }

  .eppb-card--mini:nth-of-type(2) { grid-area: mini1; }
  .eppb-card--mini:nth-of-type(3) { grid-area: mini2; }
  .eppb-card--mini:nth-of-type(4) { grid-area: mini3; }
  .eppb-card--mini:nth-of-type(5) { grid-area: mini4; }

  .eppb-card__content { position: relative; z-index: 1; }

  .eppb-card__eyebrow {
    display: inline-flex;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: rgba(18, 34, 74, 0.06);
    color: #45608e;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .eppb-card__title {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.1rem, 1.4vw, 1.5rem);
    line-height: 1.18;
    color: #14213b;
  }

  .eppb-card__desc {
    margin: 0;
    color: #566884;
    line-height: 1.65;
    font-size: 0.96rem;
  }

  .eppb-point-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .eppb-point-list li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: #243a61;
    font-weight: 600;
  }

  .eppb-point-list li::before {
    content: "";
    flex: 0 0 0.6rem;
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e, #38bdf8);
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.14);
  }

  .eppb-art { position: relative; z-index: 1; min-height: 146px; }
  .eppb-art--hero { min-height: 228px; margin-top: 0.6rem; }
  .eppb-art--mini { align-self: end; }

  /* === Hero visual: gateways === */
  .eppb-gw-stack {
