---
import { eppbIllustrations as ill } from "./illustrations";

const tabs = [
  {
    label: "Supported Gateways",
    hero: {
      title: "Stripe, Razorpay, and Tap Payments with one-click OAuth connection",
      desc: "Connect your existing gateway account with one OAuth click. Revenue settles directly to your bank on your gateway's normal schedule — EventHex is never in the payment flow.",
      visual: "gateways",
    },
    cards: [
      { title: "Razorpay", desc: "Accept UPI, net banking, cards, and wallets in India with 0% EventHex fees.", visual: "razorpay" },
      { title: "Tap Payments", desc: "Accept KNET, mada, Visa, and Mastercard in the GCC and MENA region.", visual: "tap" },
      { title: "Offline Payments", desc: "Record cash, cheque, and bank transfer payments manually in EventHex.", visual: "offline" },
      { title: "Complimentary Tickets", desc: "Issue 100% discount codes or mark registrations as complimentary.", visual: "comp" },
    ],
  },
  {
    label: "Checkout & Pricing",
    hero: {
      title: "Multi-tier tickets, promo codes, group purchases, and tax configuration",
      desc: "Create unlimited ticket types with early-bird windows, group discounts, and promo codes. Configure currency display, tax lines, and automatic tier switching.",
      visual: "checkout",
    },
    cards: [
      { title: "Promo & Discount Codes", desc: "Percentage or fixed-amount coupons with usage limits and expiry dates.", visual: "promo" },
      { title: "Group Purchases", desc: "Buy tickets for multiple people in one checkout with separate registrations.", visual: "group" },
      { title: "Currency Display", desc: "Set your event currency — attendees see prices in your chosen currency.", visual: "currency" },
      { title: "Tax & VAT", desc: "Add configurable tax lines displayed at checkout and on receipts.", visual: "tax" },
    ],
  },
  {
    label: "Refunds & Reporting",
    hero: {
      title: "Automated refunds, revenue dashboards, transaction export, and reconciliation",
      desc: "Process refunds from the dashboard, track real-time revenue, export transactions for accounting, and reconcile with your gateway.",
      visual: "reporting",
    },
    cards: [
      { title: "Transaction Export", desc: "Export all transactions as CSV or Excel with payment date, amount, and fees.", visual: "txexport" },
      { title: "Reconciliation View", desc: "Match EventHex transactions against your gateway with side-by-side view.", visual: "reconcile" },
      { title: "Revenue Roll-Up", desc: "Aggregate revenue across all events in the centralized dashboard.", visual: "rollup" },
      { title: "Revenue Reports", desc: "Gross sales, net revenue, gateway fees, and revenue by ticket type.", visual: "revreport" },
    ],
  },
];

const ICON = '<svg class="eppb-card__icon" width="24" height="24" viewBox="0 0 32 32" fill="none"><rect x="2" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="2" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="2" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/><rect x="18" y="18" width="12" height="12" rx="3" fill="#B4BAC6"/></svg>';
const layouts = ["a", "b", "c"];
---

<section class="eppb-section" id="epp-bento">
  <div class="eppb">
    <h2 class="eppb-title">
      Payment <b>Gateways</b>, Checkout &amp; <b>Reporting</b>
    </h2>
    <p class="eppb-subtitle">
      Connect your gateway, configure pricing, and track every transaction in real time.
    </p>

    <nav class="eppb-nav">
      {tabs.map((t, i) => (
        <button class={`eppb-tab ${i === 0 ? "eppb-tab--active" : ""}`} data-eppb-tab={String(i)}>{t.label}</button>
      ))}
    </nav>

    {tabs.map((t, tabIdx) => (
      <div class={`eppb-panel ${tabIdx === 0 ? "eppb-panel--active" : ""}`} data-eppb-panel={String(tabIdx)}>
        <div class="eppb-grid" data-layout={layouts[tabIdx % 3]}>
          <div class="eppb-card eppb-card--tall eppb-pos-0" style="animation-delay:0s">
            <div class="eppb-card__inner">
              <div class="eppb-card__text">
                <Fragment set:html={ICON} />
                <h3 class="eppb-card__title">{t.hero.title}</h3>
                <p class="eppb-card__desc">{t.hero.desc}</p>
              </div>
              <div class="eppb-card__img" set:html={ill[t.hero.visual]} />
            </div>
          </div>
          {t.cards.map((c, ci) => (
            <div class={`eppb-card eppb-card--sm eppb-pos-${ci + 1}`} style={`animation-delay:${((ci + 1) * 0.06).toFixed(2)}s`}>
              <div class="eppb-card__inner eppb-card__inner--row">
                <div class="eppb-card__text">
                  <Fragment set:html={ICON} />
                  <h3 class="eppb-card__title">{c.title}</h3>
                  <p class="eppb-card__desc">{c.desc}</p>
                </div>
                <div class="eppb-card__img eppb-card__img--sm" set:html={ill[c.visual]} />
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const eppbTabs = Array.from(document.querySelectorAll('[data-eppb-tab]'));
  const eppbPanels = Array.from(document.querySelectorAll('[data-eppb-panel]'));
  let eppbActive = 0;
  let eppbInterval: ReturnType<typeof setInterval>;

  function setEppbTab(index: number) {
    eppbTabs.forEach((t) => t.classList.remove('eppb-tab--active'));
    eppbPanels.forEach((p) => p.classList.remove('eppb-panel--active'));
    eppbTabs[index]?.classList.add('eppb-tab--active');
    eppbPanels[index]?.classList.add('eppb-panel--active');
    eppbActive = index;
  }
  function startEppb() {
    eppbInterval = setInterval(() => setEppbTab((eppbActive + 1) % eppbTabs.length), 5000);
  }
  eppbTabs.forEach((tab, i) => tab.addEventListener('click', () => { setEppbTab(i); clearInterval(eppbInterval); startEppb(); }));
  startEppb();
  const eppbSection = document.querySelector('.eppb-section');
  if (eppbSection) {
    eppbSection.addEventListener('mouseenter', () => clearInterval(eppbInterval));
    eppbSection.addEventListener('mouseleave', () => startEppb());
  }
</script>

<style>
  .eppb-section {
    padding: 80px 0 60px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center center / cover no-repeat;
  }
  .eppb { max-width: 1260px; margin: 0 auto; padding: 0 24px; }
  .eppb-title {
    font-family: var(--font-heading);
    font-size: 42px; font-weight: 400; line-height: 1.1; letter-spacing: -1px;
    text-align: center; color: var(--heading-dark); margin: 0 0 12px;
  }
  .eppb-title b { font-weight: 700; }
  .eppb-subtitle {
    font-family: var(--font-body); font-size: 18px; line-height: 1.6;
    color: var(--subheading-gray); text-align: center; max-width: 620px; margin: 0 auto 40px;
  }

  .eppb-nav {
    display: flex; justify-content: center; gap: 0;
    background: #F0F2F5; border-radius: 50px; padding: 4px; width: fit-content; margin: 0 auto 40px;
  }
  .eppb-tab {
    background: transparent; border: none; border-radius: 50px; padding: 10px 32px;
    font-family: var(--font-body); font-size: 15px; font-weight: 500; color: #4D5A6B;
    cursor: pointer; transition: all 0.3s cubic-bezier(.4,0,.2,1); white-space: nowrap;
  }
  .eppb-tab:hover { background: rgba(55,93,251,.08); }
  .eppb-tab--active {
    background: var(--brand-blue) !important; color: #fff !important;
    box-shadow: 0 2px 8px rgba(55,93,251,0.3);
  }

  .eppb-panel { display: none; }
  .eppb-panel--active { display: block; animation: eppbFadeUp 0.4s ease; }
  @keyframes eppbFadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .eppb-grid {
    display: grid; grid-template-columns: 1fr 1fr 1fr; grid-template-rows: 1fr 1fr;
    gap: 14px; height: 460px;
  }
  .eppb-pos-0 { grid-column: 1; grid-row: 1 / 3; }
  .eppb-pos-1 { grid-column: 2; grid-row: 1; }
  .eppb-pos-2 { grid-column: 3; grid-row: 1; }
  .eppb-pos-3 { grid-column: 2; grid-row: 2; }
  .eppb-pos-4 { grid-column: 3; grid-row: 2; }
  [data-layout="b"] .eppb-pos-0 { grid-column: 3; grid-row: 1 / 3; }
  [data-layout="b"] .eppb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="b"] .eppb-pos-2 { grid-column: 2; grid-row: 1; }
  [data-layout="b"] .eppb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="b"] .eppb-pos-4 { grid-column: 2; grid-row: 2; }
  [data-layout="c"] .eppb-pos-0 { grid-column: 2; grid-row: 1 / 3; }
  [data-layout="c"] .eppb-pos-1 { grid-column: 1; grid-row: 1; }
  [data-layout="c"] .eppb-pos-2 { grid-column: 3; grid-row: 1; }
  [data-layout="c"] .eppb-pos-3 { grid-column: 1; grid-row: 2; }
  [data-layout="c"] .eppb-pos-4 { grid-column: 3; grid-row: 2; }

  @property --eppb-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .eppb-card {
    position: relative;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2; border-radius: 20px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    opacity: 0; animation: eppbCardIn 0.5s ease forwards;
  }
  .eppb-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--eppb-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .eppb-card:hover {
    transform: translateY(-3px); box-shadow: 0 8px 32px rgba(55,93,251,0.12); border-color: rgba(55,93,251,0.15);
  }
  .eppb-card:hover::after { opacity: 1; animation: eppbBorder 2.4s linear infinite; }
  @keyframes eppbBorder { to { --eppb-angle: 360deg; } }
  @keyframes eppbCardIn { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
  .eppb-pos-1 { animation-delay: 0.06s; }
  .eppb-pos-2 { animation-delay: 0.12s; }
  .eppb-pos-3 { animation-delay: 0.18s; }
  .eppb-pos-4 { animation-delay: 0.24s; }

  .eppb-card__inner { display: flex; flex-direction: column; height: 100%; }
  .eppb-card__inner--row { flex-direction: row; }
  .eppb-card__text { display: flex; flex-direction: column; gap: 6px; }
  .eppb-card--tall .eppb-card__text { padding: 20px 20px 8px; }
  .eppb-card--sm .eppb-card__text { padding: 20px 8px 20px 20px; flex: 1 1 55%; }
  .eppb-card__icon { margin-bottom: 8px; flex-shrink: 0; }
  .eppb-card__title {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700; line-height: 1.3;
    color: var(--heading-dark); margin: 0 0 6px;
  }
  .eppb-card--sm .eppb-card__title { font-size: 17px; }
  .eppb-card__desc { font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: #667085; margin: 0; }
  .eppb-card--sm .eppb-card__desc { font-size: 13px; }

  .eppb-card__img {
    display: flex; align-items: flex-end; justify-content: center; overflow: hidden;
    background: radial-gradient(125% 80% at 50% 100%, rgba(55,93,251,.07), transparent 72%);
  }
  .eppb-card--tall .eppb-card__img { flex: 1; padding: 0 12px; min-height: 0; }
  .eppb-card--sm .eppb-card__img { flex: 0 0 42%; padding: 8px 8px 0 0; }
  .eppb-card__img :global(svg) {
    width: 100%; height: auto; max-width: none;
    filter: drop-shadow(0 8px 16px rgba(31,52,128,.12));
    transition: transform 0.4s cubic-bezier(.4,0,.2,1), filter 0.4s ease;
  }
  .eppb-card:hover .eppb-card__img :global(svg) {
    transform: translateY(-6px) scale(1.05); filter: drop-shadow(0 14px 22px rgba(31,52,128,.18));
    animation: eppbFloat 2.2s ease-in-out infinite;
  }
  @keyframes eppbFloat { 0%,100% { transform: translateY(-6px) scale(1.05); } 50% { transform: translateY(-12px) scale(1.05); } }

  @media (max-width: 1024px) {
    .eppb-section { padding: 60px 0 48px; }
    .eppb-title { font-size: 36px; }
    .eppb-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; height: auto; }
    .eppb-pos-0 { grid-column: 1 / -1; grid-row: auto; }
    .eppb-pos-1, .eppb-pos-2, .eppb-pos-3, .eppb-pos-4 { grid-column: auto; grid-row: auto; }
    [data-layout="b"] .eppb-pos-0, [data-layout="c"] .eppb-pos-0 { grid-column: 1 / -1; }
    [data-layout="b"] .eppb-pos-1, [data-layout="b"] .eppb-pos-2, [data-layout="b"] .eppb-pos-3, [data-layout="b"] .eppb-pos-4,
    [data-layout="c"] .eppb-pos-1, [data-layout="c"] .eppb-pos-2, [data-layout="c"] .eppb-pos-3, [data-layout="c"] .eppb-pos-4 { grid-column: auto; grid-row: auto; }
    .eppb-card--tall .eppb-card__inner { flex-direction: row; }
    .eppb-card--tall .eppb-card__text { flex: 1; }
    .eppb-card--tall .eppb-card__img { flex: 0 0 36%; padding: 12px; }
  }
  @media (max-width: 767px) {
    .eppb-title { font-size: 28px; }
    .eppb-subtitle { font-size: 15px; }
    .eppb-nav { flex-direction: column; width: 100%; max-width: 300px; border-radius: 16px; }
    .eppb-tab { border-radius: 12px; }
    .eppb-grid { grid-template-columns: 1fr; }
    .eppb-pos-0, .eppb-pos-1, .eppb-pos-2, .eppb-pos-3, .eppb-pos-4,
    [data-layout="b"] .eppb-pos-0, [data-layout="b"] .eppb-pos-1, [data-layout="b"] .eppb-pos-2, [data-layout="b"] .eppb-pos-3, [data-layout="b"] .eppb-pos-4,
    [data-layout="c"] .eppb-pos-0, [data-layout="c"] .eppb-pos-1, [data-layout="c"] .eppb-pos-2, [data-layout="c"] .eppb-pos-3, [data-layout="c"] .eppb-pos-4 { grid-column: 1; grid-row: auto; }
    .eppb-card--sm .eppb-card__inner, .eppb-card--tall .eppb-card__inner { flex-direction: row; }
    .eppb-card--sm .eppb-card__text, .eppb-card--tall .eppb-card__text { padding: 14px 6px 14px 14px; flex: 1 1 60%; }
    .eppb-card--sm .eppb-card__img, .eppb-card--tall .eppb-card__img { flex: 0 0 38%; padding: 4px 4px 0 0; align-items: flex-end; justify-content: flex-end; }
  }
  @media (prefers-reduced-motion: reduce) {
    .eppb-card { animation: none !important; opacity: 1; transform: none; }
    .eppb-card:hover::after { animation: none !important; }
    .eppb-card:hover .eppb-card__img :global(svg) { animation: none !important; transform: none; }
  }
</style>
