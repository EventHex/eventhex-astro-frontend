---
---

<section class="eppcta">
  <div class="eppcta__card">
    <div class="eppcta__glow eppcta__glow--1"></div>
    <div class="eppcta__glow eppcta__glow--2"></div>
    <div class="eppcta__split">
      <div class="eppcta__content">
        <span class="eppcta__eyebrow animate-on-scroll" data-animation="fadeIn">Zero Platform Fees</span>
        <h2 class="eppcta__title animate-on-scroll" data-animation="fadeInUp">Ready to Stop Paying Platform Fees on Ticket Sales?</h2>
        <p class="eppcta__desc animate-on-scroll" data-animation="fadeInUp">Connect your own gateway and run your next event with zero EventHex processing fees.</p>
        <div class="eppcta__proof-row animate-on-scroll" data-animation="fadeInUp">
          <span class="eppcta__proof-pill">0% platform fees</span>
          <span class="eppcta__proof-pill">3 gateway options</span>
          <span class="eppcta__proof-pill">Free onboarding support</span>
        </div>
        <div class="eppcta__buttons">
          <a href="/book-a-demo/" class="eppcta__btn eppcta__btn--primary">
            Book a Free Demo
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/contact-en/" class="eppcta__btn eppcta__btn--secondary">Contact Sales</a>
        </div>
        <div class="eppcta__trust">
          <span class="eppcta__trust-item">No credit card required</span>
          <span class="eppcta__trust-item">Free onboarding support</span>
          <span class="eppcta__trust-item">Cancel anytime</span>
        </div>
      </div>
      <div class="eppcta__animation">
        <div class="eppcta__lottie" data-lottie-eppcta="/animations/event-payment-processing-cta.json"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const lottieCtaEl = document.querySelector('[data-lottie-eppcta]') as HTMLElement | null;
  if (lottieCtaEl) {
    const src = lottieCtaEl.dataset.lottieEppcta;
    if (src) {
      import('lottie-web').then((lottie) => {
        lottie.default.loadAnimation({
          container: lottieCtaEl,
          renderer: 'svg',
          loop: true,
          autoplay: true,
          path: src,
        });
      });
    }
  }
</script>

<style is:global>
  .eppcta { max-width: 1200px; margin: 0 auto; padding: 60px 20px 80px; }

  .eppcta__card {
    position: relative;
    border-radius: 24px;
    padding: 60px 48px;
    overflow: hidden;
    background: #0F1629;
  }

  .eppcta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .eppcta__glow--1 {
    width: 400px;
    height: 400px;
    background: rgba(55, 93, 251, 0.2);
    top: -100px;
    left: -50px;
  }

  .eppcta__glow--2 {
    width: 300px;
    height: 300px;
    background: rgba(159, 129, 255, 0.15);
    bottom: -80px;
    right: -30px;
  }

  .eppcta__split {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .eppcta__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .eppcta__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    line-height: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .eppcta__title {
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .eppcta__desc {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.65;
    letter-spacing: -0.3px;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .eppcta__proof-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .eppcta__proof-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 9px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    line-height: 18px;
    color: rgba(255, 255, 255, 0.74);
  }

  .eppcta__buttons { display: flex; gap: 12px; }

  .eppcta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.3px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .eppcta__btn--primary {
    background: var(--brand-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(55, 93, 251, 0.35);
  }

  .eppcta__btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(55, 93, 251, 0.4);
  }

  .eppcta__btn--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .eppcta__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .eppcta__trust {
    display: flex;
    gap: 20px;
    align-items: center;
    margin-top: 8px;
  }

  .eppcta__trust-item {
    position: relative;
    padding-left: 14px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.45);
  }

  .eppcta__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
  }

  .eppcta__animation {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .eppcta__lottie {
    width: 100%;
    max-width: 420px;
  }

  @media (max-width: 1024px) {
    .eppcta__card { padding: 48px 32px; }
    .eppcta__split { gap: 2rem; }
    .eppcta__title { font-size: 32px; }
    .eppcta__desc { font-size: 15px; }
    .eppcta__lottie { max-width: 340px; }
  }

  @media (max-width: 767px) {
    .eppcta { padding: 40px 16px 60px; }
    .eppcta__card { padding: 40px 20px; border-radius: 20px; }
    .eppcta__split { grid-template-columns: 1fr; gap: 2rem; }
    .eppcta__content { align-items: center; text-align: center; }
    .eppcta__title { font-size: 28px; line-height: 1.2em; }
    .eppcta__desc { font-size: 15px; }
    .eppcta__proof-row { justify-content: center; gap: 8px; }
    .eppcta__buttons { flex-direction: column; width: 100%; justify-content: center; }
    .eppcta__btn { width: 100%; justify-content: center; }
    .eppcta__trust { flex-direction: column; gap: 8px; justify-content: center; }
    .eppcta__animation { order: -1; }
    .eppcta__lottie { max-width: 280px; }
  }
</style>
