---
import LottiePlayer from "../LottiePlayer.astro";

const heroPoints = [
  "0% EventHex Fees",
  "Bring Your Own Gateway",
  "135+ Currencies",
];

const trustItems = [
];

const metrics = [
];
---

<section class="epph-hero">
  <div class="epph-hero__shell">
    <div class="epph-hero__grid">
      <div class="epph-hero__content">
        <div class="epph-hero__badge animate-on-scroll" data-animation="fadeInDown">
          <span>Event Payment Processing</span>
        </div>

        <h1 class="epph-hero__title animate-on-scroll" data-animation="fadeInUp">
          Accept Payments via <b>Any Gateway.</b>
          <span><b>Zero Platform Fees.</b></span>
        </h1>

        <p class="epph-hero__desc animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 800ms">
          Connect your own Stripe, Razorpay, or Tap Payments account to EventHex and keep 100% of your ticket revenue. No per-ticket charge, no hidden fees — just your gateway's standard processing rate.
        </p>

        <div class="epph-hero__cta animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 1100ms">
          <a href="/book-a-demo/" class="epph-hero__btn epph-hero__btn--primary">Book a Demo</a>
          <a href="#epp-bento" class="epph-hero__btn epph-hero__btn--secondary">Explore Features</a>
        </div>
      </div>

      <div class="epph-hero__visual animate-on-scroll" data-animation="fadeInRight">
        <LottiePlayer src="/animations/event-payment-processing-hero.json" class="epph-hero__lottie" />
      </div>
    </div>
  </div>
</section>


<style is:global>
  .epph-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    padding: 0 0 220px;
    background:
      radial-gradient(circle at 16% 22%, rgba(175, 163, 255, 0.16), transparent 24%),
      radial-gradient(circle at 82% 20%, rgba(171, 255, 255, 0.16), transparent 26%),
      url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp') center center / cover no-repeat;
  }

  .epph-hero__shell {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 160px 0 0;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp') center center / cover no-repeat;
  }

  .epph-hero__grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .epph-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .epph-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .epph-hero__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 600;
    line-height: 60px;
    letter-spacing: -1px;
    color: var(--heading-dark);
  }

  .epph-hero__title span {
    display: block;
    color: var(--brand-blue);
  }

  .epph-hero__desc {
    margin: 0;
    max-width: 580px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .epph-hero__cta {
    display: flex;
    gap: 14px;
    padding-top: 6px;
  }

  .epph-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.48px;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, border-color 0.3s;
  }

  .epph-hero__btn--primary {
    color: #fff;
    background: var(--brand-blue);
    box-shadow: 0 10px 24px rgba(55, 93, 251, 0.28);
  }

  .epph-hero__btn--primary:hover {
    transform: translateY(-2px);
    background: var(--brand-blue-hover);
    box-shadow: 0 14px 30px rgba(55, 93, 251, 0.34);
  }

  .epph-hero__btn--secondary {
    color: var(--heading-dark);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid #dce4ff;
  }

  .epph-hero__btn--secondary:hover {
    transform: translateY(-2px);
    border-color: #c5d2ff;
    box-shadow: 0 10px 24px rgba(34, 39, 47, 0.06);
  }

  .epph-hero__trust {
    display: none;
  }

  .epph-hero__trust-item {
    position: relative;
    padding-left: 16px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #667085;
  }

  .epph-hero__trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
  }

  .epph-hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .epph-hero__lottie {
    width: 100%;
    max-width: 580px;
  }

  .epph-hero__lottie svg {
    width: 100% !important;
    height: auto !important;
  }

  @media (max-width: 1120px) {
    .epph-hero { padding: 0 20px 110px; }
    .epph-hero__shell { padding: 136px 0 0; }
    .epph-hero__grid { gap: 28px; padding: 0 0 40px; }
    .epph-hero__desc { max-width: 520px; }
    .epph-hero__title { font-size: 46px; line-height: 1.1em; }
  }

  @media (max-width: 960px) {
    .epph-hero { padding: 0 20px 96px; }
    .epph-hero__shell { padding: 130px 0 0; }
    .epph-hero__grid { grid-template-columns: 1fr; gap: 34px; padding: 0 0 40px; }
    .epph-hero__content { align-items: center; text-align: center; }
    .epph-hero__desc { max-width: 720px; }
    .epph-hero__trust,
    .epph-hero__cta { justify-content: center; }
    .epph-hero__title { font-size: 42px; line-height: 1.1em; }
    .epph-hero__visual { justify-content: center; }
  }

  @media (max-width: 767px) {
    .epph-hero { margin-top: -80px; padding: 0 20px 90px; }
    .epph-hero__shell { padding: 120px 0 0; }
    .epph-hero__grid { padding: 0 0 30px; }
    .epph-hero__title { font-size: 30px; line-height: 1.2em; letter-spacing: 0; }
    .epph-hero__desc { font-size: 15px; line-height: 1.7; }
    .epph-hero__badge { font-size: 16px; line-height: 1.1em; }
    .epph-hero__cta { width: 100%; flex-direction: column; }
    .epph-hero__btn { width: 100%; }
    .epph-hero__lottie { max-width: 400px; }
  }
</style>
