---
import SharedFaq from "../shared/FaqSection.astro";

const faqs = [
  { q: "Does EventHex charge any fees on ticket sales?", a: "No. EventHex charges zero platform fees on ticket transactions. You pay only your payment gateway's standard processing rate (e.g., Stripe: 2.9% + $0.30 per transaction)." },
  { q: "Which payment gateways are supported?", a: "EventHex natively supports Stripe (global), Razorpay (India), and Tap Payments (MENA/GCC). Support for additional gateways is available via our webhook API." },
  { q: "When does money reach my bank?", a: "EventHex is never in the payment flow — money goes directly from the attendee to your gateway account. Payout timing follows your gateway's schedule (typically T+2 for Stripe, T+3 for Razorpay)." },
  { q: "Can I issue refunds through EventHex?", a: "Yes. Process full or partial refunds from the attendee management dashboard. EventHex calls your gateway's refund API automatically and emails the attendee a confirmation." },
  { q: "Can I accept offline payments?", a: "Yes. Mark registrations as paid manually in EventHex for cash, NEFT, or cheque payments. EventHex issues the confirmation and ticket immediately." },
  { q: "Does EventHex support multi-currency events?", a: "Yes. Set your event currency. Stripe supports 135+ currencies. Attendees pay in the currency you configure; FX conversion is handled at the gateway level." },
];
---

<SharedFaq
  faqs={faqs}
  eyebrow="Need Help?"
  title="Frequently Asked Questions"
  description="Everything you need to know about payment processing and how it works with EventHex."
/>
