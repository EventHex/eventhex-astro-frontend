---
const faqs = [
  {
    q: "Does EventHex charge any fees on ticket sales?",
    a: "No. EventHex charges zero platform fees on ticket transactions. You pay only your payment gateway's standard processing rate (e.g., Stripe: 2.9% + $0.30 per transaction).",
  },
  {
    q: "Which payment gateways are supported?",
    a: "EventHex natively supports Stripe (global), Razorpay (India), and Tap Payments (MENA/GCC). Support for additional gateways is available via our webhook API.",
  },
  {
    q: "When does money reach my bank?",
    a: "EventHex is never in the payment flow — money goes directly from the attendee to your gateway account. Payout timing follows your gateway's schedule (typically T+2 for Stripe, T+3 for Razorpay).",
  },
  {
    q: "Can I issue refunds through EventHex?",
    a: "Yes. Process full or partial refunds from the attendee management dashboard. EventHex calls your gateway's refund API automatically and emails the attendee a confirmation.",
  },
  {
    q: "Can I accept offline payments?",
    a: "Yes. Mark registrations as paid manually in EventHex for cash, NEFT, or cheque payments. EventHex issues the confirmation and ticket immediately.",
  },
  {
    q: "Does EventHex support multi-currency events?",
    a: "Yes. Set your event currency. Stripe supports 135+ currencies. Attendees pay in the currency you configure; FX conversion is handled at the gateway level.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<section class="eppfq" data-epp-faq>
  <div class="eppfq__inner">
    <div class="eppfq__sidebar animate-on-scroll" data-animation="fadeInLeft">
      <span class="eppfq__eyebrow">Need Help?</span>
      <h2 class="eppfq__title">Frequently Asked Questions</h2>
      <p class="eppfq__desc">
        Everything you need to know about payment processing and how it works with EventHex.
      </p>
      <div class="eppfq__support-card">
        <h3 class="eppfq__support-title">Talk to Our Team</h3>
        <p class="eppfq__support-desc">Our experts can walk you through a personalized demo and answer any questions about payment setup.</p>
      </div>
      <a href="/book-a-demo/" class="eppfq__cta">Book a Demo</a>
    </div>

    <div class="eppfq__list">
      {faqs.map((faq, index) => (
        <details class="eppfq__item animate-on-scroll" data-animation="fadeInUp" data-delay={String(index * 60)} data-epp-faq-item>
          <summary class="eppfq__question">
            {faq.q}
            <svg class="eppfq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="eppfq__answer">
            <p>{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

<script>
  const eppFaqItems = Array.from(document.querySelectorAll('[data-epp-faq-item]'));

  eppFaqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (!(item instanceof HTMLDetailsElement) || !item.open) {
        return;
      }

      eppFaqItems.forEach((other) => {
        if (other !== item && other instanceof HTMLDetailsElement) {
          other.open = false;
        }
      });
    });
  });
</script>

<style is:global>
  .eppfq {
    background: var(--surface-light, #f8f9fc);
    padding: 5rem 1.5rem;
  }

  .eppfq__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .eppfq__sidebar {
    position: sticky;
    top: 6rem;
  }

  .eppfq__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-blue);
    margin-bottom: 0.5rem;
  }

  .eppfq__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0 0 0.75rem;
    line-height: 1.25;
  }

  .eppfq__desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0 0 1.25rem;
  }

  .eppfq__support-card {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf4);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .eppfq__support-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0 0 0.35rem;
  }

  .eppfq__support-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin: 0;
  }

  .eppfq__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 1.25rem;
    border-radius: 10px;
    background: var(--brand-blue);
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1;
    transition: background 0.2s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .eppfq__cta:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(55, 93, 251, 0.25);
  }

  .eppfq__list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .eppfq__item {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf4);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .eppfq__item[open] {
    border-color: var(--brand-blue);
  }

  .eppfq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--heading-dark);
    cursor: pointer;
    list-style: none;
  }

  .eppfq__question::-webkit-details-marker,
  .eppfq__question::marker {
    display: none;
  }

  .eppfq__chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
    color: var(--subheading-gray);
  }

  .eppfq__item[open] .eppfq__chevron {
    transform: rotate(180deg);
    color: var(--brand-blue);
  }

  .eppfq__answer {
    padding: 0 1.5rem 1.25rem;
  }

  .eppfq__answer p {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .eppfq__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .eppfq__sidebar {
      position: static;
    }
  }

  @media (max-width: 767px) {
    .eppfq {
      padding: 3rem 1rem;
    }
    .eppfq__title {
      font-size: 1.5rem;
    }
    .eppfq__question {
      padding: 1rem 1.25rem;
      font-size: 0.875rem;
    }
    .eppfq__answer {
      padding: 0 1.25rem 1rem;
    }
    .eppfq__cta {
      width: 100%;
    }
  }
</style>
