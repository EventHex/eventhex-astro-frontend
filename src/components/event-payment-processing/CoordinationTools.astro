---
const cards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="#375DFB" stroke-width="2"/><path d="M12 6v6l4 2" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 12h0" stroke="#22C55E" stroke-width="3" stroke-linecap="round"/></svg>`,
    title: "0% EventHex platform fees",
    desc: "Only pay your gateway's standard rate — nothing extra to EventHex.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="#375DFB" stroke-width="2"/><path d="M2 10h20" stroke="#375DFB" stroke-width="2"/><path d="M6 15h4" stroke="#375DFB" stroke-width="2" stroke-linecap="round"/><circle cx="18" cy="15" r="1" fill="#22C55E"/></svg>`,
    title: "3 leading payment gateways",
    desc: "Stripe (global), Razorpay (India), and Tap Payments (MENA/GCC) supported.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 20V8l4 4 4-8 4 6 4-4v14H3z" fill="rgba(55,93,251,0.1)" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="19" cy="6" r="2" fill="#22C55E"/></svg>`,
    title: "Real-time revenue tracking",
    desc: "Live dashboards, transaction export, and gateway reconciliation in one view.",
  },
];
---

<section class="eppc-full">
  <div class="eppc-full__inner">
    <div class="eppc-full__header">
      <span class="eppc-full__tag animate-on-scroll" data-animation="fadeIn">Why Event Organizers Choose EventHex Payments</span>
      <h2 class="eppc-full__title animate-on-scroll" data-animation="fadeInUp">Zero-Fee <b>Payment Processing</b></h2>
      <p class="eppc-full__desc animate-on-scroll" data-animation="fadeInUp">Accept payments via Stripe, Razorpay, or Tap with zero EventHex platform fees and direct revenue settlement.</p>
    </div>

    <div class="eppc-full__cards">
      {cards.map((card) => (
        <div class="eppc-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="eppc-full__card-icon" set:html={card.icon}></div>
          <h3 class="eppc-full__card-title">{card.title}</h3>
          <p class="eppc-full__card-desc">{card.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .eppc-full {
    width: 100%;
    margin: 0;
    padding: 72px 0;
    background: #000312 url('https://eventhex.ai/wp-content/uploads/2025/03/bg.svg') center / cover no-repeat;
  }

  .eppc-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .eppc-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 680px;
  }

  .eppc-full__tag {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    color: #afa3ff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .eppc-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: #fff;
    margin: 0;
  }

  .eppc-full__title b { font-weight: 700; }

  .eppc-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .eppc-full__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
  }

  .eppc-full__card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: background 0.3s, border-color 0.3s, transform 0.3s;
  }

  .eppc-full__card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(175, 163, 255, 0.35);
    transform: translateY(-2px);
  }

  .eppc-full__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(55, 93, 251, 0.15);
    border-radius: 12px;
  }

  .eppc-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .eppc-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .eppc-full { padding: 64px 0; }
    .eppc-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .eppc-full { padding: 52px 0; }
    .eppc-full__title { font-size: 30px; line-height: 1.15; }
    .eppc-full__desc { font-size: 15px; }
    .eppc-full__cards { grid-template-columns: 1fr; }
  }
</style>
