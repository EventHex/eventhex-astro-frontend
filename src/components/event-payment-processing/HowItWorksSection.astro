---
const steps = [
  {
    num: "01",
    title: "Connect Your Gateway",
    desc: "Go to Payment Settings, select Stripe, Razorpay, or Tap, and complete the OAuth connection in under 60 seconds.",
  },
  {
    num: "02",
    title: "Configure Ticket Pricing",
    desc: "Create ticket types with prices, early-bird windows, group discounts, and promo codes. Add VAT if required.",
  },
  {
    num: "03",
    title: "Start Selling",
    desc: "Publish your event page. Attendees check out through your gateway — revenue settles to your account directly.",
  },
  {
    num: "04",
    title: "Track & Export",
    desc: "Monitor revenue in the dashboard. Export to CSV for accounting or reconcile against your gateway dashboard.",
  },
];
---

<section class="epphw-full">
  <div class="epphw-full__inner">
    <div class="epphw-full__header">
      <span class="epphw-full__tag animate-on-scroll" data-animation="fadeIn">How Event Payment Processing Works</span>
      <h2 class="epphw-full__title animate-on-scroll" data-animation="fadeInUp">From Gateway Connection to <b>Revenue Tracking</b></h2>
      <p class="epphw-full__desc animate-on-scroll" data-animation="fadeInUp">
        Connect your gateway, configure pricing, start selling, and track every transaction.
      </p>
    </div>

    <div class="epphw-full__cards">
      {steps.map((step) => (
        <article class="epphw-full__card animate-on-scroll" data-animation="fadeInUp">
          <div class="epphw-full__card-icon">{step.num}</div>
          <h3 class="epphw-full__card-title">{step.title}</h3>
          <p class="epphw-full__card-desc">{step.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .epphw-full {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 80px 0 120px;
    background: url('https://cms.eventhex.ai/wp-content/uploads/2025/03/Bg.svg') center top / cover no-repeat;
  }

  .epphw-full::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 120px;
    background: linear-gradient(to bottom, transparent, #fff);
    pointer-events: none;
  }

  .epphw-full__inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  .epphw-full__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    max-width: 700px;
  }

  .epphw-full__tag {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 18px;
    color: var(--brand-blue);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .epphw-full__title {
    font-family: var(--font-heading);
    font-size: 42px;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0;
  }

  .epphw-full__title b { font-weight: 700; }

  .epphw-full__desc {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--subheading-gray);
    margin: 0;
  }

  .epphw-full__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    width: 100%;
  }

  .epphw-full__card {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--surface-card-border, #e8ecf2);
    border-radius: 20px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    box-shadow: 0 2px 12px rgba(55, 93, 251, 0.04);
    transition: background 0.3s, border-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }

  .epphw-full__card:hover {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(55, 93, 251, 0.25);
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(55, 93, 251, 0.1);
  }

  .epphw-full__card-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-blue-tint, #e5ebff);
    border-radius: 14px;
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 700;
    color: var(--brand-blue);
  }

  .epphw-full__card-title {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--heading-dark);
    margin: 0;
  }

  .epphw-full__card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.65;
    color: var(--subheading-gray);
    margin: 0;
  }

  @media (max-width: 1100px) {
    .epphw-full__cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 1024px) {
    .epphw-full { padding: 64px 0; }
    .epphw-full__title { font-size: 36px; }
  }

  @media (max-width: 767px) {
    .epphw-full { padding: 52px 0; }
    .epphw-full__title { font-size: 30px; line-height: 1.15; }
    .epphw-full__desc { font-size: 15px; }
    .epphw-full__cards { grid-template-columns: 1fr; }
  }
</style>
