---
import "../styles/design-tokens.css";
import "../styles/animations.css";
import HeaderNew from "../components/home-new/HeaderNew.astro";
import FooterNew from "../components/home-new/FooterNew.astro";
import WhatsAppWidget from "../components/WhatsAppWidget.astro";

interface Props {
  title: string;
  description: string;
  footerCtaTitle?: string;
  footerCtaButtonText?: string;
  footerCtaHref?: string;
  showFooterCta?: boolean;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  publishedTime?: string;
  modifiedTime?: string;
}

const DEFAULT_OG_IMAGE = "https://cms.eventhex.ai/wp-content/uploads/2024/09/eventhex-og-default.png";

const {
  title,
  description,
  footerCtaTitle,
  footerCtaButtonText,
  footerCtaHref,
  showFooterCta = true,
  canonical,
  ogImage,
  ogType = "website",
  robots,
  publishedTime,
  modifiedTime,
} = Astro.props;

const resolvedOgImage = ogImage || DEFAULT_OG_IMAGE;

// Auto-derive canonical from current URL if not explicitly provided
const siteOrigin = (Astro.site?.toString() ?? "https://eventhex.ai").replace(/\/$/, "");
const resolvedCanonical = canonical || `${siteOrigin}${Astro.url.pathname}`;

const organizationSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://eventhex.ai/#organization",
      name: "EventHex",
      url: "https://eventhex.ai",
      logo: {
        "@type": "ImageObject",
        url: "https://cms.eventhex.ai/wp-content/uploads/2024/09/eventhex-logo.png",
      },
      sameAs: [
        "https://www.linkedin.com/company/eventhex/",
        "https://twitter.com/eventhexai",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://eventhex.ai/#website",
      url: "https://eventhex.ai",
      name: "EventHex",
      publisher: { "@id": "https://eventhex.ai/#organization" },
    },
  ],
});

// Auto-generate BreadcrumbList from URL path
function buildBreadcrumbs(pathname: string, siteOrigin: string) {
  const segments = pathname.replace(/\/$/, "").split("/").filter(Boolean);
  if (segments.length === 0) return null; // no breadcrumbs for homepage
  const items = [{ "@type": "ListItem" as const, position: 1, item: { "@id": siteOrigin + "/", name: "Home" } }];
  let path = "";
  for (let i = 0; i < segments.length; i++) {
    path += "/" + segments[i];
    const name = segments[i].replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
    items.push({ "@type": "ListItem" as const, position: i + 2, item: { "@id": siteOrigin + path + "/", name } });
  }
  return JSON.stringify({ "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: items });
}

const breadcrumbSchema = buildBreadcrumbs(Astro.url.pathname, siteOrigin);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="https://cms.eventhex.ai/wp-content/uploads/2024/09/favicon-eventhex.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="dns-prefetch" href="https://cms.eventhex.ai" />
    <link rel="preconnect" href="https://cms.eventhex.ai" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <link rel="canonical" href={resolvedCanonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonical} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <script type="application/ld+json" set:html={organizationSchema} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
    <slot name="head" />
  </head>
  <body>
    <HeaderNew />
    <main>
      <slot />
    </main>
    <FooterNew
      ctaTitle={footerCtaTitle}
      ctaButtonText={footerCtaButtonText}
      ctaHref={footerCtaHref}
      showCta={showFooterCta}
    />
    <WhatsAppWidget />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const anim = el.dataset.animation || "fadeIn";
              const delay = parseInt(el.dataset.delay || "0", 10);
              setTimeout(() => {
                el.classList.add("is-visible");
                el.style.animationName = anim;
              }, delay);
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.15 }
      );

      document.querySelectorAll(".animate-on-scroll").forEach((el) => observer.observe(el));
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--font-body);
        color: var(--heading-dark);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }
      img { max-width: 100%; height: auto; }
      a { color: inherit; }
    </style>
  </body>
</html>
