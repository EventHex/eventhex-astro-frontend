---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event CRM Integration",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Sync event attendees, registrations, speakers, and exhibitors directly to your CRM. Native HubSpot integration with bidirectional contact sync, field mapping, deals, and custom fields.",
  url: "https://eventhex.ai/crm-integrations/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "HubSpot Bidirectional Contact Sync",
    "Field Mapping",
    "Deal Creation from Registrations",
    "Custom Field Support",
    "Attendee Sync",
    "Speaker & Exhibitor Sync",
    "Manual Resync",
    "Salesforce Integration (Roadmap)",
    "Zoho & Pipedrive Integration (Roadmap)",
  ],
};
---

<FeatureV2Layout
  pageTitle="Event CRM Integration — Sync Attendees to HubSpot & More | EventHex"
  pageDescription="Sync event attendees, registrations, speakers, and exhibitors to your CRM automatically. Native HubSpot integration with bidirectional contact sync, field mapping, and deal creation."
  canonical="https://eventhex.ai/crm-integrations/"
  badge="Event CRM Integration"
  heroTitleLine1="Your Event Data,"
  heroTitleLine2="Straight Into Your CRM"
  heroCopy="Every attendee, speaker, and exhibitor that interacts with your event flows directly into HubSpot — with the right fields, the right deals, and the right lifecycle stage. No manual exports. No data gaps."
  trustItems={["HubSpot Bidirectional Sync", "Field Mapping Wizard", "Attendee & Exhibitor Sync"]}
  stats={[
    { value: "1-click", label: "HubSpot Connection" },
    { value: "100%", label: "Bidirectional Sync" },
    { value: "4+", label: "Object Types Synced" },
    { value: "0", label: "Manual Exports Needed" },
  ]}
  statsHeadline={{
    white1: "Event data,",
    accent: "CRM-ready.",
    white2: "Zero manual",
    accent2: "exports",
  }}
  bentoHeading="Everything Marketing & RevOps Teams Need"
  bentoSubtitle="Connect EventHex to your CRM once, and every attendee registration, speaker profile, and exhibitor record flows in automatically — with full control over field mapping, deals, and sync behavior."
  bentoTabs={[
    {
      tab: "HubSpot Sync",
      cards: [
        { title: "Bidirectional Contact Sync", desc: "Attendees created or updated in EventHex sync to HubSpot contacts — and changes in HubSpot flow back", illustration: ILLOS.refresh },
        { title: "Lifecycle Stage Mapping", desc: "Map registration status to HubSpot lifecycle stages — move leads to MQL or customer automatically on event actions", illustration: ILLOS.chart },
        { title: "Attendees, Speakers & Exhibitors", desc: "All participant types — attendees, speakers, and exhibitors — sync as separate HubSpot contact records with role context", illustration: ILLOS.user },
        { title: "Manual Resync", desc: "Trigger a full resync at any time from the EventHex dashboard without re-configuring your integration", illustration: ILLOS.refresh },
        { title: "Sync Status Visibility", desc: "See per-record sync status and error logs so your team always knows what's in HubSpot and what isn't", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "Field Mapping",
      cards: [
        { title: "Visual Field Mapper", desc: "Map any EventHex registration field to any HubSpot contact property using a point-and-click interface", illustration: ILLOS.clipboard },
        { title: "Custom Field Support", desc: "Custom registration fields you've built in EventHex can be mapped to custom HubSpot properties — no hardcoded schema", illustration: ILLOS.clipboard },
        { title: "Default Field Presets", desc: "Common fields like name, email, phone, company, and job title are pre-mapped out of the box for fast setup", illustration: ILLOS.clipboard },
        { title: "Multi-Event Mapping Profiles", desc: "Create different field mapping profiles per event type — conference attendees and webinar registrants can map to different HubSpot properties", illustration: ILLOS.network },
        { title: "Validation & Preview", desc: "Preview exactly how a record will look in HubSpot before your first sync runs — catch mapping errors early", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "Pipeline & Deals",
      cards: [
        { title: "Deal Creation from Registrations", desc: "Automatically create a HubSpot deal when a paid registration is confirmed — link it to the contact and set stage from event data", illustration: ILLOS.chart },
        { title: "Deal Stage Automation", desc: "Move deals through pipeline stages based on event milestones: registered, attended, checked in, or no-show", illustration: ILLOS.chart },
        { title: "Revenue Attribution", desc: "Ticket revenue from EventHex flows into HubSpot deal amounts, giving RevOps a single source of truth for event-driven pipeline", illustration: ILLOS.chart },
        { title: "Association to Companies", desc: "Deals and contacts are automatically associated to HubSpot company records based on email domain or existing company match", illustration: ILLOS.network },
        { title: "Post-Event Follow-Up Lists", desc: "Build HubSpot lists segmented by attendance outcome to trigger nurture sequences for attendees, no-shows, and waitlisted contacts", illustration: ILLOS.mail },
      ],
    },
  ]}
  stackingHeading="CRM Integration"
  stackingHighlight="Built for Revenue Teams"
  stackingCards={[
    {
      title: "HubSpot Connected in Minutes, Not Days",
      desc: "Authenticate with HubSpot in one click, apply a field mapping preset, and your first sync runs immediately. Attendees registered yesterday are already in your CRM — no Zapier, no middleware, no custom code.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "EventHex CRM integration dashboard showing HubSpot sync status and contact records",
    },
    {
      title: "Map Every Custom Field You've Built",
      desc: "If you collect dietary preferences, job seniority, or budget range on your registration form, those answers can land directly in the right HubSpot property. The field mapper gives you full control with no developer involvement.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Field mapping wizard connecting EventHex registration fields to HubSpot contact properties",
    },
    {
      title: "Event Pipeline — All the Way to Closed Revenue",
      desc: "Paid registrations become HubSpot deals automatically. Attendance status moves those deals through your pipeline. Your sales team sees event-driven pipeline in HubSpot without touching EventHex.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "HubSpot pipeline with deals created automatically from EventHex paid registrations",
    },
  ]}
  howItWorksHeading="How CRM Integration Works"
  steps={[
    { title: "Connect Your CRM", desc: "Authenticate HubSpot from the EventHex integrations panel. The connection takes under two minutes — no API keys to copy manually." },
    { title: "Map Your Fields", desc: "Use the visual field mapper to link EventHex registration fields to HubSpot contact properties. Apply a preset or build a custom mapping profile per event type." },
    { title: "Sync Runs Automatically", desc: "From that point on, every new registration, speaker profile, and exhibitor record syncs to HubSpot in real time. Paid registrations also create deals in your pipeline." },
    { title: "Segment & Follow Up", desc: "Use HubSpot lists, workflows, and sequences to act on event data — nurture no-shows, upsell attendees, and close event-driven pipeline." },
  ]}
  ctaTitle="Ready to Turn Event Data into CRM Pipeline?"
  ctaCopy="See how EventHex connects your events to HubSpot so every attendee, exhibitor, and speaker lands in the right place — automatically."
  whyHeading="Why Marketing & RevOps Teams Choose EventHex"
  whyCards={[
    { title: "Native HubSpot Integration", desc: "Fully built bidirectional sync — not a Zapier workaround", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>' },
    { title: "Full Field Control", desc: "Map any custom registration field to any CRM property", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
    { title: "Deal Automation", desc: "Paid registrations create HubSpot deals without manual work", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>' },
    { title: "All Participant Types", desc: "Attendees, speakers, and exhibitors all sync to HubSpot", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
    { title: "Roadmap Integrations", desc: "Salesforce, Zoho, and Pipedrive integrations coming soon", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>' },
  ]}
  faqs={[
    { q: "Which CRM does EventHex integrate with today?", a: "EventHex has a fully built, native HubSpot integration with bidirectional contact sync, field mapping, deal creation, and custom field support. Salesforce, Zoho, and Pipedrive integrations are on the roadmap." },
    { q: "What does 'bidirectional sync' mean?", a: "Bidirectional sync means data flows both ways. Attendees created in EventHex appear in HubSpot, and updates made to those contacts in HubSpot can flow back into EventHex. This keeps both systems in agreement without manual reconciliation." },
    { q: "Can I map my custom registration fields to HubSpot?", a: "Yes. Any custom field you've built in EventHex — dropdown, text, checkbox, or file upload — can be mapped to any standard or custom HubSpot contact property using the visual field mapper." },
    { q: "Does EventHex sync speakers and exhibitors to HubSpot, or only attendees?", a: "All participant types sync: attendees, speakers, and exhibitors each become HubSpot contact records, with their role and event context included as properties." },
    { q: "How are deals created in HubSpot?", a: "When a paid registration is confirmed in EventHex, a HubSpot deal is created automatically — linked to the contact, associated to their company if one exists, and set to the deal stage you've configured. Ticket revenue flows into the deal amount." },
    { q: "Can I trigger a manual resync?", a: "Yes. From the EventHex integrations dashboard, you can trigger a full resync at any time. Individual record errors are shown in the sync log so you can identify and fix issues without re-running a full sync." },
  ]}
  jsonLd={jsonLd}
/>
