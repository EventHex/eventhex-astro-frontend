---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/ai-session-recap/HeroSection.astro";
import StatsSection from "../components/ai-session-recap/StatsSection.astro";
import BentoGrid from "../components/ai-session-recap/BentoGrid.astro";
import FeatureCards from "../components/ai-session-recap/FeatureCards.astro";
import HowItWorksSection from "../components/ai-session-recap/HowItWorksSection.astro";
import CTASection from "../components/ai-session-recap/CTASection.astro";
import CoordinationTools from "../components/ai-session-recap/CoordinationTools.astro";
import FaqSection from "../components/ai-session-recap/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "AI Session Recap — Auto Transcription & Summaries | EventHex";
const description = "AI session recap that auto-transcribes talks, generates summaries, extracts key takeaways, and publishes shareable recap pages — no manual work required.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex InstaRecap AI Session Recap",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/ai-session-recap/",
  description,
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Real-time AI transcription",
    "Automated session summaries and key takeaways",
    "25+ language support for transcription",
    "SEO-optimized recap pages",
    "Speaker quotes extraction",
    "Topic classification",
    "Email digest and recap delivery",
    "Speaker analytics dashboard",
    "Social sharing snippets",
    "PDF report export",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/ai-session-recap/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
