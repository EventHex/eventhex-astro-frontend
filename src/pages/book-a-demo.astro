</style>

<script define:vars={{ bookingApiBase, legacyDemoApi, fallbackConfig }}>
  const stageOrder = ["date", "time", "details"];
  const state = {
    activeStage: "date",
    activeMonth: new Date(new Date().getFullYear(), new Date().getMonth(), 1),
    selectedDate: "",
    selectedTime: "",
    config: { ...fallbackConfig },
    availabilityByMonth: new Map(),
    pluginAvailable: true,
  };

  const refs = {
    month: document.getElementById("demo-calendar-month"),
    grid: document.getElementById("demo-calendar-grid"),
    slots: document.getElementById("demo-slots"),
    selectedDate: document.getElementById("demo-selected-date"),
    selectedSlot: document.getElementById("demo-selected-slot"),
    summaryDate: document.getElementById("demo-summary-date"),
    summaryTime: document.getElementById("demo-summary-time"),
    banner: document.getElementById("demo-booking-banner"),
    message: document.getElementById("demo-form-message"),
    submitButton: document.getElementById("demo-submit-button"),
    form: document.getElementById("eventhex-demo-form"),
    stages: document.querySelectorAll("[data-stage]"),
    stepBadges: document.querySelectorAll("[data-step-badge]"),
    titleTargets: document.querySelectorAll("[data-demo-title]"),
    durationTargets: document.querySelectorAll("[data-demo-duration]"),
    locationTargets: document.querySelectorAll("[data-demo-location]"),
    timezoneTargets: document.querySelectorAll("[data-demo-timezone]"),
    slotCountTargets: document.querySelectorAll("[data-demo-slot-count]"),
    windowTargets: document.querySelectorAll("[data-demo-window]"),
    syncStatusTargets: document.querySelectorAll("[data-demo-sync-status]"),
    prevMonth: document.querySelector('[data-calendar-nav="prev"]'),
    nextMonth: document.querySelector('[data-calendar-nav="next"]'),
  };

  const monthFormatter = new Intl.DateTimeFormat("en-US", { month: "long", year: "numeric" });

  function monthKey(date) {
    return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;
  }

  function formatDateLabel(dateString) {
    return new Intl.DateTimeFormat("en-US", {
      weekday: "long",
      month: "long",
      day: "numeric",
    }).format(new Date(`${dateString}T12:00:00`));
  }

  function formatTimeLabel(timeString) {
    const [hours, minutes] = timeString.split(":").map(Number);
    const date = new Date();
    date.setHours(hours || 0, minutes || 0, 0, 0);
    return new Intl.DateTimeFormat("en-US", { hour: "numeric", minute: "2-digit" }).format(date);
  }

  function showBanner(message) {
    refs.banner.hidden = false;
    refs.banner.textContent = message;
  }

  function hideBanner() {
    refs.banner.hidden = true;
    refs.banner.textContent = "";
  }

  function showMessage(message, type) {
    refs.message.hidden = false;
    refs.message.className = `demo-form__message is-${type}`;
    refs.message.textContent = message;
  }

  function clearMessage() {
    refs.message.hidden = true;
    refs.message.className = "demo-form__message";
    refs.message.textContent = "";
  }

  function applySyncStatus() {
    const label = state.pluginAvailable ? "Live WordPress availability" : "Fallback availability mode";
    refs.syncStatusTargets.forEach((node) => {
      node.textContent = label;
      node.classList.toggle("is-fallback", !state.pluginAvailable);
    });
  }

  function applyConfig(config) {
    state.config = { ...state.config, ...config };
    refs.titleTargets.forEach((node) => {
      node.textContent = state.config.meeting_title;
    });
    refs.durationTargets.forEach((node) => {
      node.textContent = `${state.config.meeting_duration} min`;
    });
    refs.locationTargets.forEach((node) => {
      node.textContent = state.config.meeting_location;
    });
    refs.timezoneTargets.forEach((node) => {
      node.textContent = state.config.timezone;
    });
    refs.slotCountTargets.forEach((node) => {
      node.textContent = String(Array.isArray(state.config.time_slots) ? state.config.time_slots.length : 0);
    });
    refs.windowTargets.forEach((node) => {
      node.textContent = `${state.config.booking_window_days} days`;
    });
  }

  function setStage(stage) {
    state.activeStage = stage;
    refs.stages.forEach((node) => {
      node.classList.toggle("is-active", node.dataset.stage === stage);
    });
    refs.stepBadges.forEach((node) => {
      const stepIndex = stageOrder.indexOf(node.dataset.stepBadge || "");
      const activeIndex = stageOrder.indexOf(stage);
      node.classList.toggle("is-active", stepIndex === activeIndex);
      node.classList.toggle("is-complete", stepIndex < activeIndex);
    });
  }

  function buildFallbackAvailability(monthDate) {
    const availability = {};
    const start = new Date(monthDate.getFullYear(), monthDate.getMonth(), 1);
    const end = new Date(monthDate.getFullYear(), monthDate.getMonth() + 1, 0);
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const windowEnd = new Date(today);
    windowEnd.setDate(windowEnd.getDate() + state.config.booking_window_days);

    for (let cursor = new Date(start); cursor <= end; cursor.setDate(cursor.getDate() + 1)) {
      const currentDay = new Date(cursor);
      currentDay.setHours(0, 0, 0, 0);

      if (currentDay < today || currentDay > windowEnd) {
        continue;
      }

      if (!state.config.working_days.includes(cursor.getDay())) {
        continue;
      }

      const dateString = `${cursor.getFullYear()}-${String(cursor.getMonth() + 1).padStart(2, "0")}-${String(cursor.getDate()).padStart(2, "0")}`;
      availability[dateString] = state.config.time_slots.map((slot) => ({
        value: slot,
        label: formatTimeLabel(slot),
      }));
    }

    return availability;
  }

  async function loadMonthAvailability(monthDate) {
    const key = monthKey(monthDate);
    if (state.availabilityByMonth.has(key)) {
      return state.availabilityByMonth.get(key);
    }

    if (!state.pluginAvailable) {
      applySyncStatus();
      const fallback = buildFallbackAvailability(monthDate);
      state.availabilityByMonth.set(key, fallback);
      return fallback;
    }

    try {
      const response = await fetch(`${bookingApiBase}/availability?month=${key}`);
      if (!response.ok) {
        throw new Error("Booking plugin not available");
      }

      const payload = await response.json();
      if (payload.config) {
        applyConfig(payload.config);
      }

      const availability = payload.availability || {};
      state.availabilityByMonth.set(key, availability);
      state.pluginAvailable = true;
      applySyncStatus();
      hideBanner();
      return availability;
    } catch (_error) {
      state.pluginAvailable = false;
      applySyncStatus();
      showBanner("The standalone booking plugin is not deployed yet. The calendar UI is live, and submissions are temporarily falling back to the current demo endpoint.");
      const fallback = buildFallbackAvailability(monthDate);
      state.availabilityByMonth.set(key, fallback);
      return fallback;
    }
  }

  async function renderCalendar() {
    const monthStart = new Date(state.activeMonth.getFullYear(), state.activeMonth.getMonth(), 1);
    const monthEnd = new Date(state.activeMonth.getFullYear(), state.activeMonth.getMonth() + 1, 0);
    const availability = await loadMonthAvailability(monthStart);

    refs.month.textContent = monthFormatter.format(monthStart);
    refs.grid.innerHTML = "";

    for (let index = 0; index < monthStart.getDay(); index += 1) {
      const empty = document.createElement("div");
      empty.className = "demo-calendar__empty";
      refs.grid.appendChild(empty);
    }

    for (let day = 1; day <= monthEnd.getDate(); day += 1) {
      const dateString = `${monthStart.getFullYear()}-${String(monthStart.getMonth() + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
      const slots = availability[dateString] || [];
      const button = document.createElement("button");
      button.type = "button";
      button.className = "demo-calendar__day";
      button.innerHTML = `<span>${day}</span><small>${slots.length ? `${slots.length} open` : "Unavailable"}</small>`;

      if (!slots.length) {
        button.disabled = true;
        button.classList.add("is-disabled");
      }

      if (state.selectedDate === dateString) {
        button.classList.add("is-selected");
      }

      button.addEventListener("click", async () => {
        state.selectedDate = dateString;
        state.selectedTime = "";
        refs.selectedDate.textContent = formatDateLabel(dateString);
        refs.selectedSlot.textContent = "Select a time slot";
        refs.summaryDate.textContent = formatDateLabel(dateString);
        refs.summaryTime.textContent = "-";
        setStage("time");
        await renderCalendar();
        await renderSlots();
      });

      refs.grid.appendChild(button);
    }

    const currentMonth = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    if (refs.prevMonth) {
      refs.prevMonth.disabled = monthKey(monthStart) === monthKey(currentMonth);
    }

    if (refs.nextMonth) {
      const nextMonth = new Date(monthStart.getFullYear(), monthStart.getMonth() + 1, 1);
      const nextAvailability = await loadMonthAvailability(nextMonth);
      refs.nextMonth.disabled = Object.keys(nextAvailability).length === 0;
    }
  }

  async function renderSlots() {
    if (!state.selectedDate) {
      refs.slots.innerHTML = '<div class="demo-empty">Choose a date to see available time slots.</div>';
      return;
    }

    const selectedDate = new Date(`${state.selectedDate}T12:00:00`);
    const availability = await loadMonthAvailability(new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1));
    const slots = availability[state.selectedDate] || [];
    refs.selectedDate.textContent = formatDateLabel(state.selectedDate);

    if (!slots.length) {
      refs.slots.innerHTML = '<div class="demo-empty">That date no longer has any free slots. Pick another date.</div>';
      return;
    }

    refs.slots.innerHTML = "";
    slots.forEach((slot) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "demo-slot";
      if (state.selectedTime === slot.value) {
        button.classList.add("is-selected");
      }
      button.innerHTML = `
        <span class="demo-slot__primary">${slot.label}</span>
        <span class="demo-slot__meta">
          <span>${state.config.meeting_duration} min</span>
          <span>${state.config.timezone}</span>
        </span>
      `;
      button.addEventListener("click", () => {
        state.selectedTime = slot.value;
        renderSummary();
        setStage("details");
        void renderSlots();
      });
      refs.slots.appendChild(button);
    });
  }

  function renderSummary() {
    if (!state.selectedDate || !state.selectedTime) {
      refs.selectedSlot.textContent = "Select a time slot";
      refs.summaryDate.textContent = state.selectedDate ? formatDateLabel(state.selectedDate) : "-";
      refs.summaryTime.textContent = "-";
      return;
    }

    refs.selectedSlot.textContent = `${formatDateLabel(state.selectedDate)} at ${formatTimeLabel(state.selectedTime)}`;
    refs.summaryDate.textContent = formatDateLabel(state.selectedDate);
    refs.summaryTime.textContent = `${formatTimeLabel(state.selectedTime)} (${state.config.timezone})`;
  }

  async function submitLegacy(payload) {
    const legacyPayload = {
      "name-1": payload.name,
      "email-1": payload.email,
      "phone-1": payload.phone,
      "text-1": payload.company,
      "text-2": payload.job_title,
      "select-1": payload.country,
      "date-1": payload.event_date || payload.booking_date,
      "select-2": payload.attendees,
      "select-3": payload.event_type,
      "select-4": payload.module_interest,
      "select-5": payload.hear_about,
      "textarea-1": payload.notes,
      "checkbox-1": "agreed",
      ehf_hp_field: payload.hp_field,
    };

    const response = await fetch(legacyDemoApi, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(legacyPayload),
    });
    const result = await response.json().catch(() => ({}));

    if (!response.ok || !result.success) {
      throw new Error(result.message || "The fallback form submission failed.");
    }

    return result;
  }

  async function submitBooking(payload) {
    if (!state.pluginAvailable) {
      return submitLegacy(payload);
    }

    const response = await fetch(`${bookingApiBase}/book`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });
    const result = await response.json().catch(() => ({}));

    if (!response.ok) {
      if (response.status === 404 || response.status >= 500) {
        state.pluginAvailable = false;
        applySyncStatus();
        showBanner("The standalone booking plugin is not active yet. Submissions are using the current fallback endpoint until it is deployed.");
        return submitLegacy(payload);
      }
      throw new Error(result.message || "Could not confirm the booking.");
    }

    return result;
  }

  async function handleSubmit(event) {
    event.preventDefault();
    clearMessage();

    if (!state.selectedDate || !state.selectedTime) {
      showMessage("Pick a date and time before submitting the form.", "error");
      setStage("date");
      return;
    }

    const formData = new FormData(refs.form);
    const payload = {
      name: String(formData.get("name") || "").trim(),
      email: String(formData.get("email") || "").trim(),
      company: String(formData.get("company") || "").trim(),
      phone: String(formData.get("phone") || "").trim(),
      job_title: String(formData.get("job_title") || "").trim(),
      country: String(formData.get("country") || "").trim(),
      event_date: String(formData.get("event_date") || "").trim(),
      attendees: String(formData.get("attendees") || "").trim(),
      event_type: String(formData.get("event_type") || "").trim(),
      module_interest: String(formData.get("module_interest") || "").trim(),
      hear_about: String(formData.get("hear_about") || "").trim(),
      notes: String(formData.get("notes") || "").trim(),
      hp_field: String(formData.get("hp_field") || ""),
      booking_date: state.selectedDate,
      booking_time: state.selectedTime,
    };

    refs.submitButton.disabled = true;
    refs.submitButton.textContent = "Confirming...";

    try {
      const result = await submitBooking(payload);
      refs.form.reset();
      state.selectedDate = "";
      state.selectedTime = "";
      refs.selectedDate.textContent = "Choose a date first";
      refs.selectedSlot.textContent = "Select a time slot";
      refs.summaryDate.textContent = "-";
      refs.summaryTime.textContent = "-";
      showMessage(result.message || state.config.success_message, "success");
      setStage("date");
      await renderCalendar();
      await renderSlots();
    } catch (error) {
      showMessage(error instanceof Error ? error.message : "Something went wrong while confirming the booking.", "error");
    } finally {
      refs.submitButton.disabled = false;
      refs.submitButton.textContent = "Confirm Demo";
    }
  }

  if (refs.form && refs.grid && refs.slots && refs.month) {
    refs.prevMonth?.addEventListener("click", async () => {
      state.activeMonth = new Date(state.activeMonth.getFullYear(), state.activeMonth.getMonth() - 1, 1);
      await renderCalendar();
      await renderSlots();
    });

    refs.nextMonth?.addEventListener("click", async () => {
      state.activeMonth = new Date(state.activeMonth.getFullYear(), state.activeMonth.getMonth() + 1, 1);
      await renderCalendar();
      await renderSlots();
    });

    document.querySelectorAll("[data-back-stage]").forEach((button) => {
      button.addEventListener("click", async () => {
        const stage = button.getAttribute("data-back-stage") || "date";
        setStage(stage);
        if (stage === "time") {
          await renderSlots();
        }
      });
    });

    refs.form.addEventListener("submit", handleSubmit);
    applyConfig(fallbackConfig);
    applySyncStatus();
    renderSummary();
    void renderCalendar();
    void renderSlots();
  }
</script>
