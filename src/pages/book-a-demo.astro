<script>
  const WP_URL = 'https://cms.eventhex.ai';

  /* ── Helper: open / close modals ─────────────── */
  function openModal(id: string) {
    const el = document.getElementById(id);
    if (!el) return;
    el.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeModal(id: string) {
    const el = document.getElementById(id);
    if (!el) return;
    el.style.display = 'none';
    document.body.style.overflow = '';
  }

  // Close buttons & backdrops
  document.querySelectorAll('.bd-modal').forEach((modal) => {
    const id = modal.id;
    modal.querySelector('.bd-modal__close')?.addEventListener('click', () => closeModal(id));
    modal.querySelector('.bd-modal__backdrop')?.addEventListener('click', () => closeModal(id));
  });
  document.getElementById('bd-success-close')?.addEventListener('click', () => closeModal('bd-success-modal'));
  document.getElementById('bd-error-close')?.addEventListener('click', () => closeModal('bd-error-modal'));

  // Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.bd-modal').forEach((m) => {
        if ((m as HTMLElement).style.display !== 'none') closeModal(m.id);
      });
    }
  });

  /* ── Policy modals ───────────────────────────── */
  const policyCache: Record<string, { title: string; html: string }> = {};

  document.querySelectorAll('.bd-link-btn[data-modal]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const type = (btn as HTMLElement).dataset.modal!;
      const slug = type === 'privacy' ? 'privacy-policy' : 'terms-of-service';
      const titleEl = document.getElementById('bd-policy-title')!;
      const bodyEl = document.getElementById('bd-policy-body')!;

      if (policyCache[slug]) {
        titleEl.textContent = policyCache[slug].title;
        bodyEl.innerHTML = policyCache[slug].html;
      } else {
        titleEl.textContent = 'Loading…';
        bodyEl.innerHTML = '<div class="bd-modal__loading">Loading content…</div>';
      }

      openModal('bd-policy-modal');

      if (!policyCache[slug]) {
        try {
          const res = await fetch(`${WP_URL}/wp-json/wp/v2/pages?slug=${slug}&_fields=title,content`);
          const pages = await res.json();
          if (pages.length) {
            const t = pages[0].title.rendered;
            const h = pages[0].content.rendered;
            policyCache[slug] = { title: t, html: h };
            titleEl.textContent = t;
            bodyEl.innerHTML = h;
          } else {
            bodyEl.innerHTML = '<p>Content not available. Please visit the page directly.</p>';
          }
        } catch {
          bodyEl.innerHTML = '<p>Failed to load content. Please try again later.</p>';
        }
      }
    });
  });

  /* ── Geo-detection: auto-select country code + country ── */
  (async function detectCountry() {
    try {
      let cc = '';
      let ip = '';

      // Try Cloudflare trace first (fastest, works on CF-hosted sites)
      try {
        const cfRes = await fetch('/cdn-cgi/trace', { signal: AbortSignal.timeout(2000) });
        const cfText = await cfRes.text();
        const match = cfText.match(/loc=([A-Z]{2})/);
        if (match) cc = match[1];
        const ipMatch = cfText.match(/ip=([^\s]+)/);
        if (ipMatch) ip = ipMatch[1];
      } catch { /* fall through */ }

      // Fallback to ipwho.is
      if (!cc) {
        const res = await fetch('https://ipwho.is/', { signal: AbortSignal.timeout(3000) });
        const geo = await res.json();
        if (geo.success && geo.country_code) cc = geo.country_code;
        if (geo.success && geo.ip) ip = geo.ip;
      }

      if (ip && ipField) {
        ipField.value = ip;
      }

      if (!cc) return;

      // Auto-select country dropdown
      const countrySelect = document.getElementById('country-select') as HTMLSelectElement;
      if (countrySelect) {
        const opt = countrySelect.querySelector(`option[value="${cc}"]`);
        if (opt) countrySelect.value = cc;
      }

      // Auto-select phone country code
      const phoneCode = document.getElementById('phone-code') as HTMLSelectElement;
      if (phoneCode) {
        const codeOpt = phoneCode.querySelector(`option[data-country="${cc}"]`) as HTMLOptionElement;
        if (codeOpt) phoneCode.value = codeOpt.value;
      }
    } catch {
      // Silently fail — user can pick manually
    }
  })();

  // Populate hidden attribution fields
  const ipField = document.getElementById('attr-ip') as HTMLInputElement;
  const uaField = document.getElementById('attr-ua') as HTMLInputElement;
  const refField = document.getElementById('attr-referrer') as HTMLInputElement;
  const landField = document.getElementById('attr-landing') as HTMLInputElement;
  const notesField = document.getElementById('attr-notes') as HTMLInputElement;

  if (uaField) {
    uaField.value = navigator.userAgent || 'Unknown';
  }
  if (refField) {
    refField.value = document.referrer || 'Direct / None';
  }
  if (landField) {
    landField.value = window.location.href;
  }
  
  // Capture Microsoft Clarity Player Link
  if (notesField) {
    let clarityAttempts = 0;
    const captureClarity = () => {
      const getCookie = (name: string) => {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) {
          return decodeURIComponent(parts.pop()!.split(';').shift()!);
        }
        return null;
      };

      const clck = getCookie('_clck');
      const clsk = getCookie('_clsk');

      if (clck && clsk) {
        const userId = clck.split(/[|^]/)[0];
        const sessionId = clsk.split(/[|^]/)[0];
        if (userId && sessionId) {
          notesField.value = `Clarity Player Link: https://clarity.microsoft.com/player/wvcezfdsb6/${userId}/${sessionId}`;
          return;
        }
      }

      clarityAttempts++;
      if (clarityAttempts < 15) {
        setTimeout(captureClarity, 1000);
      }
    };
    setTimeout(captureClarity, 1000);
  }

  // Modules of Interest Custom Multiselect logic
  const multiselect = document.getElementById('module-multiselect');
  const trigger = document.getElementById('multiselect-trigger');
  const msLabel = trigger?.querySelector('.bd-multiselect__label');
  const checkboxes = document.querySelectorAll('#multiselect-dropdown input[type="checkbox"]');

  if (multiselect && trigger && msLabel) {
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      multiselect.classList.toggle('bd-multiselect--active');
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!multiselect.contains(e.target as Node)) {
        multiselect.classList.remove('bd-multiselect--active');
      }
    });

    const updateLabel = () => {
      const selected: string[] = [];
      checkboxes.forEach((cb: any) => {
        if (cb.checked) {
          const text = cb.nextElementSibling?.textContent?.trim() || '';
          // Remove emoji from trigger text for clean appearance
          selected.push(text.replace(/[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDC00-\uDFFF]/g, '').trim());
        }
      });

      if (selected.length === 0) {
        msLabel.textContent = "Modules of Interest (Select all that apply)";
        msLabel.style.color = "#868C98"; // placeholder gray
      } else if (selected.length <= 2) {
        msLabel.textContent = selected.join(', ');
        msLabel.style.color = "var(--heading-dark)";
      } else {
        msLabel.textContent = `${selected.slice(0, 2).join(', ')} (+${selected.length - 2} more)`;
        msLabel.style.color = "var(--heading-dark)";
      }
    };

    checkboxes.forEach((cb) => {
      cb.addEventListener('change', updateLabel);
    });

    // Initialize
    updateLabel();
  }

  // Initialize Flatpickr on #demo-datetime
  const tomorrow = new Date();
  tomorrow.setDate(tomorrow.getDate() + 1);
  
  const initFlatpickr = () => {
    if (typeof (window as any).flatpickr === 'function') {
      (window as any).flatpickr("#demo-datetime", {
        enableTime: true,
        dateFormat: "l, F j, Y \\at h:i K",
        minDate: tomorrow,
        minuteIncrement: 30,
        disableMobile: "true"
      });
    } else {
      setTimeout(initFlatpickr, 100);
    }
  };
  initFlatpickr();

  /* ── Form submission ─────────────────────────── */
  document.getElementById('ehf-demo-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const btnText = btn.querySelector('.bd-form__submit-text') as HTMLElement;
    const spinner = btn.querySelector('.bd-form__submit-spinner') as HTMLElement;
    const fd = new FormData(form);

    const data: Record<string, any> = {};
    for (const [key, val] of fd.entries()) {
      if (data[key] !== undefined) {
        if (!Array.isArray(data[key])) {
          data[key] = [data[key]];
        }
        data[key].push(val as string);
      } else {
        data[key] = val as string;
      }
    }
    const cb = form.querySelector('[name="checkbox-1"]') as HTMLInputElement;
    if (cb?.checked) {
      data['checkbox-1'] = 'agreed';
    }
    // Prepend country code to phone
    const codeSelect = document.getElementById('phone-code') as HTMLSelectElement;
    if (codeSelect && data['phone-1']) {
      data['phone-1'] = codeSelect.value + ' ' + data['phone-1'];
    }
    btn.disabled = true;
    btnText.textContent = 'Sending…';
    spinner.style.display = 'inline';

    try {
      const res = await fetch(`${WP_URL}/wp-json/ehf/v1/submit/book-a-demo`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (res.ok && json.success) {
        form.reset();
        openModal('bd-success-modal');
      } else {
        throw new Error(json.message || 'Submission failed.');
      }
    } catch (err: any) {
      document.getElementById('bd-error-text')!.textContent =
        err.message || 'Something went wrong. Please try again.';
      openModal('bd-error-modal');
    } finally {
      btn.disabled = false;
      btnText.textContent = 'Request a Demo';
      spinner.style.display = 'none';
    }
  });
</script>
