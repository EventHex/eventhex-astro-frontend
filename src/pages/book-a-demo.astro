---
import MarketingLayout from "../layouts/MarketingLayout.astro";

const title = "Book a Demo - EventHex";
const description = "Book a focused EventHex walkthrough with a calendar-first scheduling experience.";
const wpUrl = import.meta.env.WP_URL || "https://eventhex.ai";
const bookingApiBase = `${wpUrl}/wp-json/eventhex-demo/v1`;
const legacyDemoApi = `${wpUrl}/wp-json/ehf/v1/submit/book-a-demo`;

const fallbackConfig = {
  meeting_title: "EventHex AI Product Demo",
  meeting_duration: 30,
  timezone: "Asia/Kolkata",
  meeting_location: "Google Meet link shared after confirmation",
  booking_window_days: 45,
  working_days: [1, 2, 3, 4, 5],
  time_slots: ["10:00", "10:30", "11:00", "11:30", "14:00", "14:30", "15:00", "15:30"],
  success_message: "Your demo request has been received. Check your inbox for the next step.",
};
---

<MarketingLayout {title} {description}>
  <section class="demo-booking">
    <div class="demo-booking__shell">
      <aside class="demo-sidebar">
        <div class="demo-sidebar__badges">
          <span class="demo-pill"><span data-demo-duration>{fallbackConfig.meeting_duration} min</span> meeting</span>
          <span class="demo-pill demo-pill--ghost" data-demo-sync-status>Live WordPress availability</span>
        </div>

        <p class="demo-sidebar__kicker">Live Product Session</p>
        <h1 class="demo-sidebar__title">
          Book a focused <span class="demo-sidebar__title-accent"><span data-demo-duration>{fallbackConfig.meeting_duration} min</span> walkthrough</span> without the usual back-and-forth.
        </h1>
        <p class="demo-sidebar__lead">
          Choose a live slot controlled from WordPress. Confirmation, admin alerts, reminder email, and follow-up
          are already wired into the same booking flow.
        </p>

        <div class="demo-sidebar__journey">
          <div class="demo-journey-card">
            <span class="demo-journey-card__index">01</span>
            <strong>Pick a live slot</strong>
          </div>
          <div class="demo-journey-card">
            <span class="demo-journey-card__index">02</span>
            <strong>Share your details</strong>
          </div>
          <div class="demo-journey-card">
            <span class="demo-journey-card__index">03</span>
            <strong>Team gets notified</strong>
          </div>
          <div class="demo-journey-card">
            <span class="demo-journey-card__index">04</span>
            <strong>Reminder goes out automatically</strong>
          </div>
        </div>

        <div class="demo-sidebar__visual">
          <div class="demo-sidebar__glow"></div>
          <img
            src="https://eventhex.ai/wp-content/uploads/2025/01/iPhone-16-pro-isolated-on-white-background-v11-front-view-copy-1.png"
            alt="EventHex AI on mobile"
            width="250"
            height="500"
            loading="eager"
            class="demo-sidebar__phone"
          />
        </div>

        <div class="demo-sidebar__facts">
          <div class="demo-fact-card">
            <span class="demo-fact-card__label">Session</span>
            <strong class="demo-fact-card__value" data-demo-title>{fallbackConfig.meeting_title}</strong>
          </div>
          <div class="demo-fact-card">
            <span class="demo-fact-card__label">Duration</span>
            <strong class="demo-fact-card__value" data-demo-duration>{fallbackConfig.meeting_duration} min</strong>
          </div>
          <div class="demo-fact-card">
            <span class="demo-fact-card__label">Location</span>
            <strong class="demo-fact-card__value" data-demo-location>{fallbackConfig.meeting_location}</strong>
          </div>
          <div class="demo-fact-card">
            <span class="demo-fact-card__label">Timezone</span>
            <strong class="demo-fact-card__value" data-demo-timezone>{fallbackConfig.timezone}</strong>
          </div>
        </div>
      </aside>

      <div class="demo-scheduler">
        <header class="demo-scheduler__header">
          <div>
            <p class="demo-scheduler__eyebrow">Step-by-Step Booking</p>
            <h2 class="demo-scheduler__title">Pick a live date, lock a time, then send your details.</h2>
          </div>

          <div class="demo-progress" aria-label="Booking progress">
            <span class="demo-progress__step is-active" data-step-badge="date">1 Date</span>
            <span class="demo-progress__step" data-step-badge="time">2 Time</span>
            <span class="demo-progress__step" data-step-badge="details">3 Details</span>
          </div>
        </header>

        <div class="demo-live-strip">
          <div class="demo-live-strip__status">
            <span class="demo-live-strip__dot"></span>
            <span data-demo-sync-status>Live WordPress availability</span>
          </div>
          <p class="demo-live-strip__copy">
            The booking plugin controls duration, schedule, and slot inventory. Change it in WordPress and this
            scheduler reflects it here.
          </p>
          <div class="demo-live-strip__metrics">
            <div class="demo-live-metric">
              <strong data-demo-duration>{fallbackConfig.meeting_duration} min</strong>
              <span>meeting length</span>
            </div>
            <div class="demo-live-metric">
              <strong data-demo-slot-count>{fallbackConfig.time_slots.length}</strong>
              <span>configured starts</span>
            </div>
            <div class="demo-live-metric">
              <strong data-demo-window>{fallbackConfig.booking_window_days} days</strong>
              <span>booking window</span>
            </div>
          </div>
        </div>

        <div class="demo-scheduler__banner" id="demo-booking-banner" hidden></div>

        <div class="demo-scheduler__body">
          <section class="demo-stage is-active" data-stage="date">
            <div class="demo-stage__head">
              <button class="demo-stage__nav" type="button" data-calendar-nav="prev" aria-label="Previous month">&larr;</button>
              <div>
                <p class="demo-stage__label">Available Dates</p>
                <h3 class="demo-stage__title" id="demo-calendar-month">Month</h3>
              </div>
              <button class="demo-stage__nav" type="button" data-calendar-nav="next" aria-label="Next month">&rarr;</button>
            </div>

            <div class="demo-calendar__weekdays" aria-hidden="true">
              <span>Sun</span>
              <span>Mon</span>
              <span>Tue</span>
              <span>Wed</span>
              <span>Thu</span>
              <span>Fri</span>
              <span>Sat</span>
            </div>

            <div class="demo-calendar__grid" id="demo-calendar-grid"></div>
          </section>

          <section class="demo-stage" data-stage="time">
            <div class="demo-stage__head demo-stage__head--split">
              <div>
                <p class="demo-stage__label">Selected Date</p>
                <h3 class="demo-stage__title" id="demo-selected-date">Choose a date first</h3>
              </div>
              <button class="demo-stage__back" type="button" data-back-stage="date">Change date</button>
            </div>

            <div class="demo-slots" id="demo-slots"></div>
          </section>

          <section class="demo-stage" data-stage="details">
            <div class="demo-stage__head demo-stage__head--split">
              <div>
                <p class="demo-stage__label">Confirmed Slot</p>
                <h3 class="demo-stage__title" id="demo-selected-slot">Select a time slot</h3>
              </div>
              <button class="demo-stage__back" type="button" data-back-stage="time">Change time</button>
            </div>

            <div class="demo-summary">
              <div class="demo-summary__item">
                <span class="demo-summary__tag">Meeting</span>
                <span data-demo-title>{fallbackConfig.meeting_title}</span>
              </div>
              <div class="demo-summary__item">
                <span class="demo-summary__tag">Date</span>
                <span id="demo-summary-date">-</span>
              </div>
              <div class="demo-summary__item">
                <span class="demo-summary__tag">Time</span>
                <span id="demo-summary-time">-</span>
              </div>
              <div class="demo-summary__item">
                <span class="demo-summary__tag">Duration</span>
                <span data-demo-duration>{fallbackConfig.meeting_duration} min</span>
              </div>
              <div class="demo-summary__item">
                <span class="demo-summary__tag">Location</span>
                <span data-demo-location>{fallbackConfig.meeting_location}</span>
              </div>
            </div>

            <form class="demo-form" id="eventhex-demo-form">
              <div class="demo-form__grid">
                <label class="demo-form__field">
                  <span class="demo-form__label">Full Name <span class="demo-form__req">*</span></span>
                  <input class="demo-form__input" name="name" type="text" placeholder="Your name" required />
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Work Email <span class="demo-form__req">*</span></span>
                  <input class="demo-form__input" name="email" type="email" placeholder="you@company.com" required />
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Phone <span class="demo-form__req">*</span></span>
                  <input class="demo-form__input" name="phone" type="tel" placeholder="Phone number" required />
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Company <span class="demo-form__req">*</span></span>
                  <input class="demo-form__input" name="company" type="text" placeholder="Company / Organization" required />
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Job Title / Role</span>
                  <input class="demo-form__input" name="job_title" type="text" placeholder="e.g. Event Manager" />
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Country <span class="demo-form__req">*</span></span>
                  <select class="demo-form__input" name="country" required>
                    <option value="" disabled selected>Select country</option>
                    <option value="IN">India</option>
                    <option value="AE">United Arab Emirates</option>
                    <option value="SA">Saudi Arabia</option>
                    <option value="US">United States</option>
                    <option value="GB">United Kingdom</option>
                    <option value="SG">Singapore</option>
                    <option value="QA">Qatar</option>
                    <option value="BH">Bahrain</option>
                    <option value="KW">Kuwait</option>
                    <option value="OM">Oman</option>
                    <option value="DE">Germany</option>
                    <option value="FR">France</option>
                    <option value="NL">Netherlands</option>
                    <option value="AU">Australia</option>
                    <option value="CA">Canada</option>
                    <option value="MY">Malaysia</option>
                    <option value="ID">Indonesia</option>
                    <option value="TH">Thailand</option>
                    <option value="JP">Japan</option>
                    <option value="KR">South Korea</option>
                    <option value="ZA">South Africa</option>
                    <option value="NG">Nigeria</option>
                    <option value="KE">Kenya</option>
                    <option value="EG">Egypt</option>
                    <option value="BR">Brazil</option>
                    <option value="MX">Mexico</option>
                    <option value="OTHER">Other</option>
                  </select>
                </label>
              </div>

              <div class="demo-form__grid demo-form__grid--event">
                <label class="demo-form__field">
                  <span class="demo-form__label">Expected Event Date</span>
                  <input class="demo-form__input" name="event_date" type="date" />
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Estimated Attendees</span>
                  <select class="demo-form__input" name="attendees">
                    <option value="" disabled selected>Select range</option>
                    <option value="under-100">Under 100</option>
                    <option value="100-500">100 – 500</option>
                    <option value="500-1000">500 – 1,000</option>
                    <option value="1000-5000">1,000 – 5,000</option>
                    <option value="5000-10000">5,000 – 10,000</option>
                    <option value="10000-plus">10,000+</option>
                  </select>
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Event Type</span>
                  <select class="demo-form__input" name="event_type">
                    <option value="" disabled selected>Select type</option>
                    <option value="conference">Conference</option>
                    <option value="exhibition">Exhibition / Trade Show</option>
                    <option value="corporate">Corporate Event</option>
                    <option value="workshop">Workshop / Training</option>
                    <option value="networking">Networking Event</option>
                    <option value="seminar">Seminar / Webinar</option>
                    <option value="festival">Festival / Concert</option>
                    <option value="award-gala">Award Ceremony / Gala</option>
                    <option value="hackathon">Hackathon / Competition</option>
                    <option value="other">Other</option>
                  </select>
                </label>

                <label class="demo-form__field">
                  <span class="demo-form__label">Module of Interest</span>
                  <select class="demo-form__input" name="module_interest">
                    <option value="" disabled selected>What interests you most?</option>
                    <option value="registration-ticketing">Event Registration & Ticketing</option>
                    <option value="speaker-session">Speaker & Session Management</option>
                    <option value="exhibitor-sponsor">Exhibitor & Sponsor Management</option>
                    <option value="checkin-badges">Event Check-in & Badges</option>
                    <option value="website-builder">Event Website Builder</option>
                    <option value="analytics">Event Analytics & Reports</option>
                    <option value="ai-features">AI Features (Copilot, Smart Connect)</option>
                    <option value="polling-qa">Live Polling & Q&A</option>
                    <option value="full-platform">Full Platform Overview</option>
                  </select>
                </label>
              </div>

              <label class="demo-form__field">
                <span class="demo-form__label">How did you hear about us?</span>
                <select class="demo-form__input" name="hear_about">
                  <option value="" disabled selected>Select one</option>
                  <option value="google">Google / Search Engine</option>
                  <option value="social-media">Social Media</option>
                  <option value="advertisement">Advertisement</option>
                  <option value="event-exhibition">Event / Exhibition</option>
                  <option value="referral">Referral / Word of Mouth</option>
                  <option value="other">Other</option>
                </select>
              </label>

              <label class="demo-form__field">
                <span class="demo-form__label">Anything else you'd like us to know?</span>
                <textarea class="demo-form__input demo-form__input--textarea" name="notes" rows="3" placeholder="Current workflow, team size, or anything we should prepare."></textarea>
              </label>

              <div class="demo-form__hidden" aria-hidden="true">
                <input name="hp_field" type="text" tabindex="-1" autocomplete="off" />
              </div>

              <div class="demo-form__actions">
                <p class="demo-form__note">Confirmation email, admin notification, reminder email, and follow-up are triggered after booking.</p>
                <button class="demo-form__submit" id="demo-submit-button" type="submit">Confirm Demo</button>
              </div>

              <div class="demo-form__message" id="demo-form-message" hidden></div>
            </form>
          </section>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .demo-booking {
    --demo-ink: #16223a;
    --demo-muted: #607089;
    --demo-blue: #2256ee;
    --demo-blue-deep: #1538a8;
    --demo-line: rgba(34, 86, 238, 0.16);
    --demo-card: rgba(255, 255, 255, 0.88);
    --demo-success-bg: #ddfbe6;
    --demo-success-text: #0d7a3b;
    --demo-error-bg: #fee2e2;
    --demo-error-text: #b42318;
    padding: 32px 20px 88px;
    background:
      radial-gradient(circle at top left, rgba(34, 86, 238, 0.14), transparent 24%),
      linear-gradient(180deg, #f7fbff 0%, #edf3ff 100%);
  }

  .demo-booking__shell {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 28px;
    align-items: start;
  }

  .demo-sidebar {
    position: relative;
    overflow: hidden;
    padding: 36px 34px;
    border-radius: 32px;
    background: linear-gradient(160deg, rgba(10, 28, 86, 0.97) 0%, rgba(29, 72, 188, 0.96) 58%, rgba(67, 118, 255, 0.92) 100%);
    color: #f6f9ff;
    box-shadow: 0 24px 60px rgba(29, 55, 138, 0.18);
  }

  .demo-sidebar::after {
    content: "";
    position: absolute;
    right: -110px;
    bottom: -140px;
    width: 320px;
    height: 320px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.2), transparent 68%);
  }

  .demo-sidebar__kicker,
  .demo-scheduler__eyebrow,
  .demo-stage__label,
  .demo-fact-card__label,
  .demo-summary__tag {
    margin: 0 0 10px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .demo-sidebar__kicker,
  .demo-fact-card__label {
    color: rgba(237, 244, 255, 0.76);
  }

  .demo-sidebar__badges {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
  }

  .demo-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(255, 214, 102, 0.18);
    border: 1px solid rgba(255, 214, 102, 0.34);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
    color: #fff5d6;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .demo-pill--ghost {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.22);
    color: rgba(241, 246, 255, 0.92);
  }

  .demo-sidebar__title {
    margin: 0;
    font-family: "Manrope", var(--font-heading);
    font-size: clamp(2.3rem, 4vw, 4rem);
    line-height: 1.03;
    letter-spacing: -0.06em;
  }

  .demo-sidebar__title-accent {
    color: #ffe29b;
  }

  .demo-sidebar__lead {
    margin: 18px 0 0;
    max-width: 36rem;
    font-size: 1.03rem;
    line-height: 1.75;
    color: rgba(244, 248, 255, 0.88);
  }

  .demo-sidebar__journey {
    position: relative;
    z-index: 1;
    margin-top: 24px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .demo-journey-card {
    padding: 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(14px);
    box-shadow: 0 16px 30px rgba(5, 14, 46, 0.12);
  }

  .demo-journey-card strong {
    display: block;
    color: #fff;
    line-height: 1.4;
  }

  .demo-journey-card__index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    margin-bottom: 12px;
    border-radius: 999px;
    background: rgba(255, 214, 102, 0.2);
    color: #ffe4a8;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .demo-sidebar__visual {
    position: relative;
    z-index: 1;
    margin-top: 30px;
    min-height: 260px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px);
    overflow: hidden;
  }

  .demo-sidebar__glow {
    position: absolute;
    width: 240px;
    height: 240px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.34), transparent 68%);
    filter: blur(8px);
  }

  .demo-sidebar__phone {
    position: relative;
    z-index: 1;
    width: min(220px, 62%);
    height: auto;
    filter: drop-shadow(0 22px 50px rgba(0, 0, 0, 0.28));
  }

  .demo-sidebar__facts {
    position: relative;
    z-index: 1;
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .demo-fact-card {
    padding: 18px;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(14px);
  }

  .demo-fact-card__value {
    display: block;
    color: #fff;
    line-height: 1.5;
  }

  .demo-scheduler {
    padding: 28px;
    border-radius: 32px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(244, 248, 255, 0.94) 100%),
      var(--demo-card);
    border: 1px solid rgba(255, 255, 255, 0.88);
    box-shadow: 0 28px 70px rgba(34, 55, 120, 0.12);
    backdrop-filter: blur(18px);
  }

  .demo-scheduler__header,
  .demo-stage__head--split,
  .demo-form__actions {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 18px;
  }

  .demo-scheduler__header {
    margin-bottom: 22px;
  }

  .demo-live-strip {
    margin-bottom: 20px;
    padding: 18px;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(34, 86, 238, 0.06) 0%, rgba(255, 255, 255, 0.82) 100%);
    border: 1px solid rgba(34, 86, 238, 0.1);
  }

  .demo-live-strip__status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--demo-blue-deep);
  }

  .demo-live-strip__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #1fa971;
    box-shadow: 0 0 0 5px rgba(31, 169, 113, 0.12);
  }

  .demo-live-strip__copy {
    margin: 12px 0 0;
    color: var(--demo-muted);
    line-height: 1.7;
  }

  .demo-live-strip__metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .demo-live-metric {
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(34, 86, 238, 0.08);
  }

  .demo-live-metric strong {
    display: block;
    color: var(--demo-ink);
    font-family: "Manrope", var(--font-heading);
    font-size: 1.2rem;
    letter-spacing: -0.04em;
  }

  .demo-live-metric span {
    display: block;
    margin-top: 6px;
    color: #66778f;
    font-size: 0.84rem;
    line-height: 1.45;
  }

  [data-demo-sync-status].is-fallback {
    color: #ffd2aa;
  }

  .demo-scheduler__eyebrow,
  .demo-stage__label,
  .demo-summary__tag {
    color: #6a7c98;
  }

  .demo-scheduler__title,
  .demo-stage__title {
    margin: 0;
    color: var(--demo-ink);
    font-family: "Manrope", var(--font-heading);
    line-height: 1.12;
    letter-spacing: -0.04em;
  }

  .demo-scheduler__title {
    max-width: 17ch;
    font-size: clamp(1.65rem, 2.2vw, 2.2rem);
  }

  .demo-stage__title {
    font-size: 1.4rem;
  }

  .demo-progress {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px;
  }

  .demo-progress__step {
    padding: 10px 14px;
    border-radius: 999px;
    background: #eef2fb;
    color: #72829a;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .demo-progress__step.is-active,
