---
import MarketingLayout from "../layouts/MarketingLayout.astro";

const title = "Book a Demo - EventHex";
const description = "Schedule a one-on-one meeting with our product expert to get a live product demo of EventHex AI.";
---

<MarketingLayout {title} {description}>
  <section class="demo-hero">
    <div class="demo-hero__inner">
      <!-- Left Info Panel -->
      <div class="demo-info">
        <h1 class="demo-info__title">Schedule A Meeting</h1>
        <p class="demo-info__desc">Book a one-on-one meeting with our product expert to get a live product demo!</p>

        <div class="demo-info__visual">
          <img
            src="https://eventhex.ai/wp-content/uploads/2025/01/iPhone-16-pro-isolated-on-white-background-v11-front-view-copy-1.png"
            alt="EventHex AI on iPhone"
            width="250"
            height="500"
            loading="eager"
            class="demo-info__phone"
          />
        </div>

        <div class="demo-info__details">
          <h2 class="demo-info__heading">EventHex AI</h2>
          <h3 class="demo-info__subheading">30 Minute Meeting</h3>
          <div class="demo-info__meta">
            <div class="demo-info__meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span>20 min</span>
            </div>
            <div class="demo-info__meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#375DFB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 10l4.553-2.276A1 1 0 0 1 21 8.618v6.764a1 1 0 0 1-1.447.894L15 14M5 18h8a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2z"></path>
              </svg>
              <span>Web conferencing details provided upon confirmation</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Form Panel -->
      <div class="demo-form-wrap">
        <form class="demo-form" action="https://eventhex.ai/book-a-demo/" method="post" data-demo-form>
          <div class="demo-form__field">
            <label for="demo-name" class="demo-form__label">Name <span class="demo-form__req">*</span></label>
            <input type="text" id="demo-name" name="name" required class="demo-form__input" />
          </div>
          <div class="demo-form__field">
            <label for="demo-email" class="demo-form__label">Email <span class="demo-form__req">*</span></label>
            <input type="email" id="demo-email" name="email" required class="demo-form__input" />
          </div>
          <div class="demo-form__field">
            <label for="demo-company" class="demo-form__label">Company Name <span class="demo-form__req">*</span></label>
            <input type="text" id="demo-company" name="company" required class="demo-form__input" />
          </div>
          <div class="demo-form__field">
            <label for="demo-address" class="demo-form__label">Address</label>
            <input type="text" id="demo-address" name="address" class="demo-form__input" />
          </div>
          <div class="demo-form__field">
            <label for="demo-phone" class="demo-form__label">Phone Number <span class="demo-form__req">*</span></label>
            <input type="tel" id="demo-phone" name="phone" required class="demo-form__input" />
          </div>
          <div class="demo-form__field">
            <label for="demo-date" class="demo-form__label">Preferred Demo Date <span class="demo-form__req">*</span></label>
            <input type="date" id="demo-date" name="preferred_date" required class="demo-form__input" />
          </div>
          <button type="submit" class="demo-form__submit">Book a Demo</button>
        </form>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .demo-hero {
    padding: 40px 20px 80px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .demo-hero__inner {
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }

  /* Info Panel */
  .demo-info {
    flex: 1;
  }

  .demo-info__title {
    font-family: "Manrope", var(--font-heading);
    font-size: 48px;
    font-weight: 700;
    line-height: 1.15;
    color: #22272F;
    margin: 0 0 16px;
    letter-spacing: -1px;
  }

  .demo-info__desc {
    font-family: "Inter", var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: #475467;
    margin: 0 0 32px;
  }

  .demo-info__visual {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
    background: url("https://eventhex.ai/wp-content/uploads/2025/01/Frame-1000003101-1-564x1024.png") no-repeat center center;
    background-size: contain;
    padding: 20px;
    min-height: 400px;
    align-items: center;
  }

  .demo-info__phone {
    width: 200px;
    height: auto;
    display: block;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.15));
  }

  .demo-info__heading {
    font-family: "Manrope", var(--font-heading);
    font-size: 28px;
    font-weight: 700;
    color: #22272F;
    margin: 0 0 8px;
  }

  .demo-info__subheading {
    font-family: "Inter", var(--font-body);
    font-size: 20px;
    font-weight: 600;
    color: #22272F;
    margin: 0 0 16px;
  }

  .demo-info__meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .demo-info__meta-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: "Inter", var(--font-body);
    font-size: 15px;
    color: #475467;
  }

  .demo-info__meta-item svg {
    flex-shrink: 0;
  }

  /* Form Panel */
  .demo-form-wrap {
    flex-shrink: 0;
    width: 440px;
    background: #F4F5FF;
    border-radius: 24px;
    padding: 40px;
  }

  .demo-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .demo-form__label {
    display: block;
    font-family: "Inter", var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: #22272F;
    margin-bottom: 6px;
  }

  .demo-form__req {
    color: #E53E3E;
  }

  .demo-form__input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #E2E4E9;
    border-radius: 10px;
    font-family: "Inter", var(--font-body);
    font-size: 15px;
    color: #22272F;
    background: #ffffff;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .demo-form__input:focus {
    border-color: #375DFB;
  }

  .demo-form__submit {
    padding: 14px 24px;
    background-color: #375DFB;
    color: #ffffff;
    font-family: "Inter", var(--font-body);
    font-size: 16px;
    font-weight: 600;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background-color 0.2s;
    margin-top: 4px;
  }

  .demo-form__submit:hover {
    background-color: #1C46D4;
  }

  @media (max-width: 1024px) {
    .demo-hero__inner {
      flex-direction: column;
    }

    .demo-form-wrap {
      width: 100%;
    }

    .demo-info__title {
      font-size: 35px;
    }
  }

  @media (max-width: 767px) {
    .demo-hero {
      padding: 20px 20px 40px;
    }

    .demo-info__title {
      font-size: 28px;
    }

    .demo-info__visual {
      min-height: 300px;
    }

    .demo-info__phone {
      width: 150px;
    }

    .demo-form-wrap {
      padding: 24px;
    }
  }
</style>
