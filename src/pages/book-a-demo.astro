---
import MarketingLayout from "../layouts/MarketingLayout.astro";

const title = "Book a Demo - EventHex";
const description =
  "Book a live EventHex walkthrough — registration, ticketing, attendee engagement, and event operations.";
const canonical = "https://eventhex.ai/book-a-demo/";
// const calendlyUrl = "https://calendly.com/eventhex-info/30min";
---

<MarketingLayout {title} {description} {canonical} showFooterCta={false}>
  {/* Calendly script commented out – using inline form instead
  <slot name="head">
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  </slot>
  */}

  <!-- Main section: left copy + right form -->
  <section class="bd-main">
    <div class="bd-main__inner">
      <!-- Left column -->
      <div class="bd-copy animate-on-scroll" data-animation="fadeInUp">
        <p class="bd-copy__subtitle">Book a Demo</p>
        <h1 class="bd-copy__title">
          See EventHex in action — built around your event workflow.
        </h1>
        <p class="bd-copy__desc">
          Fill in the form and our team will reach out to schedule a
          personalized walkthrough of the modules that matter most to your
          next event.
        </p>

        <ul class="bd-steps">
          <li>
            <span class="bd-steps__num">1</span>
            <div>
              <strong>Fill in the form</strong>
              <p>Tell us about your event and how to reach you.</p>
            </div>
          </li>
          <li>
            <span class="bd-steps__num">2</span>
            <div>
              <strong>We'll get in touch</strong>
              <p>Our team will contact you to find a convenient time.</p>
            </div>
          </li>
          <li>
            <span class="bd-steps__num">3</span>
            <div>
              <strong>Get your walkthrough</strong>
              <p>Join a live demo of the EventHex modules that matter to you.</p>
            </div>
          </li>
        </ul>

        <p class="bd-copy__note">
          Need a broader enterprise discussion?
          Email <a href="mailto:info@eventhex.ai">info@eventhex.ai</a>
        </p>
      </div>

      <!-- Right column: Demo request form -->
      <div class="bd-form-wrap animate-on-scroll" data-animation="fadeInUp" data-delay="100">
        <form class="bd-form" id="ehf-demo-form">
          <div class="bd-form__field">
            <input type="text" name="name-1" placeholder="Full Name" required class="bd-form__input" />
          </div>
          <div class="bd-form__field">
            <input type="email" name="email-1" placeholder="Work Email" required class="bd-form__input" />
          </div>
          <div class="bd-form__field">
            <input type="text" name="name-2" placeholder="Company / Organization" required class="bd-form__input" />
          </div>
          <div class="bd-form__field">
            <input type="tel" name="phone-1" placeholder="Phone Number" required class="bd-form__input" />
          </div>
          <div class="bd-form__field">
            <select name="select-1" class="bd-form__input bd-form__select">
              <option value="" disabled selected>How did you hear about us?</option>
              <option value="one">Google / Search Engine</option>
              <option value="two">Social Media</option>
              <option value="Advertisement">Advertisement</option>
              <option value="Event-Exhibition">Event / Exhibition</option>
              <option value="Others">Others</option>
            </select>
          </div>
          <div class="bd-form__field">
            <textarea name="textarea-1" placeholder="Tell us about your event or what you'd like to see in the demo" rows="4" class="bd-form__input bd-form__textarea"></textarea>
          </div>
          <!-- Honeypot -->
          <div style="position:absolute;left:-9999px" aria-hidden="true">
            <input type="text" name="ehf_hp_field" tabindex="-1" autocomplete="off" />
          </div>
          <div class="bd-form__field bd-form__checkbox">
            <label>
              <input type="checkbox" name="checkbox-1" required />
              <span>I agree to the <a href="/privacy-policy/">Privacy Policy</a> and <a href="/terms-of-service/">Terms of Service</a></span>
            </label>
          </div>
          <button type="submit" class="bd-form__submit">Request a Demo</button>
          <div id="ehf-demo-msg" class="bd-form__message" style="display:none"></div>
        </form>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* ── Main section ────────────────────────────── */
  .bd-main {
    margin-top: -90px;
    padding: 160px 20px 80px;
    background:
      url("https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp") center top / cover no-repeat,
      url("https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp") center center / cover no-repeat;
  }

  .bd-main__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ── Left copy ───────────────────────────────── */
  .bd-copy__subtitle {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin: 0 0 12px;
  }

  .bd-copy__title {
    font-family: var(--font-heading);
    font-size: 44px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0 0 16px;
  }

  .bd-copy__desc {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.65;
    color: var(--subheading-gray);
    margin: 0 0 40px;
    max-width: 480px;
  }

  .bd-copy__note {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--body-light);
    margin: 36px 0 0;
  }

  .bd-copy__note a {
    color: var(--brand-blue);
    font-weight: 600;
    text-decoration: none;
  }

  /* ── Steps ───────────────────────────────────── */
  .bd-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 24px;
  }

  .bd-steps li {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 14px;
    align-items: start;
  }

  .bd-steps__num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-light);
    border: 1px solid var(--surface-card-border);
    color: var(--brand-blue);
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
  }

  .bd-steps strong {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    color: var(--heading-dark);
    display: block;
    margin-bottom: 2px;
  }

  .bd-steps p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--subheading-gray);
    margin: 0;
  }

  /* ── Right: Demo form ─────────────────────────── */
  .bd-form-wrap {
    background: rgba(187, 194, 255, 0.16);
    border-radius: 24px;
    padding: 40px;
  }

  .bd-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bd-form__input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #E2E4E9;
    border-radius: 10px;
    font-family: "Inter", var(--font-body);
    font-size: 15px;
    color: #22272F;
    background: #ffffff;
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .bd-form__input:focus {
    border-color: #375DFB;
  }

  .bd-form__input::placeholder {
    color: #868C98;
  }

  .bd-form__select {
    appearance: none;
    cursor: pointer;
  }

  .bd-form__textarea {
    resize: vertical;
    min-height: 100px;
  }

  .bd-form__checkbox {
    font-family: "Inter", var(--font-body);
    font-size: 14px;
    color: #475467;
  }

  .bd-form__checkbox label {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    cursor: pointer;
  }

  .bd-form__checkbox a {
    color: #375DFB;
    text-decoration: underline;
  }

  .bd-form__submit {
    padding: 12px 24px;
    background-color: #375DFB;
    color: #ffffff;
    font-family: "Inter", var(--font-body);
    font-size: 15px;
    font-weight: 600;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .bd-form__submit:hover {
    background-color: #1C46D4;
  }

  .bd-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .bd-form__message {
    padding: 12px 16px;
    border-radius: 10px;
    font-family: "Inter", var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    text-align: center;
  }
  .bd-form__message--success {
    background: #d1fadf;
    color: #12b76a;
    border: 1px solid #12b76a;
  }
  .bd-form__message--error {
    background: #fee4e2;
    color: #d92d20;
    border: 1px solid #d92d20;
  }

  /* ── Responsive ──────────────────────────────── */
  @media (max-width: 1024px) {
    .bd-main__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .bd-copy__title {
      font-size: 36px;
    }

    .bd-form-wrap {
      width: 100%;
    }
  }

  @media (max-width: 767px) {
    .bd-main {
      padding: 120px 16px 56px;
    }

    .bd-copy__title {
      font-size: 28px;
      letter-spacing: 0;
    }

    .bd-copy__desc {
      font-size: 16px;
      margin-bottom: 28px;
    }

    .bd-steps__num {
      width: 36px;
      height: 36px;
      font-size: 14px;
    }

    .bd-steps strong {
      font-size: 15px;
    }

    .bd-steps p {
      font-size: 14px;
    }

    .bd-form-wrap {
      padding: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
    }
  }
</style>

<script>
  const WP_URL = 'https://cms.eventhex.ai';

  document.getElementById('ehf-demo-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const msg = document.getElementById('ehf-demo-msg')!;
    const fd = new FormData(form);

    const data: Record<string, string | boolean> = {};
    for (const [key, val] of fd.entries()) {
      data[key] = val as string;
    }
    // Consent checkbox
    const cb = form.querySelector('[name="checkbox-1"]') as HTMLInputElement;
    if (cb?.checked) {
      data['checkbox-1'] = 'I agree to receive email notifications and updates from EventHex. I understand that I can unsubscribe at any time.';
    }

    btn.disabled = true;
    btn.textContent = 'Sending...';
    msg.style.display = 'none';

    try {
      const res = await fetch(`${WP_URL}/wp-json/ehf/v1/submit/contact-form`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (res.ok && json.success) {
        msg.className = 'bd-form__message bd-form__message--success';
        msg.textContent = json.message || 'Thank you! Our team will reach out to schedule your demo.';
        msg.style.display = 'block';
        form.reset();
      } else {
        throw new Error(json.message || 'Submission failed.');
      }
    } catch (err: any) {
      msg.className = 'bd-form__message bd-form__message--error';
      msg.textContent = err.message || 'Something went wrong. Please try again.';
      msg.style.display = 'block';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Request a Demo';
    }
  });
</script>
