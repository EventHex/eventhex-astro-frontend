---
import MarketingLayout from "../layouts/MarketingLayout.astro";

const title = "Book a Demo - EventHex";
const description =
  "Book a live EventHex walkthrough — registration, ticketing, attendee engagement, and event operations.";
const canonical = "https://eventhex.ai/book-a-demo/";
const calendlyUrl = "https://calendly.com/eventhex-info/30min";
---

<MarketingLayout {title} {description} {canonical} showFooterCta={false}>
  <slot name="head">
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  </slot>

  <!-- Main section: left copy + right Calendly -->
  <section class="bd-main">
    <div class="bd-main__inner">
      <!-- Left column -->
      <div class="bd-copy animate-on-scroll" data-animation="fadeInUp">
        <p class="bd-copy__subtitle">Book a Demo</p>
        <h1 class="bd-copy__title">
          See EventHex in action — built around your event workflow.
        </h1>
        <p class="bd-copy__desc">
          Pick a time, meet our team, and walk through the modules that matter
          most to your next event.
        </p>

        <ul class="bd-steps">
          <li>
            <span class="bd-steps__num">1</span>
            <div>
              <strong>Choose a time</strong>
              <p>Pick a slot from the calendar that works for your team.</p>
            </div>
          </li>
          <li>
            <span class="bd-steps__num">2</span>
            <div>
              <strong>Share your goals</strong>
              <p>Tell us which event workflow or challenge to focus on.</p>
            </div>
          </li>
          <li>
            <span class="bd-steps__num">3</span>
            <div>
              <strong>Get your walkthrough</strong>
              <p>Join a live demo of the EventHex modules that matter to you.</p>
            </div>
          </li>
        </ul>

        <p class="bd-copy__note">
          Need a broader enterprise discussion?
          Email <a href="mailto:info@eventhex.ai">info@eventhex.ai</a>
        </p>
      </div>

      <!-- Right column: Calendly embed -->
      <div class="bd-calendly animate-on-scroll" data-animation="fadeInUp" data-delay="100">
        <div
          class="calendly-inline-widget"
          data-url={`${calendlyUrl}?hide_gdpr_banner=1&background_color=ffffff&text_color=22272f&primary_color=375dfb`}
          style="min-width:320px;width:100%;height:700px;"
        ></div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* ── Main section ────────────────────────────── */
  .bd-main {
    margin-top: -90px;
    padding: 160px 20px 80px;
    background:
      url("https://eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp") center top / cover no-repeat,
      url("https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp") center center / cover no-repeat;
  }

  .bd-main__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ── Left copy ───────────────────────────────── */
  .bd-copy__subtitle {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin: 0 0 12px;
  }

  .bd-copy__title {
    font-family: var(--font-heading);
    font-size: 44px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -1px;
    color: var(--heading-dark);
    margin: 0 0 16px;
  }

  .bd-copy__desc {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.65;
    color: var(--subheading-gray);
    margin: 0 0 40px;
    max-width: 480px;
  }

  .bd-copy__note {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--body-light);
    margin: 36px 0 0;
  }

  .bd-copy__note a {
    color: var(--brand-blue);
    font-weight: 600;
    text-decoration: none;
  }

  /* ── Steps ───────────────────────────────────── */
  .bd-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 24px;
  }

  .bd-steps li {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 14px;
    align-items: start;
  }

  .bd-steps__num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-light);
    border: 1px solid var(--surface-card-border);
    color: var(--brand-blue);
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 700;
  }

  .bd-steps strong {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    color: var(--heading-dark);
    display: block;
    margin-bottom: 2px;
  }

  .bd-steps p {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--subheading-gray);
    margin: 0;
  }

  /* ── Right: Calendly embed ───────────────────── */
  .bd-calendly {
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--surface-card-border);
    box-shadow: 0 24px 56px rgba(34, 39, 47, 0.07);
  }

  .calendly-inline-widget {
    border-radius: 20px;
  }

  /* ── Responsive ──────────────────────────────── */
  @media (max-width: 1024px) {
    .bd-main__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .bd-copy__title {
      font-size: 36px;
    }
  }

  @media (max-width: 767px) {
    .bd-main {
      padding: 120px 16px 56px;
    }

    .bd-copy__title {
      font-size: 28px;
      letter-spacing: 0;
    }

    .bd-copy__desc {
      font-size: 16px;
      margin-bottom: 28px;
    }

    .bd-steps__num {
      width: 36px;
      height: 36px;
      font-size: 14px;
    }

    .bd-steps strong {
      font-size: 15px;
    }

    .bd-steps p {
      font-size: 14px;
    }

    .bd-calendly {
      border-radius: 16px;
    }

    .calendly-inline-widget {
      height: 650px !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
    }
  }
</style>
