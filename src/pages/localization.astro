---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Multilingual Event Management Platform",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Run events in multiple languages with EventHex — full support for English, Arabic (RTL), and German across attendee apps, registration forms, and email communications.",
  url: "https://eventhex.ai/localization/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "English, Arabic, and German Language Support",
    "Full RTL Layout for Arabic",
    "Localised Attendee App",
    "Localised Registration Forms",
    "Localised Email Notifications",
    "AI-Assisted Content Translation",
    "MEA and European Market Support",
  ],
};
---

<FeatureV2Layout
  pageTitle="Multilingual Event Software — Arabic RTL, English & German | EventHex"
  pageDescription="Run events in multiple languages with EventHex — full Arabic RTL support, German, and English across your attendee app, registration forms, and email communications. Built for MEA and European markets."
  canonical="https://eventhex.ai/localization/"
  ogImage="https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png"
  badge="Multilingual & Localisation"
  heroTitleLine1="Run Events in Any Language"
  heroTitleLine2="Including Full Arabic RTL"
  heroCopy="EventHex supports English, Arabic with full right-to-left layout, and German — across your attendee app, registration forms, and email communications. Built for event organisers serving MEA and European audiences."
  trustItems={["Arabic RTL Support", "Localised Registration Forms", "AI-Assisted Translation"]}
  stats={[
    { value: "3+", label: "Languages Supported" },
    { value: "100%", label: "RTL Layout for Arabic" },
    { value: "MEA", label: "& European Markets" },
    { value: "AI", label: "Translation Assist" },
  ]}
  statsHeadline={{
    white1: "One platform.",
    accent: "Every language.",
    white2: "Events that feel",
    accent2: "local everywhere",
  }}
  bentoHeading="Localisation Built Into Every Layer"
  bentoSubtitle="Language support in EventHex isn't a translation plugin bolted on — it's built into the attendee app, registration forms, and email flows so every touchpoint feels native to your audience."
  bentoTabs={[
    {
      tab: "Multi-Language UI",
      cards: [
        { title: "English, Arabic & German", desc: "EventHex supports English, Arabic, and German across the platform — with more languages on the roadmap", illustration: ILLOS.translate },
        { title: "Attendee App Localisation", desc: "The attendee-facing app switches language based on the attendee's preference, displaying all labels, navigation, and content in their chosen language", illustration: ILLOS.globe },
        { title: "AI-Assisted Translation", desc: "Use AI translation assistance to quickly localise your event content — session names, speaker bios, agenda items — without a manual translation workflow", illustration: ILLOS.bot },
        { title: "Consistent Localisation", desc: "Language settings apply consistently across the app, registration flow, and emails so attendees never encounter mixed-language experiences", illustration: ILLOS.translate },
        { title: "Localised Date & Time Formats", desc: "Dates and times are displayed in formats appropriate for the selected language and region, reducing confusion for international attendees", illustration: ILLOS.calendar },
      ],
    },
    {
      tab: "RTL & Arabic",
      cards: [
        { title: "Full Right-to-Left Layout", desc: "The entire UI flips to a proper RTL layout for Arabic — not just text alignment, but navigation, buttons, and form fields", illustration: ILLOS.translate },
        { title: "Arabic Registration Forms", desc: "Registration forms render in Arabic with RTL layout, so Arabic-speaking attendees experience a natural, native interface", illustration: ILLOS.chatform },
        { title: "Arabic Email Notifications", desc: "Attendee emails — confirmation, reminders, check-in — are sent in Arabic with correct RTL formatting when the attendee's language is set to Arabic", illustration: ILLOS.mail },
        { title: "Bidirectional Content", desc: "Mixed Arabic and English content is handled correctly, with bidirectional text support throughout the platform", illustration: ILLOS.document },
        { title: "MEA Market Ready", desc: "EventHex is actively used for events in the Middle East and North Africa — Arabic language support is production-tested, not experimental", illustration: ILLOS.globe },
      ],
    },
    {
      tab: "Localised Comms",
      cards: [
        { title: "Localised Email Templates", desc: "Registration confirmations, reminders, and post-event emails are sent in the attendee's language — English, Arabic, or German", illustration: ILLOS.mail },
        { title: "Localised Registration Forms", desc: "Form field labels, validation messages, and placeholder text are displayed in the attendee's chosen language", illustration: ILLOS.chatform },
        { title: "Language-Specific Notifications", desc: "Automated notifications respect the attendee's language setting — no manual segmentation or separate campaigns needed", illustration: ILLOS.mail },
        { title: "Consent Language by Locale", desc: "GDPR consent text and opt-in language can be customised per locale to match your legal requirements in each market", illustration: ILLOS.document },
        { title: "Organiser Language Controls", desc: "Event organisers can set a default event language and allow attendees to override it from their profile or during registration", illustration: ILLOS.translate },
      ],
    },
  ]}
  stackingHeading="Multilingual Event Management"
  stackingHighlight="From Registration to App"
  stackingCards={[
    {
      title: "Full Arabic RTL — Not Just Text Alignment",
      desc: "True RTL support means the entire interface mirrors for Arabic audiences — navigation sits on the right, form labels align correctly, and reading flows naturally. Your Arabic-speaking attendees get a platform that feels built for them.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "EventHex attendee app with full Arabic right-to-left RTL layout",
    },
    {
      title: "Localised Registration Forms That Convert",
      desc: "When your registration form appears in the attendee's language — with correctly formatted fields, native validation messages, and localised consent text — completion rates improve and support requests drop.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Multilingual event registration form in Arabic and English with RTL support",
    },
    {
      title: "AI Translation Assistance for Event Content",
      desc: "Use the built-in AI translation assistant to localise session titles, speaker descriptions, and agenda content across English, Arabic, and German — cutting translation time without sacrificing accuracy.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "AI-assisted content translation for multilingual event management in EventHex",
    },
  ]}
  howItWorksHeading="How Multilingual Events Work in EventHex"
  steps={[
    { title: "Set Your Event Language", desc: "Choose the primary language for your event and enable additional languages for attendees — English, Arabic, or German — from the event settings panel." },
    { title: "Localise Your Content", desc: "Add localised versions of your event name, session titles, speaker bios, and agenda. Use AI translation assistance to speed up the process." },
    { title: "Attendees Register in Their Language", desc: "The registration form detects or lets attendees select their preferred language. Form fields, labels, and consent text all render in the chosen language — with full RTL layout for Arabic." },
    { title: "Automated Comms in the Right Language", desc: "Confirmation emails, reminders, and check-in notifications are sent to each attendee in their selected language — no manual segmentation needed." },
  ]}
  ctaTitle="Ready to Run Events for Global Audiences?"
  ctaCopy="See how EventHex makes multilingual and RTL event management straightforward — for MEA, European, and international audiences."
  whyHeading="Why Multilingual Organisers Choose EventHex"
  whyCards={[
    { title: "Real RTL Support", desc: "Full right-to-left layout for Arabic — the whole UI, not just text direction", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 10H3"/><path d="m21 6-4 4 4 4"/><path d="M21 14H7"/><path d="m3 18 4-4-4-4"/></svg>' },
    { title: "3+ Languages", desc: "English, Arabic, and German supported across app, forms, and emails", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' },
    { title: "AI Translation Assist", desc: "Speed up content localisation with AI-assisted translation built in", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>' },
    { title: "MEA Ready", desc: "Production-tested for Middle East and North Africa events", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>' },
    { title: "Localised Comms", desc: "Emails and notifications in the attendee's language — automatically", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>' },
  ]}
  faqs={[
    { q: "Which languages does EventHex support?", a: "EventHex currently supports English, Arabic, and German. Arabic includes full right-to-left (RTL) layout across the attendee app, registration forms, and email communications. More languages are on the roadmap." },
    { q: "Is the Arabic RTL support full-layout or just text direction?", a: "Full-layout RTL. When Arabic is selected, the entire interface mirrors — navigation, buttons, form fields, and content all render right-to-left. It's not limited to text alignment." },
    { q: "Can attendees choose their own language?", a: "Yes. Attendees can select their preferred language during registration or from their profile. The platform applies that preference across the app, forms, and automated email notifications." },
    { q: "Can I localise event content like session titles and speaker bios?", a: "Yes. Organisers can add localised versions of event content — session names, speaker descriptions, agenda items — for each supported language. The AI translation assistant helps speed up this process." },
    { q: "Are registration forms and emails also localised?", a: "Yes. Registration form labels, validation messages, and consent text render in the attendee's language. Confirmation emails, reminders, and check-in notifications are sent in the attendee's selected language automatically." },
    { q: "Is EventHex used for events in the Middle East?", a: "Yes. EventHex is actively used by event organisers across the Middle East and North Africa. Arabic RTL support is production-tested in live events, not a prototype feature." },
  ]}
  jsonLd={jsonLd}
/>
