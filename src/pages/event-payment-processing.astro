---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-payment-processing/HeroSection.astro";
import StatsSection from "../components/event-payment-processing/StatsSection.astro";
import BentoGrid from "../components/event-payment-processing/BentoGrid.astro";
import FeatureCards from "../components/event-payment-processing/FeatureCards.astro";
import HowItWorksSection from "../components/event-payment-processing/HowItWorksSection.astro";
import CTASection from "../components/event-payment-processing/CTASection.astro";
import CoordinationTools from "../components/event-payment-processing/CoordinationTools.astro";
import FaqSection from "../components/event-payment-processing/FaqSection.astro";

const ogImage = "https://eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Event Payment Processing — 0% Platform Fees | EventHex";
const description = "Accept event ticket payments via Stripe, Razorpay, or Tap with zero EventHex platform fees. 135+ currencies, automated refunds, and real-time revenue reporting.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Payment Processing — 0% Platform Fees",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/event-payment-processing/",
  description: description,
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "0% Platform Fees",
    "Stripe Integration",
    "Razorpay Integration",
    "Tap Payments Integration",
    "Multi-Currency Support",
    "Promo Codes",
    "Automated Refunds",
    "Revenue Reports",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-payment-processing/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
