---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/feature-page/HeroSection.astro";
import FeatureSection from "../components/feature-page/FeatureSection.astro";
import CTASection from "../components/feature-page/CTASection.astro";

const title = "Event Registration - EventHex";
const description = "EventHex's event registration software helps you analyse the registration trend, manage attendee types, approve registration requests, track ticket purchases, and monitor payment status.";

const featureSections = [
  {
    sectionTitle: "View & Manage All Registered Participants",
    imageLeft: true,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Mac-Studio.png",
    imageAlt: "EventHex attendee registration list management interface",
    items: [
      {
        title: "View",
        description: "View the total registration list with chosen field info such as name, email, and the time of registration",
      },
      {
        title: "Export",
        description: "Export the registration list into an excel file and use it elsewhere as needed",
      },
      {
        title: "Search by Category",
        description: "You can search and organize by pre-set categories such as delegate, exhibitor, and so on",
      },
    ],
  },
  {
    sectionTitle: "Track Ticket Purchase and Payment Status",
    imageLeft: false,
    dark: true,
    backgroundColor: "#000312",
    backgroundImage: "https://eventhex.ai/wp-content/uploads/2025/03/bg.svg",
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-1.png",
    imageAlt: "EventHex ticket purchase tracking and payment status dashboard",
    imageOverflow: true,
    items: [
      {
        title: "Review & Approve",
        description: "You can enable waitlist management to require manual approval for the completion of registration",
      },
      {
        title: "Track Purchase",
        description: "Track ticket purchase with type, order ID, amount, discount availed, and payment status",
      },
      {
        title: "Payment Status",
        description: "Filter attendee base on the payment status and reach out to request completion of the purchase",
      },
    ],
  },
  {
    sectionTitle: "Monitor Attendance and Check-In Instances",
    imageLeft: true,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/ZenBook-Duo-14.png",
    imageAlt: "EventHex attendance monitoring and check-in tracking interface",
    items: [
      {
        title: "Check-In/Pending List",
        description: "Analyse the check-in and pending data coming from the registration point on the event day.",
      },
      {
        title: "Set-Up Instances",
        description: "Set up which tickets types can be validated or not at each scanning points such as food",
      },
      {
        title: "Instance Check-In",
        description: "View where all an attendee scanned, the total check-in rate at an instance, pending list, and so on",
      },
    ],
  },
];
---

<MarketingLayout {title} {description}>
  <!-- Section 0: Hero -->
  <HeroSection
    eyebrow="Event Registration"
    title="Manage Attendees with Our Event Registration Platform"
    description="EventHex's event registration software helps you analyse the registration trend, manage attendee types, approve registration requests, track ticket purchases, and monitor payment status."
    image="https://eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png"
    imageAlt="EventHex Event Registration dashboard on tablet"
  />

  <!-- Feature Sections -->
  {featureSections.map((section) => (
    <FeatureSection
      sectionTitle={section.sectionTitle}
      items={section.items}
      image={section.image}
      imageAlt={section.imageAlt}
      imageLeft={section.imageLeft}
      dark={section.dark}
      backgroundImage={section.backgroundImage}
      backgroundColor={section.backgroundColor}
      imageOverflow={section.imageOverflow}
    />
  ))}

  <!-- CTA Section -->
  <CTASection />
</MarketingLayout>
