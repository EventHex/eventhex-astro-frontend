---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { spoIllustrations as ill } from "../components/sponsor-management/illustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Sponsor Management Software",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Event sponsor management with tiered packages, multi-channel logo placement, impression tracking, and auto-generated ROI reports.",
  url: "https://eventhex.ai/sponsor-management/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Tiered Sponsor Categories",
    "Logo Placement Control",
    "Sponsor ROI Reports",
    "Impression Tracking",
    "Mobile App Sponsor Listings",
    "Badge Branding",
    "Partner Spotlights",
    "Sponsorship Package Management",
  ],
};
---

<FeatureV2Layout
  pageTitle="Sponsor Management Software — Manage Sponsors & Prove ROI | EventHex"
  pageDescription="Organize tiered sponsor packages, control logo placements across your event website, app, and badges, and deliver auto-generated ROI reports that make sponsors renew every year."
  canonical="https://eventhex.ai/sponsor-management/"
  ogImage="https://eventhex.ai/wp-content/uploads/2025/04/HP-Elite-Dragonfly-1.png"
  badge="Sponsor Management Software"
  heroTitleLine1="Manage Sponsors Professionally."
  heroTitleLine2="Prove ROI. Win Repeat Deals."
  heroCopy="Organize tiered sponsor packages, control logo placements across your event website, app, and badges, and deliver auto-generated ROI reports that make sponsors renew every year."
  trustItems={["Tiered Sponsor Packages", "Multi-Channel Logo Placement", "Auto ROI Reports"]}
  stats={[
    { value: "3x", label: "Higher Sponsor Renewal" },
    { value: "100%", label: "Automated ROI Reports" },
    { value: "6+", label: "Placement Channels" },
    { value: "Built-In", label: "Gold/Silver/Bronze Tiers" },
  ]}
  statsHeadline={{
    white1: "Sponsors that stay.",
    accent: "ROI that shows.",
    white2: "Powered by",
    accent2: "EventHex",
  }}
  bentoHeading="Everything You Need for Sponsor Management"
  bentoSubtitle="From logo placement on registration pages to post-event brand impression reports — EventHex gives sponsors the professional experience that converts one-time partners into long-term sponsors."
  bentoTabs={[
    {
      tab: "Sponsor Profiles",
      cards: [
        { title: "Tiered Sponsor Categories", desc: "Create Gold, Silver, Bronze and custom tiers with different visibility levels and benefits", illustration: ill.spo1 },
        { title: "Logo Placement Control", desc: "Assign where each sponsor's logo appears — website, app, badges, emails, or digital signage", illustration: ill.spo2 },
        { title: "Sponsor Website Links", desc: "Each sponsor profile includes a direct link to their website displayed across your event surfaces", illustration: ill.spo3 },
        { title: "Contact Information", desc: "Store sponsor contact details, account owners, and renewal notes in one organized profile", illustration: ill.spo4 },
        { title: "Sponsor Description", desc: "Rich text sponsor descriptions displayed on event website sponsor sections and app listings", illustration: ill.spo5 },
      ],
    },
    {
      tab: "Visibility & Exposure",
      cards: [
        { title: "Website Sponsor Section", desc: "Auto-generated sponsor section on your event website with logos organized by tier", illustration: ill.spo6 },
        { title: "Mobile App Sponsor Logos", desc: "Sponsors appear on the event app home screen, session pages, and dedicated sponsor tab", illustration: ill.spo7 },
        { title: "Badge Sponsor Branding", desc: "Sponsor logos on attendee badges — configurable by tier with size control", illustration: ill.spo8 },
        { title: "Email Sponsor Mentions", desc: "Include sponsor logos and names in event emails with configurable placement", illustration: ill.spo9 },
        { title: "Digital Signage Placement", desc: "Export sponsor assets for on-site screens, banners, and LED displays", illustration: ill.spo10 },
      ],
    },
    {
      tab: "ROI & Analytics",
      cards: [
        { title: "Sponsor Impression Tracking", desc: "Count how many times sponsor logos and names were viewed across all event surfaces", illustration: ill.spo11 },
        { title: "Click-Through Analytics", desc: "Track how many attendees clicked through to each sponsor's website from your event pages", illustration: ill.spo12 },
        { title: "Partner Spotlight Features", desc: "Give sponsors dedicated spotlight blocks on the event website and app for premium visibility", illustration: ill.spo13 },
        { title: "Sponsor Comparison Reports", desc: "Compare impression and engagement metrics across all sponsors in one side-by-side view", illustration: ill.spo14 },
        { title: "Sponsorship Value Reporting", desc: "Auto-generate branded PDF reports for each sponsor showing their full ROI from the event", illustration: ill.spo15 },
      ],
    },
  ]}
  stackingHeading="Sponsor Management Features"
  stackingHighlight="That Drive Renewals"
  stackingCards={[
    {
      title: "Structured Packages That Sell Themselves",
      desc: "Define Gold, Silver, Bronze, and custom sponsor tiers with clear benefits at each level. Sponsors self-select packages online, and benefits apply automatically across all event surfaces.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/EventHex-Booth-Management-1.png",
      alt: "Sponsor tier management with Gold, Silver, Bronze packages",
    },
    {
      title: "Reports That Make Sponsors Renew",
      desc: "After every event, sponsors receive auto-generated PDF reports showing logo impressions, click-throughs, app engagement, and booth traffic — the proof they need to justify renewal.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/HP-Elite-Dragonfly-1.png",
      alt: "Auto-generated sponsor ROI report PDF",
    },
    {
      title: "Sponsors Everywhere Attendees Look",
      desc: "Logo placement goes beyond a website banner — sponsors appear on registration confirmations, mobile app, check-in badges, event emails, and digital signage all from one control panel.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Sponsor logo placement across website, app, and badges",
    },
  ]}
  howItWorksHeading="How Sponsor Management Works"
  steps={[
    { title: "Create Sponsor Tiers", desc: "Define your Gold, Silver, Bronze and custom tiers. Set the benefits, logo sizes, and placement channels for each level." },
    { title: "Add Sponsor Profiles", desc: "Enter sponsor details, upload logos, and assign each sponsor to a tier. Benefits apply automatically across all event surfaces." },
    { title: "Manage Placements", desc: "Control exactly where each sponsor appears — website, app, badges, emails, and signage — from one central dashboard." },
    { title: "Deliver ROI Reports", desc: "After the event, auto-generate branded PDF reports showing impressions, clicks, and engagement for each sponsor." },
  ]}
  ctaTitle="Ready to Give Sponsors an Experience They'll Renew?"
  ctaCopy="See how EventHex automates sponsor visibility, tracks real ROI, and makes sponsors want to come back next year."
  whyHeading="Why Organizers Choose EventHex for Sponsors"
  whyCards={[
    { title: "Tiered Packages", desc: "Structured Gold/Silver/Bronze tiers with auto-applied benefits" },
    { title: "Multi-Channel Logos", desc: "Website, app, badges, emails, and signage from one panel" },
    { title: "Auto ROI Reports", desc: "Branded PDFs delivered to sponsors after every event" },
    { title: "Impression Tracking", desc: "Measure logo views and click-throughs across all channels" },
    { title: "Partner Spotlights", desc: "Premium sponsor spotlight blocks on website and app" },
  ]}
  faqs={[
    { q: "How do I manage event sponsors?", a: "EventHex provides a sponsor management dashboard where you create sponsor profiles, assign tiers, upload logos, and control placement channels. All visibility settings apply automatically across your event website, mobile app, badges, and emails." },
    { q: "Can I create sponsor tiers like Gold, Silver, and Bronze?", a: "Yes. You can create unlimited tiers with custom names and set the benefits for each — including logo size, placement channels, app features, and spotlight blocks. Sponsors assigned to a tier automatically receive all tier benefits." },
    { q: "Where do sponsor logos appear?", a: "Sponsor logos can appear on your event website, mobile app, attendee badges, registration confirmation emails, event reminder emails, and digital signage exports. Each channel is configurable per sponsor tier." },
    { q: "Can sponsors track their visibility?", a: "Yes. EventHex tracks logo impressions, website click-throughs, and app engagement for each sponsor. You can share this data with sponsors via auto-generated PDF reports after the event." },
    { q: "How do I create sponsor packages?", a: "Create tier definitions with a list of benefits, set a price for each tier, and publish your sponsorship package page. Sponsors can view and purchase packages online, and their benefits are applied as soon as they're confirmed." },
  ]}
  jsonLd={jsonLd}
/>
