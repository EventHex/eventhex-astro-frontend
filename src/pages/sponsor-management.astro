---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/feature-page/HeroSection.astro";
import FeatureSection from "../components/feature-page/FeatureSection.astro";
import FaqSection from "../components/feature-page/FaqSection.astro";
import CTASection from "../components/feature-page/CTASection.astro";

const title = "Sponsor Management - EventHex";
const description = "EventHex's Sponsorship Management allows you to easily manage your event's sponsors and their promotional materials across your Attendee App, event website, tickets, badges and so on!";

const featureSections = [
  {
    sectionTitle: "Give Your Sponsors the Visibility They Deserve!",
    imageLeft: true,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/EventHex-Booth-Management-1.png",
    imageAlt: "EventHex sponsor booth management and visibility dashboard",
    items: [
      {
        title: "Speaker Bios",
        description: "Showcase each speaker's expertise and background in a professional format.",
      },
      {
        title: "Schedules and Topics",
        description: "Keep track of session timings, topics, and room allocations with ease.",
      },
      {
        title: "Presentation Materials",
        description: "Collect, organize, and distribute slides or other resources in advance with the audience.",
      },
    ],
  },
];

const faqItems = [
  {
    question: "What are speakers in event management?",
    answer: "<p>Speakers in event management refer to individuals who present information, share insights, or lead discussions at events such as conferences, seminars, and workshops. They play a crucial role in delivering content and engaging attendees, making their selection and management essential for successful event execution.</p>",
  },
  {
    question: "What is a conference management tool?",
    answer: "<p>A conference management tool is a specialized software solution designed to assist event planners in organizing and executing conferences efficiently. It streamlines various tasks such as registration, scheduling, abstract submission, and communication with participants, ultimately enhancing the overall event experience.</p>",
  },
  {
    question: "What is speaker management?",
    answer: "<p>Speaker management involves the processes and tools used to coordinate and oversee speakers for an event. This includes managing speaker submissions, scheduling presentations, facilitating communication, and ensuring that all logistical details are handled effectively to create a seamless experience for both speakers and attendees.</p>",
  },
  {
    question: "How can speaker management software improve my event planning?",
    answer: "<p>Speaker management software enhances event planning by automating tasks related to speaker coordination, such as collecting submissions, managing schedules, and communicating updates. This not only saves time but also reduces errors, ensuring that your event runs smoothly and efficiently.</p>",
  },
];
---

<MarketingLayout {title} {description}>
  <HeroSection
    eyebrow="Sponsor Management"
    title="Value Your Sponsors with Our Sponsor Management Software"
    description="EventHex's Sponsorship Management allows you to easily manage your event's sponsors and their promotional materials across your Attendee App, event website, tickets, badges and so on!"
    image="https://eventhex.ai/wp-content/uploads/2025/04/HP-Elite-Dragonfly-1.png"
    imageAlt="EventHex Sponsor Management dashboard on laptop"
  />

  {featureSections.map((section) => (
    <FeatureSection
      sectionTitle={section.sectionTitle}
      items={section.items}
      image={section.image}
      imageAlt={section.imageAlt}
      imageLeft={section.imageLeft}
    />
  ))}

  <FaqSection items={faqItems} />

  <CTASection title={"Explore EventHex's\nSponsor Management Now!"} />
</MarketingLayout>
