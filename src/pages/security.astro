---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Secure Event Management Platform",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "EventHex is designed with enterprise-grade security practices — encryption in transit and at rest, role-based access control, GDPR-aligned data handling, and payment processing via PCI-compliant gateways.",
  url: "https://eventhex.ai/security/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Data Encryption in Transit and at Rest",
    "Role-Based Access Control",
    "GDPR-Aligned Data Handling",
    "Attendee Data Ownership & Export",
    "PCI-Compliant Payment Gateways",
    "Audit Logging",
    "Consent Management",
    "Data Deletion on Request",
  ],
};
---

<FeatureV2Layout
  pageTitle="Event Management Security — Data Protection & Compliance | EventHex"
  pageDescription="EventHex is built with enterprise security in mind — encryption in transit and at rest, GDPR-aligned data handling, role-based access control, and payment processing via PCI-compliant gateways."
  canonical="https://eventhex.ai/security/"
  ogImage="https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png"
  badge="Security & Compliance"
  heroTitleLine1="Enterprise-Grade Security"
  heroTitleLine2="Built Into Every Event"
  heroCopy="EventHex is designed with security-first principles — your attendee data is encrypted, access is controlled, payments run through PCI-compliant gateways, and your organisation stays in full control of its data at every step."
  trustItems={["Encryption in Transit & at Rest", "GDPR-Aligned Data Handling", "Role-Based Access Control"]}
  stats={[
    { value: "TLS 1.3", label: "Encryption Standard" },
    { value: "AES-256", label: "Data at Rest" },
    { value: "RBAC", label: "Permission Model" },
    { value: "100%", label: "Data Ownership" },
  ]}
  statsHeadline={{
    white1: "Your attendee data.",
    accent: "Protected.",
    white2: "Your organisation",
    accent2: "in control",
  }}
  bentoHeading="Security Designed for Event Organisers"
  bentoSubtitle="From registration forms to payment processing, EventHex follows security best practices that procurement teams and IT departments expect — without adding friction for your event team."
  bentoTabs={[
    {
      tab: "Data Protection",
      cards: [
        { title: "Encryption in Transit", desc: "All data exchanged between your browser and EventHex is encrypted using TLS 1.3", illustration: ILLOS.lock },
        { title: "Encryption at Rest", desc: "Attendee records and event data are stored encrypted using AES-256 at the infrastructure level", illustration: ILLOS.shield },
        { title: "Cloud Infrastructure", desc: "EventHex runs on reputable cloud infrastructure providers with physical security, redundancy, and uptime SLAs", illustration: ILLOS.globe },
        { title: "Data Minimisation", desc: "Collect only the fields you define — EventHex does not add hidden tracking fields to your registration forms", illustration: ILLOS.clipboard },
        { title: "Audit Logging", desc: "Key actions — logins, data exports, attendee edits — are recorded in an audit log accessible to administrators", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "Access & Compliance",
      cards: [
        { title: "Role-Based Access Control", desc: "Assign team members roles with specific permissions — limit who can export data, manage payments, or edit event settings", illustration: ILLOS.user },
        { title: "GDPR-Aligned Data Handling", desc: "EventHex follows GDPR-aligned data practices including consent capture, data subject requests, and retention controls", illustration: ILLOS.shield },
        { title: "Consent Management", desc: "Built-in consent checkboxes on registration forms with customisable opt-in language that you control", illustration: ILLOS.clipboard },
        { title: "Data Subject Requests", desc: "Administrators can export or delete a specific attendee's data on request, supporting your compliance workflows", illustration: ILLOS.user },
        { title: "Regular Security Reviews", desc: "Our engineering team conducts regular internal security reviews and updates dependencies to address known vulnerabilities", illustration: ILLOS.refresh },
      ],
    },
    {
      tab: "Payments & Privacy",
      cards: [
        { title: "PCI-Compliant Gateways", desc: "EventHex processes payments via Stripe, Razorpay, and Tap — all PCI DSS-certified providers. Card data never touches EventHex servers", illustration: ILLOS.creditcard },
        { title: "No Card Data Storage", desc: "Payment card details are tokenised and stored exclusively by the payment gateway — EventHex only receives transaction status", illustration: ILLOS.creditcard },
        { title: "Attendee Data Ownership", desc: "Your attendee data belongs to your organisation. EventHex does not sell or share it with third parties", illustration: ILLOS.user },
        { title: "Data Export & Portability", desc: "Export your full attendee dataset at any time in CSV or Excel format — no vendor lock-in", illustration: ILLOS.document },
        { title: "Data Deletion", desc: "Request complete deletion of your event and attendee data at any time — no retention beyond what you choose", illustration: ILLOS.clipboard },
      ],
    },
  ]}
  stackingHeading="Security Features"
  stackingHighlight="That Scale With You"
  stackingCards={[
    {
      title: "Access Control That Matches Your Team Structure",
      desc: "Assign roles — admins, coordinators, check-in staff — each with permissions scoped to what they actually need. No single account with access to everything. Audit logs track who did what and when.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "EventHex role-based access control and permissions dashboard",
    },
    {
      title: "GDPR-Ready Registration Forms Out of the Box",
      desc: "Add consent checkboxes with your own opt-in language, control which data fields are collected, and respond to data subject requests with built-in export and deletion tools — all without involving a developer.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "GDPR consent fields and data handling controls in EventHex registration form builder",
    },
    {
      title: "Payments Handled by PCI-Certified Gateways",
      desc: "Stripe, Razorpay, and Tap handle all card processing. EventHex never stores or transmits raw card data — you get the transaction outcome, and the gateway carries the PCI compliance burden.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Secure event ticketing payment processing via PCI-compliant gateways",
    },
  ]}
  howItWorksHeading="How EventHex Keeps Your Data Secure"
  steps={[
    { title: "Data Is Encrypted from the Start", desc: "Every registration form submission, attendee record, and event setting is encrypted in transit (TLS 1.3) and at rest (AES-256) on our cloud infrastructure." },
    { title: "Access Is Controlled by Role", desc: "Administrators assign team members roles with defined permissions. Only authorised users can export attendee data, view payment details, or change event settings." },
    { title: "Consent Is Captured at Registration", desc: "Your registration forms include configurable GDPR consent fields. Attendees explicitly opt in — and you have a full record of when and what they agreed to." },
    { title: "You Stay in Control of Your Data", desc: "Export your attendee data at any time, respond to deletion requests through the admin panel, and request full data removal when you close your account." },
  ]}
  ctaTitle="Ready to Run Secure, Compliant Events?"
  ctaCopy="See how EventHex gives enterprise and procurement teams the security posture they need — without slowing down your event team."
  whyHeading="Why Security Teams Trust EventHex"
  whyCards={[
    { title: "Encrypted End to End", desc: "TLS 1.3 in transit, AES-256 at rest — attendee data is protected throughout", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' },
    { title: "GDPR-Aligned", desc: "Consent capture, data subject requests, and retention controls built in", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>' },
    { title: "Role-Based Access", desc: "Granular permissions so each team member sees only what they need", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
    { title: "PCI-Compliant Payments", desc: "Card data handled exclusively by Stripe, Razorpay, or Tap — never EventHex", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "Your Data, Your Rules", desc: "Full export and deletion on demand — no lock-in, no hidden retention", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>' },
  ]}
  faqs={[
    { q: "Where is my attendee data stored?", a: "EventHex stores data on reputable cloud infrastructure. We do not publish a single-region data residency guarantee at this time — if your organisation has specific residency requirements, contact us to discuss your needs." },
    { q: "Is EventHex GDPR compliant?", a: "EventHex follows GDPR-aligned practices: registration forms include configurable consent fields, administrators can respond to data subject access and deletion requests, and you control what data is collected and retained. We recommend consulting your legal team for your specific compliance obligations." },
    { q: "Can I delete an attendee's data?", a: "Yes. Administrators can export or permanently delete a specific attendee's record from the platform at any time to support data subject deletion requests." },
    { q: "How are payments secured?", a: "EventHex integrates with Stripe, Razorpay, and Tap for payment processing — all of which are PCI DSS-certified. Raw card data is never transmitted to or stored on EventHex servers. You receive only the transaction outcome." },
    { q: "Does EventHex have SOC 2 or ISO 27001 certification?", a: "We have not published third-party certification reports at this time. Our security posture is designed to align with these frameworks, and we conduct regular internal security reviews. Enterprise customers with specific audit requirements should contact us directly." },
    { q: "Who within my organisation can access attendee data?", a: "Access is controlled by the role-based permission system. Administrators define who can view, export, or manage attendee records. Team members with check-in roles, for example, cannot access payment or export functions." },
  ]}
  jsonLd={jsonLd}
/>
