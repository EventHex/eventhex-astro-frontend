---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/call-for-papers/HeroSection.astro";
import StatsSection from "../components/call-for-papers/StatsSection.astro";
import BentoGrid from "../components/call-for-papers/BentoGrid.astro";
import FeatureCards from "../components/call-for-papers/FeatureCards.astro";
import HowItWorksSection from "../components/call-for-papers/HowItWorksSection.astro";
import CTASection from "../components/call-for-papers/CTASection.astro";
import CoordinationTools from "../components/call-for-papers/CoordinationTools.astro";
import FaqSection from "../components/call-for-papers/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Call for Papers & Abstract Submission Software | EventHex";
const description = "End-to-end call for papers management: submission portal, peer review, rubric scoring, acceptance workflows, and proceedings export.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Call for Papers & Abstract Submission",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/call-for-papers/",
  description: "End-to-end call for papers management: submission portal, peer review, rubric scoring, acceptance workflows, and proceedings export.",
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Abstract Submission Portal",
    "Peer Review Assignment",
    "Custom Scoring Rubrics",
    "Blind & Double-Blind Review",
    "Automated Decision Emails",
    "Session Assignment",
    "Proceedings Export",
    "Camera-Ready Submission",
    "Conflict of Interest Management",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/call-for-papers/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
