---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ICONS } from "../lib/featureIcons";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Invoicing & GST Billing",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Finance-grade invoicing for events — GST-compliant invoices with sequential numbering, tax breakdown, PDF generation, credit notes, refunds, multi-currency billing, and payment reconciliation.",
  url: "https://eventhex.ai/invoicing-gst/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "GST-Compliant Invoices",
    "Sequential Invoice Numbering",
    "Tax Breakdown",
    "PDF Invoice Generation",
    "Credit Notes",
    "Refunds",
    "Multi-Currency Billing",
    "Payment Reconciliation",
    "Stripe, Razorpay & Tap Integration",
  ],
};
---

<FeatureV2Layout
  pageTitle="Event Invoicing Software — GST-Compliant Billing for Events | EventHex"
  pageDescription="Finance-grade event invoicing — GST invoices with sequential numbering and tax breakdown, PDF delivery, credit notes, refunds, multi-currency support, and Stripe/Razorpay/Tap reconciliation."
  canonical="https://eventhex.ai/invoicing-gst/"
  badge="Event Invoicing & GST Billing"
  heroTitleLine1="Finance-Grade Invoicing"
  heroTitleLine2="Built for Event Organizers"
  heroCopy="Generate GST-compliant invoices automatically for every ticket sale — with sequential numbering, full tax breakdown, PDF delivery, and built-in credit notes. Designed for finance teams running B2B events in India and the GCC."
  trustItems={["GST & PAN Fields", "Sequential Invoice Numbering", "Stripe, Razorpay & Tap"]}
  stats={[
    { value: "100%", label: "GST Compliant" },
    { value: "< 5 sec", label: "Invoice Generation" },
    { value: "3+", label: "Payment Gateways" },
    { value: "Multi", label: "Currency Support" },
  ]}
  statsHeadline={{
    white1: "Every transaction.",
    accent: "Every invoice.",
    white2: "Audit-ready",
    accent2: "instantly",
  }}
  bentoHeading="Complete Event Billing in One Place"
  bentoSubtitle="From GST invoice generation to credit notes, refunds, and bank reconciliation — EventHex handles the full billing lifecycle for events so your finance team never has to touch a spreadsheet."
  bentoTabs={[
    {
      tab: "GST Invoicing",
      cards: [
        { title: "GST-Compliant Invoices", desc: "Every ticket sale generates a compliant tax invoice with GSTIN, HSN/SAC code, CGST/SGST/IGST breakdown, and your registered business details.", illustration: ILLOS.invoice },
        { title: "Sequential Invoice Numbering", desc: "Invoice numbers follow a configurable sequential series — by financial year or event — meeting GST audit requirements.", illustration: ILLOS.document },
        { title: "PDF Invoice Generation", desc: "Branded PDF invoices are generated automatically and sent to attendees by email. Download any invoice from the billing dashboard at any time.", illustration: ILLOS.mail },
        { title: "Billing Address with GST & PAN Fields", desc: "Attendees enter their company name, billing address, GSTIN, and PAN at checkout — all captured and printed on the invoice automatically.", illustration: ILLOS.clipboard },
        { title: "Multi-Currency Billing", desc: "Accept payments and issue invoices in INR, AED, USD, GBP, EUR, and more. Currency is locked at the time of payment for accurate records.", illustration: ILLOS.globe },
      ],
    },
    {
      tab: "Credit Notes & Refunds",
      cards: [
        { title: "Credit Notes", desc: "Issue a credit note against any invoice in one click — including full or partial amounts — with a compliant reference back to the original invoice.", illustration: ILLOS.document },
        { title: "Refunds", desc: "Initiate full or partial refunds directly from the billing dashboard. EventHex pushes the refund to Stripe, Razorpay, or Tap and updates the invoice status automatically.", illustration: ILLOS.refund },
        { title: "Cancellation Billing", desc: "When a registration is cancelled, EventHex can automatically void the invoice or issue a credit note based on your configured cancellation policy.", illustration: ILLOS.refresh },
        { title: "Refund Audit Trail", desc: "Every credit note and refund is logged with a timestamp, user, and reason — giving your finance team a complete, auditable paper trail.", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "Reconciliation",
      cards: [
        { title: "Payment Reconciliation", desc: "Match every payment — online, offline, or manual — against its invoice. Outstanding, settled, and partially paid invoices are surfaced automatically.", illustration: ILLOS.dashboard },
        { title: "Stripe Integration", desc: "Stripe payments sync in real time — payment intent, charge ID, and settlement status are attached to the corresponding invoice automatically.", illustration: ILLOS.creditcard },
        { title: "Razorpay Integration", desc: "Razorpay order and payment IDs are linked to invoices at checkout. Capture, refund, and settlement status update without manual reconciliation.", illustration: ILLOS.creditcard },
        { title: "Tap Integration", desc: "For GCC-based events, Tap payments are reconciled against invoices with the same one-click process as Stripe and Razorpay.", illustration: ILLOS.money },
        { title: "Manual Payment Tracking", desc: "Record cash, bank transfer, or cheque payments against any invoice. Manual payments appear in the same reconciliation view as gateway transactions.", illustration: ILLOS.clipboard },
      ],
    },
  ]}
  stackingHeading="Event Billing Features"
  stackingHighlight="Finance Teams Trust"
  stackingCards={[
    {
      title: "GST Invoices Generated at Checkout — No Manual Work",
      desc: "When an attendee completes a B2B ticket purchase, EventHex captures their GSTIN and billing address, applies the correct tax rate (CGST+SGST for intra-state, IGST for inter-state), assigns the next sequential invoice number, and generates a PDF — all before the confirmation email lands.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "GST-compliant event invoice PDF with tax breakdown and sequential numbering",
    },
    {
      title: "Credit Notes and Refunds Without the Back-and-Forth",
      desc: "Cancellations and refunds no longer require your finance team to chase the tech team. Issue a credit note or initiate a refund directly from the billing dashboard — EventHex pushes the refund to Stripe, Razorpay, or Tap, links the credit note to the original invoice, and updates the attendee's status in one action.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Credit note issuance workflow in EventHex billing dashboard",
    },
    {
      title: "Full Reconciliation Across Every Payment Channel",
      desc: "Events rarely collect money through a single channel — online card payments, bank transfers, corporate purchase orders, and comp tickets all need to be accounted for. EventHex reconciliation brings every channel into one view: gateway payments auto-matched, manual payments logged, outstanding invoices flagged, and export-ready for your accounting system.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Payment reconciliation dashboard showing matched invoices and outstanding balances",
    },
  ]}
  howItWorksHeading="How Event Invoicing Works in EventHex"
  steps={[
    { title: "Configure Your Tax & Invoice Settings", desc: "Enter your business GSTIN, invoice number series, tax rates, and billing address. Set up payment gateways — Stripe, Razorpay, or Tap — once and they apply to every event." },
    { title: "Attendees Provide Billing Details at Checkout", desc: "B2B buyers enter their company name, GSTIN, PAN, and billing address during registration. EventHex validates the GSTIN format before checkout completes." },
    { title: "Invoices Are Generated and Delivered Automatically", desc: "At payment confirmation, EventHex assigns a sequential invoice number, calculates the correct GST split, generates a branded PDF, and emails it to the buyer — no manual action required." },
    { title: "Manage Refunds and Reconcile from One Dashboard", desc: "Issue credit notes, trigger refunds, and reconcile every payment — gateway or manual — from the billing dashboard. Export invoice reports for your accounting software at any time." },
  ]}
  ctaTitle="Ready to Simplify Event Billing?"
  ctaCopy="See how EventHex automates GST invoicing, credit notes, and payment reconciliation for your next event — built for finance teams who need audit-ready records from day one."
  whyHeading="Why Finance Teams Choose EventHex Billing"
  whyCards={[
    { title: "GST Compliant Out of the Box", desc: "Sequential numbering, GSTIN capture, CGST/SGST/IGST breakdown, HSN/SAC codes, and PDF delivery — all built in, no customisation required.", icon: ICONS.document },
    { title: "Instant PDF Invoices", desc: "Branded PDF invoices are generated and emailed at the moment of payment — no post-event invoice runs, no manual PDF creation.", icon: ICONS.invoice },
    { title: "Credit Notes in One Click", desc: "Issue full or partial credit notes against any invoice directly from the billing dashboard. Each credit note links back to the original invoice for a clean audit trail.", icon: ICONS.refresh },
    { title: "Multi-Gateway Reconciliation", desc: "Stripe, Razorpay, Tap, and manual payments all reconcile in one view. No spreadsheet merging, no gateway log exports.", icon: ICONS.creditcard },
    { title: "Multi-Currency Support", desc: "Issue invoices in INR, AED, USD, GBP, EUR, and more. Currency is fixed at payment time so exchange-rate discrepancies never appear in your records.", icon: ICONS.money },
  ]}
  faqs={[
    { q: "Does EventHex generate GST-compliant invoices automatically?", a: "Yes. Every ticket sale generates a compliant tax invoice with GSTIN, billing address, CGST/SGST/IGST breakdown, HSN/SAC code, and a sequential invoice number — all automatically at payment confirmation." },
    { q: "How does sequential invoice numbering work?", a: "You configure an invoice number prefix and starting number (e.g. INV-2025-0001). EventHex assigns the next number in sequence to every new invoice, by financial year or per event, meeting GST audit requirements." },
    { q: "Can attendees enter their GSTIN and PAN at checkout?", a: "Yes. EventHex adds GSTIN, PAN, company name, and billing address fields to the B2B checkout flow. GSTIN format is validated before checkout completes. All details are printed on the invoice and stored against the attendee record." },
    { q: "How do I issue a credit note or process a refund?", a: "From the billing dashboard, find the invoice and click 'Issue Credit Note' or 'Refund'. Enter the amount (full or partial), add a reason, and confirm. EventHex pushes the refund to Stripe, Razorpay, or Tap and generates the credit note linked to the original invoice." },
    { q: "Which payment gateways does EventHex support for invoicing?", a: "EventHex integrates with Stripe (global), Razorpay (India), and Tap (GCC) for online payments. Manual payments — bank transfer, cash, cheque, PO — can also be recorded against invoices in the reconciliation dashboard." },
    { q: "Can I invoice in multiple currencies?", a: "Yes. EventHex supports INR, AED, USD, GBP, EUR, and other currencies. When a payment is made, the invoice is generated in the transaction currency and the exchange rate is locked at that point." },
    { q: "Is EventHex invoicing suitable for B2B events in India and the GCC?", a: "Yes — EventHex invoicing was designed for exactly this audience. GSTIN and PAN fields, intra-state vs. inter-state GST logic, and Razorpay integration cover Indian B2B requirements. Multi-currency and Tap integration cover GCC events. Both markets get PDF invoices, credit notes, and full reconciliation." },
    { q: "Can I export invoices for my accounting software?", a: "Yes. Export all invoices, credit notes, and payment records as CSV from the billing dashboard. The export includes invoice number, buyer details, tax breakdown, payment status, and gateway transaction ID — ready to import into Tally, QuickBooks, Zoho Books, or any accounting system." },
  ]}
  jsonLd={jsonLd}
/>
