---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "EventHex HubSpot Integration — Bidirectional CRM Sync",
  pageDescription: "Sync attendee data bidirectionally between EventHex and HubSpot CRM. Auto-create contacts, deals, and triggers with zero manual data entry.",
  canonical: "https://eventhex.ai/integrations/hubspot/",
  badge: "HubSpot Integration",
  heroTitleLine1: "Connect EventHex to",
  heroTitleLine2: "HubSpot CRM — Zero Manual Data Entry",
  heroCopy: "Every attendee registration, check-in, and session interaction flows automatically into HubSpot. Update contact records, create deals, and trigger follow-up sequences without leaving EventHex.",
  accentColor: "#FF7A59",
  stats: [
    { value: "Bidirectional", label: "CRM Sync" },
    { value: "Real-Time", label: "Data Updates" },
    { value: "1-Click", label: "Setup" },
    { value: "0", label: "Manual Exports" },
  ],
  featuresHeading: "Everything You Need for a Connected CRM",
  featuresSubheading: "Attendee data flows into HubSpot automatically. Deals, tags, and sequences follow.",
  features: [
    { emoji: "🔄", title: "Bidirectional Contact Sync", description: "Attendee registrations create or update HubSpot contacts automatically. Changes in HubSpot sync back to EventHex — no duplicates, no gaps." },
    { emoji: "💼", title: "Deal Creation", description: "Create HubSpot deals automatically when an attendee registers, pays, or reaches a specific engagement threshold at your event." },
    { emoji: "🏷️", title: "Attendee Tags & Properties", description: "Push ticket type, check-in status, session attendance, and engagement scores as custom contact properties in HubSpot." },
    { emoji: "📧", title: "Trigger Email Sequences", description: "Enroll contacts in HubSpot email sequences based on EventHex events — registration, check-in, session attendance, or feedback submission." },
    { emoji: "📊", title: "Event ROI Attribution", description: "Track which event touchpoints generate pipeline and revenue in HubSpot. Attribute deals to specific events, sessions, or campaigns." },
    { emoji: "📋", title: "List Segmentation", description: "Automatically add attendees to HubSpot lists based on ticket type, event status, or engagement level. Power targeted follow-up campaigns." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Connect HubSpot", description: "Authorize your HubSpot account via OAuth. EventHex connects securely without sharing passwords." },
    { title: "Map Fields", description: "Map EventHex attendee fields to HubSpot contact properties. Custom fields are supported." },
    { title: "Configure Sync Rules", description: "Choose what triggers sync — registration, check-in, session attendance, or all of the above." },
    { title: "Activate", description: "Turn on bidirectional sync. Data flows automatically in real time." },
  ],
  useCasesHeading: "Who Uses HubSpot with EventHex?",
  useCases: [
    { emoji: "🏭", title: "Trade Show Lead Capture", description: "Every booth visit, badge scan, and session attendance creates or updates a HubSpot contact with engagement data for immediate sales follow-up." },
    { emoji: "🎤", title: "Conference Follow-Up", description: "Automatically enroll attendees in post-conference email sequences based on which sessions they attended and their engagement level." },
    { emoji: "🤝", title: "Sponsor Pipeline", description: "Create HubSpot deals for sponsor packages. Track sponsor engagement at the event and attribute pipeline to specific activations." },
    { emoji: "📝", title: "Sales-Driven Registration", description: "Sync HubSpot contact lists to EventHex for VIP invitations. Track registration and attendance back in HubSpot for pipeline attribution." },
  ],
  ctaTitle: "Ready to Sync EventHex with HubSpot?",
  ctaCopy: "Connect your HubSpot account and start syncing attendee data in real time — zero manual exports.",
  faqs: [
    { question: "Is the sync truly bidirectional?", answer: "Yes. Changes in EventHex push to HubSpot, and changes in HubSpot push back to EventHex. Contact properties, tags, and lifecycle stages stay synchronized." },
    { question: "Can I trigger HubSpot workflows from EventHex events?", answer: "Yes. EventHex updates HubSpot contact properties in real time. You can build HubSpot workflows that trigger on these property changes — for example, enrolling a contact in a sequence when check-in status changes to 'checked-in'." },
    { question: "Which HubSpot tiers are supported?", answer: "The integration works with HubSpot Free, Starter, Professional, and Enterprise tiers. Some features like custom properties and workflows may require Professional or above." },
    { question: "How does authentication work?", answer: "EventHex uses HubSpot's OAuth 2.0 flow. You authorize once and the connection stays active. No API keys or passwords are shared." },
    { question: "Can I sync historical event data?", answer: "Yes. When you first connect, EventHex can push existing attendee data to HubSpot. You choose which events and fields to include in the initial sync." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex HubSpot Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/hubspot/",
    description: "Bidirectional CRM sync between EventHex and HubSpot. Auto-create contacts, deals, and email sequences.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
