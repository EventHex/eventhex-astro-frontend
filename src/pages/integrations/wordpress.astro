---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "EventHex WordPress Plugin — Embed Event Registration & Ticket Sales",
  pageDescription: "Add the EventHex WordPress plugin to embed event listings, registration forms, ticket checkout, and attendee portals into any WordPress page.",
  canonical: "https://eventhex.ai/integrations/wordpress/",
  badge: "WordPress Integration",
  heroTitleLine1: "Sell Tickets & Manage Events",
  heroTitleLine2: "Directly from Your WordPress Website",
  heroCopy: "Add the EventHex WordPress plugin to embed event listings, registration forms, ticket checkout, and attendee portals into any WordPress page. No redirects, no iframes — native WordPress integration.",
  accentColor: "#21759B",
  stats: [
    { value: "Shortcodes", label: "& Block Editor Support" },
    { value: "1-Click", label: "Plugin Install" },
    { value: "0%", label: "EventHex Platform Fee" },
    { value: "Full CSS", label: "Theme Customization" },
  ],
  featuresHeading: "WordPress-Native Event Management",
  featuresSubheading: "Embed event ticketing, registration, and attendee portals into any WordPress theme.",
  features: [
    { emoji: "📋", title: "Event Listings Block", description: "Add an event listing block or shortcode to any WordPress page. Display upcoming events with dates, venues, ticket availability, and registration buttons." },
    { emoji: "🎫", title: "Ticket Checkout Embed", description: "Embed the full ticket checkout flow into a WordPress page. Attendees complete purchases without leaving your website." },
    { emoji: "👤", title: "Attendee Portal", description: "Give attendees a self-service portal on your WordPress site to view tickets, update profiles, and access event resources." },
    { emoji: "🎨", title: "Full CSS Control", description: "Every embedded element inherits your WordPress theme styles. Override with custom CSS for pixel-perfect integration with any theme." },
    { emoji: "🔗", title: "REST API Bridge", description: "The plugin bridges EventHex REST APIs with WordPress. Event data is fetched in real time — no stale caches or sync delays." },
    { emoji: "📊", title: "Registration Data in WP", description: "Access attendee registration data directly in the WordPress admin. Export reports, manage check-ins, and view analytics without leaving WP." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Install Plugin", description: "Upload the EventHex plugin to your WordPress site or install from the plugin repository. Activate in one click." },
    { title: "Connect Account", description: "Enter your EventHex API key in the plugin settings to link your WordPress site to your EventHex account." },
    { title: "Add to Pages", description: "Use the block editor or shortcodes to embed event listings, registration forms, or ticket checkout on any page." },
    { title: "Style to Match Theme", description: "The plugin inherits your theme styles. Add custom CSS overrides if you need pixel-perfect design control." },
  ],
  useCasesHeading: "Who Uses WordPress with EventHex?",
  useCases: [
    { emoji: "🏛️", title: "Association Websites", description: "Professional associations with existing WordPress websites that need to add event registration and member ticketing without redirecting to an external platform." },
    { emoji: "🏢", title: "Corporate Intranets", description: "Internal WordPress sites where employees register for town halls, training sessions, and company events without leaving the intranet." },
    { emoji: "🎤", title: "Conference Websites", description: "Dedicated conference WordPress sites that need embedded ticketing, speaker listings, and real-time schedule displays." },
    { emoji: "📅", title: "Multi-Event Organizations", description: "Organizations running dozens of events per year that need a centralized event listing page with registration flows embedded in their main WordPress site." },
  ],
  ctaTitle: "Ready to Sell Tickets Directly from Your WordPress Website?",
  ctaCopy: "Install the EventHex WordPress plugin and embed event registration on any page — zero redirects, 0% platform fees.",
  faqs: [
    { question: "Does the plugin replace my existing WordPress site?", answer: "No. The plugin adds EventHex functionality to your existing WordPress site. It embeds event listings, registration forms, and checkout flows into your pages without changing your site structure." },
    { question: "Will it match my WordPress theme?", answer: "Yes. The plugin's embedded elements inherit your theme's typography, colors, and spacing. You can add custom CSS overrides for additional control." },
    { question: "Do attendees leave my website to complete checkout?", answer: "No. The full checkout flow — ticket selection, form fields, and payment — happens on your WordPress page. Attendees never see a redirect to eventhex.ai." },
    { question: "Does it work with WooCommerce?", answer: "The EventHex plugin operates independently of WooCommerce. You do not need WooCommerce installed. If you have WooCommerce, both can coexist without conflicts." },
    { question: "Can I restrict event access to logged-in WordPress users?", answer: "Yes. You can configure the plugin to show event registration only to logged-in WordPress users, specific user roles, or membership levels." },
    { question: "Does it work with page builders like Elementor?", answer: "Yes. The plugin provides both Gutenberg blocks and shortcodes. Shortcodes work inside any page builder — Elementor, Beaver Builder, Divi, and others." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex WordPress Plugin",
    applicationCategory: "WordPressPlugin",
    operatingSystem: "WordPress",
    url: "https://eventhex.ai/integrations/wordpress/",
    description: "Embed event listings, registration forms, ticket checkout, and attendee portals into any WordPress page.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
