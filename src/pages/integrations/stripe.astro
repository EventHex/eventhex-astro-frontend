---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "EventHex Stripe Integration — 0% Fee Event Ticketing Payments",
  pageDescription: "Accept event ticket payments via Stripe with zero EventHex platform fees. 135+ currencies, automated refunds, PCI DSS compliant.",
  canonical: "https://eventhex.ai/integrations/stripe/",
  badge: "Stripe Integration",
  heroTitleLine1: "Collect Ticket Payments via",
  heroTitleLine2: "Stripe — Keep 100% of Revenue",
  heroCopy: "Connect your Stripe account to EventHex and start accepting card payments globally. No per-ticket fees from EventHex. You pay Stripe's standard processing rate and nothing else.",
  accentColor: "#635BFF",
  stats: [
    { value: "0%", label: "EventHex Platform Fees" },
    { value: "135+", label: "Currencies Supported" },
    { value: "Real-Time", label: "Payment Confirmation" },
    { value: "Instant", label: "Payout to Your Account" },
  ],
  featuresHeading: "Everything You Need for Seamless Payments",
  featuresSubheading: "Stripe powers the world's top platforms. Now it powers your events too.",
  features: [
    { emoji: "🔗", title: "One-Click Stripe Connect", description: "Link your Stripe account to EventHex in seconds. No complex API configuration required — just authorize and start selling tickets." },
