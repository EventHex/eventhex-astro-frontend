    { question: "Which countries support Stripe Connect?", answer: "Stripe is available in 47+ countries. If your business has a Stripe account, you can connect it to EventHex regardless of where your attendees are located." },
    { question: "Can I test Stripe integration before going live?", answer: "Yes. EventHex supports Stripe test mode so you can simulate payments, refunds, and webhook events without processing real transactions." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Stripe Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/stripe/",
    description: "Accept event ticket payments via Stripe with zero EventHex platform fees.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
