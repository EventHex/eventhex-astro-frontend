    { emoji: "🛒", title: "Multi-Ticket Checkout", description: "Attendees can purchase multiple ticket types in a single Stripe Checkout session — early-bird, VIP, workshop add-ons, and group bundles." },
    { emoji: "🧾", title: "Payment Receipts", description: "Stripe automatically sends payment confirmation receipts. EventHex triggers ticket delivery and check-in QR codes on successful payment." },
    { emoji: "🔒", title: "PCI DSS Compliance", description: "Stripe is PCI Level 1 certified. Card data never touches EventHex servers — it goes directly to Stripe's secure infrastructure." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Connect Stripe Account", description: "Authorize your Stripe account through EventHex settings. One click, no code." },
    { title: "Set Ticket Prices", description: "Create ticket types with prices in your preferred currency. Stripe handles the rest." },
    { title: "Attendees Pay via Stripe", description: "Buyers complete checkout through Stripe's secure hosted payment page." },
    { title: "Confirmation & Revenue", description: "Tickets are delivered instantly. Revenue settles directly into your Stripe account." },
  ],
  useCasesHeading: "Who Uses Stripe with EventHex?",
  useCases: [
    { emoji: "🌐", title: "International Conferences", description: "Accept payments from 195+ countries in 135+ currencies. Let Stripe handle FX, compliance, and local card networks." },
    { emoji: "🎟️", title: "Early-Bird Campaigns", description: "Launch time-limited discounted tickets with automatic price tier transitions. Stripe processes each sale in real time." },
    { emoji: "👥", title: "Group Purchases", description: "Enable group ticket bundles where one buyer purchases for multiple attendees in a single Stripe Checkout session." },
    { emoji: "🏢", title: "Sponsorship Payments", description: "Collect sponsorship fees, exhibitor booth payments, and premium access charges through the same Stripe account." },
  ],
  ctaTitle: "Start Collecting Payments with 0% EventHex Fees",
  ctaCopy: "Connect your Stripe account today and keep every dollar of your ticket revenue.",
  faqs: [
    { question: "Does EventHex charge any fees on Stripe payments?", answer: "No. EventHex charges 0% platform fee when you connect your own Stripe account. You only pay Stripe's standard processing rate (typically 2.9% + 30¢ per transaction, varies by country)." },
    { question: "When do I receive my payouts?", answer: "Payouts follow your Stripe account schedule — typically 2 business days for most countries. EventHex does not hold or delay your funds." },
