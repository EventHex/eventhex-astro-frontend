---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "YouTube Integration — Live Stream & Publish Session Recordings | EventHex",
  pageDescription: "Live-stream event sessions to YouTube and automatically publish session recordings to your YouTube channel via OAuth upload. Reach global audiences beyond your registered attendees.",
  canonical: "https://eventhex.ai/integrations/youtube/",
  badge: "YouTube Integration",
  heroTitleLine1: "Live-Stream Sessions & Publish",
  heroTitleLine2: "Recordings to YouTube — Automatically",
  heroCopy: "Connect your YouTube channel to EventHex via OAuth and live-stream keynotes to a global audience. Session recordings are automatically uploaded to YouTube after the event — turning every session into evergreen on-demand content.",
  accentColor: "#FF0000",
  stats: [
    { value: "Live", label: "YouTube Stream per Session" },
    { value: "Auto", label: "Post-Event Upload" },
    { value: "Global", label: "Audience Reach Beyond Venue" },
    { value: "1-Click", label: "OAuth Channel Connect" },
  ],
  featuresHeading: "Turn Every Session into YouTube Content",
  featuresSubheading: "YouTube is the world's largest video platform. EventHex puts your sessions there — live and on-demand — with zero manual effort.",
  features: [
    { emoji: "📡", title: "Live Stream to YouTube", description: "EventHex generates a YouTube Live broadcast for each session and distributes the stream URL to presenters. Go live with one click from the organizer dashboard." },
    { emoji: "🔴", title: "Simulcast Support", description: "Stream to YouTube and your in-person audience simultaneously. EventHex manages the RTMP stream key handoff to your AV team or encoder software automatically." },
    { emoji: "📤", title: "Automatic Post-Event Upload", description: "After a session ends, EventHex uploads the recording to your YouTube channel via the YouTube Data API v3. No manual download or re-upload required." },
    { emoji: "🔒", title: "Privacy Control per Session", description: "Set each YouTube upload as Public, Unlisted, or Private from EventHex. Unlock recordings after the event or keep them gated for registered attendees only." },
    { emoji: "📝", title: "Auto-Generated Titles & Descriptions", description: "YouTube video titles, descriptions, tags, and playlists are pre-populated from EventHex session metadata — speaker name, session title, event name, and date." },
    { emoji: "📋", title: "Chapter Markers from Agenda", description: "EventHex adds YouTube chapter timestamps to video descriptions based on session agenda segments — making long recordings easy to navigate for viewers." },
    { emoji: "📊", title: "YouTube Analytics in EventHex", description: "View time, watch duration, and audience demographics from YouTube are surfaced in the EventHex post-event analytics dashboard alongside registration and attendance data." },
    { emoji: "🎬", title: "Playlist Organisation", description: "Sessions are automatically organised into event-specific YouTube playlists — one per track or one per event day — so your channel stays structured as you scale." },
  ],
  howItWorksHeading: "From Live Session to YouTube — Fully Automated",
  steps: [
    { title: "Connect YouTube Channel", description: "Authorize EventHex with your YouTube/Google account via OAuth. Your channel is linked instantly — one-time setup." },
    { title: "Configure Session Streaming", description: "Enable YouTube streaming per session in EventHex. Broadcast IDs and RTMP stream keys are generated automatically." },
    { title: "Go Live & Stream", description: "Click 'Start Stream' in EventHex or hand the stream key to your AV encoder. YouTube Live goes live in seconds." },
    { title: "Recordings Upload Automatically", description: "When the session ends, EventHex uploads the recording to YouTube with pre-populated metadata, chapters, and playlist assignment." },
  ],
  useCasesHeading: "Who Uses YouTube with EventHex?",
  useCases: [
    { emoji: "🎤", title: "Keynote & Plenary Sessions", description: "Live-stream flagship keynotes to YouTube for global reach beyond your venue capacity. Capture audiences who couldn't register or attend in person." },
    { emoji: "🖥️", title: "Virtual & Hybrid Conferences", description: "Deliver the full virtual conference experience on YouTube for non-registered audiences while EventHex manages the registered attendee experience on the event app." },
    { emoji: "📚", title: "On-Demand Content Libraries", description: "Build a permanent YouTube content library from every session. EventHex uploads all recordings post-event, creating evergreen content that drives organic search traffic." },
    { emoji: "🚀", title: "Product Launches & Announcements", description: "Live-stream product reveal sessions and demos on YouTube to maximize reach. Auto-upload the recording as a permanent product launch video on your channel." },
  ],
  ctaTitle: "Live-Stream & Publish Sessions to YouTube with EventHex",
  ctaCopy: "Connect your YouTube channel and let EventHex handle live streaming, automatic post-event uploads, and content organization — with zero manual effort.",
  faqs: [
    { question: "Do I need a YouTube channel to use this integration?", answer: "Yes. You need a YouTube channel associated with a Google account. EventHex connects via OAuth and creates broadcasts and uploads on behalf of your channel." },
    { question: "Can I control which sessions are streamed to YouTube?", answer: "Yes. YouTube streaming is enabled per session in EventHex settings. You can stream all sessions, keynotes only, or a specific track — the choice is made per session." },
    { question: "How are session recordings uploaded to YouTube?", answer: "After a session ends, EventHex uses the YouTube Data API v3 to upload the recording file directly to your channel. Title, description, tags, and playlist assignment are pre-populated from session metadata." },
    { question: "Can recordings be private until I approve them?", answer: "Yes. You can set the default upload visibility to Private or Unlisted in EventHex. Once you review a recording, you can change visibility to Public directly from the EventHex organizer dashboard." },
    { question: "Does EventHex support YouTube Live for multi-stream setups?", answer: "Yes. EventHex generates RTMP stream keys that work with standard encoders (OBS, vMix, hardware encoders). This enables professional multi-camera setups to stream to YouTube through EventHex." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex YouTube Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/youtube/",
    description: "Live-stream event sessions to YouTube and automatically upload session recordings to your channel via OAuth with auto-populated metadata and playlist organisation.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
---

<IntegrationLayout {...data} />
