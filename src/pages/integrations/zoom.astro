---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "Zoom Integration — Host Virtual & Hybrid Events | EventHex",
  pageDescription: "Run virtual and hybrid event sessions directly on Zoom with EventHex. Automated meeting creation, bot join for recording and transcription, and live session links for attendees.",
  canonical: "https://eventhex.ai/integrations/zoom/",
  badge: "Zoom Integration",
  heroTitleLine1: "Host Virtual & Hybrid Sessions",
  heroTitleLine2: "Powered by Zoom — Zero Manual Setup",
  heroCopy: "Connect Zoom to EventHex and automatically spin up meeting links for every session. Our meeting bot joins each call to capture attendance, record, and transcribe — all synced back to your event dashboard.",
  accentColor: "#2D8CFF",
  stats: [
    { value: "Auto", label: "Meeting Link Generation" },
    { value: "Real-Time", label: "Attendance Capture" },
    { value: "1-Click", label: "Recording Download" },
    { value: "AI", label: "Session Transcription" },
  ],
  featuresHeading: "Everything You Need for Virtual & Hybrid Sessions",
  featuresSubheading: "Zoom powers billions of meetings. EventHex makes every one of them part of your event experience.",
  features: [
    { emoji: "🔗", title: "Auto Meeting Creation", description: "When you publish a session in EventHex, a Zoom meeting link is generated automatically and delivered to registered attendees — no manual scheduling." },
    { emoji: "🤖", title: "Meeting Bot Join", description: "EventHex's bot joins each Zoom session at the scheduled start time to capture real-time attendance data without requiring host intervention." },
    { emoji: "🎙️", title: "Recording & Transcription", description: "Sessions are recorded and transcribed automatically. Transcripts are indexed in EventHex for searchable on-demand content after the event." },
    { emoji: "📅", title: "Calendar-Synced Scheduling", description: "Zoom links are embedded in calendar invites sent to attendees. EventHex manages time-zone conversion and reminder emails automatically." },
    { emoji: "🔐", title: "Password & Waiting Room Control", description: "Enforce Zoom waiting rooms and per-session passwords directly from EventHex settings — keeping your sessions private and attendee-only." },
    { emoji: "📊", title: "Engagement Analytics", description: "EventHex pulls Zoom poll results, Q&A logs, and reaction data into the event analytics dashboard for a full picture of attendee engagement." },
    { emoji: "🌐", title: "Hybrid Session Support", description: "Combine in-person and remote attendees in one session. Zoom handles the virtual stream; EventHex manages check-in for both audiences simultaneously." },
    { emoji: "🔄", title: "Post-Event Content Delivery", description: "Recordings and AI-generated summaries are automatically published to the attendee portal once a session ends — no manual upload required." },
  ],
  howItWorksHeading: "From Setup to Session in Minutes",
  steps: [
    { title: "Connect Zoom Account", description: "Authorize your Zoom account via OAuth in EventHex settings. Takes under 60 seconds." },
    { title: "Create Your Sessions", description: "Add sessions to your EventHex agenda. Zoom meeting links are generated instantly for each one." },
    { title: "Attendees Join Seamlessly", description: "Registered attendees receive Zoom links in confirmation emails and the event app — one click to join." },
    { title: "Capture & Analyze", description: "EventHex bot records attendance, captures recordings, and surfaces engagement analytics post-event." },
  ],
  useCasesHeading: "Who Uses Zoom with EventHex?",
  useCases: [
    { emoji: "🖥️", title: "Virtual Conferences", description: "Run multi-track virtual conferences with automatically generated Zoom links per session. Attendees navigate tracks via the EventHex agenda." },
    { emoji: "🔀", title: "Hybrid Events", description: "Blend in-person and remote participation. EventHex syncs check-in data with Zoom attendance so you know exactly who joined from where." },
    { emoji: "🎓", title: "Training & Workshops", description: "Host interactive workshops on Zoom with breakout rooms. EventHex tracks completion and issues digital certificates automatically." },
    { emoji: "🚀", title: "Product Launches & Demos", description: "Stream product launches live on Zoom, capture viewer Q&A, and repurpose the recording as gated on-demand content inside EventHex." },
  ],
  ctaTitle: "Launch Your First Virtual Event on Zoom with EventHex",
  ctaCopy: "Connect Zoom today and let EventHex handle session scheduling, bot attendance, and post-event content delivery.",
  faqs: [
    { question: "Does EventHex create Zoom meetings automatically?", answer: "Yes. When you publish a session in EventHex, a Zoom meeting is created automatically using your connected Zoom account. The link is delivered to attendees via email and the event app." },
    { question: "What does the EventHex meeting bot do in Zoom?", answer: "The bot joins each session at the scheduled time to log attendance in real time, verify registered attendees, and trigger recording. It does not interfere with the meeting host's controls." },
    { question: "Can I use my existing Zoom account?", answer: "Yes. You connect your own Zoom account via OAuth. EventHex creates meetings on behalf of the host account, so the meetings appear in your Zoom dashboard as normal." },
    { question: "Are recordings stored in Zoom or EventHex?", answer: "Recordings are stored in your Zoom cloud account. EventHex links to them from the attendee portal and can display transcripts generated from the recording." },
    { question: "Does this work for Zoom Webinars as well as meetings?", answer: "EventHex currently supports Zoom Meetings. Zoom Webinar support is on the roadmap. Contact us to discuss your webinar use case." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Zoom Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/zoom/",
    description: "Host virtual and hybrid event sessions on Zoom with automated meeting creation, bot attendance capture, and session transcription.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
---

<IntegrationLayout {...data} />
