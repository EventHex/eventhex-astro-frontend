---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "EventHex + Firebase Push Notifications — Real-Time Attendee Alerts",
  pageDescription: "Send real-time push notifications to iOS & Android via Firebase Cloud Messaging. Session reminders, schedule changes, and gamification alerts.",
  canonical: "https://eventhex.ai/integrations/push-notifications/",
  badge: "Push Notifications Integration",
  heroTitleLine1: "Send Real-Time Push Notifications via",
  heroTitleLine2: "Firebase — Direct to Attendee Devices",
  heroCopy: "Last-minute session changes, speaker announcements, game leaderboard updates, and emergency alerts — reach every attendee instantly through Firebase Cloud Messaging.",
  accentColor: "#FFCA28",
  stats: [
    { value: "< 1s", label: "Delivery Time" },
    { value: "iOS + Android", label: "Platform Support" },
    { value: "Rich Media", label: "Notification Content" },
    { value: "Targeted", label: "Segment Delivery" },
  ],
  featuresHeading: "Real-Time Notifications for Every Event Moment",
  featuresSubheading: "Push the right message to the right attendees at the right time.",
  features: [
    { emoji: "⚡", title: "Real-Time Delivery", description: "Notifications reach attendee devices in under 1 second. Ideal for time-sensitive announcements like session changes or emergency alerts." },
    { emoji: "🎯", title: "Segment Targeting", description: "Send notifications to specific attendee segments — VIPs, speakers, exhibitors, or attendees of a particular session track." },
    { emoji: "🖼️", title: "Rich Push Notifications", description: "Include images, action buttons, and deep links in push notifications. Direct attendees to specific sessions, polls, or sponsor pages." },
    { emoji: "📅", title: "Scheduled Notifications", description: "Pre-schedule notifications to fire at specific times — session start reminders, lunch break announcements, or closing ceremony alerts." },
    { emoji: "📊", title: "Delivery Analytics", description: "Track delivery rates, open rates, and click-through rates for every notification. Identify which messages drive the most engagement." },
    { emoji: "🔕", title: "Frequency Capping", description: "Set maximum notification frequency per attendee to prevent notification fatigue. Prioritize critical messages over promotional ones." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Connect Firebase", description: "Link your Firebase Cloud Messaging project to EventHex with your server key and project ID." },
    { title: "Configure Branding", description: "Set your notification icon, default sound, and branding for iOS and Android appearances." },
    { title: "Create Segments", description: "Define attendee segments based on ticket type, session tracks, or custom tags." },
    { title: "Send or Schedule", description: "Send notifications immediately or schedule them for specific event moments." },
  ],
  useCasesHeading: "Who Uses Push Notifications with EventHex?",
  useCases: [
    { emoji: "📋", title: "Schedule Changes", description: "Notify attendees instantly when a session is moved, a room changes, or a speaker cancels. No more confused attendees checking outdated schedules." },
    { emoji: "🎪", title: "Festival & Multi-Venue Alerts", description: "Guide attendees across multiple stages and venues with location-aware push notifications and real-time program updates." },
    { emoji: "⏰", title: "Session Reminders", description: "Send 'starting in 5 minutes' reminders for sessions attendees have bookmarked. Increase session attendance by up to 40%." },
    { emoji: "🎮", title: "Gamification Updates", description: "Push leaderboard updates, badge earned alerts, and challenge completion notifications to keep attendees engaged throughout the event." },
  ],
  ctaTitle: "Ready to Reach Attendees Instantly with Push Notifications?",
  ctaCopy: "Connect Firebase Cloud Messaging and start sending real-time alerts to every attendee's device.",
  faqs: [
    { question: "Do attendees need to download a separate app?", answer: "Attendees use the EventHex mobile app or your white-labeled event app, which includes Firebase push notification support. No additional downloads are needed beyond the event app." },
    { question: "Can I target notifications to specific sessions?", answer: "Yes. You can send push notifications to attendees who have bookmarked or registered for specific sessions, tracks, or workshop slots." },
    { question: "Does it work on both iOS and Android?", answer: "Yes. Firebase Cloud Messaging supports both iOS (APNs) and Android. EventHex handles the platform-specific formatting automatically." },
    { question: "Can I include images and action buttons?", answer: "Yes. Rich push notifications support images, up to 3 action buttons, and deep links that open specific screens in the event app." },
    { question: "Are there limits on how many notifications I can send?", answer: "Firebase Cloud Messaging does not charge per message and has generous rate limits. EventHex includes frequency capping controls to prevent notification fatigue." },
    { question: "Can I track which notifications were opened?", answer: "Yes. EventHex tracks delivery, display, and open events for every push notification. Analytics are available per notification and per segment." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Push Notifications (Firebase)",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web, iOS, Android",
    url: "https://eventhex.ai/integrations/push-notifications/",
    description: "Send real-time push notifications via Firebase Cloud Messaging to iOS & Android attendee devices.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
---

<IntegrationLayout {...data} />
