---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "Google Calendar Integration — Push Sessions & Agenda to Attendees | EventHex",
  pageDescription: "Sync your EventHex agenda to attendees' Google Calendars automatically. Push sessions, schedule reminders, and propagate real-time updates so attendees never miss a session.",
  canonical: "https://eventhex.ai/integrations/google-calendar/",
  badge: "Google Calendar Integration",
  heroTitleLine1: "Push Your Entire Event Agenda",
  heroTitleLine2: "to Attendees' Google Calendars",
  heroCopy: "Connect EventHex to Google Calendar and automatically push every session, workshop, and networking break to attendees' personal calendars at registration. Updates, cancellations, and reminders propagate in real time — zero manual effort.",
  accentColor: "#4285F4",
  stats: [
    { value: "Auto", label: "Calendar Event Creation" },
    { value: "Real-Time", label: "Schedule Update Sync" },
    { value: "1-Click", label: "Attendee Add-to-Calendar" },
    { value: "Multi", label: "Session Track Support" },
  ],
  featuresHeading: "Your Event Agenda, Directly in Google Calendar",
  featuresSubheading: "Attendees live in Google Calendar. EventHex puts your entire event there — automatically, accurately, and always up to date.",
  features: [
    { emoji: "📅", title: "One-Click Add to Calendar", description: "Attendees get a single 'Add all sessions to Google Calendar' button at registration. EventHex creates individual calendar events for every session they've selected." },
    { emoji: "🔄", title: "Real-Time Schedule Sync", description: "When you update a session time, room, or speaker in EventHex, the Google Calendar event updates automatically for all attendees — no re-send required." },
    { emoji: "⏰", title: "Automated Session Reminders", description: "Google Calendar reminders trigger on attendees' devices before each session. EventHex configures reminder timing (e.g. 1 hour, 15 minutes before) per event." },
    { emoji: "🗓️", title: "Full Agenda Push", description: "Push your entire multi-track, multi-day agenda to attendee calendars at once. Each session appears as a separate calendar event with full description, location, and links." },
    { emoji: "📍", title: "Location & Room Details", description: "Session room names, building locations, and venue addresses are embedded in each Google Calendar event — attendees always know exactly where to go." },
    { emoji: "🔗", title: "Session Links in Calendar", description: "For virtual and hybrid sessions, the Zoom, Teams, or Meet link is embedded in the Google Calendar event so attendees can join directly from their calendar." },
    { emoji: "🎯", title: "Track-Based Calendar Sync", description: "Attendees who select a specific track or session bundle get only the relevant sessions added to their calendar — not the full agenda, just what matters to them." },
    { emoji: "❌", title: "Cancellation Propagation", description: "If a session is cancelled in EventHex, the Google Calendar event is deleted and attendees receive an automatic cancellation notification via Google Calendar." },
  ],
  howItWorksHeading: "Session Published to Calendar in Seconds",
  steps: [
    { title: "Connect Google Calendar", description: "Authorize EventHex via Google OAuth. Calendar write permissions are granted so EventHex can create and manage events on behalf of attendees." },
    { title: "Publish Your Agenda", description: "Build your agenda in EventHex. Sessions are ready to sync to attendee calendars the moment they register." },
    { title: "Attendees Add Sessions at Registration", description: "During registration, attendees click 'Add to Google Calendar.' EventHex creates calendar events for all selected sessions instantly." },
    { title: "Sync Updates Automatically", description: "Every schedule change in EventHex propagates to Google Calendar in real time. Attendees see updates without any action on their part." },
  ],
  useCasesHeading: "Who Uses Google Calendar with EventHex?",
  useCases: [
    { emoji: "🎪", title: "Multi-Day Conferences", description: "Push a full 3-day conference agenda — keynotes, breakouts, networking, lunches — to attendees' Google Calendars so they can plan their entire experience in advance." },
    { emoji: "🏢", title: "Corporate Event Planning", description: "Internal events where all attendees use Google Workspace get automatic calendar distribution at registration — no invitation emails or calendar links to distribute manually." },
    { emoji: "🎓", title: "Training & Certification Programs", description: "Send multi-session training schedules to participants' calendars at enrollment. Completion reminders and assessment dates sync automatically as the program progresses." },
    { emoji: "🌐", title: "Virtual & Hybrid Events", description: "Calendar events for virtual sessions include the Zoom or Meet join link — attendees join directly from Google Calendar with one click, no searching for links in emails." },
  ],
  ctaTitle: "Put Your Event Agenda in Every Attendee's Google Calendar",
  ctaCopy: "Connect Google Calendar and let EventHex push sessions, sync updates, and keep attendees on schedule — automatically.",
  faqs: [
    { question: "Do attendees need to authorize Google Calendar access?", answer: "Yes. Attendees click 'Add to Google Calendar' during or after registration and grant EventHex permission to create calendar events in their personal calendar. This is a one-time authorization." },
    { question: "What happens when a session time changes?", answer: "EventHex automatically updates the corresponding Google Calendar event for all attendees who added that session. Google Calendar sends attendees an update notification on their device." },
    { question: "Can attendees add individual sessions rather than the full agenda?", answer: "Yes. Attendees can choose to add the full agenda, specific tracks, or individual sessions they have registered for. EventHex creates only the relevant calendar events." },
    { question: "Does this work for virtual sessions with Zoom or Teams links?", answer: "Yes. When a session has a Zoom, Teams, or Google Meet link associated in EventHex, the join URL is embedded in the Google Calendar event description and as a conference link." },
    { question: "Can I push the agenda to attendees after they have registered?", answer: "Yes. You can trigger a calendar sync for all registered attendees at any time from the EventHex organizer dashboard — useful when you publish new sessions after registration opens." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Google Calendar Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/google-calendar/",
    description: "Automatically push EventHex session agendas to attendees' Google Calendars with real-time schedule sync, reminders, and cancellation propagation.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
---

<IntegrationLayout {...data} />
