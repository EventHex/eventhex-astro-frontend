---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "EventHex + AWS SES Email Integration — 99%+ Deliverability",
  pageDescription: "Send event emails at scale via Amazon SES. Registration confirmations, ticket PDFs, reminder sequences, and campaigns with 99%+ deliverability on your own domain.",
  canonical: "https://eventhex.ai/integrations/email/",
  badge: "Email Integration",
  heroTitleLine1: "Send Event Emails at Scale via",
  heroTitleLine2: "Amazon SES — 99%+ Deliverability",
  heroCopy: "Registration confirmations, ticket PDFs, reminder sequences, and post-event campaigns — all sent through Amazon SES on your own domain with industry-leading deliverability.",
  accentColor: "#FF9900",
  stats: [
    { value: "99%+", label: "Deliverability Rate" },
    { value: "$0.10", label: "Per 1,000 Emails" },
    { value: "Your Domain", label: "Custom Sender" },
    { value: "DKIM + SPF", label: "Authentication" },
  ],
  featuresHeading: "Enterprise-Grade Email Delivery",
  featuresSubheading: "Send from your own domain with full authentication and industry-leading inbox placement.",
  features: [
    { emoji: "🌐", title: "Custom Domain Sending", description: "Send emails from your own domain (e.g., tickets@yourconference.com). Build brand trust and improve deliverability with domain-level reputation." },
    { emoji: "🔐", title: "DKIM & SPF Authentication", description: "Full email authentication with DKIM signing and SPF records. Pass DMARC checks and maximize inbox placement across all major providers." },
    { emoji: "📨", title: "Transactional Emails", description: "Registration confirmations, ticket PDFs, payment receipts, and check-in instructions — sent instantly and reliably via SES." },
    { emoji: "📢", title: "Campaign Broadcasts", description: "Send event updates, schedule announcements, and promotional emails to all attendees or targeted segments. Full template editor included." },
    { emoji: "📊", title: "Delivery Tracking", description: "Monitor delivery rates, bounces, complaints, and opens in real time. SES provides per-email delivery status feedback." },
    { emoji: "🚫", title: "Unsubscribe Management", description: "Automatic unsubscribe link in every email. EventHex respects opt-out preferences and maintains a suppression list." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Verify Domain in SES", description: "Add DNS records to verify your sending domain in Amazon SES. This takes about 5 minutes." },
    { title: "Connect to EventHex", description: "Enter your SES credentials in EventHex settings. We support SES in all AWS regions." },
    { title: "Configure Sender", description: "Set your From name, From address, and reply-to address. Customize email templates." },
    { title: "Monitor Deliverability", description: "Track delivery, bounce, and complaint rates in your EventHex and AWS dashboards." },
  ],
  useCasesHeading: "Who Uses AWS SES with EventHex?",
  useCases: [
    { emoji: "🏟️", title: "High-Volume Conferences", description: "Send tens of thousands of confirmation emails, reminders, and post-event surveys without worrying about rate limits or deliverability." },
    { emoji: "🏛️", title: "Government & Enterprise Events", description: "Organizations that require sending from their own authenticated domain to meet security and compliance requirements." },
    { emoji: "🏷️", title: "White-Label Platforms", description: "Event management agencies running events for clients who need emails to come from the client's domain, not a generic platform address." },
    { emoji: "🔁", title: "Automated Reminder Sequences", description: "Set up multi-step email sequences — registration confirmation, event reminders, day-of logistics, and post-event follow-up." },
  ],
  ctaTitle: "Ready to Send Event Emails with 99%+ Deliverability?",
  ctaCopy: "Connect your AWS SES account and start sending event emails from your own domain at $0.10 per 1,000.",
  faqs: [
    { question: "Why does EventHex use Amazon SES instead of a built-in email service?", answer: "Amazon SES provides enterprise-grade deliverability, full domain authentication, and transparent per-email pricing. By using your own SES account, you control your sending reputation and domain." },
    { question: "Do I need my own AWS account?", answer: "Yes. You need an AWS account with SES configured. EventHex provides documentation on verifying your domain and configuring IAM credentials." },
    { question: "How does EventHex handle email bounces?", answer: "EventHex automatically processes SES bounce notifications. Hard bounces are added to a suppression list, and the affected attendee records are flagged in your dashboard." },
    { question: "Can I send from multiple domains?", answer: "Yes. You can verify multiple domains in SES and select the appropriate sender address per event in EventHex. Useful for agencies managing events across different client brands." },
    { question: "Are there any sending limits?", answer: "SES has initial sending limits that increase as your account builds reputation. New accounts typically start at 200 emails per 24-hour period and can request increases." },
    { question: "Can I track open and click rates?", answer: "Yes. EventHex tracks open rates, click-through rates, and delivery status for every email sent through SES. Analytics are available per event and per campaign." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Email Integration (AWS SES)",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/email/",
    description: "Send event emails at scale via Amazon SES with 99%+ deliverability on your own domain.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
---

<IntegrationLayout {...data} />
