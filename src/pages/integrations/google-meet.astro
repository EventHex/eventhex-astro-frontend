---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "Google Meet Integration — Virtual Sessions & Calendar Sync | EventHex",
  pageDescription: "Run event sessions on Google Meet with EventHex. Auto-generate Meet links, sync with Google Calendar, and capture attendance and recordings via the EventHex bot.",
  canonical: "https://eventhex.ai/integrations/google-meet/",
  badge: "Google Meet Integration",
  heroTitleLine1: "Host Sessions on Google Meet —",
  heroTitleLine2: "Auto-Links, Bot Join & Calendar Sync",
  heroCopy: "Connect your Google Workspace to EventHex and get Google Meet links generated for every session automatically. Our bot joins each call to capture attendance and record, while Google Calendar keeps attendees reminded and on time.",
  accentColor: "#00897B",
  stats: [
    { value: "Auto", label: "Meet Link Generation" },
    { value: "Real-Time", label: "Attendance Logging" },
    { value: "1-Click", label: "Calendar Add" },
    { value: "AI", label: "Session Transcription" },
  ],
  featuresHeading: "Seamless Virtual Sessions with Google Meet",
  featuresSubheading: "Built on Google Workspace — so your sessions live inside the tools your attendees already use every day.",
  features: [
    { emoji: "🔗", title: "Auto Meet Link Generation", description: "Publish a session in EventHex and a Google Meet link is created instantly via the Google Calendar API — no manual meeting setup required." },
    { emoji: "🤖", title: "Bot Join & Attendance", description: "EventHex's meeting bot joins each Google Meet session at the scheduled time to log real-time attendance and verify registered participants." },
    { emoji: "🎙️", title: "Recording & Transcription", description: "Sessions are recorded to Google Drive and transcribed automatically. Transcripts sync back to EventHex for searchable on-demand content." },
    { emoji: "📅", title: "Google Calendar Sync", description: "Session details and Meet links are pushed to attendees' Google Calendars at registration. Updates and cancellations propagate automatically." },
    { emoji: "⏰", title: "Automated Reminders", description: "Google Calendar reminders supplement EventHex email reminders — attendees get notifications on all their devices before each session starts." },
    { emoji: "🔐", title: "Workspace Domain Restriction", description: "Lock sessions to specific Google Workspace domains for internal corporate events, ensuring only verified employees can join." },
    { emoji: "📊", title: "Engagement Data Sync", description: "Poll results and chat logs from Google Meet sessions are pulled into the EventHex analytics dashboard for a complete engagement view." },
    { emoji: "🌐", title: "Hybrid-Ready", description: "Combine in-room and remote attendees. EventHex tracks both check-in and Meet attendance so your hybrid headcount is always accurate." },
  ],
  howItWorksHeading: "From Google Workspace to Live Session",
  steps: [
    { title: "Connect Google Workspace", description: "Authorize EventHex via Google OAuth. Your calendar and Meet permissions are granted in one step." },
    { title: "Add Sessions to Agenda", description: "Create sessions in EventHex. Each session automatically gets a Google Meet link and a Calendar event." },
    { title: "Attendees Register & Add to Calendar", description: "Registered attendees receive a one-click 'Add to Google Calendar' link with the Meet URL embedded." },
    { title: "Bot Captures the Session", description: "EventHex bot joins at start time, logs attendance, records the session, and syncs data to your dashboard." },
  ],
  useCasesHeading: "Who Uses Google Meet with EventHex?",
  useCases: [
    { emoji: "🏢", title: "Corporate & Internal Events", description: "Run all-hands meetings, town halls, and internal training sessions on Google Meet with automatic calendar distribution to your entire organization." },
    { emoji: "🎓", title: "Online Training Programs", description: "Deliver multi-session training on Meet. EventHex tracks attendance per session and issues certificates on completion." },
    { emoji: "🖥️", title: "Virtual Summits", description: "Host multi-track virtual summits with separate Meet links per track. Attendees pick their track in the EventHex agenda and join with one click." },
    { emoji: "🤝", title: "Partner & Customer Events", description: "Invite external partners to a Google Workspace-gated session. EventHex manages registration while Meet handles secure access control." },
  ],
  ctaTitle: "Run Your Next Virtual Event on Google Meet with EventHex",
  ctaCopy: "Connect Google Workspace and let EventHex handle session links, calendar sync, and bot attendance capture automatically.",
  faqs: [
    { question: "Do I need a Google Workspace account to use this integration?", answer: "A Google Workspace account is recommended for full features like domain restriction and Google Drive recording storage. Personal Gmail accounts work for basic Meet link generation and Calendar sync." },
    { question: "How are Meet links delivered to attendees?", answer: "Meet links are included in the registration confirmation email, added to the Google Calendar event sent at registration, and displayed in the EventHex attendee app." },
    { question: "Where are recordings stored?", answer: "Recordings are saved to the host's Google Drive. EventHex links to the recording from the attendee portal and displays AI-generated transcripts." },
    { question: "Can attendees outside my organization join?", answer: "Yes. Google Meet supports external participants by default. You can optionally restrict access to your Workspace domain for internal-only events from the EventHex session settings." },
    { question: "What happens if a session is rescheduled?", answer: "Updating the session time in EventHex automatically updates the linked Google Calendar event and sends an update notification to all attendees." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Google Meet Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/google-meet/",
    description: "Host virtual event sessions on Google Meet with automated link generation, calendar sync, bot attendance capture, and session recording.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
---

<IntegrationLayout {...data} />
