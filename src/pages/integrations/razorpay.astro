---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "EventHex Razorpay Integration — India Event Payments with UPI & Net Banking",
  pageDescription: "Accept event payments in India via Razorpay — UPI, cards, net banking, wallets. 0% EventHex platform fees. GST-ready invoicing.",
  canonical: "https://eventhex.ai/integrations/razorpay/",
  badge: "Razorpay Integration",
  heroTitleLine1: "Accept Indian Payments via",
  heroTitleLine2: "Razorpay — UPI, Cards & Net Banking",
  heroCopy: "Connect your Razorpay account to EventHex and accept payments via UPI, credit/debit cards, net banking, and wallets. The preferred payment gateway for India-based events — with 0% EventHex fees.",
  accentColor: "#072654",
  stats: [
    { value: "0%", label: "EventHex Platform Fees" },
    { value: "100+", label: "Payment Methods" },
    { value: "INR", label: "Native Currency" },
    { value: "Real-Time", label: "Payment Confirmation" },
  ],
  featuresHeading: "Built for the Indian Payment Ecosystem",
  featuresSubheading: "Every payment method your Indian attendees expect — in one integration.",
  features: [
    { emoji: "📱", title: "UPI Payments", description: "Accept payments via Google Pay, PhonePe, Paytm, and any UPI app. Attendees scan a QR or enter their UPI ID to complete purchases instantly." },
    { emoji: "🏦", title: "Net Banking", description: "Support 50+ Indian banks for direct net banking payments. Ideal for corporate attendees who prefer bank transfers." },
    { emoji: "💳", title: "Cards & Wallets", description: "Visa, Mastercard, RuPay, American Express — plus wallets like Paytm, Freecharge, and Mobikwik. Every method in one checkout." },
    { emoji: "↩️", title: "Automated Refunds", description: "Process full or partial refunds from EventHex. Razorpay routes the refund back to the original payment method automatically." },
    { emoji: "🧾", title: "GST-Ready Invoicing", description: "Generate GST-compliant invoices with your GSTIN, HSN codes, and tax breakdowns. Essential for Indian corporate and B2B events." },
    { emoji: "🔒", title: "PCI DSS Compliant", description: "Razorpay is PCI DSS Level 1 certified. All sensitive card data stays within Razorpay's secure environment." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Connect Razorpay", description: "Link your Razorpay account to EventHex via API keys. Takes under 2 minutes." },
    { title: "Set INR Prices", description: "Create ticket types priced in Indian Rupees. Add GST if required." },
    { title: "Attendees Pay", description: "Buyers choose UPI, card, net banking, or wallet at checkout." },
    { title: "Instant Confirmation", description: "Tickets are delivered immediately. Settlement flows to your Razorpay account." },
  ],
  useCasesHeading: "Who Uses Razorpay with EventHex?",
  useCases: [
    { emoji: "🏢", title: "Corporate India", description: "Large-scale corporate events, town halls, and annual conferences where attendees prefer net banking and corporate card payments." },
    { emoji: "🎓", title: "Education & Workshops", description: "Training sessions, bootcamps, and educational summits where UPI is the dominant payment method for students and professionals." },
    { emoji: "🤝", title: "Associations & Chapters", description: "Professional association meetings, chapter events, and membership renewals with GST-compliant invoicing for every transaction." },
    { emoji: "🏭", title: "Trade Shows & Expos", description: "B2B events where exhibitors and buyers need net banking and invoice-based payment flows for procurement compliance." },
  ],
  ctaTitle: "India's Preferred Gateway + 0% EventHex Fees",
  ctaCopy: "Connect your Razorpay account and start selling event tickets with UPI, cards, and net banking — all with zero EventHex platform fees.",
  faqs: [
    { question: "Does EventHex charge any fees on Razorpay payments?", answer: "No. EventHex charges 0% platform fee when you use your own Razorpay account. You only pay Razorpay's standard processing rate." },
    { question: "Is UPI supported for event ticket payments?", answer: "Yes. Attendees can pay using any UPI app including Google Pay, PhonePe, and Paytm. The UPI payment confirmation is instant." },
    { question: "Can I generate GST-compliant invoices?", answer: "Yes. EventHex supports GST invoice generation with your GSTIN, HSN/SAC codes, and CGST/SGST/IGST breakdowns for every transaction." },
    { question: "Can I test Razorpay integration before going live?", answer: "Yes. Razorpay provides test mode API keys. You can simulate payments and refunds in EventHex without processing real transactions." },
    { question: "How fast are Razorpay settlements?", answer: "Razorpay offers T+2 settlement for most payment methods. Instant settlements are available on supported Razorpay plans." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Razorpay Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/razorpay/",
    description: "Accept event payments in India via Razorpay — UPI, cards, net banking, wallets. 0% EventHex fees.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "INR" },
  },
};
