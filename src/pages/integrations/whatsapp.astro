---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "EventHex WhatsApp Integration — Event Notifications & Campaigns",
  pageDescription: "Send ticket confirmations, event reminders, session alerts, and campaigns via WhatsApp Business API. 98% open rates for your event messages.",
  canonical: "https://eventhex.ai/integrations/whatsapp/",
  badge: "WhatsApp Integration",
  heroTitleLine1: "Reach Every Attendee via",
  heroTitleLine2: "WhatsApp — Open Rates Above 95%",
  heroCopy: "Send ticket confirmations, event reminders, session alerts, and post-event messages via WhatsApp Business API. Reach attendees on the app they check most.",
  accentColor: "#25D366",
  stats: [
    { value: "98%", label: "Open Rate" },
    { value: "Real-Time", label: "Message Delivery" },
    { value: "2B+", label: "Global WhatsApp Users" },
    { value: "Multi-Language", label: "Template Support" },
  ],
  featuresHeading: "WhatsApp Messaging for Every Event Touchpoint",
  featuresSubheading: "From registration to post-event follow-up — reach attendees where they actually read.",
  features: [
    { emoji: "✅", title: "Registration Confirmations", description: "Send instant WhatsApp confirmations when an attendee registers. Include event details, venue info, and a link to their digital ticket." },
    { emoji: "⏰", title: "Event Reminders", description: "Schedule automated reminders 24 hours, 2 hours, and 30 minutes before the event. Reduce no-shows with timely nudges." },
    { emoji: "📢", title: "Broadcast Campaigns", description: "Send announcements, schedule changes, and promotional messages to all attendees or targeted segments via WhatsApp broadcasts." },
    { emoji: "🎫", title: "Ticket QR Delivery", description: "Deliver ticket QR codes directly via WhatsApp. Attendees save the message and show the QR at check-in — no email digging required." },
    { emoji: "💬", title: "Session Feedback", description: "Send post-session feedback forms via WhatsApp. Higher response rates than email surveys — attendees reply in the same chat thread." },
    { emoji: "🤖", title: "WhatsApp Bot", description: "Enable an automated chatbot that answers attendee questions about schedule, venue, speakers, and tickets — 24/7, in multiple languages." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Connect WhatsApp Business", description: "Link your WhatsApp Business API account to EventHex. We support official Meta Business API partners." },
    { title: "Choose Templates", description: "Select from pre-approved message templates or submit custom templates for Meta approval." },
    { title: "Configure Triggers", description: "Set up automatic triggers — registration, payment, reminder, check-in, or session start." },
    { title: "Monitor Delivery", description: "Track delivery rates, read receipts, and reply metrics in your EventHex dashboard." },
  ],
  useCasesHeading: "Who Uses WhatsApp with EventHex?",
  useCases: [
    { emoji: "🌍", title: "MENA & South Asia Events", description: "In regions where WhatsApp is the dominant messaging app, event communications have 98%+ open rates compared to 20-30% for email." },
    { emoji: "🚨", title: "Last-Minute Communication", description: "Venue changes, speaker cancellations, schedule updates — WhatsApp ensures critical messages reach attendees instantly, not buried in inboxes." },
    { emoji: "🏢", title: "Exhibitor Follow-Up", description: "Send exhibitor booth assignments, setup instructions, and lead reports via WhatsApp for immediate visibility and response." },
    { emoji: "🤝", title: "Sponsor Messages", description: "Deliver sponsor messages, promotional codes, and partner offers via WhatsApp with higher engagement than traditional channels." },
  ],
  ctaTitle: "Reach Your Attendees Where They Actually Read",
  ctaCopy: "Connect WhatsApp Business API and start sending event notifications with 98% open rates.",
  faqs: [
    { question: "Do attendees need to download anything?", answer: "No. If an attendee has WhatsApp installed (which 2B+ users do), they receive messages directly. No additional app or download is required." },
    { question: "Do I need a WhatsApp Business API account?", answer: "Yes. EventHex connects to the official WhatsApp Business API through Meta-approved partners. A regular WhatsApp account is not sufficient for automated messaging." },
    { question: "Can attendees opt out of WhatsApp messages?", answer: "Yes. Every message includes an opt-out option. EventHex respects opt-out preferences and stops sending messages to attendees who unsubscribe." },
    { question: "Are there per-message charges?", answer: "WhatsApp Business API has per-conversation charges set by Meta, which vary by country. EventHex does not add any markup — you pay Meta's standard rates." },
    { question: "Can I personalize WhatsApp messages?", answer: "Yes. Messages can include the attendee's name, ticket type, event name, session details, and custom fields. Templates support dynamic variables." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex WhatsApp Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/whatsapp/",
    description: "Send event notifications and campaigns via WhatsApp Business API with 98% open rates.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
