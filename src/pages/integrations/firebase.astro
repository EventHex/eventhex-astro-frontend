---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "Firebase Push Notifications — Real-Time Attendee Alerts | EventHex",
  pageDescription: "Send real-time push notifications to attendees via Firebase Cloud Messaging. Session reminders, schedule changes, announcements, and speaker alerts — all delivered instantly to the EventHex mobile app.",
  canonical: "https://eventhex.ai/integrations/firebase/",
  badge: "Firebase FCM Integration",
  heroTitleLine1: "Real-Time Push Notifications",
  heroTitleLine2: "via Firebase Cloud Messaging",
  heroCopy: "Connect Firebase Cloud Messaging to EventHex and send instant push notifications to every attendee's mobile device. Session reminders, last-minute changes, sponsor announcements, and emergency alerts — delivered in milliseconds.",
  accentColor: "#FFCA28",
  stats: [
    { value: "Real-Time", label: "Notification Delivery" },
    { value: "iOS + Android", label: "Platform Coverage" },
    { value: "Targeted", label: "Audience Segmentation" },
    { value: "Auto", label: "Session Reminders" },
  ],
  featuresHeading: "Keep Every Attendee Informed — Instantly",
  featuresSubheading: "Firebase Cloud Messaging is the industry standard for mobile push. EventHex puts it to work for your events.",
  features: [
    { emoji: "📲", title: "Instant Push Delivery", description: "Notifications sent from the EventHex dashboard reach attendee devices via Firebase Cloud Messaging in milliseconds — regardless of whether the app is open." },
    { emoji: "⏰", title: "Automated Session Reminders", description: "EventHex automatically sends FCM push reminders 24 hours, 1 hour, and 15 minutes before each session — no manual scheduling required." },
    { emoji: "🚨", title: "Real-Time Schedule Alerts", description: "If a session moves rooms, changes times, or is cancelled, push a real-time alert to all affected attendees instantly from the EventHex organizer panel." },
    { emoji: "🎯", title: "Audience Segmentation", description: "Target notifications by ticket type, session track, registration group, or custom tag. Send speaker-only alerts or VIP-only announcements with precision." },
    { emoji: "📢", title: "Sponsor & Partner Announcements", description: "Broadcast sponsor messages, product announcements, and booth activation alerts to opted-in attendees at the right moment during your event." },
    { emoji: "📊", title: "Delivery & Open Analytics", description: "EventHex displays FCM delivery rates, open rates, and click-through data per notification so you can measure engagement and optimize future campaigns." },
    { emoji: "🌐", title: "Multi-Language Notifications", description: "Send localized push notifications based on attendee language preferences — EventHex automatically selects the right message variant per device." },
    { emoji: "🔔", title: "In-App & Background Push", description: "FCM delivers notifications whether the EventHex app is in the foreground, background, or completely closed — maximizing attendee reach across the event day." },
  ],
  howItWorksHeading: "Push Notifications in 4 Steps",
  steps: [
    { title: "Connect Firebase Project", description: "Add your Firebase project credentials to EventHex settings. The FCM server key links your project to the notification engine." },
    { title: "Attendees Install Event App", description: "Attendees download the EventHex mobile app for your event. FCM tokens are registered automatically at login." },
    { title: "Create & Schedule Notifications", description: "Compose notifications in the EventHex dashboard. Schedule them or send immediately. Target all attendees or specific segments." },
    { title: "Deliver & Measure", description: "Firebase delivers the push to every registered device. EventHex tracks delivery, open rate, and click-through in real time." },
  ],
  useCasesHeading: "Who Uses Firebase Push Notifications with EventHex?",
  useCases: [
    { emoji: "🗓️", title: "Large Multi-Day Conferences", description: "Keep thousands of attendees aligned across a multi-day agenda. Push daily schedules each morning and session reminders throughout the day automatically." },
    { emoji: "🏟️", title: "In-Person Event Logistics", description: "Notify attendees of room changes, shuttle schedules, networking breaks, and emergency instructions via push in real time during the event." },
    { emoji: "🎤", title: "Speaker & Session Promotion", description: "Push targeted alerts to attendees who bookmarked specific sessions or tracks — driving attendance to keynotes and sponsor-led sessions." },
    { emoji: "🤝", title: "Networking & Matchmaking", description: "Send FCM notifications when a meeting request is accepted or when a recommended connection is nearby — triggering in-app networking actions." },
  ],
  ctaTitle: "Keep Attendees Informed with Real-Time Push Notifications",
  ctaCopy: "Connect Firebase Cloud Messaging and let EventHex deliver automated reminders, alerts, and announcements to every attendee's device.",
  faqs: [
    { question: "Do I need a Firebase account to use FCM push notifications?", answer: "Yes. You need a Firebase project with Cloud Messaging enabled. EventHex connects to your Firebase project using your server credentials — attendees do not need their own Firebase account." },
    { question: "Does EventHex send push notifications automatically for session reminders?", answer: "Yes. Once FCM is connected, EventHex automatically sends push reminders before each session based on your configured reminder schedule (e.g. 1 hour before, 15 minutes before)." },
    { question: "Can I send a push notification to a specific group of attendees?", answer: "Yes. EventHex supports segmented push by ticket type, session track, registration tag, or custom audience. You can also broadcast to all attendees at once." },
    { question: "How do attendees opt in to push notifications?", answer: "When attendees install the EventHex mobile app and log in to the event, they are prompted to allow push notifications. Opted-in attendees have their FCM token registered automatically." },
    { question: "What analytics are available for push notifications?", answer: "EventHex displays delivery rate, open rate, and click-through rate per notification sent via Firebase. You can compare campaign performance across different audience segments." },
