---
import IntegrationLayout from "../../components/integrations/IntegrationLayout.astro";

const data = {
  pageTitle: "Google Maps Integration — Venue Maps & Directions for Events | EventHex",
  pageDescription: "Embed Google Maps in your event app and site with venue locations, indoor floor plans, directions, and nearby points of interest. Help attendees navigate complex venues with ease.",
  canonical: "https://eventhex.ai/integrations/google-maps/",
  badge: "Google Maps Integration",
  heroTitleLine1: "Venue Maps, Directions & Location",
  heroTitleLine2: "Features — Powered by Google Maps",
  heroCopy: "Connect Google Maps to EventHex and give attendees interactive venue maps, turn-by-turn directions, parking guidance, and indoor navigation directly in the event app and website — so no one gets lost on event day.",
  accentColor: "#34A853",
  stats: [
    { value: "Interactive", label: "Venue Maps in App" },
    { value: "Real-Time", label: "Directions & Transit" },
    { value: "Indoor", label: "Floor Plan Support" },
    { value: "Multi", label: "Venue Location Pins" },
  ],
  featuresHeading: "Navigation Built Into Your Event Experience",
  featuresSubheading: "Google Maps is the navigation tool your attendees already trust. EventHex embeds it where they need it most — your event app and website.",
  features: [
    { emoji: "📍", title: "Interactive Venue Map", description: "Embed a fully interactive Google Map of your venue on the event website and in the attendee app — showing the exact entrance, parking, and all session room locations." },
    { emoji: "🧭", title: "Turn-by-Turn Directions", description: "Attendees tap any venue location in EventHex and get turn-by-turn directions from their current location via Google Maps — driving, walking, cycling, or public transit." },
    { emoji: "🏢", title: "Indoor Floor Plans", description: "For venues with Google Maps indoor floor plans, EventHex displays room-level navigation inside convention centres, hotels, and stadiums so attendees can find session rooms quickly." },
    { emoji: "📌", title: "Multi-Location Event Mapping", description: "Running a multi-venue event or city-wide conference? Pin all venue locations on a single Google Map in EventHex with labels, distances, and shuttle route overlays." },
    { emoji: "🅿️", title: "Parking & Transport Guidance", description: "Mark parking areas, drop-off zones, shuttle stops, and public transit entrances on the event map. Attendees see all transport options before they arrive." },
    { emoji: "🍽️", title: "Nearby Points of Interest", description: "Display nearby restaurants, hotels, ATMs, and coffee shops on the event map. Help attendees plan meals and accommodation around your venue with Google Places data." },
    { emoji: "🗺️", title: "Custom Map Markers & Branding", description: "Replace default Google Map pins with branded EventHex markers for session rooms, registration desks, sponsor booths, and networking zones to match your event identity." },
    { emoji: "🔗", title: "Deep-Link to Google Maps App", description: "One tap on any location in the EventHex app opens Google Maps natively on iOS or Android for full navigation — no copy-pasting addresses required." },
  ],
  howItWorksHeading: "Venue on the Map in Minutes",
  steps: [
    { title: "Connect Google Maps API", description: "Add your Google Maps API key to EventHex settings. The Maps JavaScript API and Places API are enabled for your event domain." },
    { title: "Configure Venue Locations", description: "Enter venue addresses and add custom pins for registration desks, session rooms, and sponsor areas. EventHex renders them on the interactive map." },
    { title: "Publish to Event App & Site", description: "The map appears automatically in the EventHex attendee app and on your event website — no embedding code needed." },
    { title: "Attendees Navigate with Ease", description: "On event day, attendees open the EventHex app, tap their next session location, and get real-time directions from wherever they are." },
  ],
  useCasesHeading: "Who Uses Google Maps with EventHex?",
  useCases: [
    { emoji: "🏟️", title: "Large Convention Centre Events", description: "Complex multi-hall venues with hundreds of rooms are navigable for attendees via EventHex indoor maps powered by Google's floor plan data." },
    { emoji: "🏙️", title: "City-Wide & Multi-Venue Festivals", description: "Pin all venues across a city on a single EventHex map with session tracks per location. Attendees plan their day and navigate between venues using Google Maps routing." },
    { emoji: "🌿", title: "Outdoor & Campus Events", description: "Map outdoor stages, food courts, sponsor zones, and shuttle routes at festival and campus events so attendees can orient themselves across large open spaces." },
    { emoji: "🚌", title: "Transport Logistics", description: "Display shuttle routes, bus stops, and parking zones alongside the venue map. Attendees see exactly where to park or catch a shuttle on arrival." },
  ],
  ctaTitle: "Help Attendees Navigate Your Venue with Google Maps",
  ctaCopy: "Connect Google Maps and give every attendee interactive directions, floor plans, and venue navigation — built into the EventHex app.",
  faqs: [
    { question: "Do I need a Google Maps API key to use this integration?", answer: "Yes. You need a Google Maps Platform API key with the Maps JavaScript API and Places API enabled. EventHex uses your key so map usage is billed to your Google Cloud account at standard Maps rates." },
    { question: "Can EventHex show indoor floor plans for my venue?", answer: "Yes, if your venue has indoor maps available on Google Maps (many major convention centres, hotels, and stadiums do). EventHex automatically renders indoor floor plan data when available." },
    { question: "Can I add custom markers for session rooms and sponsor booths?", answer: "Yes. EventHex lets you add custom map markers for any location within your venue — registration desk, sponsor village, breakout rooms, F&B areas — with your branding and labels." },
    { question: "How does the Google Maps integration appear in the event app?", answer: "The Maps integration appears as a dedicated 'Venue Map' section in the EventHex attendee app. Attendees can also tap any session in the agenda to see a map of the room location with directions." },
    { question: "Does the map work offline at the venue?", answer: "Google Maps on mobile supports limited offline caching for areas you have previously viewed. For reliable in-venue navigation, we recommend attendees open the event map before arriving so it pre-caches." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Google Maps Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/google-maps/",
    description: "Embed interactive Google Maps venue navigation, indoor floor plans, directions, and custom location markers in the EventHex event app and website.",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  },
};
---

<IntegrationLayout {...data} />
