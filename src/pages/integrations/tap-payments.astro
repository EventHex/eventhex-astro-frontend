  pageTitle: "EventHex + Tap Payments — GCC Event Ticketing with mada, KNET & Apple Pay",
  pageDescription: "Sell event tickets across the GCC with Tap Payments. Accept Visa, Mastercard, mada, KNET, BENEFIT, and Apple Pay in local currencies with 0% EventHex fee.",
  canonical: "https://eventhex.ai/integrations/tap-payments/",
  badge: "Tap Payments Integration",
  heroTitleLine1: "Accept Middle East Payments via",
  heroTitleLine2: "Tap Payments — Cards, mada & Apple Pay",
  heroCopy: "Sell event tickets to attendees across the GCC with Tap Payments. Accept Visa, Mastercard, mada, KNET, BENEFIT, and Apple Pay — all in local currencies with 0% EventHex platform fee.",
  accentColor: "#2ACFCF",
  stats: [
    { value: "6", label: "GCC Countries Supported" },
    { value: "Local", label: "Currency Settlement" },
    { value: "0%", label: "EventHex Platform Fee" },
    { value: "mada + KNET", label: "Local Card Networks" },
  ],
  featuresHeading: "Built for GCC Payment Methods",
  featuresSubheading: "Every payment method your Middle East attendees expect — mada, KNET, BENEFIT, and Apple Pay.",
  features: [
    { emoji: "🏦", title: "GCC Payment Methods", description: "Accept mada (Saudi Arabia), KNET (Kuwait), BENEFIT (Bahrain), and OmanNet alongside Visa and Mastercard. Local methods your attendees trust." },
    { emoji: "💱", title: "Multi-Currency Support", description: "Price tickets in SAR, KWD, AED, BHD, QAR, or OMR. Attendees pay in their local currency with no conversion surprises." },
