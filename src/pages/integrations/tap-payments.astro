    { emoji: "↩️", title: "Instant Refunds", description: "Process refunds from the EventHex dashboard. Tap Payments routes the refund back to the original payment method." },
    { emoji: "🔐", title: "3D Secure Authentication", description: "All card transactions go through 3D Secure verification as required by GCC banking regulations. Reduces fraud and chargebacks." },
    { emoji: "📊", title: "Revenue Dashboard", description: "Track ticket sales, refunds, and settlement in real time through both EventHex analytics and your Tap Payments dashboard." },
  ],
  howItWorksHeading: "How It Works",
  steps: [
    { title: "Connect Tap Payments", description: "Link your Tap Payments merchant account to EventHex via API keys." },
    { title: "Set Currency & Prices", description: "Choose your settlement currency and set ticket prices in SAR, AED, KWD, or other GCC currencies." },
    { title: "Enable Payment Methods", description: "Activate mada, KNET, BENEFIT, Apple Pay, and international cards for your event." },
    { title: "Go Live", description: "Attendees complete checkout through Tap's secure payment page. Tickets are delivered instantly." },
  ],
  useCasesHeading: "Who Uses Tap Payments with EventHex?",
  useCases: [
    { emoji: "🇸🇦", title: "Saudi Arabia Events", description: "Accept mada card payments — the dominant debit network in Saudi Arabia — alongside Visa and Mastercard for conferences and corporate events." },
    { emoji: "🇰🇼", title: "Kuwait Conferences", description: "Enable KNET — Kuwait's national payment network — so attendees can pay for event tickets using their local bank cards." },
    { emoji: "🍎", title: "UAE Apple Pay Events", description: "Offer Apple Pay at checkout for UAE-based attendees who prefer mobile wallet payments for quick, frictionless ticket purchases." },
    { emoji: "🌍", title: "Multi-Country GCC Tours", description: "Run events across multiple GCC countries with a single Tap Payments account. Price tickets in each country's local currency." },
  ],
  ctaTitle: "Ready to Accept GCC Payments with Tap Payments?",
  ctaCopy: "Connect your Tap Payments account and start selling event tickets across the Middle East with 0% EventHex platform fees.",
  faqs: [
    { question: "Which countries does Tap Payments support?", answer: "Tap Payments operates in Saudi Arabia, UAE, Kuwait, Bahrain, Qatar, and Oman — covering all six GCC member states." },
    { question: "Is mada card payment supported?", answer: "Yes. mada is fully supported through Tap Payments. Saudi attendees can pay using their mada debit cards directly at EventHex checkout." },
    { question: "Does EventHex charge any fees on Tap Payments transactions?", answer: "No. EventHex charges 0% platform fee when you use your own Tap Payments account. You only pay Tap's standard processing rate." },
    { question: "Can I issue refunds for Tap Payments transactions?", answer: "Yes. You can process full or partial refunds from the EventHex dashboard. The refund flows back through Tap Payments to the original payment method." },
    { question: "Are VAT-compliant invoices supported?", answer: "Yes. EventHex generates VAT-compliant invoices with your tax registration number, VAT breakdowns, and proper formatting for GCC countries." },
    { question: "Can I test Tap Payments before going live?", answer: "Yes. Tap Payments provides sandbox API keys. You can simulate transactions in EventHex without processing real payments." },
  ],
  jsonLd: {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "EventHex Tap Payments Integration",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    url: "https://eventhex.ai/integrations/tap-payments/",
