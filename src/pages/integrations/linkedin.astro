    { emoji: "🤝", title: "Networking Profile Enrichment", description: "LinkedIn login data enriches attendee networking profiles inside the event app — attendees can see who else in their industry or function is at the event." },
    { emoji: "📇", title: "Lead Capture for Exhibitors", description: "Exhibitors scanning attendee badges get LinkedIn-enriched contact data — company, title, seniority — giving sales teams higher-quality leads without manual data entry." },
    { emoji: "🌐", title: "Social Sharing from EventHex", description: "Attendees can share session attendance, speaker connections, and event participation directly to their LinkedIn feed from within the EventHex app." },
    { emoji: "🛡️", title: "Secure OAuth 2.0 Flow", description: "The LinkedIn integration uses standard OAuth 2.0 with defined scopes. EventHex never stores LinkedIn passwords and respects all permission boundaries." },
  ],
  howItWorksHeading: "From LinkedIn Profile to Event Registration",
  steps: [
    { title: "Connect LinkedIn App", description: "Register an EventHex LinkedIn OAuth app and add the client credentials to your EventHex integration settings." },
    { title: "Enable Login & Import", description: "Activate LinkedIn social login on your event registration page and enable speaker profile import in your agenda settings." },
    { title: "Attendees Register with LinkedIn", description: "Attendees click 'Continue with LinkedIn' on the registration page. Profile data pre-fills instantly — registration takes seconds." },
    { title: "Speakers Sync Automatically", description: "Add a LinkedIn profile URL for any speaker. EventHex imports their bio, photo, and title automatically and keeps it current." },
  ],
  useCasesHeading: "Who Uses LinkedIn with EventHex?",
  useCases: [
    { emoji: "🏢", title: "B2B & Professional Conferences", description: "LinkedIn login is the natural choice for professional conferences. Attendees get a frictionless registration experience and organizers get verified professional data." },
    { emoji: "🎤", title: "Speaker-Heavy Summits", description: "For events with 20, 50, or 200+ speakers, profile import eliminates hours of bio collection and ensures headshots are always high-quality and current." },
    { emoji: "🤝", title: "Networking-First Events", description: "LinkedIn-enriched profiles power meaningful networking matching inside the EventHex app — connecting attendees by role, industry, and company size automatically." },
    { emoji: "🏭", title: "Expo & Trade Shows", description: "Give exhibitors LinkedIn-enriched lead data at scan — company, title, seniority level — so sales follow-ups are informed and personalized from day one." },
