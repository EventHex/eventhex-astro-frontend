  pageTitle: "LinkedIn Integration — Social Login & Speaker Profile Import | EventHex",
  pageDescription: "Enable LinkedIn OAuth social login for attendees and import verified speaker profiles directly from LinkedIn into EventHex. Reduce registration friction and keep speaker bios accurate.",
  canonical: "https://eventhex.ai/integrations/linkedin/",
  badge: "LinkedIn Integration",
  heroTitleLine1: "LinkedIn Social Login &",
  heroTitleLine2: "Speaker Profile Import for Events",
  heroCopy: "Let attendees register with one click via LinkedIn OAuth — no form filling. Import speaker profiles directly from LinkedIn to keep bios, headshots, and credentials accurate and up to date in your event agenda automatically.",
  accentColor: "#0A66C2",
  stats: [
    { value: "1-Click", label: "LinkedIn Social Login" },
    { value: "Auto", label: "Speaker Profile Sync" },
    { value: "Verified", label: "Professional Identity" },
    { value: "Zero", label: "Manual Bio Entry" },
  ],
  featuresHeading: "Professional Identity, Zero Friction",
  featuresSubheading: "LinkedIn is where your attendees and speakers already live professionally. EventHex brings that identity directly into your event.",
  features: [
    { emoji: "🔐", title: "LinkedIn OAuth Social Login", description: "Attendees register and log in with their LinkedIn credentials via OAuth — no new password, no long forms. Profile data (name, email, company, title) pre-fills automatically." },
    { emoji: "👤", title: "Verified Professional Profiles", description: "LinkedIn-authenticated attendees bring verified professional identity — real name, employer, job title — into EventHex, improving networking accuracy and badge data." },
