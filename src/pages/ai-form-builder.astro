---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { afbIllustrations as ill } from "../components/ai-form-builder/illustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — AI Form Builder for Events",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "AI-powered event form builder with voice creation, conditional logic, approval workflows, GDPR consent, and WhatsApp notifications.",
  url: "https://eventhex.ai/ai-form-builder/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Voice Form Creation",
    "AI Field Detection",
    "Conditional Logic",
    "Drag-and-Drop Editor",
    "Approval Workflows",
    "GDPR Consent Fields",
    "WhatsApp Notifications",
    "50+ Form Templates",
    "Form Submission Analytics",
  ],
};
---

<FeatureV2Layout
  pageTitle="AI Form Builder — Build Event Forms by Speaking | EventHex"
  pageDescription="Describe your form in plain English and AI builds it instantly — with the right field types, conditional logic, GDPR consent, and multi-language support. No drag-and-drop experience required."
  canonical="https://eventhex.ai/ai-form-builder/"
  ogImage="https://cms.eventhex.ai/wp-content/uploads/2025/04/AI-Form-Builder.png"
  badge="AI Form Builder for Events"
  heroTitleLine1="Build Event Forms by Speaking."
  heroTitleLine2="Go Live in Minutes."
  heroCopy="Describe your form in plain English and AI builds it instantly — with the right field types, conditional logic, GDPR consent, and multi-language support. No drag-and-drop experience required."
  heroImage="/feature-images/ai-form-builder/hero-visual.svg"
  trustItems={["Voice-to-Form Creation", "Conditional Logic", "GDPR & Approval Workflows"]}
  stats={[
    { value: "60s", label: "Form Creation Time" },
    { value: "20+", label: "Field Types" },
    { value: "50+", label: "Form Templates" },
    { value: "100%", label: "GDPR Ready" },
  ]}
  statsHeadline={{
    white1: "Any form.",
    accent: "Any field.",
    white2: "Built in",
    accent2: "seconds",
  }}
  bentoHeading="Everything You Need in an AI Form Builder"
  bentoSubtitle="From a 3-field sign-up to a 30-field speaker application with conditional logic and file uploads — describe what you need and AI builds it. Then tweak it visually with the drag-and-drop editor."
  bentoTabs={[
    {
      tab: "Voice Form Creation",
      cards: [
        { title: "Speak to Create Forms", desc: "Describe your form in plain English and AI generates the right fields, types, and structure instantly", illustration: ill.afb1 },
        { title: "AI Field Detection", desc: "AI identifies the right field type for each data point — text, date, dropdown, file upload, or phone", illustration: ill.afb2 },
        { title: "Natural Language Processing", desc: "Use conversational language — 'ask them to upload a headshot' turns into a file-upload field", illustration: ill.afb3 },
        { title: "Template Suggestions", desc: "AI suggests matching templates based on your description for faster form creation", illustration: ill.afb4 },
        { title: "Multi-Language Voice", desc: "Create forms in any language by speaking in that language — AI processes and builds correctly", illustration: ill.afb5 },
      ],
    },
    {
      tab: "Form Builder",
      cards: [
        { title: "Drag-and-Drop Editor", desc: "Add, reorder, and style form fields with a visual editor after AI generates the initial structure", illustration: ill.afb6 },
        { title: "Conditional Logic", desc: "Show or hide fields based on previous answers, ticket type, or attendee role", illustration: ill.afb7 },
        { title: "Custom Field Types", desc: "20+ field types including ratings, NPS, signature capture, QR scan, and table inputs", illustration: ill.afb8 },
        { title: "Form Templates", desc: "50+ pre-built templates for registration, feedback, surveys, speaker applications, and more", illustration: ill.afb9 },
        { title: "Pre-Fill from Registration", desc: "Auto-populate form fields with data the attendee already provided at registration", illustration: ill.afb10 },
      ],
    },
    {
      tab: "Notifications & Security",
      cards: [
        { title: "Email Notifications per Submission", desc: "Send automatic confirmation emails to submitters and alert emails to your team", illustration: ill.afb11 },
        { title: "WhatsApp Notifications", desc: "Trigger WhatsApp messages to attendees or team members on form submission", illustration: ill.afb12 },
        { title: "GDPR Consent Management", desc: "Built-in consent checkboxes with customizable opt-in language and data retention controls", illustration: ill.afb13 },
        { title: "Captcha Protection", desc: "Automated bot protection on all public forms with invisible reCAPTCHA integration", illustration: ill.afb14 },
        { title: "Approval Workflows", desc: "Route submissions to an approver before they're confirmed — ideal for speaker and exhibitor applications", illustration: ill.afb15 },
      ],
    },
  ]}
  stackingHeading="AI Form Builder Features"
  stackingHighlight="in Action"
  stackingCards={[
    {
      title: "Your Words Become Working Forms",
      desc: "Open the form builder, speak your requirements, and watch AI assemble the form in real time — with the right field types, validation, and structure. Edit anything visually afterward.",
      image: "/feature-images/ai-form-builder/stacking-card-1.svg",
      alt: "Voice-powered AI form creation with real-time field generation",
    },
    {
      title: "Smart Forms That Adapt to Every Attendee",
      desc: "Don't show every attendee every question. Add conditional logic to show or hide fields based on ticket type, role, or previous answers — for a cleaner, faster form experience.",
      image: "/feature-images/ai-form-builder/stacking-card-2.svg",
      alt: "Conditional logic editor showing field branching rules",
    },
    {
      title: "Forms That Route to the Right Person",
      desc: "For speaker applications, exhibitor sign-ups, and grant requests — route form submissions through an approval workflow before confirmation is sent. All within EventHex.",
      image: "/feature-images/ai-form-builder/stacking-card-3.svg",
      alt: "Form approval workflow with submission status dashboard",
    },
  ]}
  howItWorksHeading="How AI Form Builder Works"
  howItWorksImage="/feature-images/ai-form-builder/how-it-works-visual.svg"
  steps={[
    { title: "Speak or Select a Template", desc: "Describe your form in plain English or choose from 50+ pre-built templates. AI generates the initial form structure instantly." },
    { title: "Customise with Drag-and-Drop", desc: "Refine the AI-generated form — add conditional logic, reorder fields, adjust labels, and set validation rules." },
    { title: "Configure Notifications and Workflows", desc: "Set up submission notifications via email or WhatsApp. Add approval workflows for forms that require review before confirmation." },
    { title: "Publish and Collect Submissions", desc: "Embed the form on your event page, share a link, or use it in-app. View and export all submissions from the dashboard." },
  ]}
  ctaTitle="Ready to Build Forms in Under a Minute?"
  ctaCopy="See how EventHex AI Form Builder turns form creation from a chore into a 60-second task — with conditional logic, approval workflows, and GDPR compliance built in."
  ctaImage="/feature-images/ai-form-builder/cta-visual.svg"
  whyHeading="Why Organizers Choose EventHex Form Builder"
  whyCards={[
    { title: "Voice Creation", desc: "Build forms by describing them in plain English", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>' },
    { title: "Drag-and-Drop Editor", desc: "20+ field types with live visual preview", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>' },
    { title: "Conditional Logic", desc: "Smart forms that adapt to attendee responses", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="12" r="3"/><line x1="8.59" x2="15" y1="13.51" y2="15.5"/><line x1="15.41" x2="8.59" y1="8.49" y2="10.49"/></svg>' },
    { title: "GDPR Ready", desc: "Built-in consent fields and data retention controls", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>' },
    { title: "Approval Workflows", desc: "Multi-stage approval routing for sensitive forms", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M8 3H3v5"/><path d="M12 22v-8.3a4 4 0 0 0-1.172-2.872L3 3"/><path d="m15 9 6-6"/><path d="M16 21h5v-5"/><path d="M8 21H3v-5"/></svg>' },
  ]}
  faqs={[
    { q: "How does the AI form builder work?", a: "You describe the form you need in plain English — either by typing or speaking. The AI identifies the required fields, selects appropriate field types, and generates the form structure instantly. You can then edit it visually with the drag-and-drop editor." },
    { q: "What types of forms can I build?", a: "You can build registration forms, session feedback surveys, speaker and exhibitor applications, workshop sign-up forms, satisfaction surveys, lead capture forms, and any other custom form your event requires." },
    { q: "What is conditional logic in forms?", a: "Conditional logic lets you show or hide specific form fields based on previous answers. For example, show a dietary preference field only when the attendee selects a catering option, or show speaker bio fields only when the ticket type is Speaker." },
    { q: "How do approval workflows work?", a: "When you enable an approval workflow on a form, submissions go into a pending state. Approvers receive an email notification with a one-click approve or reject action. Once approved, the submitter receives their confirmation email automatically." },
    { q: "Is the form builder GDPR compliant?", a: "Yes. Every form can include GDPR consent checkboxes with customizable opt-in language. EventHex supports granular consent categories, data retention settings, and tools to handle data subject requests." },
    { q: "Can forms be submitted via WhatsApp?", a: "EventHex supports WhatsApp notifications on form submission — sending confirmation messages to submitters and alert messages to your team. Full WhatsApp-based form flows are available via the EventHex WhatsApp integration." },
  ]}
  jsonLd={jsonLd}
/>
