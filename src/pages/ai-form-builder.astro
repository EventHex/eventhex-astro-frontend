---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/feature-page/HeroSection.astro";
import FeatureSection from "../components/feature-page/FeatureSection.astro";
import CTASection from "../components/feature-page/CTASection.astro";

const title = "AI Form Builder - EventHex";
const description = "EventHex introduces the AI Form Builder to the event tech landscape that allows you to create and fill forms as you talk to your device!";

const featureSections = [
  {
    sectionTitle: "Easily Editable Form Templates & Fields",
    imageLeft: true,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Form-builder-default-e1744711712873.png",
    imageAlt: "EventHex form builder with editable templates and fields",
    items: [
      {
        title: "Primary Fields for Ticketing",
        description: "Decide what goes as standard information when purchasing tickets.",
      },
      {
        title: "Customizable Form Fields",
        description: "Chose what types of information are to be required from the list of fields provided.",
      },
      {
        title: "Control Form Visibility",
        description: "Update the current status of the form, whether open, closed, or sold-out.",
      },
    ],
  },
  {
    sectionTitle: "Custom Text Notification Upon Submission",
    imageLeft: false,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-1.svg",
    imageAlt: "EventHex custom notification settings for form submissions",
    items: [
      {
        title: "Submission Text",
        description: "Custom set the text to be sent upon successful registration for the ticket.",
      },
      {
        title: "Email Notification",
        description: "EventHex gives you the option to notify the registered attendees via email.",
      },
      {
        title: "WhatsApp Notification",
        description: "If not by mail, you may opt to send the notification via WhatsApp.",
      },
    ],
  },
  {
    sectionTitle: "Approval Messaging for Corresponding Tickets",
    imageLeft: true,
    dark: true,
    backgroundColor: "#000312",
    backgroundImage: "https://eventhex.ai/wp-content/uploads/2025/03/bg.svg",
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-1-1.svg",
    imageAlt: "EventHex approval messaging and badge attachment interface",
    items: [
      {
        title: "Enable Approval",
        description: "This will send an approval mail for the corresponding ticket once registered.",
      },
      {
        title: "Customize Mail Content",
        description: "You can decide what to be sent upon the approval of the registration.",
      },
      {
        title: "Attach Badge Upon Approval",
        description: "Attach registration badge along with the email that is to be send to the attendees.",
      },
    ],
  },
  {
    sectionTitle: "Enhanced Security and Privacy",
    imageLeft: false,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-1000003199.png",
    imageAlt: "EventHex form security with captcha and consent settings",
    items: [
      {
        title: "Protect with a Captcha",
        description: "This will make sure the respondent is a human before the submission of the form.",
      },
      {
        title: "Consent Button",
        description: "Request consent to the terms and policy. This will be placed near the primary action button.",
      },
      {
        title: "Add Terms & Policy",
        description: "Enable consent to terms and policies if your events has any.",
      },
    ],
  },
];
---

<MarketingLayout {title} {description}>
  <HeroSection
    eyebrow="AI Form Builder"
    title="Build and Fill Forms by Just Speaking to Your Device"
    description="EventHex introduces the AI Form Builder to the event tech landscape that allows you to create and fill forms as you talk to your device!"
    image="https://eventhex.ai/wp-content/uploads/2025/04/AI-Form-Builder.png"
    imageAlt="EventHex AI Form Builder interface"
  />

  {featureSections.map((section) => (
    <FeatureSection
      sectionTitle={section.sectionTitle}
      items={section.items}
      image={section.image}
      imageAlt={section.imageAlt}
      imageLeft={section.imageLeft}
      dark={section.dark}
      backgroundImage={section.backgroundImage}
      backgroundColor={section.backgroundColor}
    />
  ))}

  <CTASection title={"Explore EventHex's\nAI Form Builder Now!"} />
</MarketingLayout>
