---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-website-builder/HeroSection.astro";
import StatsSection from "../components/event-website-builder/StatsSection.astro";
import BentoGrid from "../components/event-website-builder/BentoGrid.astro";
import FeatureCards from "../components/event-website-builder/FeatureCards.astro";
import HowItWorksSection from "../components/event-website-builder/HowItWorksSection.astro";
import CTASection from "../components/event-website-builder/CTASection.astro";
import CoordinationTools from "../components/event-website-builder/CoordinationTools.astro";
import FaqSection from "../components/event-website-builder/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Event Website Builder — Drag & Drop with 0 Code | EventHex";
const description = "Build professional event websites in minutes with drag-and-drop builder, 40+ templates, embedded registration, SEO optimization, and custom domain support.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Website Builder",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/event-website-builder/",
  description,
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Drag & Drop Visual Editor",
    "40+ Event Templates",
    "Custom Domain Support",
    "Embedded Registration Widget",
    "Multi-Track Agenda Display",
    "Speaker Profile Sections",
    "Tiered Sponsor Showcase",
    "SEO Auto-Optimization",
    "Google Analytics Integration",
    "UTM Tracking",
    "Core Web Vitals Optimized",
    "Mobile Responsive Design",
    "Template Cloning",
    "Team Collaboration",
    "Brand Library",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-website-builder/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
