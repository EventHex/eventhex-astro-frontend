---
import MarketingLayout from "../layouts/MarketingLayout.astro";

import HeroSection from "../components/ai-event-copilot/HeroSection.astro";
import StatsSection from "../components/ai-event-copilot/StatsSection.astro";
import BentoGrid from "../components/ai-event-copilot/BentoGrid.astro";
import FeatureCards from "../components/ai-event-copilot/FeatureCards.astro";
import HowItWorksSection from "../components/ai-event-copilot/HowItWorksSection.astro";
import CTASection from "../components/ai-event-copilot/CTASection.astro";
import CoordinationTools from "../components/ai-event-copilot/CoordinationTools.astro";
import FaqSection from "../components/ai-event-copilot/FaqSection.astro";

const title = "AI Event Copilot — 4 Specialized AI Agents for Event Management | EventHex";
const description = "Four AI agents: Analyst, Session Builder, Copywriter, and Ticket Agent. Automate data analysis, agenda building, content generation, and attendee support.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "EventHex AI Copilot — AI Event Management Agents",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "url": "https://eventhex.ai/ai-event-copilot/",
  "description": "Four specialized AI agents for event management: data analysis, session planning, content generation, and attendee support.",
  "creator": {
    "@type": "Organization",
    "name": "EventHex",
    "url": "https://eventhex.ai"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Free demo available"
  },
  "featureList": [
    "Analyst Agent",
    "Session Agent",
    "Copywriter Agent",
    "Ticket Agent",
    "Natural Language Queries",
    "Multi-Language Content",
    "24/7 Availability",
    "Smart Escalation"
  ]
};
---

<MarketingLayout
  {title}
  {description}
  canonical="https://eventhex.ai/ai-event-copilot/"
  ogImage="https://eventhex.ai/wp-content/uploads/2025/01/Instasnap.png"
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
