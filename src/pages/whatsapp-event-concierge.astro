---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ICONS } from "../lib/featureIcons";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex MsgHex — WhatsApp Event Concierge",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "A full-service WhatsApp Business event concierge that handles registration, agenda, networking, polls, payments, and proactive reminders — all inside the chat attendees already use.",
  url: "https://eventhex.ai/whatsapp-event-concierge/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Conversational WhatsApp Registration",
    "WhatsApp Flows (Native In-Chat Forms)",
    "Agenda & Schedule Delivery",
    "Networking via WhatsApp",
    "In-Chat Polls & Feedback",
    "Payment Collection in Chat",
    "Proactive Reminders & Alerts",
    "Broadcast & Segmented Campaigns",
    "Delivery Tracking",
    "~98% Open Rates",
  ],
};
---

<FeatureV2Layout
  pageTitle="WhatsApp Event Concierge — Registration, Agenda & Automation | EventHex"
  pageDescription="EventHex MsgHex is a WhatsApp Business event concierge that handles registration, schedules, networking, polls, payments, and reminders — all inside the chat attendees already have open."
  canonical="https://eventhex.ai/whatsapp-event-concierge/"
  badge="WhatsApp Event Automation"
  heroTitleLine1="Your Event Concierge,"
  heroTitleLine2="Already in Their Pocket"
  heroCopy="EventHex MsgHex turns WhatsApp Business into a full-service event concierge — handling registration, agenda queries, polls, payments, and proactive reminders in the chat your attendees already use. No app downloads. No email open-rate anxiety. ~98% messages read."
  trustItems={["WhatsApp Flows for Native In-Chat Forms", "~98% Message Open Rates", "MEA & India Market Ready"]}
  stats={[
    { value: "~98%", label: "Average Message Open Rate" },
    { value: "0", label: "App Downloads Required" },
    { value: "360°", label: "Event Lifecycle Covered" },
    { value: "1", label: "Chat for Everything" },
  ]}
  statsHeadline={{
    white1: "Every attendee.",
    accent: "Every touchpoint.",
    white2: "Handled inside",
    accent2: "WhatsApp",
  }}
  bentoHeading="Full Event Automation Inside WhatsApp"
  bentoSubtitle="MsgHex is not a notification sender — it is a conversational layer that manages the entire attendee journey from registration to post-event feedback without ever leaving WhatsApp."
  bentoTabs={[
    {
      tab: "Conversational Concierge",
      cards: [
        { title: "WhatsApp Registration", desc: "Attendees register by replying to a WhatsApp message — no browser tab, no email link, no separate form portal", illustration: ILLOS.whatsapp },
        { title: "Agenda on Demand", desc: "Attendees type 'agenda' or 'my sessions' and instantly receive their personalised schedule inside the chat", illustration: ILLOS.calendar },
        { title: "Networking Introductions", desc: "MsgHex facilitates opt-in peer introductions and networking prompts based on attendee interests and roles", illustration: ILLOS.chatform },
        { title: "In-Chat Polls & Live Q&A", desc: "Run session polls and audience Q&A directly in WhatsApp — responses are collected and surfaced to speakers in real time", illustration: ILLOS.broadcast },
        { title: "Post-Event Feedback", desc: "Automated feedback requests go out the moment a session ends — response rates far exceed email surveys", illustration: ILLOS.refresh },
      ],
    },
    {
      tab: "WhatsApp Flows",
      cards: [
        { title: "Native In-Chat Forms", desc: "WhatsApp Flows render full registration and feedback forms natively inside WhatsApp — no browser redirect, no drop-off", illustration: ILLOS.chatform },
        { title: "Payment Collection", desc: "Collect ticket payments and on-site purchases inside the chat using WhatsApp Flows payment integration", illustration: ILLOS.whatsapp },
        { title: "Multi-Step Registration Flows", desc: "Guide attendees through multi-field registration sequences — dietary preferences, session selection, T-shirt sizes — step by step in chat", illustration: ILLOS.clipboard },
        { title: "Consent & GDPR Flows", desc: "Capture consent and data processing agreements through structured flows that produce compliant audit records", illustration: ILLOS.document },
        { title: "Zero Browser Redirects", desc: "The entire attendee journey — from registration to payment — stays inside WhatsApp with no external links required", illustration: ILLOS.whatsapp },
      ],
    },
    {
      tab: "Campaigns & Broadcasts",
      cards: [
        { title: "Segmented Broadcasts", desc: "Send targeted messages to specific attendee segments — VIPs, speakers, workshop participants, or custom groups", illustration: ILLOS.broadcast },
        { title: "Proactive Reminders", desc: "Automated session reminders, venue directions, and check-in prompts sent at exactly the right time before each touchpoint", illustration: ILLOS.bell },
        { title: "Delivery Tracking", desc: "See delivered, read, and replied status for every broadcast message — no guessing whether your message landed", illustration: ILLOS.chart },
        { title: "Day-of Alerts", desc: "Push real-time updates about schedule changes, room switches, or important announcements directly to attendees", illustration: ILLOS.bell },
        { title: "Post-Event Follow-Up", desc: "Automatically distribute recordings, slides, certificates, and thank-you messages after sessions conclude", illustration: ILLOS.mail },
      ],
    },
  ]}
  stackingHeading="WhatsApp Concierge Features"
  stackingHighlight="That Actually Convert"
  stackingCards={[
    {
      title: "Registration Without the Registration Page",
      desc: "MsgHex opens a WhatsApp conversation with your event bot, walks the attendee through registration questions using WhatsApp Flows, collects payment if required, and confirms the booking — all inside a single chat thread. No website visit. No email verification loop. Conversion rates improve because the friction disappears.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "WhatsApp event registration flow showing conversational bot collecting attendee details",
    },
    {
      title: "Campaigns That Get Read",
      desc: "Email campaigns average 20-30% open rates. WhatsApp messages average ~98%. MsgHex broadcast campaigns reach segmented attendee groups — VIPs, workshop participants, last-minute registrants — with personalised messages that land in the inbox they actually check. Delivery and read receipts give you certainty email never provides.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "WhatsApp broadcast campaign dashboard showing delivery and read receipt tracking",
    },
    {
      title: "The Full Attendee Journey in One Thread",
      desc: "A single WhatsApp conversation thread becomes the attendee's event companion — confirming registration, delivering the agenda, sending session reminders, facilitating networking introductions, collecting live poll responses, and following up with recordings after the event. One channel. Zero app downloads. Everything tracked in EventHex.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Full attendee event journey shown as a WhatsApp conversation thread",
    },
  ]}
  howItWorksHeading="How WhatsApp Event Concierge Works"
  steps={[
    { title: "Connect Your WhatsApp Business Account", desc: "Link your verified WhatsApp Business number to EventHex. MsgHex configures your event bot with your branding, registration questions, and session data." },
    { title: "Build Your Flows and Campaigns", desc: "Set up WhatsApp Flows for registration, payment, and feedback. Schedule broadcast campaigns and proactive reminders tied to your event timeline." },
    { title: "Attendees Interact in Chat", desc: "Share your WhatsApp link or QR code. Attendees register, ask questions, receive their agenda, respond to polls, and make payments — all inside WhatsApp." },
    { title: "Track Everything in EventHex", desc: "Registration data, payment status, campaign delivery reports, poll results, and feedback are all captured in your EventHex dashboard in real time." },
  ]}
  ctaTitle="Ready to Run Your Event Through WhatsApp?"
  ctaCopy="See how EventHex MsgHex turns WhatsApp Business into a full-service event concierge — from first registration to post-event follow-up, all in the chat your attendees already have open."
  whyHeading="Why Event Teams Choose MsgHex for WhatsApp Automation"
  whyCards={[
    { title: "No App Friction", desc: "Attendees need no new app, no account, and no login — WhatsApp is already on their phone and already open", icon: ICONS.mobile },
    { title: "~98% Open Rates", desc: "WhatsApp messages are read at rates email can't match — your reminders, updates, and follow-ups actually get seen", icon: ICONS.bolt },
    { title: "Native In-Chat Forms via WhatsApp Flows", desc: "Registration and payment happen inside WhatsApp with no browser redirect — dramatically reducing drop-off compared to web forms", icon: ICONS.chat },
    { title: "MEA & India Market Strength", desc: "WhatsApp is the primary communication channel across MEA and India — MsgHex puts your event where your audience already is", icon: ICONS.globe },
  ]}
  faqs={[
    { q: "What is EventHex MsgHex?", a: "MsgHex is EventHex's WhatsApp Business automation layer. It is a conversational event concierge bot that handles the full attendee journey — registration, agenda, networking, polls, payments, reminders, and post-event follow-up — directly inside WhatsApp." },
    { q: "What are WhatsApp Flows and why do they matter?", a: "WhatsApp Flows are native in-chat forms that render inside the WhatsApp app itself, with no browser redirect required. MsgHex uses Flows for registration, payment collection, feedback surveys, and consent capture — keeping attendees in the channel they're already using and reducing drop-off significantly." },
    { q: "Does this require a verified WhatsApp Business account?", a: "Yes. MsgHex connects to a WhatsApp Business Platform (API) account. EventHex can guide you through the verification process or connect to an account you already have." },
    { q: "Can I send broadcast messages to specific attendee segments?", a: "Yes. MsgHex supports segmented broadcast campaigns — you can target VIPs, speakers, workshop participants, or any custom segment based on ticket type, registration data, or check-in status." },
    { q: "How does payment collection work inside WhatsApp?", a: "MsgHex uses WhatsApp Flows payment integration to present a payment step natively inside the chat. Attendees complete payment without leaving WhatsApp, and the transaction is recorded in your EventHex dashboard." },
    { q: "Is MsgHex suitable for large events?", a: "Yes. MsgHex is built on the WhatsApp Business API which handles high message volumes at scale. Broadcasts can reach thousands of attendees simultaneously, with full delivery and read-receipt tracking." },
    { q: "How do the ~98% open rates compare to email?", a: "Industry email open rates for event communications typically range from 20-35%. WhatsApp messages are read by approximately 98% of recipients, often within minutes of delivery. This makes WhatsApp particularly effective for time-sensitive communications like same-day reminders and schedule changes." },
  ]}
  jsonLd={jsonLd}
/>
