---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroNew from "../components/home-new/HeroNew.astro";
import DashboardSection from "../components/home-new/DashboardSection.astro";
import FeaturesSection from "../components/home-new/FeaturesSection.astro";
import AISection from "../components/home-new/AISection.astro";
import TestimonialsSection from "../components/home-new/TestimonialsSection.astro";
import BlogSection from "../components/home-new/BlogSection.astro";

const title = "EventHex - The AI-Powered Event Management Platform";
const description = "Simplify Events, Amplify Results. The AI-Powered Event Management Platform for Every Event.";
---

<MarketingLayout title={title} description={description}>
  <HeroNew />
  <DashboardSection />
  <FeaturesSection />
  <AISection />
  <TestimonialsSection />
  <BlogSection />
</MarketingLayout>
