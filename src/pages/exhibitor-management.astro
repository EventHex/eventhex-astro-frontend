---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { exhIllustrations as ill } from "../components/exhibitor-management/illustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Exhibitor Management Software",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Exhibitor management with self-service portal, QR lead capture, product catalogs, interactive floor plans, and real-time analytics.",
  url: "https://eventhex.ai/exhibitor-management/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Self-Service Exhibitor Portal",
    "QR Lead Scanning",
    "Product Catalog Management",
    "Interactive Floor Plans",
    "Booth Allocation",
    "Lead Export & CRM Sync",
    "Team Member Access",
    "Exhibitor Packages",
  ],
};
---

<FeatureV2Layout
  pageTitle="Exhibitor Management Software — Self-Service Portal & Lead Capture | EventHex"
  pageDescription="Give exhibitors their own branded portal to manage booth details, upload product catalogs, invite team members, and capture QR leads — without emailing you for every update."
  canonical="https://eventhex.ai/exhibitor-management/"
  ogImage="https://eventhex.ai/wp-content/uploads/2025/04/iPhone-15-Pro.png"
  badge="Exhibitor Management Software"
  heroTitleLine1="A Self-Service Portal Exhibitors"
  heroTitleLine2="Actually Use"
  heroCopy="Give exhibitors their own branded portal to manage booth details, upload product catalogs, invite team members, and capture QR leads — without emailing you for every update."
  trustItems={["Self-Service Exhibitor Portal", "QR Lead Capture", "Interactive Floor Plans"]}
  stats={[
    { value: "80%", label: "Fewer Organizer Emails" },
    { value: "3x", label: "More Leads Captured" },
    { value: "500+", label: "Exhibitors Managed" },
    { value: "100%", label: "Self-Service Setup" },
  ]}
  statsHeadline={{
    white1: "Exhibitors run their own",
    accent: "setup.",
    white2: "You run",
    accent2: "the show",
  }}
  bentoHeading="Everything You Need for Exhibitor Management"
  bentoSubtitle="Exhibitors log in, fill out their booth profile, invite their team, upload their product catalog, and start scanning leads — all without a single email to you."
  bentoTabs={[
    {
      tab: "Exhibitor Portal",
      cards: [
        { title: "Self-Service Dashboard", desc: "Exhibitors manage their own booth details, contacts, and profile from a branded portal", illustration: ill.exh1 },
        { title: "Booth Setup Wizard", desc: "Step-by-step guided setup for booth description, logo, website, and social links", illustration: ill.exh2 },
        { title: "Product Catalog Management", desc: "Upload and organize product listings with photos, descriptions, and pricing", illustration: ill.exh3 },
        { title: "Team Member Invites", desc: "Exhibitors invite booth staff who all get scanner access and lead management", illustration: ill.exh4 },
        { title: "Document Uploads", desc: "Submit booth diagrams, compliance docs, and marketing materials directly from the portal", illustration: ill.exh5 },
      ],
    },
    {
      tab: "Lead Management",
      cards: [
        { title: "QR Lead Scanning", desc: "Booth staff scan attendee QR codes with a phone to capture contact info instantly", illustration: ill.exh6 },
        { title: "Manual Lead Entry", desc: "Add leads manually when QR scanning isn’t an option — form pre-fills from attendee data", illustration: ill.exh7 },
        { title: "Lead Export & CRM Sync", desc: "Export leads as CSV or push directly to CRM tools via webhook integration", illustration: ill.exh8 },
        { title: "Lead Qualification Notes", desc: "Add private notes, hot/warm/cold ratings, and follow-up reminders per lead", illustration: ill.exh9 },
        { title: "Registration-Based Leads", desc: "Match attendee registration data with leads for enriched profiles and segmentation", illustration: ill.exh10 },
      ],
    },
    {
      tab: "Floor Plans & Logistics",
      cards: [
        { title: "Interactive Floor Plans", desc: "Upload venue maps and assign booths visually with clickable booth allocation", illustration: ill.exh11 },
        { title: "Booth Allocation", desc: "Assign and reassign booth numbers, sizes, and zones from the organizer dashboard", illustration: ill.exh12 },
        { title: "Category Management", desc: "Group exhibitors by industry, product category, or sponsorship tier for filtering", illustration: ill.exh13 },
        { title: "Exhibitor Packages", desc: "Offer Standard, Premium, and Custom packages with different booth sizes and benefits", illustration: ill.exh14 },
        { title: "FAQ Management", desc: "Publish exhibitor FAQs and on-site guidelines directly in the exhibitor portal", illustration: ill.exh15 },
      ],
    },
  ]}
  stackingHeading="Exhibitor Management Features"
  stackingHighlight="That Save Hours"
  stackingCards={[
    {
      title: "Self-Service Setup That Saves You Hours",
      desc: "Exhibitors log in to their own branded portal and handle everything themselves — booth descriptions, team invites, product uploads, and document submissions. No chasing emails.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/iPhone-15-Pro.png",
      alt: "Self-service exhibitor portal with booth setup wizard",
    },
    {
      title: "Exhibitors Scan Leads. You Export the Data.",
      desc: "Every booth gets a QR scanner — attendees scan in, their contact details flow to the exhibitor's lead list, and organizers can see aggregated lead counts across all booths.",
      image: "https://eventhex.ai/wp-content/uploads/2026/01/Screenshot-2026-01-03-at-8.35.11-PM.png",
      alt: "QR lead scanning at exhibition booth",
    },
    {
      title: "Visual Booth Allocation. Interactive Maps.",
      desc: "Upload your venue floor plan, assign booths visually, and publish an interactive map on your event website — attendees find exhibitors, exhibitors know exactly where to set up.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/Mac-Studio.png",
      alt: "Interactive exhibition floor plan with booth assignments",
    },
  ]}
  howItWorksHeading="How Exhibitor Management Works"
  steps={[
    { title: "Set Up Exhibitor Packages", desc: "Define Standard, Premium, and Custom packages with booth sizes and included features. Assign exhibitors to packages." },
    { title: "Invite Exhibitors", desc: "Send each exhibitor a login link to their personal portal. They set up their own profile, team, and content." },
    { title: "Manage Booth Allocations", desc: "Assign booths using the interactive floor plan. Exhibitors see their booth number and location in the portal." },
    { title: "Go Live & Capture Leads", desc: "On event day, booth staff scan attendee QR codes to capture leads. All data flows to the organizer dashboard in real time." },
  ]}
  ctaTitle="Ready to Give Exhibitors a Portal They'll Love?"
  ctaCopy="See how EventHex turns exhibitor chaos into a smooth, self-service experience that saves your team hours and boosts exhibitor satisfaction."
  whyHeading="Why Organizers Choose EventHex for Exhibitors"
  whyCards={[
    { title: "Self-Service Portal", desc: "Exhibitors set up everything themselves — no chasing emails" },
    { title: "QR Lead Capture", desc: "Phone-based scanning, instant export, and lead qualification" },
    { title: "Floor Plans", desc: "Visual booth allocation with interactive public maps" },
    { title: "Product Catalogs", desc: "Exhibitors upload and manage their own product listings" },
    { title: "Lead Export", desc: "One-click CSV export or direct CRM sync for all booth leads" },
  ]}
  faqs={[
    { q: "What is the exhibitor portal?", a: "The exhibitor portal is a branded, self-service web app where exhibitors manage their own booth profile, invite team members, upload product catalogs, and capture leads — without needing to contact the organizer." },
    { q: "How do exhibitors manage their own booth?", a: "Each exhibitor receives a login link to their personal portal. They fill in booth description, upload logos and product catalogs, invite staff, and submit required documents through a guided setup wizard." },
    { q: "Can exhibitors scan leads?", a: "Yes. Booth staff use their smartphones to scan attendee QR codes. Contact details are captured instantly and added to the exhibitor's lead list. Leads can be qualified with notes and exported as CSV at any time." },
    { q: "How does floor plan management work?", a: "Upload your venue floor plan image and assign booths visually by clicking on booth areas. Exhibitors see their booth location in the portal, and an interactive public map can be embedded on your event website." },
    { q: "Can exhibitors upload their product catalogs?", a: "Yes. Each exhibitor portal includes a product catalog section where they can add products with photos, descriptions, pricing, and tags. The catalog is visible to attendees on the event website and app." },
  ]}
  jsonLd={jsonLd}
/>
