---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import FeatureSection from "../components/feature-page/FeatureSection.astro";
import CTASection from "../components/feature-page/CTASection.astro";

const title = "Exhibitor Management - EventHex";
const description = "Manage exhibitors and booth members from a single dashboard. EventHex provides complete control over exhibitor profiles, categories, and booth allocation.";
---

<MarketingLayout {title} {description}>
  <!-- Hero Section — unique layout for Exhibitor Management -->
  <section class="exh-hero">
    <div class="exh-hero__outer">
      <div class="exh-hero__card">
        <div class="exh-hero__bg-overlay"></div>
        <div class="exh-hero__inner">
          <div class="exh-hero__content">
            <div class="exh-hero__text">
              <div class="exh-hero__label-group">
                <h3 class="exh-hero__eyebrow">Exhibition & Trade Show Management</h3>
              </div>
              <h1 class="exh-hero__title">Manage Exhibitors and Booth Members from A Single Dashboard</h1>
            </div>
            <div class="exh-hero__actions">
              <a href="/book-a-demo/" class="exh-hero__btn">Request a demo</a>
            </div>
          </div>
          <div class="exh-hero__media">
            <img
              src="https://eventhex.ai/wp-content/uploads/2025/04/iPhone-15-Pro.png"
              alt="EventHex Exhibitor Management mobile interface"
              width="400"
              height="600"
              loading="eager"
            />
          </div>
        </div>
      </div>

      <!-- Stats Banner -->
      <div class="exh-hero__stats-banner">
        <div class="exh-hero__stats-inner">
          <h3 class="exh-hero__stats-text">EventHex boosts retention through <span class="exh-accent-purple">enhanced attendee engagement</span> and <span class="exh-accent-cyan">personalized user experiences</span></h3>
          <div class="exh-hero__stats-logos">
            <img src="https://eventhex.ai/wp-content/uploads/2024/12/Layer_1.svg" alt="Partner logos" width="400" height="40" loading="lazy" />
          </div>
          <p class="exh-hero__stats-subtitle">Used in Exhibitions and Trade Shows</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Section -->
  <FeatureSection
    sectionTitle="Now Manage All Exhibitors with Total Control"
    imageLeft={false}
    image="https://eventhex.ai/wp-content/uploads/2026/01/Screenshot-2026-01-03-at-8.35.11-PM.png"
    imageAlt="EventHex exhibitor management interface showing exhibitor profiles and categories"
    items={[
      {
        title: "Exhibitor Profile",
        description: "Add, edit, and delete exhibitor details such as company name, website, logo, description, etc",
      },
      {
        title: "Exhibitor Category",
        description: "Create and edit exhibitor categories based on price, lead capture, booth details and so on",
      },
      {
        title: "Booth Allocation",
        description: "Allocate booth and manage booth members by designation, email, and phone number",
      },
    ]}
  />

  <!-- CTA Section -->
  <CTASection title={"Know More About\nExhibitor and Trade Show\nManagement"} />
</MarketingLayout>

<style>
  .exh-hero {
    padding: 20px 10px 0;
    max-width: 1300px;
    margin: 0 auto;
  }

  .exh-hero__outer {
    display: flex;
    flex-direction: column;
  }

  .exh-hero__card {
    position: relative;
    background:
      url("https://eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.png") center / cover no-repeat,
      url("https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.png") center / cover no-repeat;
    border: 1px solid rgba(172, 161, 241, 0.51);
    border-radius: 49px;
    padding: 60px 40px;
    overflow: hidden;
  }

  .exh-hero__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .exh-hero__content {
    width: 50%;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .exh-hero__text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .exh-hero__eyebrow {
    font-family: "Inter", var(--font-body);
    font-size: 22px;
    font-weight: 400;
    color: #1461D0;
    margin: 0;
  }

  .exh-hero__title {
    font-family: "Manrope", var(--font-heading);
    font-size: 50px;
    font-weight: 400;
    line-height: 58px;
    letter-spacing: -1px;
    color: #000000;
    margin: 0;
  }

  .exh-hero__actions {
    display: flex;
    gap: 12px;
  }

  .exh-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    background-color: #375DFB;
    color: #ffffff;
    font-family: "Inter", var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    border-radius: 10px;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .exh-hero__btn:hover {
    background-color: #1C46D4;
  }

  .exh-hero__media {
    width: 44%;
    display: flex;
    justify-content: center;
  }

  .exh-hero__media img {
    width: 100%;
    max-width: 350px;
    height: auto;
    display: block;
  }

  .exh-hero__stats-banner {
    background:
      url("https://eventhex.ai/wp-content/uploads/2024/12/bg-1.png") center / cover no-repeat;
    border-radius: 0 0 30px 30px;
    padding: 60px 40px;
    text-align: center;
    margin-top: -20px;
    position: relative;
    z-index: 0;
  }

  .exh-hero__stats-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
  }

  .exh-hero__stats-text {
    font-family: "Manrope", var(--font-heading);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.4;
    color: #ffffff;
    margin: 0;
  }

  .exh-accent-purple {
    color: #AFA3FF;
  }

  .exh-accent-cyan {
    color: #ABFFFF;
  }

  .exh-hero__stats-logos img {
    height: 40px;
    width: auto;
    display: block;
    opacity: 0.8;
  }

  .exh-hero__stats-subtitle {
    font-family: "Inter", var(--font-body);
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .exh-hero__card {
      padding: 30px;
    }

    .exh-hero__title {
      font-size: 35px;
      line-height: 1.1;
    }

    .exh-hero__stats-text {
      font-size: 22px;
    }
  }

  @media (max-width: 767px) {
    .exh-hero__inner {
      flex-direction: column;
      gap: 30px;
    }

    .exh-hero__content,
    .exh-hero__media {
      width: 100%;
    }

    .exh-hero__card {
      border-radius: 30px;
      padding: 40px 20px 20px;
    }

    .exh-hero__title {
      font-size: 30px;
      line-height: 1.2;
    }

    .exh-hero__stats-banner {
      padding: 40px 20px;
    }

    .exh-hero__stats-text {
      font-size: 20px;
    }
  }
</style>
