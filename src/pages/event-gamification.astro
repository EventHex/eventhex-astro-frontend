---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-gamification/HeroSection.astro";
import StatsSection from "../components/event-gamification/StatsSection.astro";
import BentoGrid from "../components/event-gamification/BentoGrid.astro";
import FeatureCards from "../components/event-gamification/FeatureCards.astro";
import HowItWorksSection from "../components/event-gamification/HowItWorksSection.astro";
import CTASection from "../components/event-gamification/CTASection.astro";
import CoordinationTools from "../components/event-gamification/CoordinationTools.astro";
import FaqSection from "../components/event-gamification/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Event Gamification Software — Leaderboards & Rewards | EventHex";
const description = "Event gamification software with leaderboards, badges, challenges, and lucky draws. Boost attendee participation and track sponsor ROI with real-time engagement data.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Gamification Platform",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, iOS, Android",
  url: "https://eventhex.ai/event-gamification/",
  description: "Boost event engagement with challenges, leaderboards, lucky draws, and rewards. Track sponsor ROI with QR-verified data.",
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Custom Challenge Builder",
    "Real-Time Leaderboards",
    "Lucky Draw System",
    "QR Code Verification",
    "Master Game Templates",
    "Wall of Fame",
    "Sponsor ROI Tracking",
    "Engagement Heatmaps",
    "Milestone Rewards",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-gamification/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
