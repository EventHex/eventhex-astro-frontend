---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ICONS } from "../lib/featureIcons";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — B2B Appointment & Meeting Scheduling",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "B2B 1:1 appointment and meeting scheduling for expos and conferences — AI-assisted matchmaking, in-app booking, availability-based scheduling, and meeting calendars for attendees and exhibitors.",
  url: "https://eventhex.ai/appointments-meetings/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Availability-Based Meeting Booking",
    "AI-Assisted Matchmaking",
    "In-App Meeting Scheduling",
    "Automated Meeting Reminders",
    "Exhibitor Meeting Calendar",
    "Attendee Meeting Calendar",
    "Upcoming & Past Meeting Views",
    "Trade Show Networking",
    "B2B Matchmaking",
  ],
};
---

<FeatureV2Layout
  pageTitle="B2B Meeting Scheduler & Matchmaking for Expos and Conferences | EventHex"
  pageDescription="Let attendees and exhibitors book 1:1 meetings by availability at your expo or conference — AI-assisted matchmaking, in-app scheduling, automated reminders, and full meeting calendars."
  canonical="https://eventhex.ai/appointments-meetings/"
  badge="Appointments & Meetings"
  heroTitleLine1="Turn Every Expo Into"
  heroTitleLine2="a Meeting Machine"
  heroCopy="Let attendees and exhibitors book 1:1 meetings based on real availability — no email chains, no scheduling chaos. AI-assisted matchmaking surfaces the right connections, in-app booking closes them, and automated reminders make sure they show up."
  trustItems={["AI-Assisted Matchmaking", "Availability-Based Booking", "Automated Reminders"]}
  stats={[
    { value: "1:1", label: "Meetings at Scale" },
    { value: "AI", label: "Powered Matchmaking" },
    { value: "0", label: "Scheduling Emails Needed" },
    { value: "100%", label: "In-App Experience" },
  ]}
  statsHeadline={{
    white1: "Right people.",
    accent: "Right time.",
    white2: "Booked",
    accent2: "automatically.",
  }}
  bentoHeading="Everything You Need for B2B Meeting Scheduling"
  bentoSubtitle="From AI-powered matchmaking to exhibitor meeting calendars — EventHex turns your expo or conference into a structured networking engine where every valuable conversation gets booked, not missed."
  bentoTabs={[
    {
      tab: "Meeting Scheduling",
      cards: [
        { title: "Availability-Based Booking", desc: "Attendees and exhibitors publish their availability windows — meetings only get booked in open slots", illustration: ILLOS.calendar },
        { title: "In-App Booking Flow", desc: "Requestors send a meeting request, recipients confirm or suggest an alternative — all inside the event app", illustration: ILLOS.chatform },
        { title: "Automated Reminders", desc: "Meeting reminders are sent automatically before each scheduled appointment so no-shows are minimized", illustration: ILLOS.bell },
        { title: "Meeting Calendar View", desc: "Every participant has a personal calendar showing upcoming and past meetings with details and notes", illustration: ILLOS.calendar },
        { title: "Meeting Cancellation & Rescheduling", desc: "Participants can cancel or reschedule directly in-app — the calendar updates instantly for both parties", illustration: ILLOS.refresh },
      ],
    },
    {
      tab: "Matchmaking",
      cards: [
        { title: "AI-Assisted Matchmaking", desc: "EventHex analyses attendee and exhibitor profiles to surface the most relevant meeting suggestions for each participant", illustration: ILLOS.network },
        { title: "Interest & Category Matching", desc: "Match attendees to exhibitors based on product categories, industries, or custom profile fields", illustration: ILLOS.search },
        { title: "Mutual Match Scoring", desc: "Each suggested match is scored by relevance so participants focus their meeting time on the highest-value connections", illustration: ILLOS.chart },
        { title: "Match Notifications", desc: "Participants are notified of new AI-suggested matches and can accept or decline with one tap", illustration: ILLOS.bell },
        { title: "Matchmaking Rules", desc: "Organizers configure matching criteria — attendee tier, session interest, geography, company size — per event", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "Exhibitor Meetings",
      cards: [
        { title: "Exhibitor Booking Pages", desc: "Each exhibitor gets a dedicated booking page where attendees can view availability and request meetings", illustration: ILLOS.portal },
        { title: "Team Availability Management", desc: "Exhibitors with multiple booth staff can assign meetings to specific team members based on their calendars", illustration: ILLOS.user },
        { title: "Exhibitor Meeting Dashboard", desc: "Exhibitors see all confirmed, pending, and completed meetings in a single dashboard with attendee details", illustration: ILLOS.dashboard },
        { title: "Meeting Notes & Follow-Ups", desc: "Booth staff can log meeting notes directly in the app and flag leads for post-event follow-up", illustration: ILLOS.clipboard },
        { title: "Meeting Volume Reporting", desc: "Organizers and exhibitors both get reports on total meetings booked, attended, and cancelled per exhibitor", illustration: ILLOS.chart },
      ],
    },
  ]}
  stackingHeading="B2B Meeting Features"
  stackingHighlight="That Drive Connections"
  stackingCards={[
    {
      title: "AI Matchmaking That Finds the Right Meetings",
      desc: "EventHex analyses every attendee and exhibitor profile to surface the most relevant 1:1 meeting suggestions — before your event even begins. Participants arrive with a prioritized meeting list, not a blank calendar.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "AI-assisted matchmaking suggestions screen on a tablet",
    },
    {
      title: "In-App Booking With Zero Email Back-and-Forth",
      desc: "Attendees browse exhibitor availability, send a meeting request, and get a confirmation — all inside the event app. No email threads, no spreadsheet coordination, no double bookings. The calendar updates instantly for both sides.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "In-app meeting booking flow on a tablet",
    },
    {
      title: "Every Meeting Tracked From Request to Follow-Up",
      desc: "Participants see upcoming and past meetings in one calendar view. Exhibitors log notes and flag leads during the meeting. Organizers get a full picture of networking activity across the entire event floor.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Meeting calendar and exhibitor dashboard on a tablet",
    },
  ]}
  howItWorksHeading="How B2B Meeting Scheduling Works"
  steps={[
    { title: "Set Up Meeting Scheduling for Your Event", desc: "Enable the meetings module, configure availability windows, and set matchmaking criteria — industry, interest, attendee tier, or custom fields." },
    { title: "AI Suggests the Best Connections", desc: "EventHex analyses attendee and exhibitor profiles and sends each participant a list of AI-suggested meetings ranked by relevance." },
    { title: "Attendees & Exhibitors Book Meetings", desc: "Participants browse availability, send meeting requests, and confirm bookings entirely in-app. Automated reminders handle the follow-through." },
    { title: "Track Meetings & Capture Leads", desc: "Exhibitors log notes and follow-up flags in real time. Organizers see live meeting analytics across the full event." },
  ]}
  ctaTitle="Ready to Turn Your Expo Into a Structured Networking Event?"
  ctaCopy="See how EventHex eliminates scheduling chaos and helps every attendee and exhibitor walk away with the meetings that matter."
  whyHeading="Why Organizers Choose EventHex for B2B Meetings"
  whyCards={[
    { title: "AI Matchmaking", desc: "Relevant meeting suggestions for every participant — ranked by mutual fit", icon: ICONS.sparkles },
    { title: "Zero Email Scheduling", desc: "Availability-based in-app booking replaces all back-and-forth coordination", icon: ICONS.calendar },
    { title: "Automated Reminders", desc: "Meeting reminders sent automatically — no manual follow-up required", icon: ICONS.bell },
    { title: "Exhibitor Lead Capture", desc: "Booth staff log notes and follow-up flags during every meeting", icon: ICONS.clipboard },
    { title: "Meeting Analytics", desc: "Live reporting on meetings booked, attended, and cancelled per exhibitor", icon: ICONS.chart },
  ]}
  faqs={[
    { q: "How does B2B meeting scheduling work at an expo?", a: "Attendees and exhibitors publish their availability windows in the EventHex app. Participants can then browse each other's availability and send meeting requests. Once confirmed, the meeting appears on both calendars and automated reminders are sent before the appointment." },
    { q: "How does AI matchmaking work?", a: "EventHex analyses the profiles of all attendees and exhibitors — including interests, industries, session registrations, and custom profile fields — and generates a ranked list of suggested meetings for each participant. The more profile data provided, the more accurate the matches." },
    { q: "Can exhibitors manage multiple team members' availability?", a: "Yes. Exhibitors with multiple booth staff can add team members and assign their individual availability. Incoming meeting requests can be routed to the most appropriate team member based on topic or availability." },
    { q: "Are attendees notified about their meetings?", a: "Yes. Participants receive automated in-app notifications and email reminders before each scheduled meeting. They can also view all upcoming and past meetings in their personal meeting calendar." },
    { q: "Can organizers see meeting activity across the whole event?", a: "Yes. EventHex provides organizer-level reports showing total meetings booked, attended, cancelled, and completed per exhibitor and across the entire event — giving you a live picture of networking activity on the event floor." },
    { q: "Is this suitable for trade shows?", a: "Yes. The appointments and meetings feature was designed specifically for trade shows and expos where structured 1:1 networking between attendees and exhibitors is critical. It replaces email scheduling and paper-based appointment systems entirely." },
  ]}
  jsonLd={jsonLd}
/>
