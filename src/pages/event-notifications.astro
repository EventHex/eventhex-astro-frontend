---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-notifications/HeroSection.astro";
import StatsSection from "../components/event-notifications/StatsSection.astro";
import BentoGrid from "../components/event-notifications/BentoGrid.astro";
import FeatureCards from "../components/event-notifications/FeatureCards.astro";
import HowItWorksSection from "../components/event-notifications/HowItWorksSection.astro";
import CTASection from "../components/event-notifications/CTASection.astro";
import CoordinationTools from "../components/event-notifications/CoordinationTools.astro";
import FaqSection from "../components/event-notifications/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Event Notification Software — Email, WhatsApp, Push & SMS | EventHex";
const description = "Send event notifications via email, WhatsApp, push, and SMS from one dashboard. Automated triggers, delivery analytics, and GDPR compliance.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Notifications & Multi-Channel Communication",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/event-notifications/",
  description: "Send event notifications via email, WhatsApp, push, and SMS from one dashboard. Automated triggers, delivery analytics, and GDPR compliance.",
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Email Notifications",
    "WhatsApp Business API",
    "Push Notifications",
    "SMS via Twilio",
    "Automated Triggers",
    "Delivery Analytics",
    "A/B Testing",
    "GDPR Compliance",
    "Suppression Lists",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-notifications/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
