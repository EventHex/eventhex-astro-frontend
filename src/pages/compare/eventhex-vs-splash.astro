---
import MarketingLayout from "../../layouts/MarketingLayout.astro";

const title = "EventHex vs Splash: Event Management vs Event Marketing | EventHex";
const description = "Comparing EventHex and Splash on full event management, AI features, check-in, WhatsApp automation, and pricing. See which platform fits your events beyond brand pages.";

const tableRows = [
  {
    feature: "Pricing model",
    eventhex: "Flexible tiers; 0% platform fee when using your own payment gateway",
    competitor: "Quote-based; varies by plan and feature set",
  },
  {
    feature: "AI features",
    eventhex: "AI Copilot (content/emails), AI Smart Connect (networking), AI Photo Gallery (face-match delivery)",
    competitor: "Limited AI; some content generation tools",
  },
  {
    feature: "Registration & ticketing",
    eventhex: "Fully branded, multi-ticket types, approval workflows, waitlists",
    competitor: "Yes — registration and RSVP management; strong event page builder",
  },
  {
    feature: "On-site check-in (QR/face)",
    eventhex: "QR scan + face-match check-in natively built in",
    competitor: "QR check-in available; no native face-recognition",
  },
  {
    feature: "Virtual & hybrid",
    eventhex: "Native virtual rooms, session streaming, hybrid attendee tracking",
    competitor: "Limited; primarily focused on in-person event marketing",
  },
  {
    feature: "WhatsApp automation",
    eventhex: "Native WhatsApp concierge — reminders, tickets, updates",
    competitor: "Not native; email-based attendee communication",
  },
  {
    feature: "Mobile event app",
    eventhex: "White-label branded attendee app",
    competitor: "Limited native app; primarily web-based event pages",
  },
  {
    feature: "White-label / multi-org",
    eventhex: "Full white-label; multi-organisation support",
    competitor: "Custom-branded event pages; field marketing workflow support",
  },
  {
    feature: "Regional payments (GCC/India)",
    eventhex: "Native support for GCC and India payment gateways",
    competitor: "Primarily US/global gateways; limited regional coverage",
  },
  {
    feature: "Support",
    eventhex: "Dedicated success team; onboarding support included",
    competitor: "Support available; varies by tier",
  },
];

const switchReasons = [
  {
    heading: "Full event operations, not just marketing pages",
    body: "Splash excels at beautiful branded event pages and CRM integration for field marketing. EventHex covers the full stack: registration, on-site check-in, session management, virtual rooms, attendee app, and post-event analytics — all in one platform.",
  },
  {
    heading: "AI built into every stage",
    body: "EventHex's AI Copilot handles pre-event content and emails. AI Smart Connect runs networking matchmaking. AI Photo Gallery auto-delivers face-matched photos after the event. Splash's AI tooling is more limited in scope.",
  },
  {
    heading: "WhatsApp-first attendee communication",
    body: "For events in GCC, South Asia, and Africa, WhatsApp outperforms email significantly for attendee reach. EventHex's native concierge sends tickets, reminders, and real-time updates through attendees' preferred channel.",
  },
  {
    heading: "0% platform fee — keep your full revenue",
    body: "Connect your own payment gateway and pay zero platform commission per ticket. EventHex's pricing scales with your team, not with your ticket sales volume.",
  },
];

const faqs = [
  {
    q: "How does EventHex compare to Splash for field marketing events?",
    a: "Splash is purpose-built for field marketing with Salesforce and HubSpot integration and beautiful event pages. EventHex covers the same ground — branded pages, CRM integration, RSVP management — while also handling on-site operations, attendee apps, and virtual events that Splash handles less well.",
  },
  {
    q: "Does EventHex have a good event page builder like Splash?",
    a: "Yes. EventHex includes a fully branded event website builder with custom domains, multi-session pages, and sponsor sections — while adding registration workflows, approval gates, and ticketing that go beyond event marketing pages.",
  },
  {
    q: "Can EventHex integrate with Salesforce and HubSpot?",
    a: "Yes. EventHex integrates with leading CRM and marketing platforms, supporting the same marketing attribution and lead capture workflows that make Splash popular with B2B marketing teams.",
  },
  {
    q: "Which regions does EventHex serve?",
    a: "EventHex is purpose-built for the GCC, South Asia, and global markets. It supports local payment gateways in the UAE, Saudi Arabia, India, and more — regions where Splash's coverage is limited.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/compare/eventhex-vs-splash/"
  footerCtaTitle="Ready to go beyond Splash?"
  footerCtaButtonText="Book a demo"
  footerCtaHref="/book-a-demo/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="compare-hero">
    <div class="container">
      <p class="eyebrow">Platform Comparison</p>
      <h1>EventHex vs Splash: Event Management vs Event Marketing</h1>
      <p class="intro">
        Splash built a strong reputation for beautiful event pages and tight CRM integration
        for field marketing teams. But for teams that need on-site operations, virtual events,
        AI-powered features, and regional payment support, EventHex offers a fuller platform.
        Here's the comparison.
      </p>
      <a href="/book-a-demo/" class="btn-primary">See EventHex in action →</a>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="table-section">
    <div class="container">
      <h2>Feature Comparison: EventHex vs Splash</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="feature-col">Feature</th>
              <th class="eventhex-col">
                <span class="col-label eventhex-label">EventHex</span>
              </th>
              <th class="competitor-col">
                <span class="col-label">Splash</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {tableRows.map((row, i) => (
              <tr class={i % 2 === 0 ? "row-even" : ""}>
                <td class="feature-name">{row.feature}</td>
                <td class="eventhex-cell">{row.eventhex}</td>
                <td class="competitor-cell">{row.competitor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Why Switch -->
  <section class="switch-section">
    <div class="container">
      <h2>Why Teams Switch to EventHex</h2>
      <div class="switch-grid">
        {switchReasons.map((r) => (
          <div class="switch-card">
            <h3>{r.heading}</h3>
            <p>{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mid-cta">
    <div class="container mid-cta-inner">
      <div>
        <h2>See the difference for yourself</h2>
        <p>Book a personalised walkthrough and compare EventHex side-by-side with your current setup.</p>
      </div>
      <a href="/book-a-demo/" class="btn-primary">Book a demo</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-question">{f.q}</summary>
            <p class="faq-answer">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="disclaimer-section">
    <div class="container">
      <p class="disclaimer">
        Comparison based on publicly available information as of 2026. Verify current details with each vendor.
      </p>
    </div>
  </section>
</MarketingLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .compare-hero {
    background: var(--surface-light);
    padding: 80px 24px 60px;
    text-align: center;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 14px;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: var(--heading-dark);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .intro {
    font-size: 1.1rem;
    color: var(--subheading-gray);
    max-width: 660px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .btn-primary {
    display: inline-block;
    background: var(--brand-blue);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--brand-blue-hover);
  }

  /* Table */
  .table-section {
    padding: 72px 24px;
    background: #fff;
  }

  .table-section h2,
  .switch-section h2,
  .faq-section h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--heading-dark);
    margin-bottom: 32px;
  }

  .table-wrap {
    overflow-x: auto;
    border-radius: 14px;
    border: 1.5px solid var(--surface-card-border);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  thead th {
    padding: 16px 20px;
    text-align: left;
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 2px solid var(--surface-card-border);
  }

  .feature-col { width: 22%; color: var(--heading-dark); background: var(--surface-light); }
  .eventhex-col { width: 39%; background: #EEF2FF; }
  .competitor-col { width: 39%; }

  .col-label {
    font-size: 1rem;
    font-weight: 700;
    font-family: var(--font-heading);
  }

  .eventhex-label { color: var(--brand-blue); }

  tbody tr td {
    padding: 14px 20px;
    vertical-align: top;
    border-bottom: 1px solid var(--surface-card-border);
    line-height: 1.6;
    color: var(--body-gray);
  }

  .row-even td { background: #fafbff; }
  .eventhex-cell { background: #F5F8FF; color: var(--heading-dark); font-weight: 500; }
  .feature-name { font-weight: 600; color: var(--heading-dark); font-size: 0.9rem; }

  /* Switch */
  .switch-section {
    padding: 72px 24px;
    background: var(--surface-light);
  }

  .switch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }

  .switch-card {
    background: #fff;
    border: 1.5px solid var(--surface-card-border);
    border-radius: 14px;
    padding: 28px 24px;
  }

  .switch-card h3 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin-bottom: 10px;
  }

  .switch-card p {
    font-size: 0.93rem;
    color: var(--body-gray);
    line-height: 1.65;
  }

  /* Mid CTA */
  .mid-cta {
    padding: 60px 24px;
    background: var(--brand-blue);
    color: #fff;
  }

  .mid-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .mid-cta h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .mid-cta p {
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
  }

  .mid-cta .btn-primary {
    background: #fff;
    color: var(--brand-blue);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mid-cta .btn-primary:hover {
    background: var(--surface-blue-tint);
  }

  /* FAQ */
  .faq-section {
    padding: 72px 24px;
    background: #fff;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 820px;
  }

  .faq-item {
    border: 1.5px solid var(--surface-card-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .faq-question {
    padding: 18px 24px;
    font-weight: 600;
    font-size: 1rem;
    color: var(--heading-dark);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question::after {
    content: '+';
    font-size: 1.3rem;
    color: var(--brand-blue);
    flex-shrink: 0;
  }

  details[open] .faq-question::after { content: '−'; }

  .faq-answer {
    padding: 0 24px 18px;
    font-size: 0.95rem;
    color: var(--body-gray);
    line-height: 1.7;
  }

  /* Disclaimer */
  .disclaimer-section {
    padding: 20px 24px 40px;
    text-align: center;
  }

  .disclaimer {
    font-size: 0.78rem;
    color: var(--label-gray);
  }
</style>
