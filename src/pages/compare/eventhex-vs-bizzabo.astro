---
import MarketingLayout from "../../layouts/MarketingLayout.astro";

const title = "EventHex vs Bizzabo: Which Event Platform Fits Your Team? | EventHex";
const description = "EventHex vs Bizzabo — compare AI features, check-in, pricing, virtual events, and regional payment support to find the right event platform for your team.";

const tableRows = [
  {
    feature: "Pricing model",
    eventhex: "Flexible tiers; 0% platform fee with your own payment gateway",
    competitor: "Enterprise quote-based; module pricing",
  },
  {
    feature: "AI features",
    eventhex: "AI Copilot, AI Smart Connect (networking), AI Photo Gallery with face-match delivery",
    competitor: "AI-driven content recommendations and audience insights",
  },
  {
    feature: "Registration & ticketing",
    eventhex: "Multi-ticket types, approval workflows, waitlists, fully branded pages",
    competitor: "Yes — robust registration and ticketing suite",
  },
  {
    feature: "On-site check-in (QR/face)",
    eventhex: "QR scan + face-match check-in built in natively",
    competitor: "QR check-in available; face recognition varies",
  },
  {
    feature: "Virtual & hybrid",
    eventhex: "Native virtual rooms, session streaming, hybrid attendee tracking",
    competitor: "Yes — strong virtual and hybrid event capabilities",
  },
  {
    feature: "WhatsApp automation",
    eventhex: "Native WhatsApp concierge for reminders, tickets, and updates",
    competitor: "Not native; requires third-party integration",
  },
  {
    feature: "Mobile event app",
    eventhex: "White-label branded attendee app",
    competitor: "Yes — Bizzabo mobile event app",
  },
  {
    feature: "White-label / multi-org",
    eventhex: "Full white-label; multi-organisation dashboard",
    competitor: "White-label available at higher tiers",
  },
  {
    feature: "Regional payments (GCC/India)",
    eventhex: "Native GCC and India payment gateway support",
    competitor: "Primarily US/global gateways; regional support varies",
  },
  {
    feature: "Support",
    eventhex: "Dedicated success team; onboarding included",
    competitor: "Enterprise support available; tier-dependent",
  },
];

const switchReasons = [
  {
    heading: "Face-match photo delivery — a genuine differentiator",
    body: "EventHex's AI Photo Gallery uses facial recognition to automatically deliver event photos to each attendee. Bizzabo doesn't offer this natively, meaning organizers still rely on manual photo curation.",
  },
  {
    heading: "WhatsApp reaches your audience first",
    body: "In GCC and South Asia, WhatsApp open rates far exceed email. EventHex's native concierge sends tickets, reminders, and post-event wrap-ups over WhatsApp — no extra integration needed.",
  },
  {
    heading: "0% platform fee keeps margins intact",
    body: "Connect your own payment gateway and pay nothing per ticket. Bizzabo's enterprise pricing can include per-attendee fees that scale against your revenue.",
  },
  {
    heading: "Built for regional payment realities",
    body: "EventHex natively supports local payment gateways across the UAE, Saudi Arabia, and India — removing the workarounds that global platforms require for regional events.",
  },
];

const faqs = [
  {
    q: "How does EventHex compare to Bizzabo for B2B conferences?",
    a: "Both platforms support B2B conference formats well. EventHex adds WhatsApp-native attendee communication and AI-powered photo delivery that Bizzabo doesn't offer natively, making it a stronger fit for GCC and South Asia markets.",
  },
  {
    q: "Does EventHex support the same virtual event features as Bizzabo?",
    a: "Yes. EventHex includes native virtual rooms, live session streaming, and hybrid attendee tracking. Sponsors and exhibitors also get dedicated virtual booths.",
  },
  {
    q: "Can I use my own ticketing payment gateway with EventHex?",
    a: "Yes. EventHex integrates with your own payment gateway and charges 0% platform fee on ticket revenue — you keep 100% of what you collect.",
  },
  {
    q: "Is EventHex suitable for global events, not just GCC?",
    a: "Absolutely. EventHex serves global customers and supports multiple currencies, languages, and time zones. Its regional strengths in GCC and India are additions, not limitations.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/compare/eventhex-vs-bizzabo/"
  footerCtaTitle="Curious how EventHex stacks up for your events?"
  footerCtaButtonText="Book a demo"
  footerCtaHref="/book-a-demo/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="compare-hero">
    <div class="container">
      <p class="eyebrow">Platform Comparison</p>
      <h1>EventHex vs Bizzabo: Which Event Platform Fits Your Team?</h1>
      <p class="intro">
        Bizzabo is a well-regarded enterprise event platform — especially for marketing-led
        conferences. This comparison lays out where each platform excels and where they differ,
        so you can make an informed decision.
      </p>
      <a href="/book-a-demo/" class="btn-primary">See EventHex in action →</a>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="table-section">
    <div class="container">
      <h2>Feature Comparison: EventHex vs Bizzabo</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="feature-col">Feature</th>
              <th class="eventhex-col">
                <span class="col-label eventhex-label">EventHex</span>
              </th>
              <th class="competitor-col">
                <span class="col-label">Bizzabo</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {tableRows.map((row, i) => (
              <tr class={i % 2 === 0 ? "row-even" : ""}>
                <td class="feature-name">{row.feature}</td>
                <td class="eventhex-cell">{row.eventhex}</td>
                <td class="competitor-cell">{row.competitor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Why Switch -->
  <section class="switch-section">
    <div class="container">
      <h2>Why Teams Switch to EventHex</h2>
      <div class="switch-grid">
        {switchReasons.map((r) => (
          <div class="switch-card">
            <h3>{r.heading}</h3>
            <p>{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mid-cta">
    <div class="container mid-cta-inner">
      <div>
        <h2>See how EventHex handles your events</h2>
        <p>Get a personalised demo and bring your own event scenario — we'll walk through it together.</p>
      </div>
      <a href="/book-a-demo/" class="btn-primary">Book a demo</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-question">{f.q}</summary>
            <p class="faq-answer">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="disclaimer-section">
    <div class="container">
      <p class="disclaimer">
        Comparison based on publicly available information as of 2026. Verify current details with each vendor.
      </p>
    </div>
  </section>
</MarketingLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .compare-hero {
    background: var(--surface-light);
    padding: 80px 24px 60px;
    text-align: center;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 14px;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: var(--heading-dark);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .intro {
    font-size: 1.1rem;
    color: var(--subheading-gray);
    max-width: 660px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .btn-primary {
    display: inline-block;
    background: var(--brand-blue);
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    padding: 14px 32px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover { background: var(--brand-blue-hover); }

  .table-section {
    padding: 72px 24px;
    background: #fff;
  }

  .table-section h2,
  .switch-section h2,
  .faq-section h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    color: var(--heading-dark);
    margin-bottom: 32px;
  }

  .table-wrap {
    overflow-x: auto;
    border-radius: 14px;
    border: 1.5px solid var(--surface-card-border);
  }

  table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }

  thead th {
    padding: 16px 20px;
    text-align: left;
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 2px solid var(--surface-card-border);
  }

  .feature-col { width: 22%; color: var(--heading-dark); background: var(--surface-light); }
  .eventhex-col { width: 39%; background: #EEF2FF; }
  .competitor-col { width: 39%; }

  .col-label { font-size: 1rem; font-weight: 700; font-family: var(--font-heading); }
  .eventhex-label { color: var(--brand-blue); }

  tbody tr td {
    padding: 14px 20px;
    vertical-align: top;
    border-bottom: 1px solid var(--surface-card-border);
    line-height: 1.6;
    color: var(--body-gray);
  }

  .row-even td { background: #fafbff; }
  .eventhex-cell { background: #F5F8FF; color: var(--heading-dark); font-weight: 500; }
  .feature-name { font-weight: 600; color: var(--heading-dark); font-size: 0.9rem; }

  .switch-section { padding: 72px 24px; background: var(--surface-light); }

  .switch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }

  .switch-card {
    background: #fff;
    border: 1.5px solid var(--surface-card-border);
    border-radius: 14px;
    padding: 28px 24px;
  }

  .switch-card h3 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin-bottom: 10px;
  }

  .switch-card p { font-size: 0.93rem; color: var(--body-gray); line-height: 1.65; }

  .mid-cta { padding: 60px 24px; background: var(--brand-blue); color: #fff; }

  .mid-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .mid-cta h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 8px;
  }

  .mid-cta p { font-size: 1rem; color: rgba(255,255,255,0.85); }

  .mid-cta .btn-primary {
    background: #fff;
    color: var(--brand-blue);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .mid-cta .btn-primary:hover { background: var(--surface-blue-tint); }

  .faq-section { padding: 72px 24px; background: #fff; }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 820px;
  }

  .faq-item {
    border: 1.5px solid var(--surface-card-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .faq-question {
    padding: 18px 24px;
    font-weight: 600;
    font-size: 1rem;
    color: var(--heading-dark);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after { content: '+'; font-size: 1.3rem; color: var(--brand-blue); flex-shrink: 0; }
  details[open] .faq-question::after { content: '−'; }

  .faq-answer {
    padding: 0 24px 18px;
    font-size: 0.95rem;
    color: var(--body-gray);
    line-height: 1.7;
  }

  .disclaimer-section { padding: 20px 24px 40px; text-align: center; }
  .disclaimer { font-size: 0.78rem; color: var(--label-gray); }
</style>
