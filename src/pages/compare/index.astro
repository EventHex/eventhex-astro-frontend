---
import MarketingLayout from "../../layouts/MarketingLayout.astro";

const title = "EventHex vs Competitors — Platform Comparisons | EventHex";
const description = "Compare EventHex with Cvent, Bizzabo, Whova, and other event management platforms. See features, pricing models, and why teams switch to EventHex.";

const comparisons = [
  {
    slug: "eventhex-vs-cvent",
    competitor: "Cvent",
    tagline: "Enterprise power without the enterprise price tag.",
    highlights: ["0% platform fee", "Face-match check-in", "WhatsApp automation"],
  },
  {
    slug: "eventhex-vs-bizzabo",
    competitor: "Bizzabo",
    tagline: "All-in-one AI platform vs. a marketing-first suite.",
    highlights: ["AI photo gallery", "Virtual & hybrid", "GCC/India payments"],
  },
  {
    slug: "eventhex-vs-whova",
    competitor: "Whova",
    tagline: "Mobile-first networking without the trade-offs.",
    highlights: ["White-label app", "On-site face check-in", "Own payment gateway"],
  },
  {
    slug: "eventhex-vs-eventbrite",
    competitor: "Eventbrite",
    tagline: "Full event management vs. consumer ticketing.",
    highlights: ["0% platform fee", "Session management", "WhatsApp automation"],
  },
  {
    slug: "eventhex-vs-hopin",
    competitor: "Hopin",
    tagline: "AI-powered all-in-one vs. virtual-first networking.",
    highlights: ["Face-match check-in", "AI Copilot", "GCC/India payments"],
  },
  {
    slug: "eventhex-vs-splash",
    competitor: "Splash",
    tagline: "Full event ops vs. event marketing pages.",
    highlights: ["On-site face check-in", "Virtual & hybrid", "WhatsApp automation"],
  },
  {
    slug: "eventhex-vs-airmeet",
    competitor: "Airmeet",
    tagline: "In-person + virtual platform vs. webinar-focused.",
    highlights: ["Face-match check-in", "AI Smart Connect", "Own payment gateway"],
  },
];
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/compare/"
  footerCtaTitle="Ready to see EventHex in action?"
  footerCtaButtonText="Book a demo"
  footerCtaHref="/book-a-demo/"
>
  <section class="compare-hero">
    <div class="container">
      <p class="eyebrow">Platform Comparisons</p>
      <h1>How EventHex Stacks Up</h1>
      <p class="intro">
        Choosing the right event platform is a long-term decision. We've put together
        honest, feature-by-feature comparisons so you can evaluate EventHex alongside
        the most popular alternatives.
      </p>
    </div>
  </section>

  <section class="compare-grid">
    <div class="container">
      <div class="cards">
        {comparisons.map((c) => (
          <a href={`/compare/${c.slug}/`} class="card">
            <div class="card-header">
              <span class="vs-badge">EventHex vs</span>
              <h2 class="competitor-name">{c.competitor}</h2>
            </div>
            <p class="card-tagline">{c.tagline}</p>
            <ul class="card-highlights">
              {c.highlights.map((h) => (
                <li>
                  <span class="check">✓</span> {h}
                </li>
              ))}
            </ul>
            <span class="card-cta">Compare now →</span>
          </a>
        ))}

        <a href="/compare/best-event-management-software-2026/" class="card card-listicle">
          <div class="card-header">
            <span class="vs-badge">Ranked list</span>
            <h2 class="competitor-name">Best Event Management Software 2026</h2>
          </div>
          <p class="card-tagline">
            An honest look at the top platforms — who they're for, what they do well,
            and where EventHex fits.
          </p>
          <ul class="card-highlights">
            <li><span class="check">✓</span> 8–10 platforms reviewed</li>
            <li><span class="check">✓</span> Honest pros per tool</li>
            <li><span class="check">✓</span> FAQ + schema markup</li>
          </ul>
          <span class="card-cta">Read the guide →</span>
        </a>

        <a href="/compare/best-conference-apps/" class="card card-listicle">
          <div class="card-header">
            <span class="vs-badge">Ranked list</span>
            <h2 class="competitor-name">Best Conference Apps 2026</h2>
          </div>
          <p class="card-tagline">
            Eight conference apps ranked honestly — AI check-in, WhatsApp automation,
            hybrid support, and regional payments compared.
          </p>
          <ul class="card-highlights">
            <li><span class="check">✓</span> 8 platforms reviewed</li>
            <li><span class="check">✓</span> In-person, virtual &amp; hybrid coverage</li>
            <li><span class="check">✓</span> FAQ + schema markup</li>
          </ul>
          <span class="card-cta">Read the guide →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="disclaimer-section">
    <div class="container">
      <p class="disclaimer">
        All comparisons are based on publicly available information as of 2026.
        Verify current details directly with each vendor.
      </p>
    </div>
  </section>
</MarketingLayout>

<style>
  .compare-hero {
    background: var(--surface-light);
    padding: 80px 24px 60px;
    text-align: center;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 16px;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--heading-dark);
    margin-bottom: 20px;
  }

  .intro {
    font-size: 1.125rem;
    color: var(--subheading-gray);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .compare-grid {
    padding: 64px 24px;
    background: #fff;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px 28px;
    border: 1.5px solid var(--surface-card-border);
    border-radius: 16px;
    background: #fff;
    text-decoration: none;
    color: var(--heading-dark);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .card:hover {
    border-color: var(--brand-blue);
    box-shadow: 0 8px 32px rgba(55, 93, 251, 0.1);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .vs-badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--brand-blue);
    background: var(--surface-blue-tint);
    padding: 3px 10px;
    border-radius: 20px;
    width: fit-content;
  }

  .competitor-name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--heading-dark);
  }

  .card-tagline {
    font-size: 0.95rem;
    color: var(--subheading-gray);
    line-height: 1.6;
  }

  .card-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 0;
  }

  .card-highlights li {
    font-size: 0.9rem;
    color: var(--body-gray);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .check {
    color: var(--brand-blue);
    font-weight: 700;
    flex-shrink: 0;
  }

  .card-cta {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--brand-blue);
    margin-top: auto;
  }

  .card-listicle {
    border-color: var(--surface-blue-tint);
    background: var(--surface-light);
  }

  .disclaimer-section {
    padding: 24px;
    text-align: center;
  }

  .disclaimer {
    font-size: 0.8rem;
    color: var(--label-gray);
  }
</style>
