---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { getCaseStudies } from "../../lib/wordpress";

const title = "Customer Stories & Case Studies | EventHex";
const description = "See how event teams worldwide use EventHex to cut check-in times, boost engagement, and deliver flawless events at scale.";

const caseStudies = await getCaseStudies();
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/customers/"
  footerCtaTitle="Ready to write your own success story?"
  footerCtaButtonText="Book a demo"
  footerCtaHref="/book-a-demo/"
>
  <!-- Hero -->
  <section class="hero-section">
    <div class="container">
      <p class="eyebrow">Customer Stories</p>
      <h1 class="hero-title">Trusted by event teams worldwide</h1>
      <p class="hero-desc">{description}</p>
    </div>
  </section>

  <!-- Grid -->
  <section class="grid-section">
    <div class="container">
      {caseStudies.length === 0 ? (
        <div class="empty-state">
          <p>Customer stories coming soon. <a href="/book-a-demo/">Talk to our team →</a></p>
        </div>
      ) : (
        <div class="cs-grid">
          {caseStudies.map((cs) => (
            <article class="cs-card">
              <div class="cs-card__header">
                <span class="cs-industry-tag">{cs.industry}</span>
                <h2 class="cs-client-name">{cs.clientName}</h2>
                <p class="cs-result-headline">{cs.resultHeadline}</p>
              </div>

              {cs.metrics.length > 0 && (
                <div class="cs-metrics">
                  {cs.metrics.map((m) => (
                    <div class="cs-metric">
                      <span class="cs-metric__value">{m.value}</span>
                      <span class="cs-metric__label">{m.label}</span>
                    </div>
                  ))}
                </div>
              )}

              <p class="cs-excerpt" set:html={cs.excerpt} />

              <a href={`/case-studies/${cs.slug}/`} class="cs-read-link">
                Read story
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</MarketingLayout>

<style>
  .hero-section {
    background: var(--surface-light);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--surface-card-border);
  }

  .container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 1rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--heading-dark);
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }

  .hero-desc {
    font-size: 1.125rem;
    color: var(--subheading-gray);
    max-width: 44rem;
    margin: 0 auto;
    line-height: 1.7;
  }

  .grid-section {
    padding: 4rem 0 5rem;
  }

  .cs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
    gap: 1.75rem;
  }

  .cs-card {
    background: #fff;
    border: 1px solid var(--surface-card-border);
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .cs-card:hover {
    box-shadow: 0 4px 24px rgba(55, 93, 251, 0.1);
    border-color: #c7d4fe;
  }

  .cs-card__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cs-industry-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--brand-blue);
    background: var(--surface-blue-tint);
    border-radius: 2rem;
    padding: 0.25rem 0.75rem;
    width: fit-content;
  }

  .cs-client-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin: 0;
  }

  .cs-result-headline {
    font-size: 0.9375rem;
    color: var(--body-gray);
    margin: 0;
    line-height: 1.5;
  }

  .cs-metrics {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1rem;
    background: var(--surface-light);
    border-radius: 0.625rem;
  }

  .cs-metric {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1 1 auto;
  }

  .cs-metric__value {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--brand-blue);
    line-height: 1;
  }

  .cs-metric__label {
    font-size: 0.75rem;
    color: var(--label-gray);
    font-weight: 500;
  }

  .cs-excerpt {
    font-size: 0.9375rem;
    color: var(--body-gray);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .cs-excerpt :global(p) {
    margin: 0;
  }

  .cs-read-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--brand-blue);
    text-decoration: none;
    margin-top: auto;
    transition: gap 0.15s;
  }

  .cs-read-link:hover {
    gap: 0.6rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--subheading-gray);
    font-size: 1.125rem;
  }

  .empty-state a {
    color: var(--brand-blue);
    font-weight: 600;
  }
</style>
