---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { glossaryEntries } from "../../data/glossary";

export const prerender = true;

export async function getStaticPaths() {
  return glossaryEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { term, slug, short, body, related = [] } = entry;

// Map slugs to EventHex feature pages
const featureLinks: Record<string, { href: string; label: string }> = {
  "event-ticketing-platform":       { href: "/event-ticketing/",           label: "Explore EventHex Ticketing" },
  "event-registration-software":    { href: "/event-registration/",        label: "Explore EventHex Registration" },
  "session-management":             { href: "/session-management/",        label: "Explore Session Management" },
  "ai-session-recap":               { href: "/ai-session-recap/",          label: "Explore AI Session Recap" },
  "white-label-event-platform":     { href: "/white-label/",               label: "Explore White-Label" },
  "whatsapp-event-marketing":       { href: "/whatsapp-event-concierge/",  label: "Explore WhatsApp Concierge" },
  "virtual-event-platform":         { href: "/virtual-hybrid-events/",     label: "Explore Virtual & Hybrid Events" },
  "hybrid-event":                   { href: "/virtual-hybrid-events/",     label: "Explore Hybrid Events" },
  "event-analytics":                { href: "/event-analytics/",           label: "Explore Event Analytics" },
  "event-check-in-software":        { href: "/event-check-in/",            label: "Explore Check-In Software" },
  "qr-code-check-in":               { href: "/event-check-in/",            label: "Explore QR Check-In" },
  "badge-printing":                 { href: "/badge-certificate-designer/", label: "Explore Badge & Certificate Designer" },
  "event-certificate":              { href: "/badge-certificate-designer/", label: "Explore Certificate Designer" },
  "event-gamification":             { href: "/event-gamification/",        label: "Explore Gamification" },
  "live-polling":                   { href: "/live-polling-qa/",           label: "Explore Live Polling & Q&A" },
  "event-app":                      { href: "/event-mobile-app/",          label: "Explore EventHex Mobile App" },
  "event-website-builder":          { href: "/event-website-builder/",     label: "Explore Event Website Builder" },
  "speaker-management":             { href: "/speaker-management/",        label: "Explore Speaker Management" },
  "exhibitor-management":           { href: "/exhibitor-management/",      label: "Explore Exhibitor Management" },
  "event-marketing-automation":     { href: "/event-marketing/",           label: "Explore Event Marketing" },
  "push-notifications-events":      { href: "/event-notifications/",       label: "Explore Event Notifications" },
  "ai-event-networking":            { href: "/enhance-networking-ai-smart-connect/", label: "Explore AI Smart Connect" },
  "event-management-software":      { href: "/event-management/",          label: "Explore EventHex Platform" },
  "sponsor-roi-report":             { href: "/sponsor-management/",        label: "Explore Sponsor Management" },
  "event-sponsorship":              { href: "/sponsor-management/",        label: "Explore Sponsor Management" },
  "event-sponsorship-tiers":        { href: "/sponsor-management/",        label: "Explore Sponsor Management" },
  "event-sponsorship-proposal":     { href: "/sponsor-management/",        label: "Explore Sponsor Management" },
  "event-lead-generation":          { href: "/event-check-in/",            label: "Explore Lead Capture" },
  "on-demand-recording":            { href: "/virtual-hybrid-events/",     label: "Explore On-Demand Content" },
  "webinar-platform":               { href: "/virtual-hybrid-events/",     label: "Explore Webinar Capabilities" },
  "conference-management-software": { href: "/event-management/",          label: "Explore Conference Tools" },
  "trade-show-management":          { href: "/exhibitor-management/",      label: "Explore Trade Show Tools" },
};

const featureLink = featureLinks[slug] ?? null;

// Resolve related entries
const relatedEntries = related
  .map((s) => glossaryEntries.find((e) => e.slug === s))
  .filter(Boolean) as typeof glossaryEntries;

const canonical = `https://eventhex.ai/glossary/${slug}/`;

const definedTermSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "@id": canonical,
  name: term,
  description: short,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    "@id": "https://eventhex.ai/glossary/",
    name: "Event Management Glossary",
  },
});
---

<MarketingLayout
  title={`${term} — Event Management Glossary | EventHex`}
  description={short.slice(0, 160).trimEnd()}
  canonical={canonical}
  footerCtaTitle="See EventHex in action"
  footerCtaButtonText="Book a Free Demo"
  footerCtaHref="/book-a-demo/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={definedTermSchema} />
  </Fragment>

  <!-- HERO -->
  <section class="gt-hero">
    <div class="gt-hero__inner">
      <nav class="gt-breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="gt-breadcrumb__link">Home</a>
        <span class="gt-breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/glossary/" class="gt-breadcrumb__link">Glossary</a>
        <span class="gt-breadcrumb__sep" aria-hidden="true">/</span>
        <span class="gt-breadcrumb__current">{term}</span>
      </nav>
      <h1 class="gt-hero__title">{term}</h1>
    </div>
  </section>

  <!-- MAIN CONTENT -->
  <section class="gt-body">
    <div class="gt-body__inner">

      <!-- Definition card -->
      <article class="gt-definition">
        <div class="gt-definition__body" set:html={body} />

        {featureLink && (
          <div class="gt-definition__feature-link">
            <a href={featureLink.href} class="gt-btn gt-btn--primary">
              {featureLink.label} &rarr;
            </a>
          </div>
        )}
      </article>

      <!-- Related terms -->
      {relatedEntries.length > 0 && (
        <aside class="gt-related">
          <h2 class="gt-related__heading">Related terms</h2>
          <ul class="gt-related__list">
            {relatedEntries.map((rel) => (
              <li>
                <a href={`/glossary/${rel.slug}/`} class="gt-related__link">
                  {rel.term}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}

      <!-- CTA -->
      <div class="gt-cta">
        <div class="gt-cta__card">
          <div class="gt-cta__glow gt-cta__glow--1"></div>
          <div class="gt-cta__glow gt-cta__glow--2"></div>
          <p class="gt-cta__eyebrow">EventHex</p>
          <h2 class="gt-cta__title">Put this into practice at your next event</h2>
          <p class="gt-cta__copy">
            EventHex is an all-in-one event management platform covering registration, ticketing, check-in, marketing, analytics, and more — everything in this glossary, in one place.
          </p>
          <div class="gt-cta__btns">
            <a href="/book-a-demo/" class="gt-btn gt-btn--white">Book a Free Demo</a>
            <a href="/glossary/" class="gt-btn gt-btn--ghost">Back to Glossary</a>
          </div>
        </div>
      </div>

    </div>
  </section>
</MarketingLayout>

<style>
  /* ── Hero ── */
  .gt-hero {
    background: linear-gradient(135deg, #f0f4ff 0%, #e8edff 50%, #f8f6ff 100%);
    padding: 5.5rem 1.5rem 3.5rem;
  }
  .gt-hero__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .gt-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--subheading-gray);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .gt-breadcrumb__link {
    color: var(--brand-blue);
    text-decoration: none;
    font-weight: 500;
  }
  .gt-breadcrumb__link:hover {
    text-decoration: underline;
  }
  .gt-breadcrumb__sep {
    color: var(--label-gray);
  }
  .gt-breadcrumb__current {
    color: var(--heading-dark);
    font-weight: 500;
  }
  .gt-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.18;
    color: var(--heading-dark);
    letter-spacing: -0.5px;
  }

  /* ── Body ── */
  .gt-body {
    background: #fff;
    padding: 3.5rem 1.5rem 5rem;
  }
  .gt-body__inner {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── Definition ── */
  .gt-definition {
    background: var(--surface-light);
    border: 1px solid var(--surface-card-border);
    border-radius: 20px;
    padding: 2.5rem;
  }
  .gt-definition__body {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--body-gray);
  }
  .gt-definition__body :global(p) {
    margin-bottom: 1.25rem;
  }
  .gt-definition__body :global(p:last-child) {
    margin-bottom: 0;
  }
  .gt-definition__feature-link {
    margin-top: 2rem;
  }

  /* ── Related ── */
  .gt-related {
    background: var(--surface-light);
    border: 1px solid var(--surface-card-border);
    border-radius: 16px;
    padding: 2rem 2.5rem;
  }
  .gt-related__heading {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8125rem;
  }
  .gt-related__list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
  .gt-related__link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--brand-blue);
    text-decoration: none;
    background: rgba(55, 93, 251, 0.07);
    border: 1px solid rgba(55, 93, 251, 0.18);
    border-radius: 8px;
    padding: 0.375rem 0.875rem;
    transition: background 0.18s, border-color 0.18s;
  }
  .gt-related__link:hover {
    background: rgba(55, 93, 251, 0.15);
    border-color: var(--brand-blue);
  }

  /* ── Buttons ── */
  .gt-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    padding: 0.75rem 1.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
  }
  .gt-btn--primary {
    background: var(--brand-blue);
    color: #fff;
  }
  .gt-btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
  }
  .gt-btn--white {
    background: #fff;
    color: var(--heading-dark);
  }
  .gt-btn--white:hover {
    background: #f0f4ff;
    transform: translateY(-1px);
  }
  .gt-btn--ghost {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .gt-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* ── CTA ── */
  .gt-cta__card {
    position: relative;
    background: linear-gradient(135deg, #1a1f4e 0%, #0f1225 100%);
    border-radius: 24px;
    padding: 3.5rem 3rem;
    text-align: center;
    overflow: hidden;
  }
  .gt-cta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .gt-cta__glow--1 {
    width: 280px;
    height: 280px;
    background: rgba(55, 93, 251, 0.3);
    top: -70px;
    right: -50px;
  }
  .gt-cta__glow--2 {
    width: 220px;
    height: 220px;
    background: rgba(159, 129, 255, 0.2);
    bottom: -50px;
    left: -30px;
  }
  .gt-cta__eyebrow {
    position: relative;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
  }
  .gt-cta__title {
    position: relative;
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }
  .gt-cta__copy {
    position: relative;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    max-width: 520px;
    margin: 0 auto 2rem;
  }
  .gt-cta__btns {
    position: relative;
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .gt-hero {
      padding: 5rem 1rem 2.5rem;
    }
    .gt-body {
      padding: 2.5rem 1rem 4rem;
    }
    .gt-definition {
      padding: 1.75rem 1.25rem;
    }
    .gt-related {
      padding: 1.5rem 1.25rem;
    }
    .gt-cta__card {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
