---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/features/"
  footerCtaTitle="See how 30+ features work together"
  footerCtaButtonText="Book a Free Demo"
  footerCtaHref="/book-a-demo/"
>
  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "EventHex Platform Features",
      "description": description,
      "numberOfItems": allFeatures.length,
      "itemListElement": allFeatures.map((f, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": f.name,
        "url": `https://eventhex.ai${f.href}`,
        "description": f.desc,
      })),
    })} />
  </slot>

  <!-- Hero -->
  <section class="fhub-hero">
    <div class="fhub-hero__container">
      <span class="fhub-hero__badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
        Platform Features
      </span>
      <h1 class="fhub-hero__title">Everything You Need to <span class="fhub-hero__accent">Manage Events</span></h1>
      <p class="fhub-hero__subtitle">From AI-powered networking to multi-channel marketing, EventHex gives you 30+ features to plan, promote, and execute events of any scale.</p>
      <a href="/book-a-demo/" class="fhub-hero__cta">Get a Free Demo</a>
    </div>
  </section>

  <!-- Feature Categories -->
  <section class="fhub-categories">
    <div class="fhub-categories__container">
      {categories.map((cat) => (
        <div class="fhub-cat">
          <div class="fhub-cat__header" style={`border-bottom-color: ${cat.color}`}>
            <span class="fhub-cat__icon" style={`background: ${cat.color}15; color: ${cat.color}`} set:html={iconForCategory[cat.title]} />
            <h2 class="fhub-cat__title">{cat.title}</h2>
          </div>
          <div class="fhub-cat__grid">
            {cat.features.map((feat) => (
              <a href={feat.href} class="fhub-card" data-color={cat.color}>
                <div class="fhub-card__icon" style={`background: ${cat.color}12; color: ${cat.color}`} set:html={featureIcons[feat.name] || ""} />
                <div class="fhub-card__body">
                  <h3 class="fhub-card__title">{feat.name}</h3>
                  <p class="fhub-card__desc">{feat.desc}</p>
                  <span class="fhub-card__link" style={`color: ${cat.color}`}>Learn more &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</MarketingLayout>

<style>
  /* ── Hero ──────────────────────────────────────────── */
  .fhub-hero {
    background: linear-gradient(180deg, #F8FAFF 0%, #FFFFFF 100%);
    padding: 100px 24px 72px;
    text-align: center;
  }
  .fhub-hero__container {
    max-width: 760px;
    margin: 0 auto;
  }
  .fhub-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.08);
    color: #6366F1;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 20px;
  }
  .fhub-hero__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 800;
    line-height: 1.15;
    color: var(--heading-dark, #0F172A);
    margin-bottom: 20px;
  }
  .fhub-hero__accent {
    color: var(--brand-blue, #4A6CF7);
  }
  .fhub-hero__subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.7;
    color: #64748B;
    max-width: 640px;
    margin: 0 auto 32px;
  }
  .fhub-hero__cta {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 10px;
    background: var(--brand-blue, #4A6CF7);
    color: #fff;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .fhub-hero__cta:hover {
    background: #3B5DE7;
    transform: translateY(-1px);
  }

  /* ── Categories Section ────────────────────────────── */
  .fhub-categories {
    padding: 0 24px 96px;
    background: #fff;
  }
  .fhub-categories__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── Category Block ────────────────────────────────── */
  .fhub-cat__header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 14px;
    border-bottom: 2px solid #E5EBFF;
    margin-bottom: 28px;
  }
  .fhub-cat__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    flex-shrink: 0;
  }
  .fhub-cat__title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 600;
    color: var(--heading-dark, #0F172A);
  }

  /* ── Card Grid ─────────────────────────────────────── */
  .fhub-cat__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 20px;
  }

  /* ── Feature Card ──────────────────────────────────── */
  .fhub-card {
    display: flex;
    gap: 16px;
    padding: 24px;
    background: #fff;
    border: 1px solid #EEF2F6;
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.25s, transform 0.2s, border-left-color 0.2s;
    border-left: 3px solid transparent;
  }
  .fhub-card:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07);
    transform: translateY(-3px);
  }
  .fhub-card[data-color="#6366F1"]:hover { border-left-color: #6366F1; }
  .fhub-card[data-color="#EC4899"]:hover { border-left-color: #EC4899; }
  .fhub-card[data-color="#EF4444"]:hover { border-left-color: #EF4444; }
  .fhub-card[data-color="#F59E0B"]:hover { border-left-color: #F59E0B; }

  .fhub-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    min-width: 46px;
    border-radius: 12px;
    flex-shrink: 0;
  }
  .fhub-card__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .fhub-card__title {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    color: var(--heading-dark, #0F172A);
  }
  .fhub-card__desc {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: #64748B;
  }
  .fhub-card__link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    margin-top: 4px;
    transition: gap 0.2s;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 1024px) {
    .fhub-hero__title { font-size: 38px; }
    .fhub-cat__title { font-size: 24px; }
    .fhub-cat__grid { grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
  }
  @media (max-width: 767px) {
    .fhub-hero { padding: 80px 16px 56px; }
    .fhub-hero__title { font-size: 30px; }
    .fhub-hero__subtitle { font-size: 16px; }
    .fhub-categories { padding: 0 16px 64px; }
    .fhub-categories__container { gap: 48px; }
    .fhub-cat__title { font-size: 22px; }
    .fhub-cat__grid { grid-template-columns: 1fr; gap: 14px; }
    .fhub-card { padding: 18px; gap: 12px; }
    .fhub-card__icon { width: 40px; height: 40px; min-width: 40px; }
  }
</style>
