---
import MarketingLayout from "../layouts/MarketingLayout.astro";

const title = "EventHex Platform Features — 30+ Event Management Tools";
const description = "From AI-powered networking to multi-channel marketing, EventHex gives you 30+ features to plan, promote, and execute events of any scale.";

interface FeatureItem {
  name: string;
  href: string;
  desc: string;
}

interface FeatureCategory {
  title: string;
  color: string;
  features: FeatureItem[];
}

const categories: FeatureCategory[] = [
  {
    title: "Event Planning & Operations",
    color: "#6366F1",
    features: [
      { name: "Speaker Management", href: "/speaker-management/", desc: "AI LinkedIn import, speaker profiles, session scheduling, live engagement tools, and InstaRecap transcription." },
      { name: "Session Management", href: "/session-management/", desc: "Visual timeline scheduling, multi-track agendas, sub-sessions, capacity controls, and live engagement tools." },
      { name: "Event Ticketing", href: "/event-ticketing/", desc: "Multi-ticket checkouts, 0% platform fees with your own payment gateway, QR-coded tickets, and badge printing." },
      { name: "Event Registration", href: "/event-registration/", desc: "Registration tracking, attendee type management, waitlist approvals, payment monitoring, and check-in data." },
      { name: "Centralized Dashboard", href: "/centralized-dashboard/", desc: "Unified view of all events, real-time analytics, unlimited events and attendees, and cross-event reporting." },
      { name: "Event Check-In", href: "/event-check-in/", desc: "QR code scanning, facial recognition, self-service kiosks, and real-time attendance analytics." },
      { name: "Call for Papers", href: "/call-for-papers/", desc: "Submission portal, peer review, rubric scoring, acceptance workflows, and proceedings export." },
      { name: "Event Payment Processing", href: "/event-payment-processing/", desc: "Accept payments via Stripe, Razorpay, or Tap with zero EventHex platform fees." },
    ],
  },
  {
    title: "AI-Powered Features",
    color: "#EC4899",
    features: [
      { name: "AI Smart-Connect", href: "/enhance-networking-ai-smart-connect/", desc: "AI-powered attendee matchmaking, interest-based networking, meeting scheduling, and conversation starters." },
      { name: "AI Form Builder", href: "/ai-form-builder/", desc: "Voice-powered form creation, customizable fields, approval workflows, and CAPTCHA protection." },
      { name: "AI Session Recap", href: "/ai-session-recap/", desc: "Real-time transcription, AI summaries, searchable recap pages, and attendee analytics." },
      { name: "AI Photo Gallery", href: "/ai-photo-gallery/", desc: "Face-matching photo gallery with real-time tagging and branded sharing." },
      { name: "AI Event Copilot", href: "/ai-event-copilot/", desc: "Four AI agents: Analyst, Session Builder, Copywriter, and Ticket Agent for automated event operations." },
    ],
  },
  {
    title: "Marketing & Engagement",
    color: "#EF4444",
    features: [
      { name: "Event Marketing", href: "/event-marketing/", desc: "Email and WhatsApp campaigns, audience segmentation, advocacy posters, and delivery tracking." },
      { name: "Event Notifications", href: "/event-notifications/", desc: "Multi-channel notifications via email, WhatsApp, push, and SMS with automated triggers." },
      { name: "Live Polling & Q&A", href: "/live-polling-qa/", desc: "Live audience polls, Q&A moderation, session feedback, and engagement analytics." },
      { name: "Event Gamification", href: "/event-gamification/", desc: "Points, badges, leaderboards, challenges, and prize distribution for attendee engagement." },
      { name: "Badge & Certificate Designer", href: "/badge-certificate-designer/", desc: "Visual badge editor, on-site printing, and automated certificate generation." },
      { name: "Event Website Builder", href: "/event-website-builder/", desc: "Drag-and-drop event website builder with custom domains and responsive templates." },
      { name: "Event Mobile App", href: "/event-mobile-app/", desc: "White-label mobile app with agenda, networking, notifications, and offline access." },
    ],
  },
  {
    title: "Sponsors & Exhibitors",
    color: "#F59E0B",
    features: [
      { name: "Sponsor Management", href: "/sponsor-management/", desc: "Tiered sponsor profiles, multi-channel visibility, self-service portals, and ROI analytics." },
      { name: "Exhibitor Management", href: "/exhibitor-management/", desc: "Exhibitor profiles, booth allocation, booth member management, and dedicated exhibitor portals." },
      { name: "Partnership", href: "/partnership/", desc: "Partner programme management, co-branded events, and revenue sharing." },
    ],
  },
];

const allFeatures = categories.flatMap((c) => c.features);

const iconForCategory: Record<string, string> = {
  "Event Planning & Operations": `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  "AI-Powered Features": `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4c0 1.5-.8 2.8-2 3.4V11h3a3 3 0 0 1 3 3v1.5a2.5 2.5 0 0 1-5 0V14H9v1.5a2.5 2.5 0 0 1-5 0V14a3 3 0 0 1 3-3h3V9.4A4 4 0 0 1 12 2z"/><circle cx="12" cy="6" r="1"/></svg>`,
  "Marketing & Engagement": `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  "Sponsors & Exhibitors": `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
