---
import MarketingLayout from "../layouts/MarketingLayout.astro";

// Import speaker management section components
import HeroSection from "../components/speaker-management/HeroSection.astro";
import StatsSection from "../components/speaker-management/StatsSection.astro";
import BentoGrid from "../components/speaker-management/BentoGrid.astro";
import FeatureCards from "../components/speaker-management/FeatureCards.astro";
import CoordinationTools from "../components/speaker-management/CoordinationTools.astro";
import CTASection from "../components/speaker-management/CTASection.astro";
import FaqSection from "../components/speaker-management/FaqSection.astro";

const title = "Speaker Management Software for Events | AI-Powered | EventHex";
const description = "Manage speakers, sessions, and audience engagement with AI-powered tools. LinkedIn imports, visual timeline scheduling, live polls, Q&A, and InstaRecap transcription in one event workflow.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "EventHex Speaker Management",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": description,
  "url": "https://eventhex.ai/speaker-management/",
  "creator": {
    "@type": "Organization",
    "name": "EventHex",
    "url": "https://eventhex.ai"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Free demo available"
  },
  "featureList": [
    "AI LinkedIn speaker import",
    "Visual session timeline scheduling",
    "Live audience polls and Q&A",
    "InstaRecap AI transcription",
    "Multi-stage conference management",
    "Speaker communication automation"
  ]
};
---

<MarketingLayout
  {title}
  {description}
  canonical="https://eventhex.ai/speaker-management/"
  ogImage="https://eventhex.ai/wp-content/uploads/2025/03/Untitled-design-11-1024x576.webp"
>
  <!-- Hero: Full-width centered with bg images (matches home pattern) -->
  <HeroSection />

  <!-- Dark showcase: Dashboard image + stats + engagement text -->
  <StatsSection />

  <!-- Tabbed bento grid: Speaker Setup, Sessions, Engagement -->
  <BentoGrid />

  <!-- Stacking cards: Key features deep-dive on dark bg -->
  <FeatureCards />

  <!-- CTA: Dark gradient with trust signals -->
  <CTASection />

  <!-- Coordination tools: Dark card with glassmorphism -->
  <CoordinationTools />

  <!-- FAQ: SEO with JSON-LD structured data -->
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>