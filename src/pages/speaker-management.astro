---
import MarketingLayout from "../layouts/MarketingLayout.astro";

// Import all speaker management section components
import HeroSection from "../components/speaker-management/HeroSection.astro";
import StatsSection from "../components/speaker-management/StatsSection.astro";
import SpeakerProfiles from "../components/speaker-management/SpeakerProfiles.astro";
import BentoGrid from "../components/speaker-management/BentoGrid.astro";
import SessionScheduling from "../components/speaker-management/SessionScheduling.astro";
import CoordinationTools from "../components/speaker-management/CoordinationTools.astro";
import AudienceInteraction from "../components/speaker-management/AudienceInteraction.astro";
import InstaRecap from "../components/speaker-management/InstaRecap.astro";
import CTASection from "../components/speaker-management/CTASection.astro";
import DisplayStyles from "../components/speaker-management/DisplayStyles.astro";

const title = "Speaker Management - AI-Powered Speaker & Session Management | EventHex";
const description = "Manage speakers, sessions, and audience engagement with AI-powered tools. From LinkedIn imports to live polls and InstaRecap transcription—EventHex centralizes speaker coordination.";
---

<MarketingLayout {title} {description}>
  <!-- Section 0: Hero Banner -->
  <HeroSection />

  <!-- Section 1: Key Stats -->
  <StatsSection />

  <!-- Section 2: Speaker Profiles & AI LinkedIn Import -->
  <SpeakerProfiles />

  <!-- Section 3: Tabbed Feature Grid (Speaker Setup, Sessions, Engagement) -->
  <BentoGrid />

  <!-- Section 4: Session Scheduling with Timeline View -->
  <SessionScheduling />

  <!-- Section 5: Speaker Coordination Tools -->
  <CoordinationTools />

  <!-- Section 6: Real-time Audience Engagement Tools -->
  <AudienceInteraction />

  <!-- Section 7: AI Transcription & Summaries (InstaRecap) -->
  <InstaRecap />

  <!-- Section 8: Call-to-Action -->
  <CTASection />

  <!-- Section 9: Speaker Display Styles for Event Website -->
  <DisplayStyles />
</MarketingLayout>

<style>
  /* Global page-level spacing and layout orchestration */
  /* Component-specific styles are scoped within each component file */
  
  :global(main) {
    background-color: #ffffff;
  }

  /* Ensure consistent spacing between major sections */
  /* Each section handles its own internal padding via .sm-*__section or .sm-*-padding */
  
  /* Responsive adjustments for section interactions */
  @media (max-width: 1024px) {
    /* Tablet adjustments handled per-component */
  }

  @media (max-width: 767px) {
    /* Mobile adjustments handled per-component */
  }
</style>