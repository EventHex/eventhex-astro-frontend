---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-ticketing/HeroSection.astro";
import BentoGridSection from "../components/event-ticketing/BentoGridSection.astro";
import FeatureCardsSection from "../components/event-ticketing/FeatureCardsSection.astro";
import CTASection from "../components/event-ticketing/CTASection.astro";
import BenefitCardsSection from "../components/event-ticketing/BenefitCardsSection.astro";
import FaqLightSection from "../components/event-ticketing/FaqLightSection.astro";
import MobileCtaBar from "../components/event-ticketing/MobileCtaBar.astro";

const title = "Event Ticketing Software for Organizers | EventHex";
const description = "Launch branded event ticketing flows, route payments securely, manage waitlists, and move attendees from checkout to check-in without friction.";

const benefitCards = [
  [
    {
      title: "Versatile Platform",
      desc: "Manage events of any size with customizable event ticketing and registration.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Frame-1000002870.svg",
    },
    {
      title: "Brand First",
      desc: "Customize tickets with your logos and branding to give a professional outlook.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Frame-1000002870-1.svg",
    },
    {
      title: "Affordable Pricing",
      desc: "Save costs when using your own payment gateway and keep all the profit to yourself.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Frame-1000002870-2.svg",
    },
  ],
  [
    {
      title: "Easy Integrations",
      desc: "Sync with your event workflow to better manage and update the incoming attendee.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Frame-1000002870-3.svg",
    },
    {
      title: "Mobile Access",
      desc: "Our event ticketing app works seamlessly for attendees right on-the-go.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Frame-1000002870-4.svg",
    },
  ],
];

const faqItems = [
  {
    question: "Can I create multiple ticket types for the same event?",
    answerHtml: "<p>Yes. EventHex lets you create different ticket classes such as early-bird, VIP, group bundles, sponsor passes, or invite-only registrations. You can set different prices, capacities, access rules, and branding for each tier without building separate flows.</p>",
  },
  {
    question: "Can I use my own payment gateway?",
    answerHtml: "<p>Yes. You can connect your preferred payment gateway and keep full control over payouts, fees, and settlement timing. If you want a faster setup, EventHex can also support you with a competitive default payment flow.</p>",
  },
  {
    question: "Does EventHex support QR check-in and badge printing?",
    answerHtml: "<p>It does. Each ticket can be paired with a QR-based entry workflow so your team can scan guests on arrival, validate access quickly, and connect the same registration flow to badge printing for a smoother on-site experience.</p>",
  },
  {
    question: "Can I hold registrations for approval or waitlist them?",
    answerHtml: "<p>Yes. EventHex supports approval-based workflows and waitlists, which is especially useful for curated events, premium access, or limited-capacity ticket classes. Your team can review requests, approve attendees, and keep communication organized from one dashboard.</p>",
  },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Ticketing",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/event-ticketing/",
  description: description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free plan available — 0% platform fee with your own payment gateway",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "320",
    bestRating: "5",
  },
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-ticketing/"
  ogImage="https://cms.eventhex.ai/wp-content/uploads/2025/04/eventticketing.png"
  footerCtaTitle={"Upgrade Your Event\nTicketing System Today"}
  footerCtaButtonText="Get a demo"
  footerCtaHref="/book-a-demo/"
>
  <HeroSection
    eyebrow="Event Ticketing"
    titleHtml="Sell Smarter, Scan Faster, and Maximise <b>Revenue</b> with <b>Event Ticketing Software</b>"
    description={description}
    ctaText="Get a demo"
    ctaHref="/book-a-demo/"
    image="https://cms.eventhex.ai/wp-content/uploads/2025/04/eventticketing.png"
    imageAlt="EventHex event ticketing dashboard"
  />

  <BentoGridSection />

  <FeatureCardsSection />

  <CTASection />

  <BenefitCardsSection
    title="Why EventHex is Your Best Event Ticketing Solution"
    rows={benefitCards}
  />

  <FaqLightSection title="FAQ" items={faqItems} />

  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(softwareSchema)}</script>`} />

  <MobileCtaBar
    primaryHref="/book-a-demo/"
    primaryText="Get a demo"
    secondaryHref="#ticket-pricing"
    secondaryText="Pricing"
  />
</MarketingLayout>

<style is:global>
  html { scroll-behavior: smooth; }
  main { background-color: #ffffff; }
