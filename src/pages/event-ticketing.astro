---

<MarketingLayout
  title={title}
  description={description}
  footerCtaTitle={"Upgrade Your Event\nTicketing System Today"}
  footerCtaButtonText="Get a demo"
  footerCtaHref="/book-a-demo/"
>
  <div class="ticket-page">
    <HeroSection
      eyebrow="Event Ticketing"
      titleHtml="Sell Smarter, Scan Faster, and Maximise <b>Revenue</b> with <b>Event Ticketing Software</b>"
      description={description}
      ctaText="Get a demo"
      ctaHref="/book-a-demo/"
      image="https://eventhex.ai/wp-content/uploads/2025/04/eventticketing.png"
      imageAlt="EventHex event ticketing dashboard"
    />

    <PricingCalculatorSection ctaHref="/book-a-demo/" />

    <!-- Features intro header -->
    <div class="ticket-features-hd animate-on-scroll" data-animation="fadeInUp" style="--anim-duration:700ms">
      <span class="ticket-features-hd__eyebrow">Flow-by-flow</span>
      <h2 class="ticket-features-hd__title">Everything Built Into One Ticketing Platform</h2>
      <p class="ticket-features-hd__sub">From checkout to check-in — every step of the ticketing journey, handled.</p>
    </div>

    {splitSections.map((section, index) => (
      <FeatureSplitSection {...section} sectionNumber={index + 1} />
    ))}

    <BulkImportSection
      title="Bulk Import and Waitlist Management"
      cards={bulkCards}
    />

    <BenefitsSection
      title="Why EventHex is Your Best Event Ticketing Solution"
      rows={benefitRows}
    />

    <FaqSection title="FAQ" items={faqItems} />
    <MobileCtaBar
      primaryHref="/book-a-demo/"
      primaryText="Get a demo"
      secondaryHref="#ticket-pricing"
      secondaryText="Pricing"
    />
  </div>
</MarketingLayout>

<script>
  const tiltCards = Array.from(document.querySelectorAll("[data-ticket-tilt-card]")) as HTMLElement[];
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (!prefersReducedMotion.matches) {
    tiltCards.forEach((card) => {
      const resetTilt = () => {
        card.style.setProperty("--tilt-rotate-x", "0deg");
        card.style.setProperty("--tilt-rotate-y", "0deg");
      };

      card.addEventListener("mousemove", (event) => {
        if (window.innerWidth <= 767) return;

        const rect = card.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width;
        const y = (event.clientY - rect.top) / rect.height;
        const rotateY = (x - 0.5) * 8;
        const rotateX = (0.5 - y) * 8;

        card.style.setProperty("--tilt-rotate-x", `${rotateX.toFixed(2)}deg`);
        card.style.setProperty("--tilt-rotate-y", `${rotateY.toFixed(2)}deg`);
      });

      card.addEventListener("mouseleave", resetTilt);
      card.addEventListener("blur", resetTilt);
    });
  }
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  .ticket-page {
    background:
      radial-gradient(circle at top left, rgba(55, 93, 251, 0.06), transparent 20%),
      radial-gradient(circle at 90% 12%, rgba(186, 160, 255, 0.08), transparent 18%),
      #fff;
  }

  /* Features section introduction */
  .ticket-features-hd {
    max-width: 760px;
    margin: 60px auto 12px;
    padding: 0 24px;
    text-align: center;
  }

  .ticket-features-hd__eyebrow {
    display: inline-flex;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(55, 93, 251, 0.1);
    border: 1px solid rgba(55, 93, 251, 0.16);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--brand-blue);
  }

  .ticket-features-hd__title {
    margin-top: 16px;
    font-family: var(--font-heading);
    font-size: 48px;
    line-height: 1.06;
    font-weight: 700;
    letter-spacing: -1.4px;
    color: var(--heading-dark);
  }

  .ticket-features-hd__sub {
    margin-top: 14px;
    font-size: 18px;
    line-height: 1.7;
    color: var(--subheading-gray);
  }

  @media (max-width: 767px) {
    .ticket-features-hd { margin-top: 40px; }
    .ticket-features-hd__title { font-size: 30px; }
    .ticket-features-hd__sub { font-size: 16px; }
  }
</style>
