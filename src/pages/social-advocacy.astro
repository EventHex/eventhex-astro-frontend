---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ICONS } from "../lib/featureIcons";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Social Advocacy & Attendee Sharing",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Turn attendees into event promoters — auto-generated branded share posters, AI social copy, trackable share links, and share analytics that drive registrations via word-of-mouth.",
  url: "https://eventhex.ai/social-advocacy/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Auto-Generated Branded Share Posters",
    "AI-Generated Social Copy",
    "Trackable Share Links",
    "Share Analytics",
    "Attendee Advocacy Campaigns",
    "Word-of-Mouth Registration Growth",
    "Per-Attendee Personalized Posters",
    "Social Platform Optimized Formats",
    "Campaign Performance Reporting",
  ],
};
---

<FeatureV2Layout
  pageTitle="Event Social Sharing & Attendee Advocacy Software | EventHex"
  pageDescription="Turn every attendee into an event promoter — auto-generated branded share posters, AI social copy, trackable share links, and analytics that show which shares drive the most registrations."
  canonical="https://eventhex.ai/social-advocacy/"
  badge="Social Advocacy & Sharing"
  heroTitleLine1="Turn Every Attendee Into"
  heroTitleLine2="Your Best Promoter"
  heroCopy="EventHex auto-generates a personalized branded share poster for every attendee, pairs it with AI-written social copy, and tracks every share back to registrations — turning word-of-mouth from a nice-to-have into a measurable growth channel."
  trustItems={["Auto-Generated Branded Posters", "AI Social Copy", "Trackable Share Links"]}
  stats={[
    { value: "1:1", label: "Poster per Attendee" },
    { value: "AI", label: "Generated Social Copy" },
    { value: "100%", label: "Shares Tracked" },
    { value: "∞", label: "Word-of-Mouth Reach" },
  ]}
  statsHeadline={{
    white1: "Every share",
    accent: "branded.",
    white2: "Every click",
    accent2: "tracked.",
  }}
  bentoHeading="Everything You Need to Drive Attendee Advocacy"
  bentoSubtitle="From auto-generated share posters to trackable referral links and campaign analytics — EventHex gives every attendee the tools to promote your event and gives you the data to know exactly which shares are driving registrations."
  bentoTabs={[
    {
      tab: "Branded Share Posters",
      cards: [
        { title: "Auto-Generated per Attendee", desc: "EventHex creates a personalized branded poster for every registered attendee — no design work required", illustration: ILLOS.poster },
        { title: "Your Event Branding", desc: "Posters use your event's logo, colors, and imagery to create a consistent, professional look across every share", illustration: ILLOS.palette },
        { title: "Attendee Name on Poster", desc: "Each poster is personalized with the attendee's name — making it more likely they'll share it proudly", illustration: ILLOS.user },
        { title: "Social Format Optimization", desc: "Posters are generated in the correct dimensions for Instagram, LinkedIn, Twitter/X, Facebook, and WhatsApp", illustration: ILLOS.camera },
        { title: "One-Tap Download & Share", desc: "Attendees download or share their poster directly from the event app or registration confirmation page", illustration: ILLOS.share },
      ],
    },
    {
      tab: "AI Social Copy",
      cards: [
        { title: "AI-Generated Captions", desc: "EventHex writes ready-to-post social captions for each attendee — personalized, on-brand, and platform-appropriate", illustration: ILLOS.bot },
        { title: "Platform-Specific Tone", desc: "LinkedIn copy sounds professional; Instagram copy is conversational — AI adapts the tone automatically", illustration: ILLOS.chatform },
        { title: "Event Hashtag Integration", desc: "Your event's hashtags are woven into every AI-generated caption so all social posts amplify a single campaign thread", illustration: ILLOS.broadcast },
        { title: "Editable Before Sharing", desc: "Attendees can review and edit AI-generated copy before posting — keeping their voice while saving them the effort", illustration: ILLOS.document },
        { title: "Multi-Language Support", desc: "AI copy is generated in the attendee's preferred language for international events and diverse audiences", illustration: ILLOS.globe },
      ],
    },
    {
      tab: "Share Analytics",
      cards: [
        { title: "Trackable Share Links", desc: "Every attendee gets a unique trackable share link tied to their registration — clicks and conversions are attributed back to them", illustration: ILLOS.share },
        { title: "Registration Attribution", desc: "See which shares led to actual registrations — know your top advocates by name and channel", illustration: ILLOS.chart },
        { title: "Channel Performance", desc: "Track which social platforms are driving the most clicks and conversions from your advocacy campaign", illustration: ILLOS.trend },
        { title: "Campaign Dashboard", desc: "Live dashboard showing total shares, link clicks, registrations from shares, and top-performing advocates", illustration: ILLOS.dashboard },
        { title: "Advocacy Leaderboard", desc: "Optional leaderboard gamifies sharing — your most active advocates can earn recognition or rewards", illustration: ILLOS.chart },
      ],
    },
  ]}
  stackingHeading="Advocacy Features That"
  stackingHighlight="Drive Real Registrations"
  stackingCards={[
    {
      title: "Every Attendee Gets a Poster Worth Sharing",
      desc: "The moment an attendee registers, EventHex auto-generates a personalized branded poster with their name, your event branding, and the right dimensions for every social platform. No design team needed — just high-quality assets at scale.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Auto-generated branded share poster displayed on a tablet",
    },
    {
      title: "AI Social Copy Makes Sharing Effortless",
      desc: "Most attendees want to share — they just don't want to write the caption. EventHex generates platform-appropriate, on-brand social copy for each attendee, complete with your event hashtags. One tap to post.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "AI-generated social copy for event sharing on a tablet",
    },
    {
      title: "Track Every Share Back to a Registration",
      desc: "Every share link is unique to the attendee. EventHex tracks clicks, platform performance, and registration conversions in real time — so you know exactly which advocates are driving growth and which channels are working.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Share analytics and advocacy campaign dashboard on a tablet",
    },
  ]}
  howItWorksHeading="How Attendee Advocacy Works"
  steps={[
    { title: "Set Up Your Advocacy Campaign", desc: "Configure your event branding, hashtags, and campaign goal. EventHex handles the poster templates and AI copy prompts automatically." },
    { title: "Attendees Get Their Personal Share Pack", desc: "After registering, every attendee receives their personalized branded poster and AI-generated captions — ready to share on any social platform." },
    { title: "Shares Go Out With Trackable Links", desc: "Each shared post contains the attendee's unique trackable link. Every click is logged and every registration from that link is attributed." },
    { title: "Track Performance in Real Time", desc: "Monitor total shares, clicks, channel performance, and registrations from advocacy in your live campaign dashboard." },
  ]}
  ctaTitle="Ready to Turn Your Attendees Into a Marketing Team?"
  ctaCopy="See how EventHex transforms word-of-mouth from untracked noise into a measurable channel that drives real event registrations."
  whyHeading="Why Organizers Choose EventHex for Social Advocacy"
  whyCards={[
    { title: "Auto-Generated Posters", desc: "Branded, personalized share posters for every attendee — zero design effort", icon: ICONS.image },
    { title: "AI Social Copy", desc: "Platform-specific captions written by AI — attendees share in seconds", icon: ICONS.chat },
    { title: "Full Attribution", desc: "Every share tracked back to the attendee and channel that drove it", icon: ICONS.link },
    { title: "Registration Growth", desc: "Word-of-mouth shares that convert directly to new registrations", icon: ICONS.trendingup },
    { title: "Campaign Analytics", desc: "Live dashboard with share counts, clicks, and conversion rates by channel", icon: ICONS.chart },
  ]}
  faqs={[
    { q: "What is event social advocacy?", a: "Event social advocacy turns registered attendees into promoters of your event. EventHex auto-generates a personalized branded share poster and AI-written social captions for each attendee. When they share on social media, their unique trackable link attributes any resulting registrations back to them." },
    { q: "How are share posters generated?", a: "As soon as someone registers, EventHex automatically generates a personalized branded poster using your event's logo, colors, and imagery — with the attendee's name included. Posters are created in the correct dimensions for all major social platforms. No design work is required from you or the attendee." },
    { q: "What does AI-generated social copy do?", a: "EventHex's AI writes ready-to-post captions for each attendee, tailored to the tone of each social platform (professional for LinkedIn, conversational for Instagram). Your event hashtags are included automatically. Attendees can edit the copy before sharing if they want to add their own voice." },
    { q: "How do trackable share links work?", a: "Each attendee receives a unique share link tied to their registration. When they share that link and someone clicks through to register, the registration is attributed to that attendee. You can see exactly which advocates are driving the most new registrations in your campaign dashboard." },
    { q: "Which social platforms are supported?", a: "Share posters are generated in the correct dimensions for Instagram, LinkedIn, Twitter/X, Facebook, and WhatsApp. AI copy is tailored for each platform. Attendees can share to any platform from the event app or their registration confirmation page." },
    { q: "Can I see which channels are performing best?", a: "Yes. The advocacy campaign dashboard shows share counts, link clicks, and registration conversions broken down by social platform — so you know whether LinkedIn, Instagram, or WhatsApp is driving the most value for your specific event audience." },
  ]}
  jsonLd={jsonLd}
/>
