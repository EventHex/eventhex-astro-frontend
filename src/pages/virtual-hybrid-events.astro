---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ICONS } from "../lib/featureIcons";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Virtual & Hybrid Event Platform",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Run virtual and hybrid events with meeting bots that auto-join Zoom, Google Meet, and Teams — recording, transcribing, live streaming, and unifying in-person and remote attendees in one platform.",
  url: "https://eventhex.ai/virtual-hybrid-events/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Meeting Bot Auto-Join (Zoom, Google Meet, Microsoft Teams)",
    "Session Recording & Transcription",
    "Live Captions & Translation",
    "RTMP & YouTube Live Streaming",
    "Multi-Provider Speech-to-Text (Deepgram, Google, Speechmatics, Soniox)",
    "Speaker Timeline & Key Insights",
    "Hybrid Check-In",
    "No Attendee App Required",
  ],
};
---

<FeatureV2Layout
  pageTitle="Virtual & Hybrid Event Platform — Stream, Transcribe, Unify | EventHex"
  pageDescription="Run virtual and hybrid events with meeting bots that auto-join Zoom, Google Meet, and Teams — recording, transcribing, live streaming, and unifying in-person and remote attendees in one platform."
  canonical="https://eventhex.ai/virtual-hybrid-events/"
  badge="Virtual & Hybrid Event Software"
  heroTitleLine1="Virtual and Hybrid Events,"
  heroTitleLine2="Without the Complexity"
  heroCopy="Meeting bots auto-join Zoom, Google Meet, and Microsoft Teams — recording every session, streaming live, and transcribing in real time — so your team runs powerful virtual and hybrid events without forcing attendees into yet another app."
  trustItems={["Zoom · Google Meet · Microsoft Teams", "Live Captions & Translation", "RTMP & YouTube Streaming"]}
  stats={[
    { value: "3", label: "Platforms Auto-Joined" },
    { value: "4", label: "Speech-to-Text Providers" },
    { value: "0", label: "Forced Attendee Apps" },
    { value: "100%", label: "Sessions Recorded" },
  ]}
  statsHeadline={{
    white1: "Every session.",
    accent: "Every word.",
    white2: "Captured across",
    accent2: "every platform",
  }}
  bentoHeading="One Platform for Virtual and Hybrid Events"
  bentoSubtitle="From auto-joining your Zoom call to streaming on YouTube Live and generating transcripts — EventHex connects all the pieces so your team focuses on content, not infrastructure."
  bentoTabs={[
    {
      tab: "Virtual Hosting",
      cards: [
        { title: "Meeting Bot Auto-Join", desc: "Bots join Zoom, Google Meet, and Microsoft Teams automatically — no manual dial-in, no host coordination", illustration: ILLOS.video },
        { title: "Session Recording", desc: "Every session is captured in full and stored for post-event access, sharing, and repurposing", illustration: ILLOS.mic },
        { title: "Speaker Timeline", desc: "Automatically maps who spoke when, with timestamps and highlighted key moments", illustration: ILLOS.chart },
        { title: "Key Insights Extraction", desc: "Surface action items, topics, and highlights without watching hours of footage", illustration: ILLOS.document },
        { title: "Hybrid Check-In", desc: "Unified attendee tracking for in-person and virtual participants under one event dashboard", illustration: ILLOS.network },
      ],
    },
    {
      tab: "Live Streaming",
      cards: [
        { title: "RTMP Streaming", desc: "Push your session to any RTMP destination — YouTube Live, LinkedIn, Facebook, or a custom endpoint", illustration: ILLOS.stream },
        { title: "YouTube Live Integration", desc: "One-click connection to stream directly to your YouTube channel without leaving EventHex", illustration: ILLOS.video },
        { title: "Multi-Destination Output", desc: "Stream to multiple platforms simultaneously to maximise your live audience reach", illustration: ILLOS.globe },
        { title: "Stream Health Monitoring", desc: "Real-time alerts on bitrate, drop frames, and connection stability during live sessions", illustration: ILLOS.dashboard },
        { title: "On-Demand Replay", desc: "Recordings become on-demand content immediately after the session ends", illustration: ILLOS.refresh },
      ],
    },
    {
      tab: "Transcription & Captions",
      cards: [
        { title: "Live Transcription", desc: "Real-time transcription powered by Deepgram, Google, Speechmatics, or Soniox — choose your preferred provider", illustration: ILLOS.mic },
        { title: "Live Captions", desc: "Accessible captions displayed to attendees in real time across virtual and hybrid sessions", illustration: ILLOS.captions },
        { title: "Live Translation", desc: "Translate captions into attendees' languages on the fly — no post-processing delay", illustration: ILLOS.translate },
        { title: "Full Session Transcript", desc: "Searchable, speaker-attributed transcript ready within minutes of session end", illustration: ILLOS.document },
        { title: "Multi-Language Support", desc: "Support global audiences with captions and transcripts in multiple languages simultaneously", illustration: ILLOS.globe },
      ],
    },
  ]}
  stackingHeading="Virtual & Hybrid Features"
  stackingHighlight="Built for Real Events"
  stackingCards={[
    {
      title: "Bots That Join So You Don't Have To",
      desc: "EventHex meeting bots (powered by Recall.ai and Vexa) auto-join your scheduled Zoom, Google Meet, or Microsoft Teams call — recording, transcribing, and feeding the live stream without anyone manually starting a recording or screen share.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Meeting bot auto-joining a Zoom call and starting session recording",
    },
    {
      title: "Live Captions and Translation for Every Attendee",
      desc: "Live transcription from multiple speech-to-text providers (Deepgram, Google, Speechmatics, Soniox) feeds captions directly to your event interface. Attendees in different countries read captions in their own language — with no post-event processing lag.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Live captions and translation displayed during a virtual event session",
    },
    {
      title: "One Check-In for In-Person and Remote Attendees",
      desc: "Hybrid events split your audience across a venue and a screen. EventHex's hybrid check-in merges both into a single attendee list — so your team sees one accurate headcount, one attendance report, and one export. No reconciling spreadsheets after the event.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Unified hybrid event dashboard showing in-person and virtual attendee check-ins",
    },
  ]}
  howItWorksHeading="How Virtual & Hybrid Events Work with EventHex"
  steps={[
    { title: "Connect Your Meeting Platform", desc: "Link your Zoom, Google Meet, or Microsoft Teams account. EventHex schedules the meeting bot to join automatically at session start time." },
    { title: "Configure Streaming & Captions", desc: "Select your RTMP destination (YouTube Live, LinkedIn, or custom), choose your speech-to-text provider, and enable live captions and translation languages." },
    { title: "Run Your Event", desc: "The bot joins, recording and transcription start automatically, the live stream goes out, and captions appear for attendees — all without manual intervention." },
    { title: "Access Recordings & Insights", desc: "After the session, download full recordings, searchable transcripts, speaker timelines, and key insights — ready to share or repurpose immediately." },
  ]}
  ctaTitle="Ready to Run Seamless Virtual and Hybrid Events?"
  ctaCopy="See how EventHex connects your existing meeting tools to professional-grade streaming, transcription, and hybrid check-in — without forcing attendees into a new platform."
  whyHeading="Why Teams Choose EventHex for Virtual & Hybrid Events"
  whyCards={[
    { title: "No Attendee-App Friction", desc: "Attendees join on Zoom, Meet, or Teams as usual — EventHex works behind the scenes with no new app to download or account to create", icon: ICONS.mobile },
    { title: "Multi-Platform Coverage", desc: "One integration covers Zoom, Google Meet, and Microsoft Teams — you're not locked into a single video conferencing tool", icon: ICONS.monitor },
    { title: "Accessibility via Captions & Translation", desc: "Live captions and real-time translation make your sessions inclusive for global, multilingual, and hearing-impaired audiences", icon: ICONS.globe },
    { title: "One Record of Every Session", desc: "Recording, transcript, speaker timeline, and key insights are generated automatically and stored together — no manual stitching after the event", icon: ICONS.clipboard },
  ]}
  faqs={[
    { q: "Which video conferencing platforms does EventHex support?", a: "EventHex meeting bots (via Recall.ai and Vexa) auto-join Zoom, Google Meet, and Microsoft Teams. You schedule the session in your existing calendar tool and EventHex handles the rest." },
    { q: "Do attendees need to install anything?", a: "No. Attendees join the Zoom, Google Meet, or Teams call as they normally would. There is no EventHex app, plugin, or browser extension required on the attendee side." },
    { q: "Which speech-to-text providers are available for transcription?", a: "EventHex supports Deepgram, Google Speech-to-Text, Speechmatics, and Soniox. You can choose the provider that best matches your language, accuracy, and cost requirements." },
    { q: "Can I stream to YouTube and other platforms at the same time?", a: "Yes. EventHex supports RTMP streaming, which means you can push your live session to YouTube Live, LinkedIn Live, Facebook Live, or any custom RTMP endpoint — including multiple destinations simultaneously." },
    { q: "How does hybrid check-in work?", a: "EventHex tracks in-person attendees via badge scan or QR check-in and virtual attendees via the meeting bot. Both feeds are merged into a single attendee dashboard so you see one unified headcount and attendance report." },
    { q: "How quickly are transcripts available after a session?", a: "Full session transcripts are typically available within minutes of the session ending. They are speaker-attributed, time-stamped, and fully searchable inside the EventHex dashboard." },
  ]}
  jsonLd={jsonLd}
/>
