---
import EditorialArticlePage from "../../components/editorial/EditorialArticlePage.astro";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { normalizeNewsItem, normalizeNewsItems } from "../../lib/editorial";
import { getNews, getNewsBySlug } from "../../lib/wordpress";

const { slug } = Astro.params;
const newsItem = slug ? await getNewsBySlug(slug) : null;
const article = newsItem ? normalizeNewsItem(newsItem) : null;

if (!article) {
  Astro.response.status = 404;
}

const recentNews = article ? await getNews({ per_page: "4" }) : [];
const relatedItems = article
  ? normalizeNewsItems(recentNews.filter((candidate) => candidate.id !== article.id)).slice(0, 3)
  : [];
const title = article
  ? (article.seoTitle || `${article.title} | EventHex News`)
  : "Article not found | EventHex";
const description = article?.seoDescription || article?.description || "The requested EventHex news article could not be found.";
const siteUrl = Astro.site?.toString() ?? "https://eventhex.ai";
const canonicalUrl = article ? new URL(article.href, siteUrl).toString() : new URL("/news/", siteUrl).toString();
const ogImage = article?.seoOgImage || (article?.image?.src ?? "");
const publishedTime = newsItem?.date ?? "";
const modifiedTime = newsItem?.modified ?? "";

const jsonLd = article
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      headline: article.title,
      description: article.seoDescription || article.description,
      image: article.image?.src,
      datePublished: article.date,
      ...(newsItem?.modified && { dateModified: newsItem.modified }),
      author: {
        "@type": "Person",
        name: article.author,
      },
      publisher: {
        "@id": "https://eventhex.ai/#organization",
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalUrl,
      },
    })
  : null;

const faqJsonLd = article && article.faqs.length > 0
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: article.faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    })
  : null;
---

<MarketingLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  footerCtaTitle="Want a platform that earns headlines for the right reasons?"
  footerCtaButtonText="Talk to EventHex"
  footerCtaHref="/book-a-demo/"
>
  {jsonLd && (
    <script type="application/ld+json" set:html={jsonLd} slot="head" />
  )}
  {faqJsonLd && (
    <script type="application/ld+json" set:html={faqJsonLd} slot="head" />
  )}
  <EditorialArticlePage
    item={article}
    relatedItems={relatedItems}
    collectionHref="/news/"
    collectionLabel="News"
    canonicalUrl={canonicalUrl}
  />
</MarketingLayout>