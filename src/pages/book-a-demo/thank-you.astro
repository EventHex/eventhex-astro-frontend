---
import MarketingLayout from "../../layouts/MarketingLayout.astro";

const title = "You're booked — EventHex Demo";
const description = "Your EventHex demo is confirmed. Here's what happens next.";
const canonical = "https://eventhex.ai/book-a-demo/thank-you/";
---

<MarketingLayout {title} {description} {canonical} showFooterCta={false} robots="noindex, nofollow">
  <section class="ty">
    <div class="ty__inner">
      <span class="ty__icon" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </span>
      <p class="ty__eyebrow">Booking confirmed</p>
      <h1 class="ty__title">You're booked! 🎉</h1>
      <p class="ty__when" id="ty-when">Your 30-minute EventHex walkthrough is confirmed.</p>
      <p class="ty__desc">
        A calendar invite with the Google Meet link is on its way to your inbox.
        Add it to your calendar so you don't miss it.
      </p>

      <div class="ty__cards">
        <div class="ty__card">
          <h3>What we'll cover</h3>
          <ul>
            <li>Registration &amp; ticketing for your event</li>
            <li>Attendee check-in &amp; badge printing</li>
            <li>Engagement: live polling, networking, AI features</li>
            <li>Your questions, mapped to your workflow</li>
          </ul>
        </div>
        <div class="ty__card">
          <h3>To get the most out of it</h3>
          <ul>
            <li>Have a real upcoming event in mind</li>
            <li>Note your must-have features &amp; pain points</li>
            <li>Invite a colleague — bring a guest on the invite</li>
          </ul>
        </div>
      </div>

      <div class="ty__wa">
        <p class="ty__wa-text">Have a question before your demo? Chat with us now.</p>
        <a
          class="ty__wa-btn"
          href="https://wa.me/917356733317?text=Hi!%20I%20just%20booked%20an%20EventHex%20demo%20and%20have%20a%20quick%20question."
          target="_blank"
          rel="noopener noreferrer"
          data-wa="thankyou"
        >
          <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 .5C7.4.5.5 7.4.5 16c0 2.8.7 5.4 2 7.7L.5 31.5l8-2.1c2.2 1.2 4.8 1.9 7.5 1.9 8.6 0 15.5-6.9 15.5-15.5S24.6.5 16 .5zm0 28c-2.4 0-4.7-.6-6.7-1.8l-.5-.3-4.7 1.2 1.3-4.6-.3-.5C3.9 20.3 3.3 18.2 3.3 16 3.3 9 9 3.3 16 3.3S28.7 9 28.7 16 23 28.5 16 28.5zm7.1-9.4c-.4-.2-2.3-1.1-2.6-1.3-.3-.1-.6-.2-.8.2-.2.4-.9 1.3-1.1 1.5-.2.2-.4.3-.8.1-.4-.2-1.6-.6-3-1.9-1.1-1-1.9-2.2-2.1-2.6-.2-.4 0-.6.2-.8.2-.2.4-.4.5-.6.2-.2.2-.4.4-.6.1-.2.1-.5 0-.7-.1-.2-.8-2-1.1-2.7-.3-.7-.6-.6-.8-.6h-.7c-.2 0-.6.1-.9.5-.3.4-1.2 1.2-1.2 2.9 0 1.7 1.2 3.3 1.4 3.6.2.2 2.4 3.7 5.9 5.2.8.4 1.5.6 2 .8.8.3 1.6.2 2.2.1.7-.1 2.3-.9 2.6-1.8.3-.9.3-1.6.2-1.8-.1-.2-.3-.3-.7-.5z"></path></svg>
          Message us on WhatsApp
        </a>
      </div>

      <div class="ty__links">
        <a class="ty__btn ty__btn--primary" href="/">Back to home</a>
        <a class="ty__btn" href="/blog/">Read the EventHex blog</a>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .ty {
    margin-top: -90px;
    padding: 170px 20px 100px;
    background: var(--surface-light, #f5f8ff);
    min-height: 70vh;
  }
  .ty__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .ty__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: #d1fadf;
    color: #12b76a;
    margin-bottom: 22px;
  }
  .ty__eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--brand-blue, #375dfb);
    margin: 0 0 10px;
  }
  .ty__title {
    font-family: var(--font-heading, "Manrope", sans-serif);
    font-size: 38px;
    font-weight: 700;
    color: var(--heading-dark, #22272f);
    margin: 0 0 12px;
  }
  .ty__when {
    font-size: 18px;
    font-weight: 600;
    color: var(--heading-dark, #22272f);
    margin: 0 0 8px;
  }
  .ty__desc {
    font-size: 16px;
    line-height: 1.6;
    color: var(--body-gray, #525866);
    margin: 0 auto 36px;
    max-width: 520px;
  }
  .ty__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    text-align: left;
    margin-bottom: 36px;
  }
  .ty__card {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf2);
    border-radius: 14px;
    padding: 22px;
  }
  .ty__card h3 {
    font-family: var(--font-heading, "Manrope", sans-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--heading-dark, #22272f);
    margin: 0 0 12px;
  }
  .ty__card ul {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ty__card li {
    font-size: 14px;
    line-height: 1.5;
    color: var(--body-gray, #525866);
  }
  .ty__wa {
    background: #fff;
    border: 1px solid var(--surface-card-border, #e8ecf2);
    border-radius: 14px;
    padding: 22px;
    margin-bottom: 28px;
  }
  .ty__wa-text {
    font-size: 15px;
    color: var(--body-gray, #525866);
    margin: 0 0 14px;
  }
  .ty__wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 13px 24px;
    border-radius: 10px;
    background: #25d366;
    color: #fff;
    font-family: var(--font-heading, "Manrope", sans-serif);
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s;
  }
  .ty__wa-btn:hover {
    background: #1ebe5a;
    box-shadow: 0 8px 18px rgba(37, 211, 102, 0.3);
  }

  .ty__links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .ty__btn {
    display: inline-flex;
    align-items: center;
    padding: 12px 22px;
    border-radius: 10px;
    border: 1px solid var(--surface-card-border, #e8ecf2);
    background: #fff;
    color: var(--heading-dark, #22272f);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .ty__btn:hover {
    border-color: var(--brand-blue, #375dfb);
  }
  .ty__btn--primary {
    background: var(--brand-blue, #375dfb);
    border-color: var(--brand-blue, #375dfb);
    color: #fff;
  }
  .ty__btn--primary:hover {
    background: var(--brand-blue-hover, #1c46d4);
  }
  @media (max-width: 720px) {
    .ty__cards {
      grid-template-columns: 1fr;
    }
    .ty__title {
      font-size: 30px;
    }
  }
</style>

<script>
  // Fire the conversion event + show the booked time (from ?at=ISO).
  const params = new URLSearchParams(window.location.search);
  const at = params.get("at");
  if (at) {
    const d = new Date(at);
    if (!isNaN(d.getTime())) {
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
      const fmt = new Intl.DateTimeFormat([], {
        weekday: "long",
        month: "long",
        day: "numeric",
        hour: "numeric",
        minute: "2-digit",
      });
      const el = document.getElementById("ty-when");
      if (el) el.textContent = "Your 30-minute EventHex walkthrough is confirmed for " + fmt.format(d) + " (" + tz + ").";
    }
  }
  // GTM conversion — configure GA4/Ads tags off this event.
  (window as any).dataLayer = (window as any).dataLayer || [];
  (window as any).dataLayer.push({
    event: "demo_booking_confirmed",
    booking_time: at || null,
  });
  const clr = (window as any).clarity;
  if (typeof clr === "function") clr("event", "demo_booking_confirmed");

  // WhatsApp click tracking on the thank-you page.
  const waBtn = document.querySelector('[data-wa="thankyou"]');
  if (waBtn) {
    waBtn.addEventListener("click", () => {
      (window as any).dataLayer.push({ event: "demo_whatsapp_click", source: "thank_you" });
      if (typeof clr === "function") clr("event", "demo_whatsapp_click");
    });
  }
</script>
