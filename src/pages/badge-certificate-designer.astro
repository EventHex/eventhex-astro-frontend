---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/badge-certificate-designer/HeroSection.astro";
import StatsSection from "../components/badge-certificate-designer/StatsSection.astro";
import BentoGrid from "../components/badge-certificate-designer/BentoGrid.astro";
import FeatureCards from "../components/badge-certificate-designer/FeatureCards.astro";
import HowItWorksSection from "../components/badge-certificate-designer/HowItWorksSection.astro";
import CTASection from "../components/badge-certificate-designer/CTASection.astro";
import CoordinationTools from "../components/badge-certificate-designer/CoordinationTools.astro";
import FaqSection from "../components/badge-certificate-designer/FaqSection.astro";

const ogImage = "https://eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Badge & Certificate Designer — Visual Editor & On-Site Printing | EventHex";
const description = "Design event badges and certificates with drag-and-drop editor, QR codes, dynamic data, on-site printing, and bulk PDF generation.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Badge & Certificate Designer",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/badge-certificate-designer/",
  description: "Visual badge and certificate designer with drag-and-drop editor, QR codes, on-site printing, and bulk PDF generation for events.",
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Drag-and-Drop Badge Editor",
    "100+ Badge Templates",
    "QR Code Generation",
    "Dynamic Data Fields",
    "On-Site Badge Printing",
    "Self-Service Kiosks",
    "Certificate Templates",
    "Bulk PDF Generation",
    "Verification URLs",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/badge-certificate-designer/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
