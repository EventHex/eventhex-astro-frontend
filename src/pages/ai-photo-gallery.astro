---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/ai-photo-gallery/HeroSection.astro";
import StatsSection from "../components/ai-photo-gallery/StatsSection.astro";
import BentoGrid from "../components/ai-photo-gallery/BentoGrid.astro";
import FeatureCards from "../components/ai-photo-gallery/FeatureCards.astro";
import HowItWorksSection from "../components/ai-photo-gallery/HowItWorksSection.astro";
import CTASection from "../components/ai-photo-gallery/CTASection.astro";
import CoordinationTools from "../components/ai-photo-gallery/CoordinationTools.astro";
import FaqSection from "../components/ai-photo-gallery/FaqSection.astro";

const ogImage = "https://eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "AI Event Photo Gallery Software with Face Matching | EventHex";
const description = "Upload event photos, let attendees take a selfie, and deliver matched photos in seconds with InstaSnap AI Photo Gallery by EventHex.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex InstaSnap AI Photo Gallery",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/ai-photo-gallery/",
  description,
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "AI Face Recognition with AWS Rekognition",
    "Selfie-to-photo matching in seconds",
    "Bulk photo upload for photographers",
    "Automatic face clustering",
    "Group photo detection",
    "Person-specific share pages",
    "Sponsor banners inside the gallery",
    "Branded photo frames and galleries",
    "Download controls and watermarking",
    "Privacy-first controls with attendee opt-out",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/ai-photo-gallery/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
