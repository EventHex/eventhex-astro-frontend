---
import EditorialIndexPage from "../../components/editorial/EditorialIndexPage.astro";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { normalizeBlogPosts } from "../../lib/editorial";
import { getPosts } from "../../lib/wordpress";

const title = "Blog | EventHex";
const description = "Insights, practical playbooks, and AI-powered event strategies from the EventHex team.";
const posts = normalizeBlogPosts(await getPosts({ per_page: "18" }));
---

<MarketingLayout
  title={title}
  description={description}
  footerCtaTitle="Ready to turn these insights into action?"
  footerCtaButtonText="Book a demo"
  footerCtaHref="/book-a-demo/"
>
  <EditorialIndexPage
    kind="blog"
    eyebrow="EventHex Blog"
    pageTitle="Ideas, playbooks, and product thinking for teams building modern events."
    pageDescription={description}
    items={posts}
  />
</MarketingLayout>
