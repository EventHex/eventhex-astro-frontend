---
import EditorialArticlePage from "../../components/editorial/EditorialArticlePage.astro";
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { normalizeBlogPost, normalizeBlogPosts } from "../../lib/editorial";
import { getPostBySlug, getPosts } from "../../lib/wordpress";

const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : null;
const article = post ? normalizeBlogPost(post) : null;

if (!article) {
  Astro.response.status = 404;
}

const recentPosts = article ? await getPosts({ per_page: "4" }) : [];
const relatedItems = article
  ? normalizeBlogPosts(recentPosts.filter((candidate) => candidate.id !== article.id)).slice(0, 3)
  : [];
const title = article ? `${article.title} | EventHex Blog` : "Article not found | EventHex";
const description = article?.description ?? "The requested EventHex blog article could not be found.";
const siteUrl = Astro.site?.toString() ?? "https://eventhex.ai";
// Canonical uses root URL pattern (/{slug}/) to match WordPress indexed URLs
const canonicalUrl = article ? new URL(`/${article.slug}/`, siteUrl).toString() : new URL("/blog/", siteUrl).toString();
const ogImage = article?.image?.src ?? "";
const publishedTime = post?.date ?? "";
const modifiedTime = post?.modified ?? "";

const jsonLd = article
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: article.title,
      description: article.description,
      image: article.image?.src,
      datePublished: article.date,
      ...(post?.modified && { dateModified: post.modified }),
      author: {
        "@type": "Person",
        name: article.author,
      },
      publisher: {
        "@id": "https://eventhex.ai/#organization",
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonicalUrl,
      },
    })
  : null;
---

<MarketingLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  footerCtaTitle="Want the same clarity inside your own events?"
  footerCtaButtonText="Talk to EventHex"
  footerCtaHref="/book-a-demo/"
>
  {jsonLd && (
    <script type="application/ld+json" set:html={jsonLd} slot="head" />
  )}
  <EditorialArticlePage
    item={article}
    relatedItems={relatedItems}
    collectionHref="/blog/"
    collectionLabel="Blog"
    canonicalUrl={canonicalUrl}
  />
</MarketingLayout>
