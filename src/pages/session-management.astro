    image: "/feature-images/session-management/agenda-card-visual.svg",
  },
  {
    eyebrow: "Session structure",
    title: "Support every format from keynotes to breakout-heavy workshop flows",
    desc: "Create parent sessions, sub-sessions, and specialized formats so the published agenda matches the real shape of the event instead of flattening it into generic blocks.",
