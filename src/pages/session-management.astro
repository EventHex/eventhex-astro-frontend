            <span class="ssm-cta__proof-pill">Capacity-aware registrations</span>
            <span class="ssm-cta__proof-pill">Live polls and AI recap</span>
          </div>

          <div class="ssm-cta__buttons">
            <a href="/book-a-demo/" class="ssm-cta__btn ssm-cta__btn--primary">Book a Free Demo</a>
            <a href="/contact-en/" class="ssm-cta__btn ssm-cta__btn--secondary">Talk to the team</a>
          </div>
        </div>

        <div class="ssm-cta__visual animate-on-scroll" data-animation="fadeInRight">
          <img
            src="/feature-images/session-management/cta-visual.svg"
            alt="Session management dashboard showing agenda builder, speaker profiles, and live engagement tools"
            width="831"
            height="604"
            loading="lazy"
            class="ssm-cta__visual-img"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="ssm-ops">
    <div class="ssm-ops__inner">
      <div class="ssm-ops__header">
        <span class="ssm-ops__tag animate-on-scroll" data-animation="fadeIn">Operational Support</span>
        <h2 class="ssm-ops__title animate-on-scroll" data-animation="fadeInUp">
          Effortless session <b>coordination</b>
        </h2>
        <p class="ssm-ops__desc animate-on-scroll" data-animation="fadeInUp">
          Keep rooms, registrations, reminders, and agenda publishing connected so
          your event team can scale session operations without creating extra layers
          of admin work.
        </p>
      </div>

      <div class="ssm-ops__cards">
        {coordinationCards.map((card) => (
          <article class="ssm-ops__card animate-on-scroll" data-animation="fadeInUp">
            <div class="ssm-ops__icon">
              <span></span>
            </div>
            <h3 class="ssm-ops__card-title">{card.title}</h3>
            <p class="ssm-ops__card-desc">{card.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="ssm-faq">
    <div class="ssm-faq__inner">
      <div class="ssm-faq__support animate-on-scroll" data-animation="fadeInLeft">
        <span class="ssm-faq__eyebrow">Need a custom session setup?</span>
        <h2 class="ssm-faq__title">Frequently Asked Questions</h2>
        <p class="ssm-faq__desc">
          We help event teams structure agenda logic, access rules, session-level
          communication, and live recap workflows around the way their programs actually run.
        </p>

        <div class="ssm-faq__support-card">
          <h3 class="ssm-faq__support-title">Talk to Our Team</h3>
          <p class="ssm-faq__support-desc">Our experts can walk you through a personalized demo and answer any questions about session management.</p>
        </div>

        <a href="/book-a-demo/" class="ssm-faq__cta">Book a Demo</a>
      </div>

      <div class="ssm-faq__list">
        {faqItems.map((faq, index) => (
          <details class="ssm-faq__item animate-on-scroll" data-animation="fadeInUp" data-delay={String(index * 60)} data-session-faq open={index === 0}>
            <summary class="ssm-faq__question">
              {faq.q}
              <svg class="ssm-faq__chevron" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="ssm-faq__answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <script>
    const setupSessionTabs = () => {
      const tabs = Array.from(document.querySelectorAll("[data-session-tab]"));
      const panels = Array.from(document.querySelectorAll("[data-session-panel]"));

      tabs.forEach((tab) => {
        if (tab.dataset.bound === "true") {
          return;
        }

        tab.dataset.bound = "true";
        tab.addEventListener("click", () => {
          const activeIndex = tab.getAttribute("data-session-tab");

          tabs.forEach((item) => {
            const selected = item.getAttribute("data-session-tab") === activeIndex;
            item.classList.toggle("is-active", selected);
            item.setAttribute("aria-selected", selected ? "true" : "false");
          });

          panels.forEach((panel) => {
            const selected = panel.getAttribute("data-session-panel") === activeIndex;
            panel.classList.toggle("is-active", selected);
            panel.setAttribute("aria-hidden", selected ? "false" : "true");
          });
        });
      });

      const faqItems = Array.from(document.querySelectorAll("[data-session-faq]"));

      faqItems.forEach((item) => {
        if (item.dataset.bound === "true") {
          return;
        }

        item.dataset.bound = "true";
        item.addEventListener("toggle", () => {
          if (!(item instanceof HTMLDetailsElement) || !item.open) {
            return;
          }

          faqItems.forEach((other) => {
            if (other !== item && other instanceof HTMLDetailsElement) {
              other.open = false;
            }
          });
        });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupSessionTabs, { once: true });
    } else {
      setupSessionTabs();
    }
  </script>
</MarketingLayout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(main) {
    background-color: #ffffff;
  }

  .ssm-hero {
    position: relative;
    overflow: hidden;
    margin-top: -90px;
    padding: 0 0 220px;
    background:
      radial-gradient(circle at 15% 20%, rgba(175, 163, 255, 0.18), transparent 24%),
      radial-gradient(circle at 82% 18%, rgba(124, 180, 255, 0.16), transparent 25%),
      url("https://cms.eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11-1024x576.webp") center center / cover no-repeat;
  }

  .ssm-hero__shell {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 160px 0 0;
    background: url("https://cms.eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.webp") center center / cover no-repeat;
  }

  .ssm-hero__grid {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.04fr);
    gap: 48px;
    align-items: center;
  }

  .ssm-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }

  .ssm-hero__badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .ssm-hero__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 52px;
    font-weight: 600;
    line-height: 60px;
    letter-spacing: -1px;
    color: var(--heading-dark);
  }

  .ssm-hero__title span {
    display: block;
    color: var(--brand-blue);
  }

  .ssm-hero__desc {
    margin: 0;
    max-width: 590px;
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
    letter-spacing: -0.48px;
    color: var(--subheading-gray);
  }

  .ssm-hero__points {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .ssm-hero__point {
    display: inline-flex;
    align-items: center;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid #e5ebff;
    box-shadow: 0 8px 24px rgba(34, 39, 47, 0.05);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: #475467;
  }

  .ssm-hero__cta {
    display: flex;
    gap: 14px;
    padding-top: 6px;
  }

  .ssm-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 12px 32px;
    border-radius: 10px;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    line-height: 24px;
    letter-spacing: -0.3px;
    transition: transform 0.3s, box-shadow 0.3s, background 0.3s, border-color 0.3s;
  }

  .ssm-hero__btn--primary {
    color: #fff;
    background: var(--brand-blue);
    box-shadow: 0 10px 24px rgba(55, 93, 251, 0.28);
  }

  .ssm-hero__btn--primary:hover {
    transform: translateY(-2px);
    background: var(--brand-blue-hover);
    box-shadow: 0 14px 30px rgba(55, 93, 251, 0.34);
  }

