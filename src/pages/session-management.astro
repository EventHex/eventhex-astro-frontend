  },
  {
    eyebrow: "Capacity and access",
    title: "Use registration data to control who can enter what and when",
    desc: "EventHex connects ticket rules and session-level attendance so premium access, limited-capacity rooms, and waitlists stay operationally sound.",
    visual: "capacity",
    image: "/feature-images/session-management/capacity-card-visual.svg",
  },
  {
    eyebrow: "Live engagement and recap",
    title: "Keep interaction, feedback, recording, and AI summary in the same session workflow",
    desc: "Moderators can run live tools while ops teams monitor response, recording, and recap completion. Nothing needs to be copied into a separate post-event system.",
    visual: "engagement",
    image: "/feature-images/session-management/engagement-card-visual.svg",
  },
];

const coordinationCards = [
  {
    title: "Multi-stage control",
    desc: "Run agendas across unlimited rooms and stages while keeping speaker assignments, room notes, and schedule changes synchronized in one place.",
  },
  {
    title: "Access-aware registration",
    desc: "Connect session eligibility, capacity, waitlists, and reminders so high-demand sessions stay structured even when demand spikes.",
  },
  {
    title: "Agenda publishing and follow-up",
    desc: "Present agendas in attendee-friendly formats, then carry recordings and AI recaps forward without rebuilding the session record later.",
  },
];

const supportChecklist = [
  "Agenda blueprinting for multi-track programs",
  "Session access rules, capacity setup, and waitlists",
  "Live engagement, recording, and recap readiness",
];

const faqItems = [
  {
    q: "What is session management software?",
    a: "Session management software helps event organizers plan, schedule, and coordinate all sessions, workshops, and keynotes across multiple days and stages from a single dashboard with visual timeline views.",
  },
  {
    q: "Can I manage sessions across multiple stages and days?",
    a: "Yes. EventHex supports unlimited stages, rooms, and days. Each stage gets its own timeline track so your team can review schedules side by side, resolve clashes early, and keep the agenda coherent as the event grows.",
  },
  {
    q: "What are sub-sessions and breakout rooms?",
    a: "Sub-sessions are nested sessions created under a parent session. They are useful for workshops that split into groups, panel discussions with parallel tracks, or conferences with themed breakout streams that still belong to one larger program.",
  },
  {
    q: "Can I restrict sessions to specific ticket types?",
    a: "Yes. You can limit session access to specific ticket types or participant categories, set maximum capacity per session, and maintain waitlists when a room fills up. That makes it practical to manage VIP workshops, sponsor-only sessions, or premium add-ons.",
  },
  {
    q: "How does drag-and-drop scheduling work?",
    a: "The visual timeline lets your team move sessions between time slots or stages with direct drag-and-drop edits. Changes are reflected in the same planning view so operators can reschedule quickly without rebuilding the rest of the agenda.",
  },
  {
    q: "What live engagement tools are available during sessions?",
    a: "EventHex includes live polls with real-time analytics, Q&A with spotlight mode for fullscreen projection, emoji reactions, star ratings, and session feedback tools that attendees can use from their phones during the event.",
  },
  {
    q: "Can sessions be recorded and transcribed automatically?",
    a: "Yes. EventHex's InstaRecap workflow can pair recordings with AI-generated transcripts, summaries, and translations after the session ends, helping organizers turn session content into usable post-event knowledge faster.",
  },
  {
    q: "Can I track which attendees registered for each session?",
    a: "Yes. EventHex tracks session-level registrations so your team can review attendee counts, manage capacity, send targeted reminders, and analyze which sessions drew the strongest interest across the event.",
  },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Session Management",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/session-management/",
  description,
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Visual timeline scheduling",
    "Multi-day and multi-stage agenda control",
    "Sub-sessions and breakout room planning",
    "Session-level capacity and waitlists",
    "Ticket-restricted access rules",
    "Live polls and Q&A spotlight",
    "Emoji feedback and ratings",
    "AI-powered transcripts and session recaps",
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((faq) => ({
    "@type": "Question",
    name: faq.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.a,
    },
  })),
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/session-management/"
  footerCtaTitle={"See Your Agenda Workflow\nLive Before Launch"}
  footerCtaButtonText="Get a demo"
  footerCtaHref="/book-a-demo/"
>
  <section class="ssm-hero">
    <div class="ssm-hero__shell">
      <div class="ssm-hero__grid">
        <div class="ssm-hero__content">
          <div class="ssm-hero__badge animate-on-scroll" data-animation="fadeInDown">
            <span>Session Management</span>
          </div>

          <h1 class="ssm-hero__title animate-on-scroll" data-animation="fadeInUp">
            Plan Complex Event Agendas Without
            <span>Track-Planning Chaos</span>
          </h1>

          <p class="ssm-hero__desc animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 800ms">
            Build multi-day schedules, organize sub-sessions, control room capacity,
            and run live engagement from one operational layer built for event teams.
          </p>

          <div class="ssm-hero__points animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 950ms">
            <span class="ssm-hero__point">Visual timeline scheduling</span>
            <span class="ssm-hero__point">Sub-sessions and breakout control</span>
            <span class="ssm-hero__point">Live polls, Q&amp;A, and AI recap</span>
          </div>

          <div class="ssm-hero__cta animate-on-scroll" data-animation="fadeInUp" style="--anim-duration: 1100ms">
            <a href="/book-a-demo/" class="ssm-hero__btn ssm-hero__btn--primary">Get a Free Demo</a>
            <a href="#ssm-bento" class="ssm-hero__btn ssm-hero__btn--secondary">Explore Features</a>
          </div>

          <div class="ssm-hero__trust animate-on-scroll" data-animation="fadeIn" style="--anim-duration: 1250ms">
            <span class="ssm-hero__trust-item">50,000+ sessions scheduled</span>
            <span class="ssm-hero__trust-item">Built for multi-stage events</span>
          </div>
        </div>

        <div class="ssm-hero__visual animate-on-scroll" data-animation="fadeInRight">
          <LottiePlayer
            src="/animations/session-management-hero.lottie"
            class="ssm-hero__visual-lottie"
            eager
          />
        </div>
      </div>
    </div>
  </section>

  <section class="ssm-dark-band">
    <div class="ssm-dark-band__headline">
      <h2 class="ssm-dark-band__title animate-on-scroll" data-animation="fadeInDown">
        <span class="ssm-dark-band__white">Keep agenda planning, session access, and</span>
        <span class="ssm-dark-band__purple"> live attendee signals</span>
        <span class="ssm-dark-band__white"> inside one</span>
        <span class="ssm-dark-band__cyan"> event workflow</span>
      </h2>
    </div>

    <div class="ssm-dark-band__stats">
      {stats.map((stat) => (
        <div class="ssm-dark-band__stat">
          <span class="ssm-dark-band__value">{stat.value}</span>
          <span class="ssm-dark-band__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </section>

  <BentoGrid />

  <section class="ssm-stack">
