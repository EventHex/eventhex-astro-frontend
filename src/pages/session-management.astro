---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import BentoGrid from "../components/session-management/BentoGrid.astro";
import LottiePlayer from "../components/LottiePlayer.astro";

const title = "Session Management Software for Multi-Track Events | EventHex";
const description = "Plan multi-day agendas with visual timeline scheduling, session access controls, live polls, Q&A, and AI-powered session recaps from one event workflow.";

const stats = [
  { value: "5,000+", label: "Sessions scheduled" },
  { value: "400+", label: "Multi-track events run" },
  { value: "98%", label: "Scheduling accuracy" },
  { value: "4.8/5", label: "Organizer satisfaction" },
];

const showcaseTabs = [
  {
    label: "Agenda Builder",
    cards: [
      {
        type: "image",
        size: "wide",
        eyebrow: "Visual timeline",
        title: "Plot every day, room, and stage from one agenda view",
        desc: "Switch between days, drag sessions into new slots, and keep the full program readable even when your event spans parallel tracks and nested sessions.",
        image: "/feature-images/session-management/timeline-view.jpeg",
        alt: "EventHex session timeline showing multi-day, multi-stage scheduling",
        chips: ["Day-by-day planning", "Drag-and-drop edits", "Conflict visibility"],
      },
      {
        type: "list",
        size: "tall",
        eyebrow: "Session logic",
        title: "Handle keynotes, breakouts, workshops, and sub-sessions without workarounds",
        desc: "Model the agenda the way your event actually runs instead of flattening everything into a spreadsheet grid.",
        items: [
          "Create custom session types with color rules for instant recognition.",
          "Nest sub-sessions under parent tracks for workshops and parallel streams.",
          "Assign speakers, moderators, and room notes directly on the session.",
          "Move sessions between stages without rebuilding the rest of the day.",
        ],
      },
      {
        type: "snapshot",
        size: "small",
        eyebrow: "Operator speed",
        title: "Open the exact session context in one click",
        desc: "Jump from the agenda into session-level actions without breaking your planning flow.",
        rows: [
          { label: "Session detail", value: "speaker, room, timing" },
          { label: "Live tools", value: "polls, Q&A, feedback" },
          { label: "Recap state", value: "recording and AI summary" },
        ],
      },
    ],
  },
  {
    label: "Access & Capacity",
    cards: [
      {
        type: "capacity",
        size: "wide",
        eyebrow: "Registration control",
        title: "Protect high-value sessions with clear access and seat rules",
        desc: "Tie session entry to ticket types, enforce capacity limits, and keep waitlists moving without manual coordination.",
      },
      {
        type: "list",
        size: "tall",
        eyebrow: "Capacity rules",
        title: "Keep attendance quality high as registrations climb",
        desc: "Stay ahead of overbooking, no-shows, and room mismatches before the event day starts.",
        items: [
          "Restrict workshops and premium sessions by ticket class or participant segment.",
          "Set capacity caps per room, per day, or per session type.",
          "Auto-create waitlists when demand exceeds available seats.",
          "Trigger reminder sequences for registered attendees close to session start.",
        ],
      },
      {
        type: "snapshot",
        size: "small",
        eyebrow: "Reminder engine",
        title: "Reduce missed sessions with targeted nudges",
        desc: "Use session registration data to send reminders that are relevant, timely, and tied to the right audience segment.",
        rows: [
          { label: "VIP workshop", value: "reminder sent 2h before" },
          { label: "Waitlist release", value: "auto-fill open seats" },
          { label: "Room change", value: "notify affected attendees" },
        ],
      },
    ],
  },
  {
    label: "Live Session Layer",
    cards: [
      {
        type: "image",
        size: "wide",
        eyebrow: "Session detail panel",
        title: "Run engagement, feedback, and recap workflows from inside each session",
        desc: "Moderators and event ops teams can launch polls, review questions, track feedback, and monitor recap status without leaving session context.",
        image: "/feature-images/session-management/detail-panel.png",
        alt: "EventHex session detail panel with speaker and engagement controls",
        chips: ["Live polls", "Q&A spotlight", "AI recap status"],
      },
      {
        type: "list",
        size: "tall",
        eyebrow: "Live engagement",
        title: "Turn every session into a two-way experience",
        desc: "Engagement tools are built into the same workflow used to manage the agenda, so teams are not stitching together separate tools on event day.",
        items: [
          "Launch live polls and watch color-coded analytics update in real time.",
          "Collect audience questions and project them in spotlight mode for speakers.",
          "Capture emoji reactions and star ratings while the session is still live.",
          "Feed recordings into InstaRecap for transcripts, summaries, and translation.",
        ],
      },
      {
        type: "poll",
        size: "small",
        eyebrow: "In-session signals",
