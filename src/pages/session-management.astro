      <div class="ssm-stack__header">
        <span class="ssm-stack__subtitle">Key features that keep session operations under control</span>
        <h2 class="ssm-stack__title">
          Everything you need to <span>shape, protect, and activate</span><br />
          your event agenda
        </h2>
      </div>

      <div class="ssm-stack__cards">
        {deepDiveCards.map((card, index) => (
          <article class="ssm-stack__card" style={`top: calc(20px + ${index * 20}px);`}>
