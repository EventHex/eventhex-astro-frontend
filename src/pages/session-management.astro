];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Session Management",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/session-management/",
  description,
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
