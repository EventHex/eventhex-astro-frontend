---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/feature-page/HeroSection.astro";
import FeatureSection from "../components/feature-page/FeatureSection.astro";
import CTASection from "../components/feature-page/CTASection.astro";

const title = "Event Marketing - EventHex";
const description = "EventHex's Event Marketing module provides organizers with budget-efficient and easy-to-use marketing tools to promote their events online.";

const featureSections = [
  {
    sectionTitle: "Targeted Social Media Campaigns",
    imageLeft: true,
    dark: false,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-2.svg",
    imageAlt: "EventHex targeted social media campaign builder interface",
    items: [
      {
        title: "Personalized Campaigns",
        description: "Create and send personalized email and WhatsApp campaigns to engage with your audience",
      },
      {
        title: "Custom Templates",
        description: "Select the style of message personalization in the editor using variables such as users and events",
      },
      {
        title: "Campaign Schedule",
        description: "You can pre-set the time you want your campaign to start running",
      },
    ],
  },
  {
    sectionTitle: "Re-Campaign with Saved Audience",
    imageLeft: false,
    dark: true,
    backgroundColor: "#000312",
    backgroundImage: "https://eventhex.ai/wp-content/uploads/2025/03/bg.svg",
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Marketing-_Campaigns.png",
    imageAlt: "EventHex re-campaign audience management interface",
    imageOverflow: true,
    items: [
      {
        title: "Audience List",
        description: "Organize and manage predefined audience groups for targeted campaigns",
      },
      {
        title: "Audience Filter",
        description: "Decide if you want to filter the audience list either from the current or previous event",
      },
      {
        title: "Delivery Status",
        description: "View how many messages are pending and how many are to the selected audience list",
      },
    ],
  },
  {
    sectionTitle: "Advocacy Posters to Boost Online Presence",
    imageLeft: true,
    dark: false,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Group.svg",
    imageAlt: "EventHex advocacy poster creator for event promotion",
    extraBottomPadding: true,
    items: [
      {
        title: "Create Posters",
        description: "Create 'I'm attending' like posters for participants to share and promote your event online",
      },
      {
        title: "Customize Fields",
        description: "Decide what all details should go on the poster such as name, profile photo, company logo, etc",
      },
      {
        title: "Instant Sharing",
        description: "Let your audience do the marketing by sharing the advocacy posters on their social media handles",
      },
    ],
  },
];
---

<MarketingLayout {title} {description}>
  <!-- Section 0: Hero -->
  <HeroSection
    eyebrow="Event Marketing"
    title="Promote Your Events with Event Marketing Campaigns"
    description="EventHex's Event Marketing module provides organizers with budget-efficient and easy-to-use marketing tools to promote their events online."
    image="https://eventhex.ai/wp-content/uploads/2025/04/Event-Marketing.png"
    imageAlt="EventHex Event Marketing dashboard preview"
  />

  <!-- Feature Sections -->
  {featureSections.map((section, i) => (
    <FeatureSection
      sectionTitle={section.sectionTitle}
      items={section.items}
      image={section.image}
      imageAlt={section.imageAlt}
      imageLeft={section.imageLeft}
      dark={section.dark}
      backgroundImage={section.backgroundImage}
      backgroundColor={section.backgroundColor}
      imageOverflow={section.imageOverflow}
    />
  ))}

  <!-- CTA Section -->
  <CTASection />
</MarketingLayout>
