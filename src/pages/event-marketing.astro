---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-marketing/HeroSection.astro";
import BentoGridSection from "../components/event-marketing/BentoGridSection.astro";
import FeatureCardsSection from "../components/event-marketing/FeatureCardsSection.astro";
import CTASection from "../components/event-marketing/CTASection.astro";
import BenefitCardsSection from "../components/event-marketing/BenefitCardsSection.astro";
import FaqLightSection from "../components/event-marketing/FaqLightSection.astro";

const title = "Event Marketing Software — Email, WhatsApp & Advocacy Campaigns | EventHex";
const description = "Promote your events with EventHex's all-in-one event marketing software. Send personalized email & WhatsApp campaigns, build advocacy posters, manage audience segments, and track campaign delivery — all from one platform.";
const canonical = "https://eventhex.ai/event-marketing/";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Marketing",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "EventHex's event marketing software helps organizers promote events with personalized email and WhatsApp campaigns, advocacy posters, smart audience targeting, and real-time delivery analytics.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available"
  },
  featureList: [
    "Email Campaign Builder with HTML Editor",
    "WhatsApp Broadcast Campaigns",
    "Smart Audience Segmentation",
    "Cross-Event Audience Retargeting",
    "Campaign Scheduling",
    "Drag & Drop Advocacy Poster Builder",
    "Real-Time Delivery Analytics",
    "Per-Recipient Status Tracking",
    "Email Open Rate & Click-Through Tracking",
    "Smart Bounce & Complaint Suppression",
    "Template Variable Personalization",
    "Multi-Provider Support (SES, SMTP, WhatsApp API)"
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    ratingCount: "500",
    bestRating: "5"
  }
};
---

<MarketingLayout
  {title}
  {description}
  {canonical}
  ogImage="https://cms.eventhex.ai/wp-content/uploads/2025/04/Event-Marketing.png"
  ogType="website"
  footerCtaTitle="Explore EventHex's Event Marketing Now!"
  footerCtaButtonText="Start Marketing Your Event"
  footerCtaHref="/book-a-demo/"
>
  <!-- Section 1: Hero -->
  <HeroSection
    eyebrow="Event Marketing"
    titleHtml="Promote Events. <b>Fill Every Seat.</b> Multi-Channel Campaigns."
    description="Create personalized email and WhatsApp campaigns, build smart audience segments, design advocacy posters, and track every delivery — all from one marketing platform."
    ctaText="Start Marketing Your Event"
    ctaHref="/book-a-demo/"
    image="https://cms.eventhex.ai/wp-content/uploads/2025/04/Event-Marketing.png"
    imageAlt="EventHex Event Marketing dashboard preview"
  />

  <!-- Section 2: Bento Grid -->
  <BentoGridSection />

  <!-- Section 3: Feature Cards -->
  <FeatureCardsSection />

  <!-- Section 4: CTA -->
  <CTASection />

  <!-- Section 5: Benefits -->
  <BenefitCardsSection />

  <!-- Section 6: FAQ -->
  <FaqLightSection />

  <!-- JSON-LD Software Schema -->
  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(softwareSchema)}</script>`} />
</MarketingLayout>
