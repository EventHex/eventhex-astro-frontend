---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/feature-page/HeroSection.astro";
import FeatureSection from "../components/feature-page/FeatureSection.astro";
import BenefitsSection from "../components/feature-page/BenefitsSection.astro";
import CTASection from "../components/feature-page/CTASection.astro";

const title = "AI Event Smart-Connect - EventHex";
const description = "By leveraging advanced AI, EventHex personalizes networking opportunities, ensuring attendees connect with the right people for a truly impactful experience.";

const featureSections = [
  {
    sectionTitle: "Intelligent Matchmaking Based on Shared Interests",
    imageLeft: true,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/Group-1000002648.svg",
    imageAlt: "EventHex AI matchmaking based on shared interests visualization",
    items: [
      {
        title: "Data-Driven Profile Analysis",
        description: "AI analyzes shared interests, industries, and profile characteristics to match attendees.",
      },
      {
        title: "Purposeful Connections",
        description: "Attendees are matched based on professional goals and business aspirations.",
      },
      {
        title: "Real-Time Refinement",
        description: "AI tracks attendee's interactive behaviour as the event progresses to provide more accurate results.",
      },
    ],
  },
  {
    sectionTitle: "Personalized Networking Opportunities",
    imageLeft: false,
    dark: true,
    backgroundColor: "#000312",
    backgroundImage: "https://eventhex.ai/wp-content/uploads/2025/03/bg.svg",
    image: "https://eventhex.ai/wp-content/uploads/2025/04/iPhone-15.svg",
    imageAlt: "EventHex personalized networking app on smartphone",
    items: [
      {
        title: "Time-Bound Meeting Schedules",
        description: "Personalized meeting schedules for attendees based on other's availability.",
      },
      {
        title: "Industry-Specific Grouping",
        description: "AI aligns attendees with peers in their respective sector for better matchmaking.",
      },
      {
        title: "Exclusive VIP Connections",
        description: "Exclusive networking opportunities with high-profile guests, speakers for premium attendees.",
      },
    ],
  },
  {
    sectionTitle: "Enhanced Conversation Experience",
    imageLeft: true,
    image: "https://eventhex.ai/wp-content/uploads/2025/04/iPhone-15-Pro.svg",
    imageAlt: "EventHex AI conversation starter and dynamic grouping interface",
    items: [
      {
        title: "Conversation Starters",
        description: "AI provides tailored conversation prompts based on shared interests and professional backgrounds.",
      },
      {
        title: "Dynamic Grouping",
        description: "AI identifies and creates opportunities for group discussions, panel connections, and collaborations.",
      },
      {
        title: "Feedback Loop",
        description: "AI takes note and improves future recommendations based on users' feedback.",
      },
    ],
  },
];
---

<MarketingLayout {title} {description}>
  <!-- Hero -->
  <HeroSection
    eyebrow="AI Smart-Connect"
    title="AI Networking App for Meaningful Connections"
    description="By leveraging advanced AI, EventHex personalizes networking opportunities, ensuring attendees connect with the right people for a truly impactful experience."
    image="https://eventhex.ai/wp-content/uploads/2025/04/iPhone-16.svg"
    imageAlt="EventHex AI Smart-Connect networking app on iPhone"
  />

  <!-- Intro Section -->
  <section class="asc-intro">
    <div class="asc-intro__inner">
      <div class="asc-intro__content">
        <h2 class="asc-intro__title">Intelligent Networking for Meaningful Connections and Interactions</h2>
        <p class="asc-intro__desc">EventHex redefines event networking with AI Smart-Connect, a revolutionary system designed to create personalized networking opportunities for attendees sharing similar interests.</p>
      </div>
    </div>
  </section>

  <!-- Feature Sections -->
  {featureSections.map((section) => (
    <FeatureSection
      sectionTitle={section.sectionTitle}
      items={section.items}
      image={section.image}
      imageAlt={section.imageAlt}
      imageLeft={section.imageLeft}
      dark={section.dark}
      backgroundImage={section.backgroundImage}
      backgroundColor={section.backgroundColor}
    />
  ))}

  <!-- Why Choose Section -->
  <BenefitsSection
    sectionTitle="Why Choose EventHex's AI Networking App?"
    cards={[
      {
        icon: "https://eventhex.ai/wp-content/uploads/2025/03/Frame-1000002870.svg",
        title: "Effortless Connections",
        description: "Connects attendees with the right people automatically and with time efficiency.",
      },
      {
        icon: "https://eventhex.ai/wp-content/uploads/2025/03/Frame-1000002870-1.svg",
        title: "Personalized Experiences",
        description: "Tailors exclusive networking opportunities to attendees professional goals and interests.",
      },
      {
        icon: "https://eventhex.ai/wp-content/uploads/2025/03/Frame-1000002870-2.svg",
        title: "Industry-Leading Technology",
        description: "Stay ahead of everyone with cutting-edge AI technology that revolutionizes networking.",
      },
    ]}
  />

  <!-- Summary Section -->
  <section class="asc-summary">
    <div class="asc-summary__inner">
      <div class="asc-summary__media">
        <img src="https://eventhex.ai/wp-content/uploads/2025/04/Frame.svg" alt="EventHex AI Smart-Connect networking overview" width="500" height="400" loading="lazy" />
      </div>
      <div class="asc-summary__content">
        <h2 class="asc-summary__title">Ensure that Every Interaction Leads to Professional Growth!</h2>
        <p class="asc-summary__desc">With AI Smart-Connect, EventHex redefines event networking, ensuring that every interaction counts and every connection leads to meaningful professional growth.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection title={"Explore EventHex's\nAI Smart Connect Now!"} />
</MarketingLayout>

<style>
  .asc-intro {
    padding: 80px 20px;
    text-align: center;
  }

  .asc-intro__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .asc-intro__title {
    font-family: "Manrope", var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 60px;
    letter-spacing: -1px;
    color: #000000;
    margin: 0 0 20px;
  }

  .asc-intro__desc {
    font-family: "Inter", var(--font-body);
    font-size: 20px;
    font-weight: 400;
    line-height: 28px;
    color: #000000;
    margin: 0;
  }

  .asc-summary {
    padding: 80px 20px;
  }

  .asc-summary__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  .asc-summary__media {
    width: 50%;
  }

  .asc-summary__media img {
    width: 100%;
    height: auto;
    display: block;
  }

  .asc-summary__content {
    width: 50%;
  }

  .asc-summary__title {
    font-family: "Manrope", var(--font-heading);
    font-size: 48px;
    font-weight: 400;
    line-height: 60px;
    letter-spacing: -1px;
    color: #000000;
    margin: 0 0 16px;
  }

  .asc-summary__desc {
    font-family: "Inter", var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 26px;
    color: #475467;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .asc-intro__title,
    .asc-summary__title {
      font-size: 35px;
      line-height: 1.1;
    }

    .asc-summary__inner {
      gap: 40px;
    }
  }

  @media (max-width: 767px) {
    .asc-intro {
      padding: 40px 20px;
    }

    .asc-intro__title {
      font-size: 30px;
      line-height: 1.2;
    }

    .asc-summary {
      padding: 40px 20px;
    }

    .asc-summary__inner {
      flex-direction: column;
      gap: 30px;
    }

    .asc-summary__media,
    .asc-summary__content {
      width: 100%;
    }

    .asc-summary__title {
      font-size: 30px;
      line-height: 1.2;
    }
  }
</style>
