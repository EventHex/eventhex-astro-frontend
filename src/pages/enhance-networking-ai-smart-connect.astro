---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/ai-smart-connect/HeroSection.astro";
import BentoGridSection from "../components/ai-smart-connect/BentoGridSection.astro";
import FeatureCardsSection from "../components/ai-smart-connect/FeatureCardsSection.astro";
import CTASection from "../components/ai-smart-connect/CTASection.astro";
import BenefitCardsSection from "../components/ai-smart-connect/BenefitCardsSection.astro";
import FaqLightSection from "../components/ai-smart-connect/FaqLightSection.astro";

const title = "AI Event Smart-Connect | Intelligent Networking | EventHex";
const description = "By leveraging advanced AI, EventHex personalizes networking opportunities, ensuring attendees connect with the right people for a truly impactful experience.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex AI Smart-Connect",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/enhance-networking-ai-smart-connect/",
  description: description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "AI-powered networking included with EventHex event management platform",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "280",
    bestRating: "5",
  },
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/enhance-networking-ai-smart-connect/"
  ogImage="https://eventhex.ai/wp-content/uploads/2025/04/iPhone-16.svg"
  footerCtaTitle={"Explore EventHex's\nAI Smart Connect Now!"}
  footerCtaButtonText="Get a demo"
  footerCtaHref="/book-a-demo/"
>
  <HeroSection
    eyebrow="AI Smart-Connect"
    titleHtml="AI Networking App for <b>Meaningful</b> Event <b>Connections</b>"
    description={description}
    ctaText="Get a Free Demo"
    ctaHref="/book-a-demo/"
    image="https://eventhex.ai/wp-content/uploads/2025/04/iPhone-16.svg"
    imageAlt="EventHex AI Smart-Connect networking app on iPhone"
  />

  <BentoGridSection />

  <FeatureCardsSection />

  <CTASection />

  <BenefitCardsSection />

  <FaqLightSection />

  <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(softwareSchema)}</script>`} />
</MarketingLayout>

<style is:global>
  html { scroll-behavior: smooth; }
  main { background-color: #ffffff; }
</style>
