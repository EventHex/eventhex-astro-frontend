---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ICONS } from "../lib/featureIcons";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — White Label Event Management",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Full white-label multi-tenant event management platform for agencies, associations, and enterprises — run unlimited sub-brands with isolated data, custom domains, and Stripe Connect revenue splitting.",
  url: "https://eventhex.ai/white-label/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "White-Label Branding",
    "Custom Domains per Organization",
    "Multi-Tenant Data Isolation",
    "Stripe Connect Revenue Splitting",
    "Per-Franchise Module Gating",
    "Usage Tracking per Organization",
    "Reseller & Agency Packages",
    "Terminology Customization",
    "Unlimited Sub-Brands",
  ],
};
---

<FeatureV2Layout
  pageTitle="White Label Event Management Software for Agencies & Enterprises | EventHex"
  pageDescription="Run unlimited sub-brands and client organizations on one platform — white-label branding, custom domains, per-org data isolation, and Stripe Connect revenue splitting built for agencies and enterprises."
  canonical="https://eventhex.ai/white-label/"
  badge="White Label & Multi-Tenant"
  heroTitleLine1="Your Brand. Your Clients."
  heroTitleLine2="One Powerful Platform."
  heroCopy="Give every client or sub-brand their own fully branded event platform — custom logo, colors, domain, and terminology — while you manage everything from a single super-admin dashboard. Built for agencies, associations, and enterprises running events at scale."
  trustItems={["Unlimited Sub-Brands", "Per-Org Data Isolation", "Stripe Connect Revenue Splitting"]}
  stats={[
    { value: "∞", label: "Organizations Supported" },
    { value: "100%", label: "Data Isolation per Org" },
    { value: "0%", label: "Platform Fees on Revenue" },
    { value: "1", label: "Dashboard to Rule Them All" },
  ]}
  statsHeadline={{
    white1: "Unlimited brands.",
    accent: "Isolated data.",
    white2: "One admin.",
    accent2: "Zero conflicts.",
  }}
  bentoHeading="Everything You Need to Run a White-Label Event Business"
  bentoSubtitle="From custom domains and branded portals to Stripe Connect revenue splits and per-franchise module control — EventHex gives agencies and enterprises the infrastructure to sell event management as a service."
  bentoTabs={[
    {
      tab: "White-Label Branding",
      cards: [
        { title: "Custom Logo & Colors", desc: "Each organization gets its own logo, primary color palette, and branded event portal", illustration: ILLOS.palette },
        { title: "Custom Domains", desc: "Map any domain or subdomain to a client organization — no EventHex branding visible to their attendees", illustration: ILLOS.globe },
        { title: "Terminology Customization", desc: "Rename labels like 'attendee', 'ticket', or 'event' to match each client's industry language", illustration: ILLOS.document },
        { title: "Branded Email Templates", desc: "Confirmation, reminder, and check-in emails are sent from the client's domain with their branding", illustration: ILLOS.mail },
        { title: "White-Label Attendee Portal", desc: "Attendees see only the client's brand — from registration page through to mobile check-in", illustration: ILLOS.portal },
      ],
    },
    {
      tab: "Multi-Org Management",
      cards: [
        { title: "Unlimited Organizations", desc: "Create and manage as many client organizations or sub-brands as your business requires", illustration: ILLOS.building },
        { title: "Per-Org Data Isolation", desc: "Each organization's attendees, events, and financials are fully isolated — no data bleeds between clients", illustration: ILLOS.lock },
        { title: "Super-Admin Dashboard", desc: "Monitor all organizations from a single control panel — switch between clients in seconds", illustration: ILLOS.dashboard },
        { title: "Per-Franchise Module Gating", desc: "Enable or disable features per organization — give premium clients access to advanced modules", illustration: ILLOS.shield },
        { title: "Usage Tracking per Org", desc: "Track registrations, check-ins, revenue, and feature usage per organization for billing or reporting", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Reseller & Revenue",
      cards: [
        { title: "Stripe Connect Integration", desc: "Connect each organization's Stripe account and split revenue automatically at checkout", illustration: ILLOS.creditcard },
        { title: "Reseller Packages", desc: "Bundle EventHex capabilities into tiered packages you sell to clients at your own pricing", illustration: ILLOS.building },
        { title: "Agency Billing Controls", desc: "Invoice clients based on event volume, attendee count, or a flat monthly fee — your model, your rules", illustration: ILLOS.money },
        { title: "Revenue Split Configuration", desc: "Set platform fees, agency margins, and client payouts per organization with flexible percentage rules", illustration: ILLOS.chart },
        { title: "White-Label Invoicing", desc: "Financial documents go out under your agency brand, not EventHex", illustration: ILLOS.invoice },
      ],
    },
  ]}
  stackingHeading="White-Label Features"
  stackingHighlight="Built for Scale"
  stackingCards={[
    {
      title: "Every Client Gets Their Own Branded World",
      desc: "From the registration page to the check-in app, every touchpoint carries the client's logo, colors, and domain. Attendees never see EventHex — they see your client's brand delivered flawlessly.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "White-label event portal showing custom branding on a tablet",
    },
    {
      title: "Manage Every Client from One Super-Admin",
      desc: "Switch between organizations in seconds, monitor cross-org event activity, gate modules per client tier, and track usage for billing — all without leaving your super-admin dashboard.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Super-admin multi-organization dashboard on a tablet",
    },
    {
      title: "Stripe Connect Makes Revenue Splitting Effortless",
      desc: "Connect each client's Stripe account once. EventHex handles automatic revenue splitting at checkout — your agency margin, the client's share, and platform fees all routed correctly every time.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Stripe Connect revenue splitting configuration screen on a tablet",
    },
  ]}
  howItWorksHeading="How White-Label Event Management Works"
  steps={[
    { title: "Create a Client Organization", desc: "Add a new organization in your super-admin dashboard, assign a custom domain, and configure their branding — logo, colors, and terminology." },
    { title: "Connect Their Stripe Account", desc: "Use Stripe Connect to link the client's payment account. Configure your agency revenue split and any platform fees." },
    { title: "Gate Features to Their Package", desc: "Enable only the EventHex modules included in the client's package. Upgrade or restrict access any time from the super-admin panel." },
    { title: "Let Them Run Their Events", desc: "The client manages their own events, attendees, and check-ins in their isolated branded portal — you stay in control from the top level." },
  ]}
  ctaTitle="Ready to Launch Your White-Label Event Platform?"
  ctaCopy="See how EventHex lets agencies and enterprises deliver fully branded event experiences to every client — without building the infrastructure yourself."
  whyHeading="Why Agencies Choose EventHex for White-Label"
  whyCards={[
    { title: "True Multi-Tenancy", desc: "Full data isolation between every client organization — no shared tables, no data leakage", icon: ICONS.lock },
    { title: "Custom Domains", desc: "Each client gets their own domain — attendees never see EventHex branding", icon: ICONS.globe },
    { title: "Revenue Splitting", desc: "Stripe Connect handles automatic payout splits — set it once and let it run", icon: ICONS.money },
    { title: "Module Gating", desc: "Enable or restrict features per client tier — upsell advanced modules at any time", icon: ICONS.settings },
    { title: "Unlimited Scale", desc: "No cap on organizations, events, or sub-brands — grow your agency without platform limits", icon: ICONS.chart },
  ]}
  faqs={[
    { q: "What is white-label event management software?", a: "White-label event management software lets agencies, associations, or enterprises run a fully branded event platform under their own name — with custom logos, colors, domains, and terminology — powered by EventHex infrastructure. Clients and their attendees never see the EventHex name." },
    { q: "How many client organizations can I create?", a: "There is no limit. EventHex supports unlimited organizations, each with full data isolation, their own branding, and their own configuration. You manage them all from a single super-admin dashboard." },
    { q: "How does Stripe Connect revenue splitting work?", a: "Each client organization connects their own Stripe account via Stripe Connect. When an attendee pays, EventHex automatically routes the correct amount to the client, deducts your agency margin, and handles any platform fees — all configured once per organization." },
    { q: "Can I control which features each client can access?", a: "Yes. Per-franchise module gating lets you enable or disable specific EventHex features per organization. This allows you to sell tiered packages and upgrade clients to advanced modules at any time." },
    { q: "Is each client's data truly isolated?", a: "Yes. Every organization has fully isolated data — attendee lists, events, financials, and reports are completely separate. There is no risk of one client's data appearing in another client's dashboard." },
    { q: "Can clients use their own domain name?", a: "Yes. You can map any custom domain or subdomain to a client organization. Their attendees register and check in on the client's domain — EventHex branding is completely hidden." },
  ]}
  jsonLd={jsonLd}
/>
