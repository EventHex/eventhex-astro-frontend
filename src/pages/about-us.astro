---
import EditorialCard from "../components/editorial/EditorialCard.astro";
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { decodeHtmlEntities, normalizeBlogPosts } from "../lib/editorial";
import { getPosts } from "../lib/wordpress";

const title = "About Us - EventHex";
const description = "At EventHex, we're transforming the ways event organizers and recurring events approach event personalisation, attendee retention, and event campaigning.";
const rawPosts = await getPosts({ per_page: "6" });
const latestPosts = normalizeBlogPosts(rawPosts)
  .slice(0, 6)
  .map((post) => {
    const sourcePost = rawPosts.find((candidate) => candidate.id === post.id);
    const authorTerm = sourcePost?._embedded?.["wp:term"]
      ?.flat()
      .find((term) => term.taxonomy === "authors");

    return {
      ...post,
      author: authorTerm ? decodeHtmlEntities(authorTerm.name) : post.author,
    };
  });
---

<MarketingLayout {title} {description}>
  <section class="about-hero">
    <div class="about-hero__outer">
      <div class="about-hero__inner">
        <h1 class="about-hero__title">Built To Keep Them Recurring</h1>
        <p class="about-hero__desc">At EventHex, we're transforming the ways event organizers and recurring events approach event personalisation, attendee retention, and event campaigning.</p>
      </div>
    </div>
  </section>

  <section class="about-showcase" aria-label="EventHex showcase">
    <div class="about-showcase__frame">
      <img
        src="/about/eventhex-conference-showcase.jpg"
        alt="EventHex team at a conference"
        width="1536"
        height="742"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <section class="about-editorial" aria-labelledby="about-editorial-title">
    <div class="about-editorial__inner">
      <a href="/blog/" class="about-editorial__link">Explore More</a>
      <h2 id="about-editorial-title" class="about-editorial__title">Your Countless Events Begin Here</h2>

      <div class="about-editorial__track">
        {latestPosts.map((post) => (
          <div class="about-editorial__item">
            <EditorialCard item={post} showDescription={false} />
          </div>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .about-hero {
    padding: 0 20px 20px;
  }

  .about-hero__outer {
    background: url("https://eventhex.ai/wp-content/uploads/2024/12/Untitled-design-11.png") center / cover no-repeat;
    max-width: 1140px;
    margin: 0 auto;
    padding: clamp(88px, 10vw, 128px) clamp(20px, 3vw, 36px) clamp(110px, 14vw, 170px);
  }

  .about-hero__inner {
    background: url("https://eventhex.ai/wp-content/uploads/2024/12/Frame-48096154-1.png") center / cover no-repeat;
    min-height: clamp(260px, 27vw, 300px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    padding: 0 clamp(16px, 3vw, 28px);
  }

  .about-hero__title {
    margin: 0;
    width: 100%;
    font-family: "Manrope", var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.25rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.045em;
    color: #22272f;
    white-space: nowrap;
  }

  .about-hero__desc {
    margin: 20px auto 0;
    width: 100%;
    max-width: 720px;
    font-family: "Inter", var(--font-body);
    font-size: clamp(1.125rem, 2vw, 1.75rem);
    font-weight: 400;
    line-height: 1.5;
    color: #475467;
    text-wrap: balance;
  }

  .about-showcase {
    background: url("https://eventhex.ai/wp-content/uploads/2024/12/bg-1-539x1024.png") center top / cover no-repeat;
    padding: 0 20px 72px;
  }

  .about-showcase__frame {
    width: min(80vw, 960px);
    height: 500px;
    margin: -315px auto 0;
    border-radius: 40px;
    border: 3px solid rgba(200, 168, 255, 0.5);
    overflow: hidden;
    background: #f7f6fb;
    box-shadow: 0 18px 48px rgba(32, 43, 67, 0.08);
  }

  .about-showcase__frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .about-editorial {
    padding: 0 20px 90px;
  }

  .about-editorial__inner {
    max-width: 1140px;
    margin: 0 auto;
  }

  .about-editorial__link {
    display: inline-flex;
    align-items: center;
    font-family: "Inter", var(--font-body);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.5;
    color: #302b3f;
    text-decoration: none;
    margin-bottom: 12px;
  }

  .about-editorial__title {
    margin: 0 0 40px;
    max-width: 760px;
    font-family: "Manrope", var(--font-heading);
    font-size: clamp(2.25rem, 4.5vw, 3rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #000000;
    text-wrap: balance;
  }

  .about-editorial__track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 12px;
    scrollbar-width: none;
  }

  .about-editorial__track::-webkit-scrollbar {
    display: none;
  }

  .about-editorial__item {
    flex: 0 0 calc((100% - 40px) / 3);
    min-width: 320px;
    scroll-snap-align: start;
  }

  .about-editorial__item :global(.editorial-card) {
    height: 100%;
  }

  @media (max-width: 1024px) {
    .about-hero {
      padding-bottom: 18px;
    }

    .about-hero__outer {
      padding-bottom: clamp(96px, 14vw, 150px);
    }

    .about-showcase {
      padding-bottom: 56px;
    }

    .about-showcase__frame {
      width: min(82vw, 920px);
      height: 460px;
      margin-top: -250px;
    }

    .about-editorial {
      padding-bottom: 72px;
    }

    .about-editorial__item {
      flex-basis: calc((100% - 20px) / 2);
    }

    .about-editorial__title {
      margin-bottom: 32px;
    }
  }

  @media (max-width: 767px) {
    .about-hero {
      padding: 0 16px 16px;
    }

    .about-hero__outer {
      padding: 64px 16px 92px;
    }

    .about-hero__inner {
      min-height: 0;
    }

    .about-hero__title {
      white-space: normal;
      max-width: 10ch;
    }

    .about-hero__desc {
      margin-top: 16px;
      font-size: 18px;
    }

    .about-showcase {
      padding: 0 16px 44px;
      background-size: 160% auto;
    }

    .about-showcase__frame {
      width: 100%;
      height: auto;
      margin-top: -84px;
      border-radius: 24px;
      border-width: 2px;
    }

    .about-showcase__frame img {
      height: auto;
      aspect-ratio: 1536 / 742;
    }

    .about-editorial {
      padding: 0 16px 56px;
    }

    .about-editorial__link {
      font-size: 16px;
      margin-bottom: 10px;
    }

    .about-editorial__title {
      margin-bottom: 24px;
    }

    .about-editorial__track {
      gap: 16px;
    }

    .about-editorial__item {
      flex-basis: 82%;
      min-width: 82%;
    }
  }
</style>
