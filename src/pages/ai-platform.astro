---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ICONS } from "../lib/featureIcons";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — AI Event Platform",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "EventHex AI event platform — AI Event Copilot, InstaRecap session summaries, InstaSnap photo delivery, AI Smart-Connect networking, AI Form Builder, AI website generation, audience insights, and AI social content.",
  url: "https://eventhex.ai/ai-platform/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "AI Event Copilot",
    "InstaRecap AI Session Summaries",
    "InstaSnap AI Photo Gallery",
    "AI Smart-Connect Networking",
    "AI Form Builder",
    "AI Website Generation",
    "AI Audience Insights",
    "AI Social Content Generation",
  ],
};
---

<FeatureV2Layout
  pageTitle="AI Event Platform — Every AI Feature in One Place | EventHex"
  pageDescription="EventHex's complete AI suite for event organizers — AI Event Copilot, InstaRecap session summaries, InstaSnap photo delivery, AI Smart-Connect networking, AI Form Builder, and more."
  canonical="https://eventhex.ai/ai-platform/"
  badge="AI-Powered Event Management"
  heroTitleLine1="The AI Event Platform"
  heroTitleLine2="Built for Modern Organizers"
  heroCopy="EventHex brings every AI capability under one roof — from a conversational copilot over your event data to instant session recaps, face-matched photo delivery, and embedding-based attendee networking. Run smarter events without the manual overhead."
  trustItems={["AI Event Copilot", "InstaRecap & InstaSnap", "Embedding-Based Smart-Connect"]}
  stats={[
    { value: "8+", label: "AI Features" },
    { value: "< 2 min", label: "Session Recap Generation" },
    { value: "95%+", label: "Face-Match Accuracy" },
    { value: "0%", label: "Platform Fees" },
  ]}
  statsHeadline={{
    white1: "Every event.",
    accent: "Every moment.",
    white2: "Powered by",
    accent2: "AI",
  }}
  bentoHeading="The Full EventHex AI Suite"
  bentoSubtitle="Eight distinct AI capabilities — each purpose-built for a different phase of your event — all available inside EventHex without any third-party integrations or add-ons."
  bentoTabs={[
    {
      tab: "Plan & Build",
      cards: [
        { title: "AI Event Copilot", desc: "Ask plain-English questions over your event data — registrations, revenue, session performance — and get instant answers without writing a single report.", illustration: ILLOS.bot },
        { title: "AI Form Builder", desc: "Describe the information you need from attendees; the AI drafts a complete, logic-driven registration form in seconds. Voice input supported.", illustration: ILLOS.mic },
        { title: "AI Website Generation", desc: "Generate a branded event website from your event details in one click — agenda, speakers, ticketing, and design included.", illustration: ILLOS.code },
        { title: "AI Audience Insights", desc: "Semantic search across attendee profiles and behaviour data surfaces actionable segments, trend signals, and personalisation opportunities before your event.", illustration: ILLOS.search },
      ],
    },
    {
      tab: "Engage Attendees",
      cards: [
        { title: "AI Smart-Connect Networking", desc: "Embedding-based attendee matching surfaces the most relevant connections for each participant — by role, interest, and goal — so networking is intentional, not random.", illustration: ILLOS.network },
        { title: "AI Social Copy & Image Generation", desc: "Generate on-brand social posts, announcement copy, and promotional images for every event milestone in one click.", illustration: ILLOS.camera },
        { title: "AI-Powered Semantic Search", desc: "Attendees search the event agenda, exhibitor list, and resource library with natural language — no keyword matching required.", illustration: ILLOS.search },
      ],
    },
    {
      tab: "Capture & Recap",
      cards: [
        { title: "InstaRecap — AI Session Recap", desc: "Transcribe any session and instantly produce a structured summary, key takeaways, and action items — shareable within minutes of the session ending.", illustration: ILLOS.document },
        { title: "InstaSnap — AI Photo Gallery", desc: "Attendees find every photo they appear in via face-match delivery — no manual tagging, no scrolling through thousands of images.", illustration: ILLOS.camera },
      ],
    },
  ]}
  stackingHeading="AI Capabilities"
  stackingHighlight="That Actually Ship"
  stackingCards={[
    {
      title: "AI Event Copilot — Your Event Data, Answered Instantly",
      desc: "Ask 'Which sessions have the highest drop-off?' or 'How does registration compare to last year?' and get a direct answer. The AI Event Copilot sits on top of your live event data so every question gets a real, specific response — not a dashboard to dig through. Learn more at /ai-event-copilot/.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "AI Event Copilot chat interface answering event data questions",
    },
    {
      title: "InstaRecap & InstaSnap — Deliver Value After Every Session",
      desc: "InstaRecap transcribes sessions and generates polished summaries with takeaways in under two minutes. InstaSnap uses face-match AI to deliver personalised photo collections to every attendee automatically. Both run without manual effort from your team. See /ai-session-recap/ and /ai-photo-gallery/ for details.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "InstaRecap session summary output and InstaSnap photo gallery on tablet",
    },
    {
      title: "AI Smart-Connect — Networking That Means Something",
      desc: "Embedding-based attendee matching analyses profiles, roles, and stated goals to surface the five most relevant people for each attendee to meet. No icebreaker surveys. No random speed-networking. Just high-signal introductions. Explore /enhance-networking-ai-smart-connect/ for the full feature.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "AI Smart-Connect networking matches displayed on mobile app",
    },
  ]}
  howItWorksHeading="How the EventHex AI Platform Works"
  steps={[
    { title: "Connect Your Event", desc: "Create or import your event. All AI features activate automatically — no API keys, no configuration, no separate subscriptions." },
    { title: "AI Works in the Background", desc: "InstaRecap transcribes sessions as they happen, InstaSnap processes photos as they upload, and Smart-Connect builds attendee matches before doors open." },
    { title: "Organizers Query, Attendees Discover", desc: "Your team asks the AI Copilot questions; attendees search the agenda semantically and find their networking matches. All surfaces update in real time." },
    { title: "Instant Post-Event Delivery", desc: "Session recaps, photo galleries, and audience insight reports are ready to share within minutes of the event closing — not days." },
  ]}
  ctaTitle="See Every AI Feature in One Demo"
  ctaCopy="Book a walkthrough of the full EventHex AI suite — from the Copilot to InstaSnap — and see how AI reduces manual work across every phase of your event."
  whyHeading="Why EventHex AI Is Different"
  whyCards={[
    { title: "Eight AI Features, One Platform", desc: "AI Copilot, InstaRecap, InstaSnap, Smart-Connect, Form Builder, website generation, audience insights, and social copy — all in EventHex with no add-ons required.", icon: ICONS.sparkles },
    { title: "Conversational Copilot", desc: "Ask questions in plain English and get answers from your live event data — no BI tool, no SQL, no waiting for reports. See /ai-event-copilot/ for a full walkthrough.", icon: ICONS.chat },
    { title: "Embedding-Based Networking", desc: "AI Smart-Connect uses vector embeddings — not keyword tags — to match attendees with the highest-signal connections. Visit /enhance-networking-ai-smart-connect/ to learn more.", icon: ICONS.network },
    { title: "Face-Match Photo Delivery", desc: "InstaSnap identifies every attendee in every photo and delivers a personal gallery without manual tagging. Details at /ai-photo-gallery/.", icon: ICONS.camera },
    { title: "Session Recaps in Minutes", desc: "InstaRecap transcribes and summarises any session — with key takeaways and action items — within two minutes of the session ending. Learn more at /ai-session-recap/.", icon: ICONS.document },
    { title: "AI Form Builder with Voice Input", desc: "Describe what data you need from attendees — the AI builds the form, adds logic, and structures the fields. Voice input supported. More at /ai-form-builder/.", icon: ICONS.mic },
  ]}
  faqs={[
    { q: "What AI features does EventHex include?", a: "EventHex includes eight AI capabilities: AI Event Copilot (conversational data queries), InstaRecap (session transcription and summaries), InstaSnap (face-match photo delivery), AI Smart-Connect (embedding-based attendee networking), AI Form Builder (voice-powered form generation), AI website generation, AI audience insights with semantic search, and AI social copy and image generation." },
    { q: "What is the AI Event Copilot?", a: "The AI Event Copilot is a conversational assistant trained on your live event data. Ask questions like 'How many registrations came from LinkedIn?' or 'Which ticket type has the highest churn?' and receive direct answers — no dashboards or reports required. Learn more at /ai-event-copilot/." },
    { q: "How does InstaRecap work?", a: "InstaRecap records and transcribes your sessions in real time. When a session ends, AI generates a structured summary with key takeaways and action items — ready to share in under two minutes. No post-production editing needed. See /ai-session-recap/ for details." },
    { q: "How does InstaSnap deliver photos to attendees?", a: "InstaSnap uses face-recognition AI to scan every event photo and identify which attendees appear in each image. Each attendee receives a personalised gallery containing only the photos they feature in — delivered automatically, with no manual tagging. More at /ai-photo-gallery/." },
    { q: "What is AI Smart-Connect?", a: "AI Smart-Connect uses vector embeddings to analyse attendee profiles, job roles, interests, and stated goals. It then surfaces the highest-signal networking matches for each attendee before and during the event. Details at /enhance-networking-ai-smart-connect/." },
    { q: "Do I need separate subscriptions for each AI feature?", a: "No. All EventHex AI features are bundled into the platform — no separate AI add-ons, no third-party API keys to manage, and no per-feature billing. Everything activates when you create your event." },
    { q: "Can I use the AI Form Builder without technical skills?", a: "Yes. Describe the information you need from attendees in plain English (or via voice), and the AI Form Builder generates a complete, logic-driven registration form. You can review and adjust before publishing. More at /ai-form-builder/." },
  ]}
  jsonLd={jsonLd}
/>
