---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/live-polling-qa/HeroSection.astro";
import StatsSection from "../components/live-polling-qa/StatsSection.astro";
import BentoGrid from "../components/live-polling-qa/BentoGrid.astro";
import FeatureCards from "../components/live-polling-qa/FeatureCards.astro";
import HowItWorksSection from "../components/live-polling-qa/HowItWorksSection.astro";
import CTASection from "../components/live-polling-qa/CTASection.astro";
import CoordinationTools from "../components/live-polling-qa/CoordinationTools.astro";
import FaqSection from "../components/live-polling-qa/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Live Polling & Q&A for Events — Real-Time Interaction | EventHex";
const description = "Live polling & Q&A for events — launch polls, moderate questions, and display results on venue screens in real time. Keep every session audience engaged.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Live Polling & Q&A",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/live-polling-qa/",
  description: "Live audience polling, moderated Q&A, real-time venue display, and session feedback collection for events.",
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Multiple-Choice Polls",
    "Word Clouds",
    "Live Stage Display",
    "Moderated Q&A",
    "Question Upvoting",
    "Session Feedback Forms",
    "NPS Surveys",
    "Speaker Reports",
    "Data Export",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/live-polling-qa/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
