---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Self-Service Portals",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Self-service portals for every event stakeholder — exhibitors, sponsors, speakers, reviewers, and AV teams each get their own dedicated portal with role-appropriate access.",
  url: "https://eventhex.ai/portals/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Exhibitor Portal",
    "Sponsor Portal",
    "Speaker Hub",
    "Reviewer Portal",
    "AV Team Portal",
    "Role-Based Access",
    "Rubric Scoring for Reviewers",
    "Booth & Lead Management",
    "Session Self-Service",
  ],
};
---

<FeatureV2Layout
  pageTitle="Event Self-Service Portals for Every Stakeholder | EventHex"
  pageDescription="Give exhibitors, sponsors, speakers, reviewers, and AV teams their own self-service portal. Each role logs in to a dedicated space built for their specific tasks — no shared logins, no back-and-forth emails."
  canonical="https://eventhex.ai/portals/"
  badge="Event Self-Service Portals"
  heroTitleLine1="Every Stakeholder,"
  heroTitleLine2="Their Own Portal"
  heroCopy="Exhibitors manage booths and leads. Sponsors upload assets and track ROI. Speakers control their profiles and sessions. Reviewers score abstracts with rubrics. AV teams coordinate on-site. Every role gets its own dedicated portal — built for exactly what they need to do."
  trustItems={["Role-Based Portal Access", "Exhibitor & Sponsor Portals", "Reviewer Rubric Scoring"]}
  stats={[
    { value: "5+", label: "Dedicated Portals" },
    { value: "100%", label: "Self-Service" },
    { value: "0", label: "Shared Login Headaches" },
    { value: "Every", label: "Role Covered" },
  ]}
  statsHeadline={{
    white1: "Every role,",
    accent: "their own space.",
    white2: "Zero",
    accent2: "back-and-forth",
  }}
  bentoHeading="Dedicated Portals for Every Event Stakeholder"
  bentoSubtitle="Instead of one monolithic event platform that everyone shares, EventHex gives each stakeholder type a focused portal — with only the tools and data that role needs. Less confusion, more action."
  bentoTabs={[
    {
      tab: "Exhibitor & Sponsor",
      cards: [
        { title: "Exhibitor Booth Management", desc: "Exhibitors log in to manage their booth details, upload company profiles, and configure what visitors see on the event floor plan — with no organizer involvement required. See /exhibitor-management/ for full exhibitor features.", illustration: ILLOS.portal },
        { title: "Lead Capture & Export", desc: "Exhibitors capture leads by scanning attendee badges directly in their portal and export the lead list at any time during or after the event", illustration: ILLOS.clipboard },
        { title: "Exhibitor Team Access", desc: "Add multiple team members to a single exhibitor account so booth staff, marketing managers, and logistics contacts all have the right access", illustration: ILLOS.user },
        { title: "Sponsor Asset Upload", desc: "Sponsors upload logos, banner ads, and promotional content directly to their portal — assets are instantly available to the event organizer for placement. See /sponsor-management/ for full sponsor features.", illustration: ILLOS.document },
        { title: "Sponsor ROI Dashboard", desc: "Sponsors see their impressions, logo placements, booth traffic, and lead counts in a live dashboard built specifically for tracking event sponsorship return", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Reviewer & Speaker",
      cards: [
        { title: "Reviewer Portal with Rubric Scoring", desc: "Peer reviewers for your call for papers log in to a dedicated portal where they see only the abstracts assigned to them, score each submission against a structured rubric, and leave written feedback — with no access to other reviewers' scores until the review period closes. See /call-for-papers/ for full CFP features.", illustration: ILLOS.clipboard },
        { title: "Conflict of Interest Controls", desc: "Reviewers can flag conflicts on individual submissions and are automatically excluded from those assignments — enforcing academic integrity without organizer intervention", illustration: ILLOS.user },
        { title: "Review Progress Tracking", desc: "Organizers see completion rates per reviewer in real time — identify who's behind and send targeted reminders without exporting spreadsheets", illustration: ILLOS.clipboard },
        { title: "Speaker Hub", desc: "Accepted speakers log into the Speaker Hub to complete their profile, upload a photo and bio, confirm session details, and manage their presentation materials. See /speaker-management/ for full speaker features.", illustration: ILLOS.portal },
        { title: "Session Self-Service", desc: "Speakers update their session title, abstract, co-presenters, and A/V requirements directly from their hub — organizers see changes instantly without email chains", illustration: ILLOS.document },
      ],
    },
    {
      tab: "On-site / AV",
      cards: [
        { title: "AV Team Portal", desc: "Audio-visual and production teams get a dedicated portal showing room assignments, session run-of-show, speaker A/V requirements, and last-minute changes — without access to registration or financial data", illustration: ILLOS.mic },
        { title: "Real-Time Schedule View", desc: "The AV portal reflects the live event schedule — room changes, session swaps, and speaker cancellations propagate immediately so the on-site team is always working from current information", illustration: ILLOS.calendar },
        { title: "A/V Requirement Summary", desc: "Each session's A/V checklist — microphone type, screen configuration, recording requirements, accessibility needs — is visible per room and per time slot", illustration: ILLOS.mic },
        { title: "On-Site Coordination Notes", desc: "Organizers can push notes directly to the AV portal for time-sensitive updates without calling or texting individual team members", illustration: ILLOS.document },
        { title: "Role-Isolated Access", desc: "AV staff see only what's relevant to their job. Separate role permissions ensure that logistics staff can't accidentally edit registration data or financial records", illustration: ILLOS.user },
      ],
    },
  ]}
  stackingHeading="Self-Service Portals"
  stackingHighlight="for Every Role"
  stackingCards={[
    {
      title: "Exhibitors Run Their Own Booth — Without Emailing You",
      desc: "The Exhibitor Portal puts booth management, lead capture, and team access entirely in the exhibitor's hands. They update their profile, scan badges, and export leads independently. Your team stops being the intermediary for every exhibitor request.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Exhibitor self-service portal showing booth management and lead capture tools",
    },
    {
      title: "Peer Review at Scale — With Rubrics and Conflict Controls",
      desc: "The Reviewer Portal is built for rigorous call-for-papers review. Reviewers see only their assigned submissions, score against a structured rubric, flag conflicts of interest, and leave written feedback. Organizers track progress in real time and close the review round when ready.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Reviewer portal with rubric scoring interface for call-for-papers abstract review",
    },
    {
      title: "Speakers Self-Manage Their Profiles and Sessions",
      desc: "The Speaker Hub lets accepted speakers complete their profiles, upload bios and photos, confirm session details, and update A/V requirements — all without emailing the organizer. Changes sync immediately to the event schedule and the AV team portal.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Speaker hub portal showing session management and profile completion tools",
    },
  ]}
  howItWorksHeading="How EventHex Portals Work"
  steps={[
    { title: "Assign Roles to Stakeholders", desc: "Invite exhibitors, sponsors, speakers, reviewers, and AV staff from the EventHex organizer dashboard. Each person receives an email with access to their specific portal — nothing else." },
    { title: "Each Stakeholder Logs Into Their Own Space", desc: "Exhibitors see booth tools. Reviewers see their assigned abstracts. Speakers see their session details. AV staff see room schedules. No shared login, no confusion about permissions." },
    { title: "Stakeholders Complete Their Tasks Independently", desc: "Exhibitors upload assets and capture leads. Reviewers score submissions. Speakers confirm sessions. Everything happens in the portal without organizer involvement on every step." },
    { title: "You Monitor Progress From the Organizer Dashboard", desc: "See reviewer completion rates, exhibitor portal activity, speaker profile status, and sponsor asset uploads from one central dashboard — and step in only when something needs attention." },
  ]}
  ctaTitle="Ready to Give Every Stakeholder Their Own Space?"
  ctaCopy="See how EventHex portals replace the back-and-forth with self-service — so exhibitors, speakers, reviewers, and sponsors can manage their own tasks without emailing you."
  whyHeading="Why Event Teams Choose EventHex Portals"
  whyCards={[
    { title: "Role-Based Access", desc: "Each stakeholder sees only what their role requires — no shared logins", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
    { title: "True Self-Service", desc: "Exhibitors, speakers, and sponsors complete tasks independently", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>' },
    { title: "Rubric Review", desc: "Structured rubric scoring for rigorous call-for-papers review", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
    { title: "Live Schedule for AV Teams", desc: "On-site AV portal reflects the current schedule in real time", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
    { title: "Sponsor ROI Visibility", desc: "Sponsors track their impressions, leads, and placement in their own dashboard", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "What portals does EventHex offer?", a: "EventHex provides five dedicated portals: the Exhibitor Portal (booth management, lead capture, team access), the Sponsor Portal (asset upload, ROI dashboard), the Speaker Hub (profile and session self-service), the Reviewer Portal (rubric-based abstract scoring for call-for-papers), and the AV Team Portal (on-site schedule coordination)." },
    { q: "Can exhibitors manage their own booths without contacting the organizer?", a: "Yes. The Exhibitor Portal is fully self-service. Exhibitors update their company profile, manage booth details, add team members, capture leads by scanning badges, and export their lead list — all without organizer involvement. See the exhibitor management page for full details." },
    { q: "How does the Reviewer Portal handle peer review?", a: "Reviewers log in to see only the abstracts assigned to them. Each submission is scored against a structured rubric you define, and reviewers can leave written feedback. Conflict of interest flags let reviewers recuse themselves from specific submissions. Organizers track completion rates in real time from the organizer dashboard." },
    { q: "What can speakers do in the Speaker Hub?", a: "Speakers complete their profile (bio, photo, social links), confirm session titles and abstracts, add co-presenters, and specify A/V requirements — all from the Speaker Hub. Changes sync immediately to the event schedule and the AV team's portal view." },
    { q: "Does the AV Team Portal update in real time?", a: "Yes. The AV portal reflects the live event schedule. Room changes, session swaps, and speaker cancellations appear immediately so on-site AV staff are always working from current information. Organizers can also push notes directly to the portal for time-sensitive updates." },
    { q: "Are portals related to other EventHex features?", a: "Yes. The Exhibitor Portal connects to EventHex's exhibitor management tools at /exhibitor-management/. The Sponsor Portal extends /sponsor-management/. The Speaker Hub is part of /speaker-management/. The Reviewer Portal is built for /call-for-papers/ workflows. Each portal surfaces the same underlying data through a role-appropriate interface." },
  ]}
  jsonLd={jsonLd}
/>
