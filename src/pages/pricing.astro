---
import MarketingLayout from "../layouts/MarketingLayout.astro";

// TODO: placeholder prices — owner to set real + geo-based pricing before going live
const tiers = [
  {
    name: "Free",
    priceMonthly: "$—",       // TODO: set real price
    tagline: "Get started at no cost",
    popular: false,
    ctaLabel: "Get Started Free",
    ctaHref: "/book-a-demo/",
    features: [
      "1 active event",
      "Up to 100 attendees",
      "Basic registration & ticketing",
      "Event website builder",
      "Email notifications",
      "Community support",
    ],
  },
  {
    name: "Starter",
    priceMonthly: "$—",       // TODO: set real price
    tagline: "For small teams running regular events",
    popular: false,
    ctaLabel: "Book a Demo",
    ctaHref: "/book-a-demo/",
    features: [
      "5 active events",
      "Up to 500 attendees per event",
      "Registration & ticketing",
      "AI Form Builder",
      "WhatsApp & email notifications",
      "Basic analytics",
      "Email support",
    ],
  },
  {
    name: "Pro",
    priceMonthly: "$—",       // TODO: set real price
    tagline: "For growing event teams",
    popular: true,
    ctaLabel: "Book a Demo",
    ctaHref: "/book-a-demo/",
    features: [
      "Unlimited events",
      "Up to 2,000 attendees per event",
      "Registration, ticketing & check-in",
      "AI Copilot + AI Session Recap",
      "Face-match check-in",
      "Virtual & hybrid support",
      "WhatsApp campaigns",
      "Priority support",
    ],
  },
  {
    name: "Premium",
    priceMonthly: "$—",       // TODO: set real price
    tagline: "For high-volume & enterprise-grade events",
    popular: false,
    ctaLabel: "Book a Demo",
    ctaHref: "/book-a-demo/",
    features: [
      "Unlimited events & attendees",
      "Full registration, ticketing & check-in suite",
      "Full AI Copilot suite",
      "Face-match check-in",
      "Virtual & hybrid",
      "WhatsApp campaigns",
      "White-label mobile app",
      "Advanced integrations",
      "Dedicated account manager",
    ],
  },
  {
    name: "Enterprise",
    priceMonthly: "Custom",
    tagline: "Tailored for large organisations",
    popular: false,
    ctaLabel: "Contact Sales",
    ctaHref: "/book-a-demo/",
    features: [
      "Everything in Premium",
      "Custom attendee limits",
      "Custom integrations & API access",
      "SLA-backed uptime",
      "On-premise / private-cloud option",
      "Dedicated implementation support",
      "Custom contracts & invoicing",
    ],
  },
];

// Feature comparison matrix rows
// Values: true = included, false = not included, string = qualifier
const matrixRows: {
  capability: string;
  free: boolean | string;
  starter: boolean | string;
  pro: boolean | string;
  premium: boolean | string;
  enterprise: boolean | string;
}[] = [
  { capability: "Events",                  free: "1",        starter: "5",         pro: "Unlimited",  premium: "Unlimited",  enterprise: "Unlimited" },
  { capability: "Attendees per event",     free: "100",      starter: "500",       pro: "2,000",      premium: "Unlimited",  enterprise: "Custom" },
  { capability: "Registration & Ticketing",free: true,       starter: true,        pro: true,         premium: true,         enterprise: true },
  { capability: "AI Copilot",              free: false,      starter: false,       pro: true,         premium: true,         enterprise: true },
  { capability: "Check-in / Face-match",   free: false,      starter: false,       pro: true,         premium: true,         enterprise: true },
  { capability: "Virtual & Hybrid",        free: false,      starter: false,       pro: true,         premium: true,         enterprise: true },
  { capability: "WhatsApp campaigns",      free: false,      starter: "Basic",     pro: true,         premium: true,         enterprise: true },
  { capability: "White-label",             free: false,      starter: false,       pro: false,        premium: true,         enterprise: true },
  { capability: "Integrations",            free: false,      starter: "Basic",     pro: "Standard",   premium: "Advanced",   enterprise: "Custom" },
  { capability: "Support",                 free: "Community", starter: "Email",    pro: "Priority",   premium: "Dedicated",  enterprise: "SLA-backed" },
];

const faqs = [
  {
    q: "How does billing work?",
    a: "Plans are billed monthly or annually. Annual billing offers a discount — exact rates will be published when pricing goes live. You can cancel anytime from your account settings.",
  },
  {
    q: "Can I upgrade or downgrade my plan?",
    a: "Yes. You can upgrade at any time and the new rate is prorated for the remainder of the billing period. Downgrades take effect at the start of the next billing cycle.",
  },
  {
    q: "What is the refund policy?",
    a: "Refund terms will be detailed in our Cancellation & Refund Policy before launch. For questions, contact our support team.",
  },
  {
    q: "Are taxes (GST / VAT) included in the listed prices?",
    a: "Applicable taxes depend on your billing country. Taxes will be calculated and shown at checkout. Indian customers will see GST applied where required.",
  },
  {
    q: "Do you support multiple currencies and geo-based pricing?",
    a: "Yes — EventHex plans to support pricing in local currencies for key markets. Geo-based pricing is being finalized and will be reflected at checkout based on your billing country.",
  },
  {
    q: "Is there a free trial on paid plans?",
    a: "Trial details are being confirmed. Book a demo to explore the platform with guidance from our team.",
  },
];
---

<MarketingLayout
  title="Pricing | EventHex"
  description="Flexible EventHex pricing plans for every event team — from free to enterprise. 0% platform fee, bring your own payment gateway."
  robots="noindex, nofollow"
  showFooterCta={true}
  footerCtaTitle="Ready to see EventHex in action?"
  footerCtaButtonText="Book a Demo"
  footerCtaHref="/book-a-demo/"
>
  <!-- Draft banner -->
  <div style="background:#FFF8E1;border-bottom:1px solid #FFE082;padding:10px 20px;text-align:center;font-size:0.85rem;color:#795548;font-family:var(--font-body);">
    <strong>Draft page — pricing is being finalized.</strong> Plans and prices shown are placeholders and subject to change.
  </div>

  <!-- Hero -->
  <section style="background:var(--surface-light);padding:80px 20px 60px;text-align:center;">
    <div style="max-width:720px;margin:0 auto;">
      <span style="display:inline-block;background:var(--surface-blue-tint);color:var(--brand-blue);font-size:0.8rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:6px 14px;border-radius:999px;margin-bottom:20px;font-family:var(--font-body);">Pricing</span>
      <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3rem);font-weight:800;color:var(--heading-dark);line-height:1.15;margin-bottom:16px;">
        Simple pricing that scales<br>with your events
      </h1>
      <p style="font-size:1.1rem;color:var(--subheading-gray);line-height:1.6;margin-bottom:24px;">
        One platform for every event type — conferences, workshops, hybrid, virtual.
        No hidden fees. No per-attendee surprises.
      </p>
      <p style="font-size:0.9rem;color:var(--body-light);background:white;display:inline-block;padding:8px 20px;border-radius:8px;border:1px solid var(--surface-card-border);">
        Prices shown are placeholders — final monthly &amp; annual rates will be published soon.
        Annual plans will include a discount.
      </p>
    </div>
  </section>

  <!-- Tier cards -->
  <section style="padding:60px 20px 80px;background:white;">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:24px;align-items:start;">
      {tiers.map((tier) => (
        <div style={`
          background:${tier.popular ? "var(--brand-blue)" : "white"};
          color:${tier.popular ? "white" : "var(--heading-dark)"};
          border:2px solid ${tier.popular ? "var(--brand-blue)" : "var(--surface-card-border)"};
          border-radius:16px;
          padding:32px 24px;
          position:relative;
          box-shadow:${tier.popular ? "0 8px 32px rgba(55,93,251,0.25)" : "0 2px 8px rgba(0,0,0,0.05)"};
        `}>
          {tier.popular && (
            <span style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:#FFD700;color:#1a1a1a;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;padding:4px 14px;border-radius:999px;white-space:nowrap;font-family:var(--font-body);">
              Most Popular
            </span>
          )}
          <h2 style={`font-family:var(--font-heading);font-size:1.25rem;font-weight:700;margin-bottom:6px;color:${tier.popular ? "white" : "var(--heading-dark)"};`}>
            {tier.name}
          </h2>
          <p style={`font-size:0.85rem;margin-bottom:20px;color:${tier.popular ? "rgba(255,255,255,0.8)" : "var(--subheading-gray)"};`}>
            {tier.tagline}
          </p>
          <div style="margin-bottom:24px;">
            <span style={`font-family:var(--font-heading);font-size:2.4rem;font-weight:800;color:${tier.popular ? "white" : "var(--heading-dark)"};`}>
              {tier.priceMonthly}
            </span>
            {tier.priceMonthly !== "Custom" && (
              <span style={`font-size:0.85rem;margin-left:4px;color:${tier.popular ? "rgba(255,255,255,0.7)" : "var(--body-light)"};`}>/mo</span>
            )}
          </div>
          <ul style="list-style:none;padding:0;margin:0 0 28px;display:flex;flex-direction:column;gap:10px;">
            {tier.features.map((f) => (
              <li style={`display:flex;align-items:flex-start;gap:8px;font-size:0.875rem;color:${tier.popular ? "rgba(255,255,255,0.9)" : "var(--body-gray)"};line-height:1.4;`}>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style={`flex-shrink:0;margin-top:2px;`}>
                  <circle cx="8" cy="8" r="8" fill={tier.popular ? "rgba(255,255,255,0.25)" : "var(--surface-blue-tint)"} />
                  <path d="M5 8l2 2 4-4" stroke={tier.popular ? "white" : "var(--brand-blue)"} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={tier.ctaHref} style={`
            display:block;
            text-align:center;
            padding:12px;
            border-radius:8px;
            font-weight:600;
            font-size:0.9rem;
            text-decoration:none;
            font-family:var(--font-body);
            background:${tier.popular ? "white" : "var(--brand-blue)"};
            color:${tier.popular ? "var(--brand-blue)" : "white"};
            transition:opacity 0.15s;
          `}>
            {tier.ctaLabel}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- 0% platform fee callout -->
  <section style="background:var(--surface-blue-tint);padding:48px 20px;">
    <div style="max-width:800px;margin:0 auto;text-align:center;">
      <div style="font-size:2rem;margin-bottom:12px;">💳</div>
      <h2 style="font-family:var(--font-heading);font-size:1.6rem;font-weight:800;color:var(--heading-dark);margin-bottom:12px;">
        0% platform fee — bring your own payment gateway
      </h2>
      <p style="font-size:1rem;color:var(--subheading-gray);line-height:1.6;max-width:580px;margin:0 auto;">
        EventHex charges <strong>zero platform fees</strong> on ticket revenue.
        Connect Stripe, Razorpay, Tap, or your preferred gateway and keep 100% of every ticket sold.
        You pay only the gateway's own processing fee.
      </p>
    </div>
  </section>

  <!-- Feature comparison matrix -->
  <section style="padding:80px 20px;background:white;">
    <div style="max-width:1100px;margin:0 auto;">
      <h2 style="font-family:var(--font-heading);font-size:1.8rem;font-weight:800;color:var(--heading-dark);text-align:center;margin-bottom:48px;">
        What's included in each plan
      </h2>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-family:var(--font-body);font-size:0.875rem;">
          <thead>
            <tr>
              <th style="text-align:left;padding:12px 16px;background:var(--surface-light);color:var(--heading-dark);font-weight:700;border-bottom:2px solid var(--surface-card-border);min-width:180px;">
                Capability
              </th>
              {tiers.map((tier) => (
                <th style={`
                  text-align:center;
                  padding:12px 16px;
                  font-weight:700;
                  border-bottom:2px solid var(--surface-card-border);
                  background:${tier.popular ? "var(--brand-blue)" : "var(--surface-light)"};
                  color:${tier.popular ? "white" : "var(--heading-dark)"};
                  min-width:110px;
                `}>
                  {tier.name}
                  {tier.popular && <span style="display:block;font-size:0.68rem;font-weight:600;opacity:0.85;margin-top:2px;">Most Popular</span>}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {matrixRows.map((row, i) => {
              const cells = [row.free, row.starter, row.pro, row.premium, row.enterprise];
              return (
                <tr style={`background:${i % 2 === 0 ? "white" : "var(--surface-light)"};`}>
                  <td style="padding:12px 16px;color:var(--heading-dark);font-weight:500;border-bottom:1px solid var(--surface-card-border);">
                    {row.capability}
                  </td>
                  {cells.map((val, ci) => {
                    const isPopularCol = ci === 2; // Pro
                    return (
                      <td style={`
                        text-align:center;
                        padding:12px 16px;
                        border-bottom:1px solid var(--surface-card-border);
                        background:${isPopularCol ? "rgba(55,93,251,0.04)" : "inherit"};
                        color:${typeof val === "string" ? "var(--body-gray)" : val ? "var(--brand-blue)" : "var(--label-gray)"};
                        font-weight:${typeof val === "boolean" ? "400" : "500"};
                      `}>
                        {typeof val === "boolean"
                          ? val
                            ? "✓"
                            : "—"
                          : val}
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:80px 20px;background:var(--surface-light);">
    <div style="max-width:760px;margin:0 auto;">
      <h2 style="font-family:var(--font-heading);font-size:1.8rem;font-weight:800;color:var(--heading-dark);text-align:center;margin-bottom:48px;">
        Frequently asked questions
      </h2>
      <div style="display:flex;flex-direction:column;gap:16px;">
        {faqs.map((faq) => (
          <details style="background:white;border:1px solid var(--surface-card-border);border-radius:12px;padding:0;overflow:hidden;">
            <summary style="padding:20px 24px;cursor:pointer;font-weight:600;color:var(--heading-dark);font-family:var(--font-body);font-size:0.95rem;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              {faq.q}
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="flex-shrink:0;margin-left:12px;transition:transform 0.2s;">
                <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="var(--brand-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <p style="padding:0 24px 20px;color:var(--body-gray);font-size:0.9rem;line-height:1.65;margin:0;">
              {faq.a}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section style="padding:80px 20px;background:var(--dark-card-bg);text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-family:var(--font-heading);font-size:1.8rem;font-weight:800;color:white;margin-bottom:12px;">
        Not sure which plan is right for you?
      </h2>
      <p style="font-size:1rem;color:rgba(255,255,255,0.7);margin-bottom:32px;line-height:1.6;">
        Talk to our team — we'll walk you through the platform and help you pick the right plan for your events.
      </p>
      <a href="/book-a-demo/" style="display:inline-block;background:var(--brand-blue);color:white;font-weight:700;font-size:1rem;padding:14px 36px;border-radius:8px;text-decoration:none;font-family:var(--font-body);">
        Book a Demo
      </a>
    </div>
  </section>
</MarketingLayout>
