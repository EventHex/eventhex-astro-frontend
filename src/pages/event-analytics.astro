---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-analytics/HeroSection.astro";
import StatsSection from "../components/event-analytics/StatsSection.astro";
import BentoGrid from "../components/event-analytics/BentoGrid.astro";
import FeatureCards from "../components/event-analytics/FeatureCards.astro";
import HowItWorksSection from "../components/event-analytics/HowItWorksSection.astro";
import CTASection from "../components/event-analytics/CTASection.astro";
import CoordinationTools from "../components/event-analytics/CoordinationTools.astro";
import FaqSection from "../components/event-analytics/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Event Analytics & Reports — Real-Time Dashboards | EventHex";
const description = "Real-time analytics across registrations, attendance, engagement, revenue, and sponsor ROI with AI-powered insights.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Analytics & Reports",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: "https://eventhex.ai/event-analytics/",
  description: "Real-time event analytics with dashboards, sponsor ROI reports, AI insights, and data export for events of all sizes.",
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "Real-Time Dashboards",
    "Registration Analytics",
    "Revenue Tracking",
    "Session Analytics",
    "Sponsor ROI Reports",
    "AI-Powered Insights",
    "Custom Report Builder",
    "Multi-Event Comparison",
    "API Data Access",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-analytics/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
