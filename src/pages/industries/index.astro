---
import MarketingLayout from "../../layouts/MarketingLayout.astro";

const title = "Event Management Software for Every Industry | EventHex";
const description = "EventHex powers conferences, trade shows, and corporate events across 15+ industries worldwide. Find the right event management solution for your vertical.";

const industries = [
  { name: "Technology", color: "#6366F1", tagline: "Tech conferences, SaaS summits, and developer events", slug: "technology" },
  { name: "Healthcare", color: "#EF4444", tagline: "Medical conferences, pharma summits, and health expos", slug: "healthcare" },
  { name: "Associations", color: "#10B981", tagline: "Member events, annual meetings, and chapter conferences", slug: "associations" },
  { name: "Education", color: "#F59E0B", tagline: "University events, academic conferences, and graduation ceremonies", slug: "education" },
  { name: "Finance", color: "#0EA5E9", tagline: "Banking summits, fintech conferences, and investor meetups", slug: "finance" },
  { name: "Real Estate", color: "#8B5CF6", tagline: "Property expos, developer launches, and broker events", slug: "real-estate" },
  { name: "Hospitality", color: "#EC4899", tagline: "Hotel conferences, tourism summits, and F&B events", slug: "hospitality" },
  { name: "Government", color: "#475467", tagline: "Policy summits, public consultations, and civic events", slug: "government" },
  { name: "Media", color: "#FF6B00", tagline: "Film festivals, media conferences, and content creator events", slug: "media" },
  { name: "Manufacturing", color: "#14B8A6", tagline: "Industrial expos, trade fairs, and supply chain summits", slug: "manufacturing" },
  { name: "Retail", color: "#E11D48", tagline: "Retail expos, e-commerce conferences, and brand launch events", slug: "retail" },
  { name: "Sports", color: "#2563EB", tagline: "Sports events, fitness expos, and esports tournaments", slug: "sports" },
  { name: "NGO", color: "#059669", tagline: "Fundraising galas, awareness campaigns, and volunteer events", slug: "ngo" },
  { name: "Cultural", color: "#9333EA", tagline: "Cultural festivals, art exhibitions, and heritage events", slug: "cultural" },
  { name: "Middle East", color: "#D97706", tagline: "GCC summits, MENA conferences, and regional trade events", slug: "middle-east" },
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "EventHex Industry Solutions",
  description: description,
  numberOfItems: industries.length,
  itemListElement: industries.map((ind, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: `Event Management for ${ind.name}`,
    url: `https://eventhex.ai/industries/${ind.slug}/`,
  })),
};

const iconMap: Record<string, string> = {
  Technology: "💻",
  Healthcare: "🏥",
  Associations: "🤝",
  Education: "🎓",
  Finance: "💰",
  "Real Estate": "🏢",
  Hospitality: "🏨",
  Government: "🏛️",
  Media: "🎬",
  Manufacturing: "🏭",
  Retail: "🛍️",
  Sports: "⚽",
  NGO: "🌍",
  Cultural: "🎭",
  "Middle East": "🕌",
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/industries/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <!-- HERO -->
  <section class="indhub-hero">
    <div class="indhub-hero__inner">
      <span class="indhub-hero__badge animate-on-scroll">Industries</span>
      <h1 class="indhub-hero__title animate-on-scroll" data-delay="80">
        Event Management Software for <strong>Every Industry</strong>
      </h1>
      <p class="indhub-hero__sub animate-on-scroll" data-delay="160">
        EventHex powers conferences, trade shows, and corporate events across 15+ industries worldwide.
      </p>
      <a href="/book-a-demo/" class="indhub-btn indhub-btn--primary animate-on-scroll" data-delay="240">Book a Free Demo</a>
    </div>
  </section>

  <!-- INDUSTRY GRID -->
  <section class="indhub-grid-section">
    <div class="indhub-grid-section__inner">
      <div class="indhub-grid">
        {industries.map((ind, i) => (
          <a href={`/industries/${ind.slug}/`} class="indhub-card animate-on-scroll" data-delay={String(i * 50)}>
            <span class="indhub-card__icon" style={`background: ${ind.color}15; color: ${ind.color};`}>
              {iconMap[ind.name] || "🏢"}
            </span>
            <h2 class="indhub-card__name">{ind.name}</h2>
            <p class="indhub-card__tagline">{ind.tagline}</p>
            <span class="indhub-card__link" style={`color: ${ind.color};`}>Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="indhub-cta">
    <div class="indhub-cta__inner">
      <div class="indhub-cta__card animate-on-scroll">
        <div class="indhub-cta__glow indhub-cta__glow--1"></div>
        <div class="indhub-cta__glow indhub-cta__glow--2"></div>
        <h2 class="indhub-cta__title">Need a Solution for Your Industry?</h2>
        <p class="indhub-cta__copy">EventHex adapts to any vertical — from intimate workshops to 10,000+ attendee conferences. Talk to our team and see how we can support your events.</p>
        <div class="indhub-cta__btns">
          <a href="/book-a-demo/" class="indhub-btn indhub-btn--white">Book a Free Demo</a>
          <a href="/contact-en/" class="indhub-btn indhub-btn--ghost">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  /* ── Hero ── */
  .indhub-hero {
    background: linear-gradient(135deg, #f0f4ff 0%, #e8edff 40%, #f8f6ff 100%);
    padding: 7rem 1.5rem 4.5rem;
    text-align: center;
  }
  .indhub-hero__inner {
    max-width: 780px;
    margin: 0 auto;
  }
  .indhub-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--brand-blue);
    background: rgba(55, 93, 251, 0.08);
    border: 1px solid rgba(55, 93, 251, 0.18);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }
  .indhub-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.18;
    color: var(--heading-dark);
    margin-bottom: 1.25rem;
  }
  .indhub-hero__title strong {
    color: var(--brand-blue);
    font-weight: 800;
  }
  .indhub-hero__sub {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--subheading-gray);
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  /* ── Buttons ── */
  .indhub-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    padding: 0.75rem 1.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }
  .indhub-btn--primary {
    background: var(--brand-blue);
    color: #fff;
  }
  .indhub-btn--primary:hover {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
  }
  .indhub-btn--white {
    background: #fff;
    color: var(--heading-dark);
  }
  .indhub-btn--white:hover {
    background: #f0f4ff;
    transform: translateY(-1px);
  }
  .indhub-btn--ghost {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .indhub-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* ── Grid Section ── */
  .indhub-grid-section {
    background: #fff;
    padding: 5rem 1.5rem;
  }
  .indhub-grid-section__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .indhub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @property --indhub-angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
  .indhub-card {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #FFFFFF 0%, #F1F5FF 100%);
    border: 1px solid #E8ECF2;
    border-radius: 20px;
    padding: 2rem;
    text-decoration: none;
    box-shadow: 0 2px 12px rgba(0,0,0,.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .indhub-card::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
    background: conic-gradient(from var(--indhub-angle), transparent 0deg, transparent 280deg, var(--brand-blue) 320deg, #6F8BFF 345deg, transparent 360deg);
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); mask-composite: exclude;
    opacity: 0; transition: opacity 0.3s ease; pointer-events: none;
  }
  .indhub-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(55, 93, 251, 0.12);
    border-color: rgba(55, 93, 251, 0.15);
  }
  .indhub-card:hover::after { opacity: 1; animation: indhubBorder 2.4s linear infinite; }
  @keyframes indhubBorder { to { --indhub-angle: 360deg; } }
  @media (prefers-reduced-motion: reduce) { .indhub-card:hover::after { animation: none !important; } }
  .indhub-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .indhub-card__name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--heading-dark);
    margin-bottom: 0.4rem;
  }
  .indhub-card__tagline {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--subheading-gray);
    margin-bottom: 1rem;
    flex: 1;
  }
  .indhub-card__link {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  /* ── Bottom CTA ── */
  .indhub-cta {
    padding: 0 1.5rem 5rem;
    background: #fff;
  }
  .indhub-cta__inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .indhub-cta__card {
    position: relative;
    background: linear-gradient(135deg, #1a1f4e 0%, #0f1225 100%);
    border-radius: 24px;
    padding: 4rem 3rem;
    text-align: center;
    overflow: hidden;
  }
  .indhub-cta__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .indhub-cta__glow--1 {
    width: 300px;
    height: 300px;
    background: rgba(55, 93, 251, 0.3);
    top: -80px;
    right: -60px;
  }
  .indhub-cta__glow--2 {
    width: 250px;
    height: 250px;
    background: rgba(159, 129, 255, 0.2);
    bottom: -60px;
    left: -40px;
  }
  .indhub-cta__title {
    position: relative;
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
  }
  .indhub-cta__copy {
    position: relative;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
    max-width: 560px;
    margin: 0 auto 2rem;
  }
  .indhub-cta__btns {
    position: relative;
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Animations ── */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive 1024px ── */
  @media (max-width: 1024px) {
    .indhub-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Responsive 767px ── */
  @media (max-width: 767px) {
    .indhub-hero {
      padding: 5rem 1rem 3rem;
    }
    .indhub-grid-section {
      padding: 3.5rem 1rem;
    }
    .indhub-grid {
      grid-template-columns: 1fr;
    }
    .indhub-cta__card {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
