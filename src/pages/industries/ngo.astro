---
import IndustryLayout from "../../components/industries/IndustryLayout.astro";
---

<IndustryLayout
  industry="NGO"
  title="Event Management Software for NGOs & Non-Profit Events | EventHex"
  description="Run fundraising galas, awareness campaigns, volunteer events with EventHex."
  canonical="https://eventhex.ai/industries/ngo/"
  badge="NGO & Non-Profit Events"
  heroTitleLine1="Event Management for"
  heroTitleLine2="NGOs & Non-Profits"
  heroCopy="Manage fundraising galas, awareness campaigns, volunteer coordination, and non-profit conferences with donation-integrated ticketing, impact reporting, and budget-friendly pricing."
  trustItems={["Budget-friendly for non-profits", "Donation integration"]}
  challenges={[
    {
      icon: "💰",
      title: "Integrating fundraising and donation collection into event ticketing",
      desc: "Non-profit events need seamless donation flows alongside ticket purchases, but most event platforms treat ticketing and fundraising as separate systems."
    },
    {
      icon: "🙋",
      title: "Coordinating volunteers across multiple roles and shifts",
      desc: "Volunteer-driven events require role assignment, shift scheduling, and real-time communication — all difficult to manage with spreadsheets and email chains."
    },
    {
      icon: "📊",
      title: "Generating impact reports for donors and board members",
      desc: "Stakeholders expect detailed reports on funds raised, attendance, engagement metrics, and program outcomes — data that's scattered across disconnected tools."
    },
    {
      icon: "💵",
      title: "Running professional events on tight non-profit budgets",
      desc: "Non-profits need enterprise-grade event tools but often can't afford high per-ticket fees or expensive platform subscriptions."
    }
  ]}
  solutions={[
    {
      icon: "🎫",
      title: "Event Ticketing",
      desc: "Zero platform fees with optional donation add-ons at checkout",
      link: "/event-ticketing/"
    },
    {
      icon: "📝",
      title: "Event Registration",
      desc: "Volunteer role selection, shift sign-ups, and skill-based assignment",
      link: "/event-registration/"
    },
    {
      icon: "📊",
      title: "Event Analytics",
      desc: "Fundraising dashboards, donor engagement tracking, and impact reports",
      link: "/event-analytics/"
    },
    {
      icon: "📣",
      title: "Event Marketing",
      desc: "Donor outreach campaigns, email sequences, and social media promotion",
      link: "/event-marketing/"
    },
    {
      icon: "🏅",
      title: "Badge & Certificate Designer",
      desc: "Volunteer appreciation certificates and donor recognition badges",
      link: "/badge-certificate-designer/"
    },
    {
      icon: "🌐",
      title: "Event Website Builder",
      desc: "Campaign landing pages with donation goals, progress bars, and impact stories",
      link: "/event-website-builder/"
    }
  ]}
  useCases={[
    {
      title: "Fundraising Galas",
      desc: "Charity dinner events with tiered ticket pricing, live auction integration, and donation collection at checkout"
    },
    {
      title: "Awareness Campaigns",
      desc: "Public awareness events with campaign landing pages, social sharing, and impact metric tracking"
    },
    {
      title: "Volunteer Events",
      desc: "Community service events with volunteer role assignment, shift scheduling, and attendance tracking"
    },
    {
      title: "Non-Profit Conferences",
      desc: "Annual conferences for NGO professionals with speaker sessions, workshops, and networking"
    }
  ]}
  ctaTitle="Ready to Run Your Next Non-Profit Event?"
  ctaCopy="See how EventHex helps NGOs manage fundraising galas, volunteer events, and awareness campaigns on a budget."
  faqs={[
    {
      q: "Does EventHex offer special pricing for non-profits?",
      a: "Yes. EventHex offers budget-friendly pricing for registered non-profits, including zero platform fees on ticket sales so more funds go directly to your cause."
    },
    {
      q: "Can attendees add donations during ticket checkout?",
      a: "Yes. Add optional donation fields at checkout so attendees can contribute above the ticket price. Donation amounts appear in your fundraising dashboard in real time."
    },
    {
      q: "How do I coordinate volunteers for my event?",
      a: "Use EventHex registration to let volunteers select roles and shifts during sign-up. Assign tasks, send shift reminders, and track attendance on event day."
    },
    {
      q: "Can I generate impact reports for our board and donors?",
      a: "Yes. EventHex analytics provides fundraising totals, donor counts, attendance breakdowns, and engagement metrics — all exportable as presentation-ready reports."
    },
    {
      q: "Can I issue certificates to volunteers after the event?",
      a: "Yes. Use the Badge & Certificate Designer to create branded volunteer appreciation certificates and send them automatically after the event."
    }
  ]}
  supportNote={{ title: "Free non-profit event consultation", desc: "Our team helps set up donation-integrated ticketing, volunteer management, and impact reporting." }}
  supportCta={{ label: "Plan my non-profit event", href: "/book-a-demo/" }}
/>
