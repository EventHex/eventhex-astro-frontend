      link: "/event-payment-processing/"
    },
    {
      icon: "🤝",
      title: "Sponsor Management",
      desc: "Tiered sponsor packages with branded visibility, ROI dashboards, and lead capture",
      link: "/sponsor-management/"
    },
    {
      icon: "✅",
      title: "Event Check-In",
      desc: "Secure QR-based check-in with photo verification and access level enforcement",
      link: "/event-check-in/"
    },
    {
      icon: "🤝",
      title: "AI Smart-Connect",
      desc: "AI-powered investor-founder matching and curated networking recommendations",
      link: "/enhance-networking-ai-smart-connect/"
    },
    {
      icon: "📊",
      title: "Event Analytics",
      desc: "Engagement metrics, session attendance tracking, and sponsor ROI reporting",
