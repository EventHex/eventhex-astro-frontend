    {
      q: "Can EventHex handle VIP and invitation-only registration?",
      a: "Yes. Create approval-based registration workflows with priority access, waitlists, and invitation codes for C-suite and VIP attendees."
    },
    {
      q: "Does EventHex support multi-currency payment processing?",
      a: "Yes. Accept payments in USD, EUR, GBP, AED, SAR, INR, and 130+ other currencies via Stripe, Razorpay, or Tap Payments."
    },
    {
