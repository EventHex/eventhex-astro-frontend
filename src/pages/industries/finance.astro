    {
      title: "Banking Summits",
      desc: "Executive-level banking conferences with keynote sessions, panel discussions, and invitation-only networking"
    },
    {
      title: "Fintech Conferences",
      desc: "Technology-focused finance events with startup showcases, demo stages, and investor pitch sessions"
    },
    {
      title: "Investor Meetups",
      desc: "Curated investor-founder matching events with structured 1:1 meetings and deal flow sessions"
    },
    {
      title: "Insurance Events",
      desc: "Industry conferences for insurance professionals with CPD sessions, exhibitor halls, and awards programs"
    }
  ]}
