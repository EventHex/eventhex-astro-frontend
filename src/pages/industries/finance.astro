  trustItems={["Trusted by financial institutions", "Enterprise-grade security"]}
  challenges={[
    {
      icon: "👔",
      title: "VIP and C-suite management",
      desc: "Financial events attract high-profile executives and investors who expect priority registration, exclusive access, and white-glove experiences."
    },
    {
      icon: "🔒",
      title: "Security and compliance",
      desc: "Financial services events handle sensitive business data and require strict access controls, audit trails, and compliance-ready workflows."
    },
    {
      icon: "🤝",
      title: "Complex sponsor tiering",
      desc: "Banking and fintech events involve multiple sponsor levels with different visibility packages, making manual tracking error-prone."
