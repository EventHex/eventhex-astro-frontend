  trustItems={["Built for membership organizations", "Tiered pricing support"]}
  challenges={[
    {
      icon: "💰",
      title: "Member vs non-member pricing",
      desc: "Associations need flexible pricing that distinguishes between member tiers, early-bird rates, and non-member pricing across multiple event types."
    },
    {
      icon: "🌐",
      title: "Chapter-level events across regions",
      desc: "National and international associations run events at the chapter level, requiring decentralized management with centralized reporting."
    },
    {
      icon: "🤝",
      title: "Sponsor and exhibitor value",
      desc: "Associations depend on sponsor and exhibitor revenue but struggle to demonstrate clear ROI and justify renewal investments."
