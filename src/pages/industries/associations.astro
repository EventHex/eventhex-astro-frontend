    {
      icon: "🤝",
      title: "Sponsor Management",
      desc: "Tiered sponsor packages with branded visibility, ROI dashboards, and lead capture",
      link: "/sponsor-management/"
    },
    {
      icon: "📊",
      title: "Centralized Dashboard",
      desc: "Cross-event reporting for member engagement, attendance trends, and revenue tracking",
      link: "/centralized-dashboard/"
    },
    {
      icon: "🤝",
      title: "AI Smart-Connect",
      desc: "AI-powered member networking with interest matching and meeting scheduling",
      link: "/enhance-networking-ai-smart-connect/"
    },
    {
      icon: "📧",
      title: "Event Marketing",
      desc: "Targeted member email campaigns, segmented outreach, and event promotion tools",
      link: "/event-marketing/"
    }
  ]}
  useCases={[
    {
      title: "Annual Conferences",
      desc: "Flagship annual meetings with keynotes, breakout sessions, exhibitor halls, and member networking"
    },
    {
      title: "Chapter Events",
      desc: "Regional chapter meetings and workshops with local registration and national reporting roll-up"
    },
    {
      title: "Awards & Galas",
      desc: "Member recognition events with nomination workflows, table booking, and award ceremony management"
    },
    {
      title: "Trade Shows",
      desc: "Industry trade shows with exhibitor booth management, sponsor packages, and attendee lead capture"
    }
  ]}
  ctaTitle="Ready to Manage Your Association Events?"
  ctaCopy="See how EventHex powers annual conferences, chapter events, and trade shows for associations and membership organizations."
