    {
      q: "Can EventHex handle member vs non-member pricing?",
      a: "Yes. Create unlimited ticket types with member-exclusive pricing, early-bird tiers, group discounts, and non-member rates — all within a single event."
    },
    {
      q: "Does it support chapter-level event management?",
      a: "Yes. Chapters can manage their own events with local branding while national headquarters maintains centralized reporting and oversight across all chapters."
    },
    {
      q: "How does sponsor ROI tracking work?",
      a: "Sponsors get dashboards showing logo impressions, booth visits, lead captures, and attendee engagement metrics — making renewal conversations data-driven."
    },
    {
      q: "Can I track member engagement across multiple events?",
      a: "Yes. The centralized dashboard aggregates attendance, session participation, and networking activity across all events throughout the membership year."
    },
    {
      q: "Does EventHex support exhibitor self-service?",
      a: "Yes. Exhibitors get a portal to manage booth content, upload materials, view lead data, and track their event performance — reducing organizer workload."
    }
  ]}
  supportNote={{ title: "Free association event consultation", desc: "Our team helps you configure member pricing, chapter management, and sponsor workflows for your association events." }}
  supportCta={{ label: "Plan my association event", href: "/book-a-demo/" }}
