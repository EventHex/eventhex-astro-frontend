      desc: "AI-powered B2B networking matching buyers with suppliers",
      link: "/enhance-networking-ai-smart-connect/"
    },
    {
      icon: "📊",
      title: "Event Analytics",
      desc: "Lead scoring, visitor flow, and exhibitor ROI reporting",
      link: "/event-analytics/"
    },
    {
      icon: "💳",
      title: "Event Payment Processing",
      desc: "Multi-currency payments for international exhibitor and delegate fees",
      link: "/event-payment-processing/"
    },
    {
      icon: "📱",
      title: "Event Mobile App",
      desc: "Floor plans, exhibitor directory, and meeting scheduler in-app",
      link: "/event-mobile-app/"
    },
    {
      icon: "🤝",
