    },
    {
      q: "Can I support multiple languages for international trade fairs?",
      a: "Yes. EventHex supports multilingual registration forms, event notifications via email and WhatsApp, and event website content in multiple languages for international delegates."
    }
  ]}
  supportNote={{ title: "Free industrial event consultation", desc: "Our team helps configure exhibitor management, lead capture, and B2B networking for your event." }}
