  trustItems={["Used by industrial event organizers", "B2B lead capture built in"]}
  challenges={[
    {
      icon: "🏭",
      title: "Managing large exhibitor counts with complex booth layouts",
      desc: "Industrial expos feature hundreds of exhibitors across massive floor plans, requiring precise booth allocation and logistics coordination."
    },
    {
      icon: "🔧",
      title: "B2B lead qualification and distribution",
      desc: "Trade fairs generate thousands of leads that need to be scored, qualified, and distributed to the right exhibitor sales teams in real time."
    },
