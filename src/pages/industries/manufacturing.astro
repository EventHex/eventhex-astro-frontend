    {
      title: "Industrial Trade Fairs",
      desc: "Large-scale industrial exhibitions with hundreds of exhibitors, product demonstrations, and B2B matchmaking sessions"
    },
    {
      title: "Supply Chain Summits",
      desc: "Supplier-buyer networking events with structured meeting schedules, procurement discussions, and logistics coordination"
    },
    {
      title: "Manufacturing Technology Conferences",
      desc: "Industry 4.0 and smart manufacturing conferences with technical sessions, workshops, and innovation showcases"
    },
    {
      title: "Machinery & Equipment Expos",
      desc: "Heavy machinery and equipment exhibitions with live demonstrations, product catalogs, and dealer networking"
    }
  ]}
