    {
      icon: "✅",
      title: "Event Check-In",
      desc: "QR-based check-in for session attendance tracking and accreditation verification",
      link: "/event-check-in/"
    },
    {
      icon: "📅",
      title: "Session Management",
      desc: "Multi-track CME sessions with speaker assignments, room allocation, and attendee capacity controls",
      link: "/session-management/"
    },
    {
      icon: "📧",
      title: "Event Notifications",
      desc: "Multi-channel reminders via email, SMS, and push for session changes, deadlines, and updates",
      link: "/event-notifications/"
    },
