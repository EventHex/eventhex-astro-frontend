      title: "Abstract submissions and peer review",
      desc: "Medical conferences receive hundreds of abstract submissions that require structured review workflows, scoring rubrics, and reviewer assignment."
    },
    {
      icon: "🎓",
      title: "CE credits and accreditation tracking",
      desc: "Healthcare events must track continuing education credits per attendee and generate compliant certificates for accreditation bodies."
    },
    {
      icon: "🔒",
      title: "Patient data privacy and compliance",
