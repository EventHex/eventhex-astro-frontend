---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../lib/bentoIllustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Developer API & Webhooks",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  description: "Build on EventHex with a full REST API, outbound webhooks, API key management, and llms.txt support for AI/LLM discovery. Integrate registrations, attendees, sessions, and payments into your own stack.",
  url: "https://eventhex.ai/developers/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "REST API",
    "Outbound Webhooks",
    "API Key Management",
    "Registrations API",
    "Attendees API",
    "Sessions API",
    "Payments API",
    "llms.txt for AI Discovery",
    "Trigger-Based Automation",
  ],
};
---

<FeatureV2Layout
  pageTitle="Event Management API & Webhooks for Developers | EventHex"
  pageDescription="Build on EventHex with a full REST API, outbound webhooks, API key management, and llms.txt for AI/LLM discovery. Integrate event registrations, attendees, sessions, and payments into your own stack."
  canonical="https://eventhex.ai/developers/"
  badge="Developer Platform"
  heroTitleLine1="Build on EventHex."
  heroTitleLine2="Your Stack, Your Rules."
  heroCopy="A full REST API, outbound webhooks, and API key management give your team complete programmatic control over events, registrations, attendees, sessions, and payments — integrate EventHex into any workflow or product."
  trustItems={["Full REST API", "Outbound Webhooks", "API Key Management"]}
  stats={[
    { value: "REST", label: "API Architecture" },
    { value: "Webhooks", label: "Trigger-Based Automation" },
    { value: "llms.txt", label: "AI/LLM Discovery" },
    { value: "0", label: "Vendor Lock-In" },
  ]}
  statsHeadline={{
    white1: "Your events.",
    accent: "Your API.",
    white2: "Fully",
    accent2: "programmable",
  }}
  bentoHeading="Everything Developers Need to Build On EventHex"
  bentoSubtitle="From reading attendee lists to triggering automation on registration events — the EventHex developer platform gives you full access to your event data with the primitives your team already knows."
  bentoTabs={[
    {
      tab: "REST API",
      cards: [
        { title: "Registrations API", desc: "Read, create, and update registrations programmatically — integrate EventHex registration data into your CRM, data warehouse, or internal tools", illustration: ILLOS.code },
        { title: "Attendees API", desc: "Query attendees by event, ticket type, check-in status, or custom field values — paginated, filterable, and export-ready", illustration: ILLOS.user },
        { title: "Sessions API", desc: "Fetch session schedules, speaker assignments, and room allocations from any event to power your own agenda views or mobile apps", illustration: ILLOS.document },
        { title: "Payments API", desc: "Access payment status, ticket revenue, and refund records to reconcile EventHex income with your own finance systems", illustration: ILLOS.creditcard },
        { title: "Events API", desc: "Create and manage events, ticket types, and capacity limits programmatically — useful for teams that provision events from internal tooling", illustration: ILLOS.code },
      ],
    },
    {
      tab: "Webhooks & Automation",
      cards: [
        { title: "Outbound Webhooks", desc: "Configure EventHex to POST a payload to any URL when a trigger fires — no polling required, no missed events", illustration: ILLOS.webhook },
        { title: "Registration Triggers", desc: "Fire a webhook when a new registration is confirmed, when payment is received, or when an attendee cancels", illustration: ILLOS.webhook },
        { title: "Check-In Triggers", desc: "Trigger automation the moment an attendee checks in on-site — update your CRM, ping Slack, or send a personalized follow-up", illustration: ILLOS.webhook },
        { title: "Session & Speaker Triggers", desc: "Get notified when a session is updated, a speaker is confirmed, or an abstract is accepted through the reviewer portal", illustration: ILLOS.webhook },
        { title: "Payload & Retry Control", desc: "Each webhook delivers a structured JSON payload. Failed deliveries are retried automatically with exponential backoff and logged for inspection", illustration: ILLOS.document },
      ],
    },
    {
      tab: "Auth & Keys",
      cards: [
        { title: "API Key Management", desc: "Generate and revoke API keys from the EventHex dashboard — scope keys to read-only or read-write per integration", illustration: ILLOS.lock },
        { title: "Per-Integration Keys", desc: "Create separate API keys for each integration partner or internal service so you can revoke one without disrupting others", illustration: ILLOS.lock },
        { title: "Secure Key Storage", desc: "Keys are displayed only once at creation time and stored as hashed values — follow standard secret management practices", illustration: ILLOS.shield },
        { title: "llms.txt for AI Discovery", desc: "EventHex exposes an llms.txt file so AI tools, LLM agents, and copilots can discover the API surface automatically without manual documentation parsing", illustration: ILLOS.document },
        { title: "Developer Docs", desc: "Full API reference documentation covers every endpoint, payload schema, authentication method, and example request — available at eventhex.ai/docs", illustration: ILLOS.document },
      ],
    },
  ]}
  stackingHeading="Developer Platform"
  stackingHighlight="Built for Real Integrations"
  stackingCards={[
    {
      title: "Pull Any Event Data Into Your Own Stack",
      desc: "The EventHex REST API covers registrations, attendees, sessions, payments, and events. Whether you're syncing to a data warehouse, feeding a BI dashboard, or embedding attendee lists in an internal tool — the API gives you clean, paginated JSON with no middleware required.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "EventHex REST API response showing attendee records in JSON format",
    },
    {
      title: "React to Events as They Happen",
      desc: "Outbound webhooks mean you never have to poll for changes. Configure a webhook endpoint for registration confirmed, attendee checked in, or session updated — and EventHex posts a structured payload to your URL the moment it happens. Retries are built in.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "Webhook configuration panel in EventHex showing trigger types and endpoint settings",
    },
    {
      title: "AI Tools Can Discover Your API Automatically",
      desc: "EventHex ships an llms.txt file so AI assistants, LLM agents, and developer copilots can parse the full API surface without manual documentation ingestion. Build AI-powered event workflows on top of EventHex data with zero extra setup.",
      image: "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png",
      alt: "EventHex llms.txt file enabling AI and LLM tool discovery of the developer API",
    },
  ]}
  howItWorksHeading="How to Build on EventHex"
  steps={[
    { title: "Generate an API Key", desc: "Log into EventHex, navigate to the developer panel, and create an API key. Scope it to read-only or read-write and assign it to the integration you're building." },
    { title: "Explore the API Reference", desc: "The full REST API reference documents every endpoint, parameter, and response schema. Registrations, attendees, sessions, and payments are all covered with example requests." },
    { title: "Configure Webhooks", desc: "Choose the triggers that matter to your workflow — new registration, payment confirmed, check-in, session update — and point them at your endpoint. EventHex starts delivering payloads immediately." },
    { title: "Build & Ship", desc: "Integrate EventHex data into your CRM, data pipeline, mobile app, or internal tool. Use the API for reads and writes; use webhooks for real-time automation. The platform stays out of your way." },
  ]}
  ctaTitle="Ready to Build on EventHex?"
  ctaCopy="Connect EventHex to your stack with a full REST API, outbound webhooks, and API key management. See the platform in action — no commitment required."
  whyHeading="Why Developers & Technical Teams Choose EventHex"
  whyCards={[
    { title: "Full REST API", desc: "Every object — events, registrations, attendees, sessions, payments — is accessible via REST", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>' },
    { title: "Real-Time Webhooks", desc: "Trigger-based outbound webhooks with retry logic and delivery logs", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>' },
    { title: "API Key Control", desc: "Create, scope, and revoke keys per integration from the dashboard", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>' },
    { title: "AI-Ready via llms.txt", desc: "LLM tools and AI copilots discover the API surface automatically", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' },
    { title: "No Vendor Lock-In", desc: "Your data is yours — export, sync, or replicate it to any system", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>' },
  ]}
  faqs={[
    { q: "Does EventHex have a REST API?", a: "Yes. EventHex provides a full REST API covering events, registrations, attendees, sessions, and payments. Every endpoint returns paginated JSON and supports filtering by common fields like event ID, ticket type, and status." },
    { q: "How do outbound webhooks work?", a: "You configure a webhook endpoint URL and select the triggers you want — such as registration confirmed, payment received, or attendee checked in. EventHex sends a structured JSON payload to your URL when those triggers fire. Failed deliveries are retried automatically with exponential backoff." },
    { q: "How do I authenticate API requests?", a: "Generate an API key from the EventHex developer panel. Pass it as a Bearer token in the Authorization header. Keys can be scoped to read-only or read-write and revoked at any time without affecting other keys." },
    { q: "What is llms.txt and why does EventHex have one?", a: "llms.txt is a plain-text file that describes an application's API surface in a format AI tools and LLM agents can parse automatically. EventHex exposes one so that developer copilots and AI assistants can discover endpoints, parameters, and schemas without manual documentation ingestion." },
    { q: "Can I create events and registrations via the API?", a: "Yes. The API supports read and write operations for events and registrations, including creating ticket types, setting capacities, and adding registrations programmatically. This is useful for teams that provision events from internal tooling." },
    { q: "Where can I find the full API documentation?", a: "Full API reference documentation is available at eventhex.ai/docs and covers every endpoint, payload schema, authentication method, and example request. The llms.txt file at the root of the domain gives AI tools a machine-readable version of the same information." },
  ]}
  jsonLd={jsonLd}
/>
