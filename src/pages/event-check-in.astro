---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-check-in/HeroSection.astro";
import StatsSection from "../components/event-check-in/StatsSection.astro";
import BentoGrid from "../components/event-check-in/BentoGrid.astro";
import FeatureCards from "../components/event-check-in/FeatureCards.astro";
import HowItWorksSection from "../components/event-check-in/HowItWorksSection.astro";
import CTASection from "../components/event-check-in/CTASection.astro";
import CoordinationTools from "../components/event-check-in/CoordinationTools.astro";
import FaqSection from "../components/event-check-in/FaqSection.astro";

const ogImage = "https://cms.eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Event Check-In App — QR Scan & Face Recognition | EventHex";
const description = "Event check-in app with QR scanning, face recognition, multi-device support, and offline mode. Track real-time attendance across sessions from one dashboard.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Check-In & Operations",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, iOS, Android",
  url: "https://eventhex.ai/event-check-in/",
  description: "QR code event check-in with multi-device scanning, offline mode, session attendance tracking, and real-time operations dashboard.",
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "QR Code Scanning",
    "Multi-Device Support",
    "Offline Scanning Mode",
    "Session-Level Attendance",
    "Real-Time Dashboard",
    "On-Site Badge Printing",
    "Duplicate Scan Prevention",
    "Staff Login Portal",
    "Attendance Reports",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-check-in/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
