---
import FeatureV2Layout from "../../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../../lib/bentoIllustrations";

const stackingImage = "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Management Software in Dubai",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "End-to-end event management software for Dubai conferences, expos, and corporate events — with Arabic/RTL support, Tap Payments (mada/KNET/Apple Pay), and WhatsApp concierge.",
  url: "https://eventhex.ai/event-management/dubai/",
  areaServed: "Dubai",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
};
---

<FeatureV2Layout
  pageTitle="Event Management Software in Dubai | EventHex"
  pageDescription="Run Dubai conferences, expos, and corporate events with EventHex — Arabic/RTL registration forms, Tap Payments (mada/KNET/Apple Pay), WhatsApp concierge, and real-time attendee tracking."
  canonical="https://eventhex.ai/event-management/dubai/"
  badge="Event Management in Dubai"
  heroTitleLine1="Event Management Software"
  heroTitleLine2="Built for Dubai"
  heroCopy="From GITEX to corporate summits at DIFC, EventHex powers Dubai event organisers with Arabic/RTL registration forms, Tap Payments acceptance, WhatsApp attendee concierge, and a real-time dashboard that keeps every team member in sync."
  trustItems={["Arabic & RTL Registration Forms", "Tap Payments — mada, KNET, Apple Pay", "WhatsApp Concierge"]}
  stats={[
    { value: "0%", label: "Platform Fees" },
    { value: "3", label: "Languages Supported (EN/AR/DE)" },
    { value: "99.9%", label: "Uptime SLA" },
    { value: "100K+", label: "Registrations Processed" },
  ]}
  statsHeadline={{
    white1: "Every attendee.",
    accent: "Every dirham.",
    white2: "Tracked in",
    accent2: "real time",
  }}
  bentoHeading="Everything Dubai Event Organisers Need"
  bentoSubtitle="From pre-event registration to on-site badge printing and post-event analytics — EventHex covers the full lifecycle for Dubai's conferences, expos, and corporate gatherings."
  bentoTabs={[
    {
      tab: "Registration & Ticketing",
      cards: [
        { title: "Arabic & RTL Forms", desc: "Full right-to-left registration forms so Arabic-speaking attendees register without friction", illustration: ILLOS.translate },
        { title: "Tap Payments Integration", desc: "Accept mada, KNET, Apple Pay, and international cards through Tap Payments — one gateway for the GCC", illustration: ILLOS.creditcard },
        { title: "Multi-Ticket Types", desc: "Separate tiers for VIP, delegate, sponsor, and media passes — each with its own capacity and price", illustration: ILLOS.money },
        { title: "Real-Time Attendee List", desc: "Watch registrations arrive live and filter by ticket type, payment status, or check-in stage", illustration: ILLOS.dashboard },
        { title: "Bulk CSV Import", desc: "Import offline registrants from a spreadsheet with automatic duplicate detection", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "On-Site & Check-In",
      cards: [
        { title: "QR Badge Scanning", desc: "Scan attendee QR codes at expo entrances and breakout sessions with any smartphone", illustration: ILLOS.qr },
        { title: "Badge Printing", desc: "Print branded name badges on-site — no third-party hardware required", illustration: ILLOS.poster },
        { title: "Walk-In Registration", desc: "Add last-minute attendees at the door and collect payment instantly via Tap", illustration: ILLOS.user },
        { title: "Session Capacity Limits", desc: "Cap breakout sessions and masterclasses — QR scan enforces limits in real time", illustration: ILLOS.calendar },
        { title: "Check-In Analytics", desc: "Live arrival curves and no-show counts so operations staff can adjust staffing", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Engagement & Analytics",
      cards: [
        { title: "WhatsApp Concierge", desc: "Send schedule reminders, session changes, and venue directions via WhatsApp — the channel Dubai attendees actually read", illustration: ILLOS.whatsapp },
        { title: "Branded Event Page", desc: "Custom-domain event landing page in Arabic and English — no coding needed", illustration: ILLOS.palette },
        { title: "Post-Event Surveys", desc: "Collect structured feedback immediately after sessions or the closing ceremony", illustration: ILLOS.chatform },
        { title: "Revenue Dashboard", desc: "Real-time ticket revenue, refunds, and outstanding payments in AED", illustration: ILLOS.money },
        { title: "Attendee Export", desc: "One-click export of the full attendee list for sponsor lead delivery", illustration: ILLOS.share },
      ],
    },
  ]}
  stackingHeading="Powerful Event Tools"
  stackingHighlight="for Dubai"
  stackingCards={[
    {
      title: "Arabic-First Registration for GCC Attendees",
      desc: "EventHex registration forms render in full right-to-left layout when Arabic is selected — field labels, validation messages, and confirmation emails all localised so every attendee feels at home.",
      image: stackingImage,
      alt: "Arabic RTL event registration form on a tablet",
    },
    {
      title: "Tap Payments — One Gateway for the Entire GCC",
      desc: "Accept mada, KNET, Apple Pay, and Visa/Mastercard through Tap Payments without juggling multiple acquirers. Payouts in AED with no hidden platform fees on top of gateway costs.",
      image: stackingImage,
      alt: "Tap Payments event ticketing checkout on a tablet",
    },
    {
      title: "WhatsApp Concierge That Actually Gets Read",
      desc: "Automate schedule reminders, venue map links, and last-minute session changes via WhatsApp — the communication channel that Dubai conference and expo attendees open within minutes.",
      image: stackingImage,
      alt: "WhatsApp event concierge messages on a smartphone",
    },
  ]}
  howItWorksHeading="How EventHex Works for Dubai Events"
  steps={[
    { title: "Create Your Event & Set Up Payments", desc: "Configure ticket types, capacities, and connect Tap Payments to accept mada, KNET, and cards in AED." },
    { title: "Launch Arabic & English Registration", desc: "Publish a bilingual event page and share the registration link across email, WhatsApp, and LinkedIn." },
    { title: "Track Attendees in Real Time", desc: "Monitor registrations, payments, and check-ins from a single dashboard — accessible from anywhere in the venue." },
    { title: "Engage & Follow Up via WhatsApp", desc: "Send automated session reminders and post-event surveys via WhatsApp to maximise attendance and collect feedback." },
  ]}
  ctaTitle="Ready to Run Your Next Dubai Event?"
  ctaCopy="See how EventHex simplifies registration, payments, and on-site check-in for Dubai conferences, expos, and corporate events."
  whyHeading="Why Dubai Organisers Choose EventHex"
  whyCards={[
    { title: "Arabic / RTL Support", desc: "Native right-to-left forms and emails — no workarounds", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' },
    { title: "Tap Payments", desc: "mada, KNET, Apple Pay — one GCC gateway", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "WhatsApp Concierge", desc: "Automated attendee messaging on the channel they use", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' },
    { title: "0% Platform Fees", desc: "Pay only gateway costs — EventHex adds no ticket surcharge", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' },
    { title: "Real-Time Dashboard", desc: "Live registration, check-in, and revenue data from any device", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "Does EventHex support Arabic registration forms?", a: "Yes. EventHex renders registration forms in full right-to-left layout when Arabic is selected, including field labels, validation messages, and confirmation emails. Organisers can toggle between EN and AR without any code changes." },
    { q: "Which payment methods are supported in Dubai?", a: "EventHex integrates with Tap Payments, which accepts mada, KNET, Apple Pay, Visa, and Mastercard — covering the full range of payment preferences across the UAE and wider GCC." },
    { q: "Can I send attendee communications via WhatsApp?", a: "Yes. EventHex's WhatsApp concierge feature lets you send automated reminders, schedule updates, and venue directions directly to attendees' WhatsApp — the messaging channel with the highest open rates in the region." },
    { q: "Does EventHex charge platform fees on ticket sales?", a: "No. EventHex charges zero platform fees on ticket revenue. You pay only the payment gateway processing fees set by Tap Payments." },
    { q: "Is EventHex suitable for large Dubai expos?", a: "Yes. EventHex handles high-volume events — bulk attendee import, QR badge scanning at multiple entry points, and a real-time dashboard that supports concurrent check-in teams across large venues." },
    { q: "Can I manage both Arabic and English attendees on the same event?", a: "Yes. A single EventHex event supports bilingual registration — attendees choose their preferred language at the start of the form, and all communications (confirmations, reminders) are sent in that language." },
  ]}
  jsonLd={jsonLd}
/>
