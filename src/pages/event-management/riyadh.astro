---
import FeatureV2Layout from "../../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../../lib/bentoIllustrations";

const stackingImage = "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Management Software in Riyadh",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "End-to-end event management software for Riyadh conferences, exhibitions, and corporate events — with Arabic/RTL support, Tap Payments (mada/STC Pay), and WhatsApp concierge.",
  url: "https://eventhex.ai/event-management/riyadh/",
  areaServed: "Riyadh",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
};
---

<FeatureV2Layout
  pageTitle="Event Management Software in Riyadh | EventHex"
  pageDescription="Manage Riyadh conferences, Vision 2030 exhibitions, and corporate events with EventHex — Arabic/RTL forms, Tap Payments (mada/STC Pay), WhatsApp concierge, and live attendee tracking."
  canonical="https://eventhex.ai/event-management/riyadh/"
  badge="Event Management in Riyadh"
  heroTitleLine1="Event Management Software"
  heroTitleLine2="Built for Riyadh"
  heroCopy="From Riyadh Season mega-events to corporate summits at the King Abdullah Financial District, EventHex gives Saudi event organisers Arabic/RTL registration, mada and STC Pay acceptance via Tap Payments, WhatsApp concierge, and a real-time dashboard built for scale."
  trustItems={["Arabic & RTL Registration Forms", "Tap Payments — mada, STC Pay, Visa/MC", "WhatsApp Concierge"]}
  stats={[
    { value: "0%", label: "Platform Fees" },
    { value: "3", label: "Languages Supported (EN/AR/DE)" },
    { value: "99.9%", label: "Uptime SLA" },
    { value: "100K+", label: "Registrations Processed" },
  ]}
  statsHeadline={{
    white1: "Every attendee.",
    accent: "Every riyal.",
    white2: "Tracked in",
    accent2: "real time",
  }}
  bentoHeading="Everything Riyadh Event Organisers Need"
  bentoSubtitle="From pre-event registration to on-site check-in and post-event analytics — EventHex handles the full event lifecycle for Riyadh's conferences, exhibitions, and corporate events."
  bentoTabs={[
    {
      tab: "Registration & Ticketing",
      cards: [
        { title: "Arabic & RTL Registration", desc: "Native right-to-left forms for Saudi attendees — labels, validation, and emails all in Arabic", illustration: ILLOS.translate },
        { title: "Tap Payments — mada & STC Pay", desc: "Accept mada debit, STC Pay, and international cards in SAR through a single Tap Payments integration", illustration: ILLOS.creditcard },
        { title: "Multi-Tier Ticketing", desc: "Separate passes for delegates, VIPs, media, and sponsors — each with independent capacity and price", illustration: ILLOS.money },
        { title: "Live Registration Dashboard", desc: "Monitor sign-ups in real time and filter by ticket type, payment status, or check-in stage", illustration: ILLOS.dashboard },
        { title: "Bulk Attendee Import", desc: "Upload delegate lists from Excel or CSV with automatic duplicate detection", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "On-Site & Check-In",
      cards: [
        { title: "QR Code Check-In", desc: "Scan attendee QR badges at venue entrances using any smartphone — no dedicated scanner needed", illustration: ILLOS.qr },
        { title: "Badge Printing", desc: "Print branded Arabic/English name badges immediately as delegates arrive", illustration: ILLOS.poster },
        { title: "Walk-In Registration", desc: "Add last-minute attendees at the door and collect SAR payment via mada on the spot", illustration: ILLOS.user },
        { title: "Session Access Control", desc: "Limit breakout sessions and workshops by capacity — QR scanning enforces limits in real time", illustration: ILLOS.calendar },
        { title: "Live Arrival Analytics", desc: "Real-time check-in curves and no-show counts to help ground teams manage venue flow", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Engagement & Analytics",
      cards: [
        { title: "WhatsApp Concierge", desc: "Automated WhatsApp messages for reminders, schedule updates, and venue directions in Arabic", illustration: ILLOS.whatsapp },
        { title: "Bilingual Event Page", desc: "Branded Arabic and English event landing page under your own domain — no coding required", illustration: ILLOS.palette },
        { title: "Post-Event Surveys", desc: "Send Arabic-language feedback surveys immediately after sessions for higher response rates", illustration: ILLOS.chatform },
        { title: "Revenue in SAR", desc: "Real-time revenue dashboard showing ticket sales and outstanding payments in Saudi Riyals", illustration: ILLOS.money },
        { title: "Attendee Export", desc: "Export full delegate lists for sponsor reporting and post-event analysis", illustration: ILLOS.share },
      ],
    },
  ]}
  stackingHeading="Powerful Event Tools"
  stackingHighlight="for Riyadh"
  stackingCards={[
    {
      title: "Arabic-First Registration for Saudi Attendees",
      desc: "EventHex renders registration forms in full right-to-left layout when Arabic is selected — field labels, conditional logic, and confirmation emails all display correctly so Saudi attendees register without friction.",
      image: stackingImage,
      alt: "Arabic RTL event registration on a tablet",
    },
    {
      title: "mada & STC Pay via Tap Payments",
      desc: "Accept the payment methods Saudi attendees actually use — mada debit cards, STC Pay, and international Visa/Mastercard — all through a single Tap Payments integration with SAR payouts and no platform surcharge.",
      image: stackingImage,
      alt: "Tap Payments mada checkout on a tablet",
    },
    {
      title: "WhatsApp Concierge in Arabic",
      desc: "Automate session reminders, last-minute agenda changes, and venue directions via WhatsApp in Arabic — the messaging channel that consistently drives the highest open and response rates across Saudi Arabia.",
      image: stackingImage,
      alt: "Arabic WhatsApp event concierge on a smartphone",
    },
  ]}
  howItWorksHeading="How EventHex Works for Riyadh Events"
  steps={[
    { title: "Configure Tickets & Connect Tap Payments", desc: "Set up ticket types and pricing in SAR, then connect Tap Payments to accept mada, STC Pay, and cards." },
    { title: "Launch Arabic & English Registration", desc: "Publish a bilingual event page and share the registration link via email, WhatsApp, and social media." },
    { title: "Monitor Delegates in Real Time", desc: "Track registrations, SAR payments, and check-ins from a single dashboard accessible on any device." },
    { title: "Engage via WhatsApp & Collect Feedback", desc: "Send automated Arabic WhatsApp reminders and post-event surveys to maximise attendance and gather insights." },
  ]}
  ctaTitle="Ready to Run Your Next Riyadh Event?"
  ctaCopy="See how EventHex streamlines delegate registration, SAR payments, and on-site check-in for Riyadh conferences and exhibitions."
  whyHeading="Why Riyadh Organisers Choose EventHex"
  whyCards={[
    { title: "Arabic / RTL Support", desc: "Native Arabic forms, emails, and event pages with RTL layout", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' },
    { title: "mada & STC Pay", desc: "Saudi-preferred payments via Tap Payments in SAR", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "WhatsApp Concierge", desc: "Automated Arabic attendee messaging at scale", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' },
    { title: "0% Platform Fees", desc: "No added surcharge on SAR ticket revenue", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' },
    { title: "Real-Time Dashboard", desc: "Live delegate, check-in, and SAR revenue data on any device", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "Does EventHex support Arabic for Saudi events?", a: "Yes. EventHex renders registration forms in full RTL layout with Arabic field labels, validation messages, and confirmation emails — no separate setup required." },
    { q: "Can EventHex process mada and STC Pay payments?", a: "Yes. EventHex integrates with Tap Payments, which supports mada debit cards, STC Pay, Visa, and Mastercard — covering the primary payment methods used at Saudi events, with SAR payouts." },
    { q: "Can I send WhatsApp messages to Saudi attendees?", a: "Yes. EventHex's WhatsApp concierge allows automated Arabic-language reminders, agenda updates, and venue directions — the channel with the highest engagement rates in Saudi Arabia." },
    { q: "Is EventHex suitable for large Riyadh exhibitions?", a: "Yes. EventHex is built for high-volume events — bulk delegate import, multi-gate QR check-in, and a live operations dashboard that supports concurrent check-in teams across large venues." },
    { q: "Does EventHex add platform fees on SAR ticket sales?", a: "No. EventHex charges zero platform fees. Organisers pay only Tap Payments gateway fees." },
    { q: "Can I run registration in both Arabic and English on the same event?", a: "Yes. Attendees choose their preferred language at the start of registration and receive all communications — confirmations, reminders, and surveys — in that language." },
  ]}
  jsonLd={jsonLd}
/>
