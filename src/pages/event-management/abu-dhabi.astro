---
import FeatureV2Layout from "../../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../../lib/bentoIllustrations";

const stackingImage = "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Management Software in Abu Dhabi",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "End-to-end event management software for Abu Dhabi conferences, government summits, and corporate events — with Arabic/RTL support, Tap Payments, and WhatsApp concierge.",
  url: "https://eventhex.ai/event-management/abu-dhabi/",
  areaServed: "Abu Dhabi",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
};
---

<FeatureV2Layout
  pageTitle="Event Management Software in Abu Dhabi | EventHex"
  pageDescription="Manage Abu Dhabi conferences, government summits, and corporate events with EventHex — Arabic/RTL forms, Tap Payments (mada/KNET/Apple Pay), WhatsApp concierge, and live attendee tracking."
  canonical="https://eventhex.ai/event-management/abu-dhabi/"
  badge="Event Management in Abu Dhabi"
  heroTitleLine1="Event Management Software"
  heroTitleLine2="Built for Abu Dhabi"
  heroCopy="From ADNEC international conferences to government summits on Yas Island, EventHex equips Abu Dhabi organisers with Arabic/RTL registration, Tap Payments acceptance, WhatsApp attendee messaging, and a real-time operations dashboard."
  trustItems={["Arabic & RTL Registration Forms", "Tap Payments — mada, KNET, Apple Pay", "WhatsApp Concierge"]}
  stats={[
    { value: "0%", label: "Platform Fees" },
    { value: "3", label: "Languages Supported (EN/AR/DE)" },
    { value: "99.9%", label: "Uptime SLA" },
    { value: "100K+", label: "Registrations Processed" },
  ]}
  statsHeadline={{
    white1: "Every delegate.",
    accent: "Every session.",
    white2: "Managed in",
    accent2: "real time",
  }}
  bentoHeading="Everything Abu Dhabi Event Organisers Need"
  bentoSubtitle="From delegate registration to on-site badge printing and post-event reporting — EventHex covers the full event lifecycle for Abu Dhabi's conferences, expos, and government gatherings."
  bentoTabs={[
    {
      tab: "Registration & Ticketing",
      cards: [
        { title: "Arabic & RTL Forms", desc: "Right-to-left registration forms so Arabic-speaking delegates register without switching languages", illustration: ILLOS.translate },
        { title: "Tap Payments Integration", desc: "Accept mada, KNET, Apple Pay, and international cards — one gateway for AED payments across the GCC", illustration: ILLOS.creditcard },
        { title: "Multi-Tier Ticketing", desc: "Configure delegate, VIP, speaker, and media passes with individual capacities and pricing", illustration: ILLOS.money },
        { title: "Real-Time Attendee List", desc: "Live view of all registrations, filterable by ticket type, payment status, and check-in stage", illustration: ILLOS.dashboard },
        { title: "Bulk CSV Import", desc: "Upload offline delegate lists with automatic duplicate detection and field mapping", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "On-Site & Check-In",
      cards: [
        { title: "QR Badge Scanning", desc: "Fast QR-code check-in at any entry point using a smartphone — no dedicated hardware needed", illustration: ILLOS.qr },
        { title: "On-Site Badge Printing", desc: "Print branded name badges for delegates immediately upon arrival", illustration: ILLOS.poster },
        { title: "Walk-In Registration", desc: "Register last-minute attendees at the venue and collect payment via Tap on the spot", illustration: ILLOS.user },
        { title: "Session Access Control", desc: "Cap breakout sessions and workshops — scanning enforces limits automatically", illustration: ILLOS.calendar },
        { title: "Live Check-In Stats", desc: "Real-time arrival curves help venue and security teams manage crowd flow", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Engagement & Analytics",
      cards: [
        { title: "WhatsApp Concierge", desc: "Deliver session reminders, agenda changes, and venue directions via WhatsApp in Arabic or English", illustration: ILLOS.whatsapp },
        { title: "Bilingual Event Page", desc: "Publish a branded registration page in both Arabic and English under your own domain", illustration: ILLOS.palette },
        { title: "Post-Event Surveys", desc: "Collect structured delegate feedback immediately after sessions close", illustration: ILLOS.chatform },
        { title: "Revenue Dashboard", desc: "Real-time ticket revenue and outstanding payments displayed in AED", illustration: ILLOS.money },
        { title: "Attendee Data Export", desc: "One-click export for sponsor lead lists and post-event reporting", illustration: ILLOS.share },
      ],
    },
  ]}
  stackingHeading="Powerful Event Tools"
  stackingHighlight="for Abu Dhabi"
  stackingCards={[
    {
      title: "Arabic-First Registration for Government & Corporate Events",
      desc: "EventHex registration forms switch to full right-to-left layout when Arabic is chosen — ensuring government delegates, corporate attendees, and VIP guests can register without friction in their preferred language.",
      image: stackingImage,
      alt: "Arabic RTL delegate registration form on a tablet",
    },
    {
      title: "Tap Payments for Seamless AED Ticket Sales",
      desc: "Accept mada, KNET, Apple Pay, and international cards through a single Tap Payments integration — with payouts in AED and zero platform fees added by EventHex on top of gateway costs.",
      image: stackingImage,
      alt: "Tap Payments ticketing checkout on a tablet",
    },
    {
      title: "WhatsApp Messaging in Arabic and English",
      desc: "Send automated session reminders, agenda updates, and venue navigation links via WhatsApp — the channel Abu Dhabi attendees are most likely to act on within minutes of receiving a message.",
      image: stackingImage,
      alt: "WhatsApp bilingual event messaging on a smartphone",
    },
  ]}
  howItWorksHeading="How EventHex Works for Abu Dhabi Events"
  steps={[
    { title: "Set Up Your Event & Payment Gateway", desc: "Configure ticket types, capacities, and connect Tap Payments to collect AED payments from mada, KNET, and cards." },
    { title: "Publish a Bilingual Registration Page", desc: "Launch Arabic and English registration simultaneously — share links via email, WhatsApp, and your organisation's website." },
    { title: "Monitor Registrations in Real Time", desc: "Track delegate sign-ups, payment status, and check-ins from a single dashboard accessible from any device in the venue." },
    { title: "Engage Delegates via WhatsApp", desc: "Send automated reminders, agenda changes, and post-event surveys via WhatsApp to maintain high attendance and collect feedback." },
  ]}
  ctaTitle="Ready to Run Your Next Abu Dhabi Event?"
  ctaCopy="See how EventHex simplifies delegate registration, payments, and on-site check-in for Abu Dhabi conferences and corporate gatherings."
  whyHeading="Why Abu Dhabi Organisers Choose EventHex"
  whyCards={[
    { title: "Arabic / RTL Support", desc: "Native right-to-left forms and bilingual confirmation emails", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' },
    { title: "Tap Payments", desc: "mada, KNET, Apple Pay — one GCC gateway in AED", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "WhatsApp Concierge", desc: "Arabic & English attendee messaging at scale", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' },
    { title: "0% Platform Fees", desc: "No surcharge on ticket revenue — pay only gateway costs", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' },
    { title: "Real-Time Dashboard", desc: "Live delegate, check-in, and revenue data from any device", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "Does EventHex support Arabic for Abu Dhabi events?", a: "Yes. EventHex renders full right-to-left registration forms and sends confirmation emails in Arabic when the attendee selects their preferred language. No separate localisation setup is required." },
    { q: "Which payment gateway does EventHex use in Abu Dhabi?", a: "EventHex integrates with Tap Payments, supporting mada, KNET, Apple Pay, Visa, and Mastercard with payouts in AED — the standard choice for UAE-based event payments." },
    { q: "Can I send WhatsApp messages to Abu Dhabi delegates?", a: "Yes. EventHex's WhatsApp concierge lets you automate session reminders, venue directions, and last-minute agenda updates — delivered directly to attendees' WhatsApp in Arabic or English." },
    { q: "Is EventHex suitable for large government conferences?", a: "Yes. EventHex handles high-capacity events with bulk delegate import, multi-point QR check-in, session access control, and a real-time operations dashboard for on-site teams." },
    { q: "Does EventHex add platform fees to ticket prices?", a: "No. EventHex charges zero platform fees. You pay only the payment gateway fees set by Tap Payments." },
    { q: "Can delegates register in both Arabic and English on the same event?", a: "Yes. A single EventHex event supports bilingual registration — each delegate chooses their language at the start of the form and receives all communications accordingly." },
  ]}
  jsonLd={jsonLd}
/>
