---
import FeatureV2Layout from "../../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../../lib/bentoIllustrations";

const stackingImage = "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Management Software in Mumbai",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "End-to-end event management software for Mumbai conferences, corporate events, and exhibitions — with Razorpay (UPI/cards/net banking), GST-compliant invoicing, and real-time attendee tracking.",
  url: "https://eventhex.ai/event-management/mumbai/",
  areaServed: "Mumbai",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
};
---

<FeatureV2Layout
  pageTitle="Event Management Software in Mumbai | EventHex"
  pageDescription="Run Mumbai conferences, corporate events, and exhibitions with EventHex — Razorpay (UPI/cards/net banking), GST-compliant invoicing, and real-time attendee management."
  canonical="https://eventhex.ai/event-management/mumbai/"
  badge="Event Management in Mumbai"
  heroTitleLine1="Event Management Software"
  heroTitleLine2="Built for Mumbai"
  heroCopy="From Bombay Exhibition Centre trade shows to corporate conferences at the Taj, EventHex gives Mumbai event organisers Razorpay-powered UPI and card payments in INR, GST-compliant tax invoicing, bulk attendee import, and a real-time dashboard that keeps operations teams in sync across the venue."
  trustItems={["Razorpay — UPI, Cards, Net Banking", "GST-Compliant Tax Invoicing", "Real-Time Attendee Tracking"]}
  stats={[
    { value: "0%", label: "Platform Fees" },
    { value: "3", label: "Languages Supported (EN/AR/DE)" },
    { value: "99.9%", label: "Uptime SLA" },
    { value: "100K+", label: "Registrations Processed" },
  ]}
  statsHeadline={{
    white1: "Every attendee.",
    accent: "Every rupee.",
    white2: "Tracked in",
    accent2: "real time",
  }}
  bentoHeading="Everything Mumbai Event Organisers Need"
  bentoSubtitle="From pre-event registration to on-site check-in and GST invoicing — EventHex supports the full event lifecycle for Mumbai conferences, corporate gatherings, and trade exhibitions."
  bentoTabs={[
    {
      tab: "Registration & Ticketing",
      cards: [
        { title: "Razorpay — UPI, Cards & Net Banking", desc: "Accept UPI (GPay, PhonePe, BHIM), credit/debit cards, and net banking in INR through Razorpay", illustration: ILLOS.creditcard },
        { title: "GST-Compliant Invoicing", desc: "Automatic GST calculation and tax invoice generation for every ticket purchase — GSTIN-ready", illustration: ILLOS.invoice },
        { title: "Multi-Tier Ticketing", desc: "Delegate, VIP, exhibitor, and early bird passes — each with independent capacity and INR pricing", illustration: ILLOS.money },
        { title: "Real-Time Registration Tracking", desc: "Live dashboard showing sign-ups, payment status, and check-in stage for every ticket category", illustration: ILLOS.dashboard },
        { title: "Bulk Attendee Import", desc: "Upload delegate lists from CSV or Excel with automatic duplicate detection and field mapping", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "On-Site & Check-In",
      cards: [
        { title: "QR Badge Check-In", desc: "Scan attendee QR codes at venue entrances using any smartphone — fast and reliable at high-volume events", illustration: ILLOS.qr },
        { title: "On-Site Badge Printing", desc: "Print branded name badges immediately as delegates arrive — reducing registration queue times", illustration: ILLOS.poster },
        { title: "Walk-In Registration", desc: "Add last-minute attendees at the door and collect INR payment via UPI or card instantly via Razorpay", illustration: ILLOS.user },
        { title: "Session Capacity Control", desc: "Limit workshop and breakout session attendance — QR scanning enforces caps in real time", illustration: ILLOS.calendar },
        { title: "Live Arrival Analytics", desc: "Real-time check-in curves and no-show counts to help floor managers adjust staffing", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Engagement & Analytics",
      cards: [
        { title: "Automated Email & SMS Reminders", desc: "Send registration confirmations, ticket QR codes, and day-of reminders via email and SMS", illustration: ILLOS.bell },
        { title: "Branded Event Page", desc: "Custom-domain event landing page with your organisation's branding — no coding needed", illustration: ILLOS.palette },
        { title: "Post-Event Surveys", desc: "Collect structured attendee feedback automatically after sessions with configurable question sets", illustration: ILLOS.chatform },
        { title: "INR Revenue Dashboard", desc: "Real-time ticket revenue, GST collected, refunds, and outstanding payments in Indian Rupees", illustration: ILLOS.money },
        { title: "Attendee Export", desc: "One-click export of full delegate lists for sponsor lead delivery and GSTIN-linked reporting", illustration: ILLOS.share },
      ],
    },
  ]}
  stackingHeading="Powerful Event Tools"
  stackingHighlight="for Mumbai"
  stackingCards={[
    {
      title: "Razorpay UPI — The Payment Method Mumbai Attendees Prefer",
      desc: "EventHex integrates directly with Razorpay to accept UPI (GPay, PhonePe, BHIM), credit and debit cards, and net banking in INR — covering every payment method attendees at Mumbai corporate events and trade shows expect, with zero platform fees added by EventHex.",
      image: stackingImage,
      alt: "Razorpay UPI event ticketing on a tablet in Mumbai",
    },
    {
      title: "GST-Compliant Tax Invoices — Generated Automatically",
      desc: "Every ticket purchase on EventHex triggers an automatic GST tax invoice with the correct tax rate applied — GSTIN-ready and sent directly to the attendee's email so your organisation's finance team has nothing to chase.",
      image: stackingImage,
      alt: "GST tax invoice generated automatically on a tablet",
    },
    {
      title: "Real-Time Attendee Management Across the Venue",
      desc: "Whether it's 500 delegates at a corporate summit or 5,000 visitors at the Bombay Exhibition Centre, EventHex gives your team live check-in data, session counts, and revenue totals in INR — all from any device, anywhere in the venue.",
      image: stackingImage,
      alt: "Real-time event attendee dashboard on a tablet in Mumbai",
    },
  ]}
  howItWorksHeading="How EventHex Works for Mumbai Events"
  steps={[
    { title: "Configure Tickets & Connect Razorpay", desc: "Set up ticket tiers in INR, connect Razorpay to accept UPI, cards, and net banking, and enable GST invoicing with your GSTIN." },
    { title: "Launch Registration & Share Links", desc: "Publish your event page and distribute the registration link via email, WhatsApp, and LinkedIn." },
    { title: "Track Attendees & Payments in Real Time", desc: "Monitor INR revenue, registration counts, and check-in status from a single dashboard accessible from any device on-site." },
    { title: "Collect Feedback & Export GST Reports", desc: "Send post-event surveys automatically, then export attendee data and GST-compliant revenue reports for accounting." },
  ]}
  ctaTitle="Ready to Run Your Next Mumbai Event?"
  ctaCopy="See how EventHex simplifies registration, Razorpay UPI payments, and GST invoicing for Mumbai conferences and corporate gatherings."
  whyHeading="Why Mumbai Organisers Choose EventHex"
  whyCards={[
    { title: "Razorpay & UPI", desc: "UPI, cards, and net banking in INR — no platform fee on top of gateway costs", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "GST Invoicing", desc: "Automatic GST tax invoice for every ticket — GSTIN-ready", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
    { title: "Bulk Import", desc: "CSV attendee upload with duplicate detection and field mapping", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>' },
    { title: "0% Platform Fees", desc: "No surcharge on INR ticket revenue — pay only Razorpay fees", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' },
    { title: "Real-Time Dashboard", desc: "Live attendee, check-in, and INR revenue data on any device", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "Which payment methods does EventHex support in Mumbai?", a: "EventHex integrates with Razorpay, supporting UPI (GPay, PhonePe, BHIM), credit and debit cards, and net banking in INR — covering all the payment methods Mumbai event attendees use most." },
    { q: "Does EventHex generate GST-compliant invoices?", a: "Yes. EventHex automatically generates GST tax invoices for every ticket purchase with the correct tax rate applied. Invoices are GSTIN-ready and sent directly to the attendee's email." },
    { q: "Can I collect UPI payments at the registration desk?", a: "Yes. Walk-in registrations can be completed at the door with UPI payment collected instantly via Razorpay — no separate POS terminal needed." },
    { q: "Is EventHex suitable for large Mumbai exhibitions?", a: "Yes. EventHex handles high-volume events with bulk delegate import, multi-gate QR check-in, session capacity controls, and a real-time dashboard for teams spread across large venues like the Bombay Exhibition Centre." },
    { q: "Does EventHex add platform fees on INR ticket sales?", a: "No. EventHex charges zero platform fees. You pay only the Razorpay gateway processing fees." },
    { q: "Can EventHex export GST data for accounting?", a: "Yes. EventHex can export attendee data alongside GST invoice records — including GSTIN, tax amounts, and payment status — for reconciliation with your finance team." },
  ]}
  jsonLd={jsonLd}
/>
