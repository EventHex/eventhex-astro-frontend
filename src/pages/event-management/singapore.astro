---
import FeatureV2Layout from "../../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../../lib/bentoIllustrations";

const stackingImage = "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Management Software in Singapore",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "End-to-end event management software for Singapore conferences, trade shows, and corporate events — with Stripe payments, multi-currency support, and hybrid/virtual event tools.",
  url: "https://eventhex.ai/event-management/singapore/",
  areaServed: "Singapore",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
};
---

<FeatureV2Layout
  pageTitle="Event Management Software in Singapore | EventHex"
  pageDescription="Manage Singapore conferences, trade shows, and corporate events with EventHex — Stripe payments in SGD and multi-currency, hybrid/virtual streaming, and real-time attendee tracking."
  canonical="https://eventhex.ai/event-management/singapore/"
  badge="Event Management in Singapore"
  heroTitleLine1="Event Management Software"
  heroTitleLine2="Built for Singapore"
  heroCopy="From Marina Bay Sands convention floors to hybrid summits at Suntec Singapore, EventHex gives organisers Stripe-powered payments in SGD and 135+ currencies, hybrid and virtual event streaming, multi-language registration, and a real-time dashboard for managing Asia-Pacific attendee flows."
  trustItems={["Stripe Payments — SGD & Multi-Currency", "Hybrid & Virtual Event Tools", "Multi-Language Registration (EN/AR/DE)"]}
  stats={[
    { value: "0%", label: "Platform Fees" },
    { value: "3", label: "Languages Supported (EN/AR/DE)" },
    { value: "99.9%", label: "Uptime SLA" },
    { value: "100K+", label: "Registrations Processed" },
  ]}
  statsHeadline={{
    white1: "Every attendee.",
    accent: "Every currency.",
    white2: "Managed in",
    accent2: "real time",
  }}
  bentoHeading="Everything Singapore Event Organisers Need"
  bentoSubtitle="From pre-event registration to on-site badge scanning, hybrid streaming, and post-event analytics — EventHex supports the full lifecycle for Singapore trade shows, conferences, and corporate events."
  bentoTabs={[
    {
      tab: "Registration & Ticketing",
      cards: [
        { title: "Stripe Payments in SGD", desc: "Accept Visa, Mastercard, Amex, and Apple Pay in SGD — or in any of 135+ currencies for global attendees", illustration: ILLOS.creditcard },
        { title: "Multi-Language Registration", desc: "Registration forms in English, Arabic, and German — supporting Singapore's diverse international event audience", illustration: ILLOS.translate },
        { title: "Multi-Tier Ticketing", desc: "Delegate, exhibitor, VIP, and media passes — each with independent capacity, pricing, and access rules", illustration: ILLOS.money },
        { title: "Live Registration Dashboard", desc: "Real-time view of registrations, payment status, and check-in stage across all ticket types", illustration: ILLOS.dashboard },
        { title: "Bulk Attendee Import", desc: "Upload delegate lists from CSV or Excel with duplicate detection and automated field mapping", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "On-Site & Check-In",
      cards: [
        { title: "QR Badge Check-In", desc: "Scan attendee QR codes at exhibition hall entrances using any smartphone — no proprietary hardware", illustration: ILLOS.qr },
        { title: "On-Site Badge Printing", desc: "Print branded name badges immediately as delegates arrive — reducing reception queue times", illustration: ILLOS.poster },
        { title: "Walk-In Registration", desc: "Register walk-in attendees and collect SGD payment via Stripe at the door", illustration: ILLOS.user },
        { title: "Session Access Control", desc: "Cap workshops and breakout sessions by attendee count — scanning enforces limits in real time", illustration: ILLOS.calendar },
        { title: "Live Check-In Analytics", desc: "Real-time arrival curves and no-show counts to support ground teams at large convention venues", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Engagement & Analytics",
      cards: [
        { title: "Hybrid & Virtual Streaming", desc: "Stream keynotes and sessions to remote attendees across Asia-Pacific alongside your in-person audience", illustration: ILLOS.stream },
        { title: "Multi-Currency Support", desc: "Charge international delegates in USD, EUR, AED, or their local currency with SGD payouts via Stripe", illustration: ILLOS.globe },
        { title: "Post-Event Surveys", desc: "Collect structured delegate feedback automatically after sessions with multi-language delivery", illustration: ILLOS.chatform },
        { title: "SGD Revenue Dashboard", desc: "Real-time ticket revenue and outstanding payments displayed in Singapore Dollars", illustration: ILLOS.money },
        { title: "Delegate Export", desc: "One-click export of attendee lists for exhibitor lead delivery and post-event reporting", illustration: ILLOS.share },
      ],
    },
  ]}
  stackingHeading="Powerful Event Tools"
  stackingHighlight="for Singapore"
  stackingCards={[
    {
      title: "Stripe Payments in SGD — For Local & Global Attendees",
      desc: "Accept Visa, Mastercard, Amex, and Apple Pay in SGD through Stripe — no EventHex platform fee on top of gateway costs. International attendees pay in their own currency with SGD payouts for the organiser.",
      image: stackingImage,
      alt: "Stripe event ticketing in SGD on a tablet in Singapore",
    },
    {
      title: "Hybrid Events — Connect Asia-Pacific Audiences",
      desc: "Run hybrid conferences where Singapore-based delegates and remote attendees across Asia-Pacific participate together — live-streamed keynotes, virtual Q&A, and unified registration tracking in one platform.",
      image: stackingImage,
      alt: "Hybrid event management dashboard on a tablet",
    },
    {
      title: "Multi-Currency for International Trade Shows",
      desc: "Singapore's trade shows attract exhibitors and delegates from dozens of countries. EventHex via Stripe supports 135+ currencies so every attendee pays in the currency they prefer, while organisers receive SGD payouts.",
      image: stackingImage,
      alt: "Multi-currency international event registration on a tablet",
    },
  ]}
  howItWorksHeading="How EventHex Works for Singapore Events"
  steps={[
    { title: "Configure Tickets & Connect Stripe in SGD", desc: "Set up delegate and exhibitor passes in SGD, connect Stripe, and enable multi-currency for international attendees." },
    { title: "Launch Multi-Language Registration", desc: "Publish your event page and share registration links via email, LinkedIn, and your event partners." },
    { title: "Manage In-Person & Remote Attendees", desc: "Track on-site and virtual attendees from the same real-time dashboard — registrations, check-ins, and stream access unified." },
    { title: "Analyse & Export Post-Event", desc: "Review SGD revenue, attendance rates, and session data, then export delegate lists for exhibitor lead reporting." },
  ]}
  ctaTitle="Ready to Run Your Next Singapore Event?"
  ctaCopy="See how EventHex streamlines registration, Stripe payments, and hybrid event management for Singapore conferences and trade shows."
  whyHeading="Why Singapore Organisers Choose EventHex"
  whyCards={[
    { title: "Stripe in SGD", desc: "Accept global cards in SGD and 135+ currencies — no platform fees", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "Hybrid & Virtual", desc: "Stream to Asia-Pacific remote attendees alongside in-person audiences", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>' },
    { title: "Multi-Currency", desc: "International delegates pay in local currency — SGD payouts via Stripe", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' },
    { title: "0% Platform Fees", desc: "No added surcharge on SGD or multi-currency ticket revenue", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' },
    { title: "Real-Time Dashboard", desc: "Live attendee, check-in, and SGD revenue data on any device", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "Which payment methods does EventHex support in Singapore?", a: "EventHex integrates with Stripe, supporting Visa, Mastercard, American Express, and Apple Pay in SGD. International delegates can pay in 135+ currencies with automatic SGD conversion for organisers." },
    { q: "Does EventHex support hybrid events in Singapore?", a: "Yes. EventHex supports hybrid and virtual events — you can stream sessions to remote attendees across Asia-Pacific while managing in-person check-ins at the venue, both tracked in one real-time dashboard." },
    { q: "Can international delegates pay in their own currency?", a: "Yes. Through Stripe's multi-currency support, international attendees pay in USD, EUR, AED, or their preferred currency, while organisers receive payouts in SGD." },
    { q: "Is EventHex suitable for large Singapore trade shows?", a: "Yes. EventHex handles high-volume events with bulk delegate import, multi-gate QR check-in, session capacity controls, and a live operations dashboard for teams spread across large convention centres like Marina Bay Sands or Suntec." },
    { q: "Does EventHex charge platform fees on SGD ticket sales?", a: "No. EventHex adds zero platform fees. Organisers pay only the Stripe payment gateway fees." },
    { q: "Can EventHex handle events with attendees from multiple countries?", a: "Yes. Multi-language registration (EN/AR/DE), multi-currency Stripe payments, and hybrid streaming make EventHex well-suited for Singapore's internationally diverse trade shows and conferences." },
  ]}
  jsonLd={jsonLd}
/>
