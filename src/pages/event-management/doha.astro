---
import FeatureV2Layout from "../../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../../lib/bentoIllustrations";

const stackingImage = "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Management Software in Doha",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "End-to-end event management software for Doha conferences, international summits, and corporate events — with Arabic/RTL support, Tap Payments (KNET/Visa/MC), and WhatsApp concierge.",
  url: "https://eventhex.ai/event-management/doha/",
  areaServed: "Doha",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
};
---

<FeatureV2Layout
  pageTitle="Event Management Software in Doha | EventHex"
  pageDescription="Run Doha conferences, international summits, and corporate events with EventHex — Arabic/RTL registration forms, Tap Payments (KNET/Visa/MC), WhatsApp concierge, and real-time attendee tracking."
  canonical="https://eventhex.ai/event-management/doha/"
  badge="Event Management in Doha"
  heroTitleLine1="Event Management Software"
  heroTitleLine2="Built for Doha"
  heroCopy="From Qatar Economic Forum sessions at Sheraton Grand Doha to corporate summits at Lusail, EventHex equips Qatari event organisers with Arabic/RTL registration, Tap Payments in QAR, WhatsApp attendee messaging, and a real-time dashboard for both local and international delegates."
  trustItems={["Arabic & RTL Registration Forms", "Tap Payments — KNET, Visa/MC, Apple Pay", "WhatsApp Concierge"]}
  stats={[
    { value: "0%", label: "Platform Fees" },
    { value: "3", label: "Languages Supported (EN/AR/DE)" },
    { value: "99.9%", label: "Uptime SLA" },
    { value: "100K+", label: "Registrations Processed" },
  ]}
  statsHeadline={{
    white1: "Every delegate.",
    accent: "Every riyal.",
    white2: "Tracked in",
    accent2: "real time",
  }}
  bentoHeading="Everything Doha Event Organisers Need"
  bentoSubtitle="From pre-event registration to on-site check-in and post-event reporting — EventHex supports the full lifecycle for Doha's international conferences, summits, and corporate events."
  bentoTabs={[
    {
      tab: "Registration & Ticketing",
      cards: [
        { title: "Arabic & RTL Registration", desc: "Full right-to-left forms for Arabic-speaking delegates — labels, validation, and emails in Arabic", illustration: ILLOS.translate },
        { title: "Tap Payments in QAR", desc: "Accept KNET, Apple Pay, Visa, and Mastercard in Qatari Riyals through Tap Payments", illustration: ILLOS.creditcard },
        { title: "Multi-Tier Passes", desc: "Configure delegate, VIP, media, and exhibitor passes with independent capacities and pricing", illustration: ILLOS.money },
        { title: "Live Registration Tracking", desc: "Real-time dashboard showing registrations, payment status, and check-in stage for every attendee", illustration: ILLOS.dashboard },
        { title: "Bulk Import", desc: "Upload delegate lists from Excel or CSV with duplicate detection and field mapping", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "On-Site & Check-In",
      cards: [
        { title: "QR Badge Check-In", desc: "Scan delegate QR codes at entry points using any smartphone — fast and reliable", illustration: ILLOS.qr },
        { title: "On-Site Badge Printing", desc: "Print Arabic and English name badges immediately upon delegate arrival", illustration: ILLOS.poster },
        { title: "Walk-In Registration", desc: "Register walk-in attendees at the door and collect QAR payment via Tap instantly", illustration: ILLOS.user },
        { title: "Session Capacity Control", desc: "Cap breakout sessions by attendee count — QR scanning prevents overcrowding", illustration: ILLOS.calendar },
        { title: "Arrival Analytics", desc: "Live check-in curves and no-show reporting to keep venue operations running smoothly", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Engagement & Analytics",
      cards: [
        { title: "WhatsApp Concierge", desc: "Send Arabic and English session reminders, venue maps, and last-minute updates via WhatsApp", illustration: ILLOS.whatsapp },
        { title: "Bilingual Event Page", desc: "Arabic and English registration page under your own domain — no developer needed", illustration: ILLOS.palette },
        { title: "Post-Event Feedback", desc: "Arabic-language surveys sent automatically after sessions close", illustration: ILLOS.chatform },
        { title: "QAR Revenue Dashboard", desc: "Real-time ticket revenue, refunds, and outstanding payments in Qatari Riyals", illustration: ILLOS.money },
        { title: "Delegate Export", desc: "One-click export for sponsor leads and post-event reporting", illustration: ILLOS.share },
      ],
    },
  ]}
  stackingHeading="Powerful Event Tools"
  stackingHighlight="for Doha"
  stackingCards={[
    {
      title: "Arabic-First Registration for International & Local Delegates",
      desc: "EventHex switches to full right-to-left layout when Arabic is selected — ensuring Qatari delegates and Arabic-speaking international guests register without friction in their preferred language.",
      image: stackingImage,
      alt: "Arabic RTL delegate registration form on a tablet in Doha",
    },
    {
      title: "KNET & International Cards via Tap Payments",
      desc: "Accept KNET, Apple Pay, Visa, and Mastercard through a single Tap Payments integration with QAR payouts — covering both local Qatari payment preferences and international conference attendees.",
      image: stackingImage,
      alt: "Tap Payments KNET checkout on a tablet",
    },
    {
      title: "WhatsApp Concierge for High-Engagement Communication",
      desc: "Automate session reminders, agenda updates, and venue navigation in Arabic and English via WhatsApp — the messaging channel Doha conference attendees respond to fastest.",
      image: stackingImage,
      alt: "WhatsApp event concierge messages in Arabic and English",
    },
  ]}
  howItWorksHeading="How EventHex Works for Doha Events"
  steps={[
    { title: "Set Up Tickets & Connect Tap Payments", desc: "Configure delegate passes and pricing in QAR, then connect Tap Payments to accept KNET, Apple Pay, and international cards." },
    { title: "Launch Bilingual Registration", desc: "Publish an Arabic and English event page and share the registration link via email, WhatsApp, and your organisation's channels." },
    { title: "Track Delegates in Real Time", desc: "Monitor registrations, QAR payments, and check-ins from a single dashboard on any device." },
    { title: "Engage via WhatsApp & Collect Feedback", desc: "Send automated Arabic and English WhatsApp reminders and post-event surveys to maximise attendance and insights." },
  ]}
  ctaTitle="Ready to Run Your Next Doha Event?"
  ctaCopy="See how EventHex streamlines delegate registration, QAR payments, and on-site check-in for Doha conferences and international summits."
  whyHeading="Why Doha Organisers Choose EventHex"
  whyCards={[
    { title: "Arabic / RTL Support", desc: "Native Arabic forms and bilingual event pages with RTL layout", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' },
    { title: "KNET & International Cards", desc: "QAR payments via Tap Payments for local and global delegates", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "WhatsApp Concierge", desc: "Bilingual attendee messaging with automated workflows", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' },
    { title: "0% Platform Fees", desc: "No surcharge on QAR ticket revenue", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' },
    { title: "Real-Time Dashboard", desc: "Live delegate, check-in, and QAR revenue data on any device", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "Does EventHex support Arabic for Doha events?", a: "Yes. EventHex renders registration forms in full right-to-left layout with Arabic labels and sends confirmation emails in Arabic when selected. No additional configuration is needed." },
    { q: "Which payment methods can I accept in Qatar?", a: "EventHex integrates with Tap Payments, which supports KNET, Apple Pay, Visa, and Mastercard — covering both Qatari payment preferences and the international cards expected at global conferences." },
    { q: "Can I communicate with delegates via WhatsApp?", a: "Yes. EventHex's WhatsApp concierge automates session reminders, agenda updates, and venue directions in Arabic or English — the channel that consistently delivers the highest open rates in Qatar." },
    { q: "Is EventHex suitable for large Doha conferences?", a: "Yes. EventHex handles high-capacity events with bulk delegate import, multi-gate QR check-in, session access control, and a real-time operations dashboard for on-site teams." },
    { q: "Does EventHex charge platform fees on QAR ticket sales?", a: "No. EventHex adds zero platform fees. You pay only the Tap Payments gateway processing fees." },
    { q: "Can international delegates register in English while local delegates use Arabic?", a: "Yes. A single EventHex event supports both languages simultaneously — each delegate chooses their preferred language and receives all communications accordingly." },
  ]}
  jsonLd={jsonLd}
/>
