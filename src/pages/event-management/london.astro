---
import FeatureV2Layout from "../../components/feature-v2/FeatureV2Layout.astro";
import { ILLOS } from "../../lib/bentoIllustrations";

const stackingImage = "https://cms.eventhex.ai/wp-content/uploads/2025/04/Galaxy-Tab-S8-Ultra.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Event Management Software in London",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "End-to-end event management software for London conferences, hybrid events, and corporate gatherings — with Stripe payments, multi-currency support, and virtual/hybrid event tools.",
  url: "https://eventhex.ai/event-management/london/",
  areaServed: "London",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
};
---

<FeatureV2Layout
  pageTitle="Event Management Software in London | EventHex"
  pageDescription="Manage London conferences, hybrid events, and corporate gatherings with EventHex — Stripe payments, multi-currency support, hybrid/virtual streaming, GDPR-compliant forms, and real-time attendee tracking."
  canonical="https://eventhex.ai/event-management/london/"
  badge="Event Management in London"
  heroTitleLine1="Event Management Software"
  heroTitleLine2="Built for London"
  heroCopy="From ExCeL conference halls to hybrid summits at The O2, EventHex gives London event organisers Stripe-powered payments in GBP and 135+ currencies, hybrid and virtual event streaming, GDPR-compliant registration forms, and a real-time dashboard accessible from anywhere."
  trustItems={["Stripe Payments — GBP & Multi-Currency", "Hybrid & Virtual Event Tools", "GDPR-Compliant Registration"]}
  stats={[
    { value: "0%", label: "Platform Fees" },
    { value: "3", label: "Languages Supported (EN/AR/DE)" },
    { value: "99.9%", label: "Uptime SLA" },
    { value: "100K+", label: "Registrations Processed" },
  ]}
  statsHeadline={{
    white1: "Every attendee.",
    accent: "Every currency.",
    white2: "Managed in",
    accent2: "real time",
  }}
  bentoHeading="Everything London Event Organisers Need"
  bentoSubtitle="From pre-event registration to on-site check-in, hybrid streaming, and post-event analytics — EventHex covers the full event lifecycle for London conferences, corporate events, and hybrid gatherings."
  bentoTabs={[
    {
      tab: "Registration & Ticketing",
      cards: [
        { title: "Stripe Payments in GBP", desc: "Accept Visa, Mastercard, American Express, and Apple Pay in GBP — or in any of 135+ currencies for international delegates", illustration: ILLOS.creditcard },
        { title: "GDPR-Compliant Forms", desc: "Built-in consent checkboxes, opt-in language, and data retention controls — fully compliant with UK GDPR", illustration: ILLOS.shield },
        { title: "Multi-Tier Ticketing", desc: "Early bird, standard, VIP, and speaker passes — each with independent pricing, capacity, and access rules", illustration: ILLOS.money },
        { title: "Real-Time Registration Tracking", desc: "Live dashboard showing sign-ups, payment status, and check-in stage across all ticket types", illustration: ILLOS.dashboard },
        { title: "Bulk Attendee Import", desc: "Upload delegate lists from CSV or Excel with duplicate detection and field mapping", illustration: ILLOS.clipboard },
      ],
    },
    {
      tab: "On-Site & Check-In",
      cards: [
        { title: "QR Badge Check-In", desc: "Scan attendee QR codes at venue entrances using any smartphone — no proprietary hardware needed", illustration: ILLOS.qr },
        { title: "On-Site Badge Printing", desc: "Print branded name badges immediately as attendees arrive — reducing queue times at reception", illustration: ILLOS.poster },
        { title: "Walk-In Registration", desc: "Register last-minute attendees at the door and collect GBP payment via Stripe instantly", illustration: ILLOS.user },
        { title: "Session Capacity Control", desc: "Cap breakout sessions and workshops — QR scanning enforces limits in real time", illustration: ILLOS.calendar },
        { title: "Live Check-In Analytics", desc: "Real-time arrival curves and no-show counts to help event staff manage flow across large venues", illustration: ILLOS.chart },
      ],
    },
    {
      tab: "Engagement & Analytics",
      cards: [
        { title: "Hybrid & Virtual Streaming", desc: "Stream keynotes and sessions to remote attendees alongside your in-person audience", illustration: ILLOS.stream },
        { title: "Multi-Currency Support", desc: "Charge international delegates in their own currency while receiving GBP payouts via Stripe", illustration: ILLOS.globe },
        { title: "Post-Event Surveys", desc: "Collect structured delegate feedback immediately after sessions with automated delivery", illustration: ILLOS.chatform },
        { title: "Revenue Dashboard", desc: "Real-time GBP revenue, refunds, and outstanding payments in a single view", illustration: ILLOS.money },
        { title: "Attendee Export", desc: "Export delegate lists for sponsor lead delivery and post-event reporting", illustration: ILLOS.share },
      ],
    },
  ]}
  stackingHeading="Powerful Event Tools"
  stackingHighlight="for London"
  stackingCards={[
    {
      title: "Stripe Payments in GBP — For Every Ticket Type",
      desc: "Accept Visa, Mastercard, Amex, and Apple Pay in GBP through Stripe — with no platform fees from EventHex on top of standard Stripe gateway costs. International delegates can pay in their own currency with automatic GBP conversion.",
      image: stackingImage,
      alt: "Stripe event ticketing checkout on a tablet in London",
    },
    {
      title: "Hybrid & Virtual Events — In-Person and Online Together",
      desc: "Run hybrid London conferences where in-person delegates and remote attendees experience the same event — live-streamed keynotes, virtual networking, and unified registration in one platform.",
      image: stackingImage,
      alt: "Hybrid event management dashboard on a tablet",
    },
    {
      title: "GDPR-Compliant Registration Out of the Box",
      desc: "Every EventHex registration form includes built-in UK GDPR consent checkboxes, customisable opt-in language, and data retention controls — so your London event is compliant from day one without legal workarounds.",
      image: stackingImage,
      alt: "GDPR compliant event registration form on a tablet",
    },
  ]}
  howItWorksHeading="How EventHex Works for London Events"
  steps={[
    { title: "Configure Tickets & Connect Stripe", desc: "Set up ticket tiers in GBP, connect Stripe, and enable multi-currency for international delegates." },
    { title: "Launch GDPR-Compliant Registration", desc: "Publish your event page with UK GDPR consent fields built in and share the registration link across email and social." },
    { title: "Manage In-Person & Virtual Attendees", desc: "Track both on-site and remote attendees from the same dashboard — registrations, check-ins, and stream access all in one view." },
    { title: "Collect Feedback & Analyse Results", desc: "Send post-event surveys automatically and review revenue, attendance, and engagement data in GBP." },
  ]}
  ctaTitle="Ready to Run Your Next London Event?"
  ctaCopy="See how EventHex simplifies registration, Stripe payments, and hybrid streaming for London conferences and corporate gatherings."
  whyHeading="Why London Organisers Choose EventHex"
  whyCards={[
    { title: "Stripe Payments", desc: "GBP and 135+ currencies — no platform fee on top of gateway costs", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>' },
    { title: "Hybrid & Virtual", desc: "Stream sessions to remote attendees alongside in-person audiences", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>' },
    { title: "GDPR-Compliant", desc: "Built-in UK GDPR consent fields and data retention controls", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>' },
    { title: "0% Platform Fees", desc: "No surcharge on GBP ticket revenue — pay only Stripe fees", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>' },
    { title: "Real-Time Dashboard", desc: "Live registration, check-in, and GBP revenue data on any device", icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>' },
  ]}
  faqs={[
    { q: "Which payment methods does EventHex support in London?", a: "EventHex integrates with Stripe, supporting Visa, Mastercard, American Express, and Apple Pay in GBP. International delegates can pay in their own currency with automatic GBP conversion for payouts." },
    { q: "Is EventHex GDPR compliant?", a: "Yes. Every EventHex registration form includes built-in UK GDPR consent checkboxes, customisable opt-in language, and data retention controls. EventHex supports data subject access requests and right-to-erasure workflows." },
    { q: "Does EventHex support hybrid events?", a: "Yes. EventHex supports hybrid and virtual events — you can stream sessions to remote attendees while managing in-person check-ins, with both audiences tracked in the same real-time dashboard." },
    { q: "Can EventHex handle multi-currency payments?", a: "Yes. Through Stripe, EventHex supports 135+ currencies — international delegates pay in their preferred currency while organisers receive GBP payouts." },
    { q: "Does EventHex charge platform fees on GBP ticket sales?", a: "No. EventHex adds zero platform fees. You pay only the Stripe payment gateway processing fees." },
    { q: "Is EventHex suitable for large London conferences at ExCeL or similar venues?", a: "Yes. EventHex handles large-scale events with bulk import, multi-gate QR check-in, session capacity controls, and a live operations dashboard for teams spread across large venues." },
  ]}
  jsonLd={jsonLd}
/>
