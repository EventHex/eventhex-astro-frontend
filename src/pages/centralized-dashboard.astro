---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/feature-page/HeroSection.astro";
import FeatureSectionSimple from "../components/feature-page/FeatureSectionSimple.astro";
import BenefitsSection from "../components/feature-page/BenefitsSection.astro";
import CTASection from "../components/feature-page/CTASection.astro";

const title = "Centralized Dashboard - EventHex";
const description = "Whether you are handling multiple events across various domains or hosting simultaneous gatherings, EventHex's centralised dashboard offers a unified view of your entire event portfolio in one place.";
---

<MarketingLayout {title} {description}>
  <HeroSection
    eyebrow="Centralized Dashboard"
    title="Take Command of All Your Events from A Single Dashboard"
    description="Whether you are handling multiple events across various domains or hosting simultaneous gatherings, EventHex's centralised dashboard offers a unified view of your entire event portfolio in one place."
    image="https://eventhex.ai/wp-content/uploads/2025/04/AI-Form-Builder.png"
    imageAlt="EventHex Centralized Dashboard overview"
  />

  <FeatureSectionSimple
    sectionTitle="View Your Entire Event Portfolio in One Place"
    imageLeft={true}
    image="https://eventhex.ai/wp-content/uploads/2025/04/Dashboard.png"
    imageAlt="EventHex centralized event portfolio dashboard"
    items={[
      "Keep all your event data in one secure place",
      "Easily add, modify, and delete event data from the main board",
      "Centralized data management provides you with advanced event analytics",
    ]}
  />

  <FeatureSectionSimple
    sectionTitle="Unlimited Events, Unlimited Growth"
    imageLeft={false}
    image="https://eventhex.ai/wp-content/uploads/2025/04/Home-_Events-_All.png"
    imageAlt="EventHex unlimited events management interface"
    items={[
      "Organize as many events as you need with no caps on attendees or simultaneous gatherings",
      "Enjoy centralised control over every aspect of your events, from planning to execution",
      "Whether it's a small gathering or a large-scale conference, EventHex flexes to fit everything",
    ]}
  />

  <BenefitsSection
    sectionTitle="Why Choose EventHex for Event Management"
    cards={[
      {
        icon: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-1000003210.svg",
        title: "Efficiency",
        description: "Simplify your workflow and focus on creating exceptional attendee experiences.",
      },
      {
        icon: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-1000002870-5.svg",
        title: "Data Control",
        description: "Effortlessly sync data for enhanced event management and follow-up.",
      },
      {
        icon: "https://eventhex.ai/wp-content/uploads/2025/04/Frame-1000002870-1-1.svg",
        title: "Event Analytics",
        description: "Gain valuable insights to improve performance and attendee engagement.",
      },
    ]}
  />

  <CTASection title={"Explore EventHex's\nCentralized Dashboard"} />
</MarketingLayout>
