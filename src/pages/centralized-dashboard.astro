---
import FeatureV2Layout from "../components/feature-v2/FeatureV2Layout.astro";
import { cdbIllustrations as ill } from "../components/centralized-dashboard/illustrations";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex — Centralized Event Management Dashboard",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description: "Centralized event management dashboard with multi-event portfolio view, event cloning, role-based team access, brand customization, and cross-event analytics.",
  url: "https://eventhex.ai/centralized-dashboard/",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free demo available" },
  featureList: [
    "Multi-Event Portfolio View",
    "One-Click Event Cloning",
    "Role-Based Access Control",
    "Team Member Invitations",
    "Cross-Event Analytics",
    "Brand Customization",
    "Custom Domain Management",
    "Audit Logging",
  ],
};
---

<FeatureV2Layout
  pageTitle="Centralized Event Dashboard — All Events, One Control Panel | EventHex"
  pageDescription="Manage your entire event portfolio from a single organizational dashboard — clone events, manage teams, set role-based permissions, track subscription usage, and customize your brand across all events."
  canonical="https://eventhex.ai/centralized-dashboard/"
  ogImage="https://eventhex.ai/wp-content/uploads/2025/04/Dashboard.png"
  badge="Event Management Dashboard"
  heroTitleLine1="All Your Events. One Dashboard."
  heroTitleLine2="Full Control."
  heroCopy="Manage your entire event portfolio from a single organizational dashboard — clone events, manage teams, set role-based permissions, track subscription usage, and customize your brand across all events."
  trustItems={["Multi-Event Portfolio View", "Role-Based Access", "One-Click Event Cloning"]}
  stats={[
    { value: "300+", label: "Events Managed" },
    { value: "10x", label: "Faster Setup via Cloning" },
    { value: "5 Roles", label: "Permission Levels" },
    { value: "100%", label: "Brand Customization" },
  ]}
  statsHeadline={{
    white1: "One organization.",
    accent: "Every event.",
    white2: "Total",
    accent2: "control",
  }}
  bentoHeading="Everything You Need in a Centralized Dashboard"
  bentoSubtitle="From your org dashboard, clone last year's event in one click, assign team members to specific events, track subscription usage, and enforce brand consistency across your entire portfolio."
  bentoTabs={[
    {
      tab: "Multi-Event Management",
      cards: [
        { title: "Event Portfolio View", desc: "See all your events in one list view — with status, registration counts, and revenue at a glance", illustration: ill.cdb1 },
        { title: "One-Click Event Cloning", desc: "Clone any past event to reuse its setup, form fields, email templates, and content", illustration: ill.cdb2 },
        { title: "Cross-Event Analytics", desc: "Compare registration trends, attendance, and revenue across your full event portfolio", illustration: ill.cdb3 },
        { title: "Bulk Operations", desc: "Apply settings, templates, or team assignments across multiple events simultaneously", illustration: ill.cdb4 },
        { title: "Event Categories", desc: "Organise events by type, department, or recurring series for easier management", illustration: ill.cdb5 },
      ],
    },
    {
      tab: "Team & Permissions",
      cards: [
        { title: "Role-Based Access", desc: "Assign Admin, Manager, Marketer, Scanner, or View-Only roles with granular permission control", illustration: ill.cdb6 },
        { title: "Team Member Invites", desc: "Invite team members by email — they get instant access with the permissions you set", illustration: ill.cdb7 },
        { title: "Event-Level Admins", desc: "Assign an event-specific admin to manage one event without accessing others", illustration: ill.cdb8 },
        { title: "Activity Logging", desc: "Full audit trail of who changed what and when across all events in your organization", illustration: ill.cdb9 },
        { title: "Permission Templates", desc: "Save common permission sets as templates and apply them to new team members instantly", illustration: ill.cdb10 },
      ],
    },
    {
      tab: "Organization Settings",
      cards: [
        { title: "Brand Customization", desc: "Set org-wide logo, brand colours, email sender name, and footer for all events", illustration: ill.cdb11 },
        { title: "Custom Terminology", desc: "Rename attendees, tickets, sessions, and other terms to match your organization's language", illustration: ill.cdb12 },
        { title: "Billing & Subscription", desc: "Manage your EventHex subscription, view invoices, and update payment details from org settings", illustration: ill.cdb13 },
        { title: "Usage Tracking", desc: "Monitor events created, registrations processed, emails sent, and storage used against your plan", illustration: ill.cdb14 },
        { title: "Domain Management", desc: "Configure custom event subdomains and sender email domains for all events in your org", illustration: ill.cdb15 },
      ],
    },
  ]}
  stackingHeading="Dashboard Features"
  stackingHighlight="That Save Time"
  stackingCards={[
    {
      title: "Next Event Setup in Under 60 Seconds",
      desc: "Recurring events shouldn't require starting from scratch. Clone any past event and carry forward the setup, registration form, email templates, ticket types, and speaker structure.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/Dashboard.png",
      alt: "One-click event cloning interface with settings preview",
    },
    {
      title: "Right Access. Right People. Right Events.",
      desc: "Give your marketing team edit access only to event websites. Give check-in staff scanner-only access. Give your CEO view-only across everything. All from one permission panel.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/Home-_Events-_All.png",
      alt: "Role-based permission management dashboard",
    },
    {
      title: "Your Brand. Across Every Event Surface.",
      desc: "Set your organisation's logo, brand colours, custom email domain, and sender name once — and every event inherits those settings automatically.",
      image: "https://eventhex.ai/wp-content/uploads/2025/04/Mac-Studio.png",
      alt: "Brand customization settings with logo and color controls",
    },
  ]}
  howItWorksHeading="How the Centralized Dashboard Works"
  steps={[
    { title: "Set Up Your Organization", desc: "Create your organisation profile, set your brand assets, and configure your custom domain and email sender settings." },
    { title: "Create or Clone Events", desc: "Start a new event from scratch, or clone a past event to reuse its full setup in one click." },
    { title: "Invite and Assign Your Team", desc: "Invite team members with role-specific permissions. Assign people to specific events or give org-wide access." },
    { title: "Monitor Your Portfolio", desc: "Track all events from the portfolio dashboard — registrations, revenue, and upcoming milestones across your full calendar." },
  ]}
  ctaTitle="Ready to Manage All Your Events From One Place?"
  ctaCopy="See how EventHex centralised dashboard gives organizers full visibility, team control, and brand consistency across every event."
  whyHeading="Why Organizers Choose EventHex Dashboard"
  whyCards={[
    { title: "Portfolio View", desc: "All events in one list with live status and metrics" },
    { title: "Event Cloning", desc: "Reuse any past event setup in one click" },
    { title: "Role-Based Access", desc: "5 permission levels with event-level scoping" },
    { title: "Brand Consistency", desc: "Org-wide branding applied to every event" },
    { title: "Cross-Event Analytics", desc: "Portfolio-level view of registration and revenue trends" },
  ]}
  faqs={[
    { q: "What is the centralized event management dashboard?", a: "The EventHex centralized dashboard is an organization-level control panel where you manage your full event portfolio — creating and cloning events, managing team access, tracking usage, and enforcing brand consistency across all events." },
    { q: "How does event cloning work?", a: "Select any past event and click Clone. EventHex creates a new event with all the same settings — ticket types, registration form fields, email templates, session structure, and page content. Update the dates and you're ready to go live." },
    { q: "How do I manage team permissions?", a: "Invite team members by email and assign them a role: Admin (full access), Manager (create and edit events), Marketer (marketing campaigns only), Scanner (check-in access only), or View-Only. You can also scope roles to specific events." },
    { q: "Can I manage multiple events from one account?", a: "Yes. The EventHex organization dashboard shows all your events in a single portfolio view with live status, registration counts, and revenue. You can create, clone, archive, and manage events without switching accounts." },
    { q: "Can I use my own domain and email sender?", a: "Yes. EventHex supports custom subdomains for event pages (events.yourcompany.com) and custom sender email domains (rsvp@yourcompany.com). Both can be configured in organization settings." },
  ]}
  jsonLd={jsonLd}
/>
