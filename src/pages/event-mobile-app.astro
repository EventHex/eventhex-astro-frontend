---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import HeroSection from "../components/event-mobile-app/HeroSection.astro";
import StatsSection from "../components/event-mobile-app/StatsSection.astro";
import BentoGrid from "../components/event-mobile-app/BentoGrid.astro";
import FeatureCards from "../components/event-mobile-app/FeatureCards.astro";
import HowItWorksSection from "../components/event-mobile-app/HowItWorksSection.astro";
import CTASection from "../components/event-mobile-app/CTASection.astro";
import CoordinationTools from "../components/event-mobile-app/CoordinationTools.astro";
import FaqSection from "../components/event-mobile-app/FaqSection.astro";

const ogImage = "https://eventhex.ai/wp-content/uploads/2025/01/Instasnap.png";
const title = "Event Mobile App with AI Networking & White-Label Branding | EventHex";
const description = "Launch a branded event mobile app with AI-powered networking, live agenda, push notifications, QR check-in, and interactive maps — all under your event brand.";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "EventHex Event Mobile App",
  applicationCategory: "BusinessApplication",
  operatingSystem: "iOS, Android, Web",
  url: "https://eventhex.ai/event-mobile-app/",
  description,
  creator: {
    "@type": "Organization",
    name: "EventHex",
    url: "https://eventhex.ai",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    description: "Free demo available",
  },
  featureList: [
    "AI-powered attendee networking with Smart Connect",
    "White-label branding with App Store publishing",
    "Live agenda with personal schedule builder",
    "Push notifications and session reminders",
    "Interactive venue maps with wayfinding",
    "Live polls, Q&A, and session feedback",
    "Gamification with points, badges, and leaderboards",
    "Sponsor banners, splash screens, and sponsored sessions",
    "Contactless QR check-in with offline fallback",
    "Real-time analytics and adoption dashboard",
  ],
};
---

<MarketingLayout
  title={title}
  description={description}
  canonical="https://eventhex.ai/event-mobile-app/"
  ogImage={ogImage}
>
  <HeroSection />
  <StatsSection />
  <BentoGrid />
  <FeatureCards />
  <HowItWorksSection />
  <CTASection />
  <CoordinationTools />
  <FaqSection />

  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>
</MarketingLayout>

<style>
  :global(main) {
    background-color: #ffffff;
  }
</style>
