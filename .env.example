WP_URL=https://cms.eventhex.ai
# Optional: For authenticated requests (creating/updating content)
# WP_APP_USERNAME=
# WP_APP_PASSWORD=

# Cal.com cloud API key — server-only. Set as a secret in Cloudflare for prod.
CALCOM_API_KEY=

# Optional: comma-separated emails added as guests to EVERY demo booking
# (e.g. internal sales rep). They receive the same calendar invite.
CALCOM_GUEST_EMAILS=

# Pre-demo brochure email — calls the SaaS API (SES) after a booking.
# DEMO_NOTIFY_URL = full URL to the SaaS API endpoint, e.g.
#   https://app-api.eventhex.ai/api/v1/demo/notify
# DEMO_NOTIFY_SECRET must match DEMO_NOTIFY_SECRET in the SaaS API .env.
DEMO_NOTIFY_URL=
DEMO_NOTIFY_SECRET=

# DataHex ERP CRM — pushes each Book-a-Demo lead into the CRM after a booking.
# ERP_API_KEY = DataHex live key (server-only secret). Required to enable.
# ERP_LEADS_URL defaults to https://erp.datahex.co/api/v1/leads.
# ERP_LEAD_SOURCE defaults to "Website" (must match a CRM source name).
# ERP_LEAD_TYPE defaults to "New Business" (must match a CRM lead type).
# ERP_LEAD_OWNER = owner user email/id; defaults to hamimbdm@eventhex.ai.
#   Must match a CRM user or it falls back to unassigned.
ERP_API_KEY=
ERP_LEADS_URL=
ERP_LEAD_SOURCE=
ERP_LEAD_TYPE=
ERP_LEAD_OWNER=
