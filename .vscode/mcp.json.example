{
    "servers": {
        "wordpress": {
            "command": "/opt/homebrew/bin/npx",
            "args": [
                "-y",
                "@automattic/mcp-wordpress-remote@latest"
            ],
            "env": {
                "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin",
                "WP_API_URL": "https://cms.eventhex.ai/wp-json/mcp/mcp-adapter-default-server",
                "WP_API_USERNAME": "<your-wp-username>",
                "WP_API_PASSWORD": "<your-wp-app-password>"
            }
        },
        "gscServer": {
            "command": "/opt/homebrew/bin/uvx",
            "args": ["mcp-search-console"],
            "env": {
                "GSC_OAUTH_CLIENT_SECRETS_FILE": "<absolute-path-to-your-gsc-oauth-client-secret.json>",
                "GSC_DATA_STATE": "all"
            }
        }
    }
}
